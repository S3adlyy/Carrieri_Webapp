{% extends 'FrontOffice/base.html.twig' %}

{% block title %}Entretien IA - Simple{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h3 class="mb-0">🤖 Agent IA Recruteur</h3>
                    </div>
                    <div class="card-body">
                        <!-- Status -->
                        <div id="statusAlert" class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            Connexion au serveur...
                        </div>

                        <!-- Zone conversation -->
                        <div id="chatArea" style="height: 300px; overflow-y: auto; border: 1px solid #ddd; border-radius: 10px; padding: 15px; margin: 15px 0; background: #f9f9f9;">
                            <div class="text-center text-muted">Chargement...</div>
                        </div>

                        <!-- Mode vocal -->
                        <div class="text-center mb-3">
                            <button id="micBtn" class="btn btn-danger btn-lg rounded-circle" style="width: 80px; height: 80px;" disabled>
                                <i class="fas fa-microphone fa-2x"></i>
                            </button>
                            <p id="micStatus" class="mt-2 text-muted">Autorisez le microphone</p>
                        </div>

                        <!-- Mode texte (fallback) -->
                        <div class="input-group mt-3">
                            <input type="text" id="textInput" class="form-control" placeholder="Ou tapez votre réponse ici...">
                            <button id="sendBtn" class="btn btn-primary">Envoyer</button>
                        </div>

                        <!-- Progression -->
                        <div class="mt-3">
                            <div class="progress">
                                <div id="progressBar" class="progress-bar bg-success" style="width: 0%"></div>
                            </div>
                            <div class="text-center mt-2" id="progressText">Question 0 / 6</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal résultats -->
    <div class="modal fade" id="resultModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Résultat de l'entretien</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="resultBody"></div>
                <div class="modal-footer">
                    <a href="/ai-interview" class="btn btn-primary">Nouvel entretien</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        let ws = null;
        let currentQuestion = 0;
        let totalQuestions = 6;
        let answers = [];
        let mediaRecorder = null;
        let audioChunks = [];

        const chatArea = document.getElementById('chatArea');
        const micBtn = document.getElementById('micBtn');
        const micStatus = document.getElementById('micStatus');
        const textInput = document.getElementById('textInput');
        const sendBtn = document.getElementById('sendBtn');
        const progressBar = document.getElementById('progressBar');
        const progressText = document.getElementById('progressText');
        const statusAlert = document.getElementById('statusAlert');

        function addMessage(text, isUser = false) {
            const msgDiv = document.createElement('div');
            msgDiv.className = `mb-2 ${isUser ? 'text-end' : 'text-start'}`;
            msgDiv.innerHTML = `
            <div class="d-inline-block p-2 rounded ${isUser ? 'bg-primary text-white' : 'bg-light border'}" style="max-width: 80%;">
                ${text}
            </div>
        `;
            chatArea.appendChild(msgDiv);
            chatArea.scrollTop = chatArea.scrollHeight;
        }

        function updateProgress() {
            const percent = (currentQuestion / totalQuestions) * 100;
            progressBar.style.width = percent + '%';
            progressText.innerText = `Question ${currentQuestion} / ${totalQuestions}`;
        }

        function connectWebSocket() {
            ws = new WebSocket(`ws://${window.location.hostname}:3002`);

            ws.onopen = function() {
                statusAlert.className = 'alert alert-success';
                statusAlert.innerHTML = '<i class="fas fa-check-circle me-2"></i> Connecté au serveur - Prêt pour l\'entretien';
                micBtn.disabled = false;
            };

            ws.onmessage = function(event) {
                const data = JSON.parse(event.data);
                console.log('Reçu:', data);

                switch(data.type) {
                    case 'init':
                        addMessage(data.firstQuestion);
                        updateProgress();
                        break;

                    case 'evaluation':
                        addMessage(`📊 Score: ${data.currentScore}% - ${data.feedback}`);
                        break;

                    case 'next-question':
                        addMessage(`✅ Score enregistré. Question suivante:`);
                        setTimeout(() => {
                            addMessage(data.question);
                            updateProgress();
                        }, 1000);
                        break;

                    case 'complete':
                        showResults(data);
                        break;

                    case 'error':
                        addMessage(`❌ Erreur: ${data.message}`);
                        statusAlert.className = 'alert alert-danger';
                        statusAlert.innerHTML = `<i class="fas fa-exclamation-triangle me-2"></i> Erreur: ${data.message}`;
                        break;
                }
            };

            ws.onclose = function() {
                statusAlert.className = 'alert alert-warning';
                statusAlert.innerHTML = '<i class="fas fa-plug me-2"></i> Déconnecté - Reconnexion...';
                setTimeout(connectWebSocket, 3000);
            };
        }

        async function startRecording() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                mediaRecorder = new MediaRecorder(stream);
                audioChunks = [];

                mediaRecorder.ondataavailable = (event) => {
                    if (event.data.size > 0) audioChunks.push(event.data);
                };

                mediaRecorder.onstop = async () => {
                    const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
                    const arrayBuffer = await audioBlob.arrayBuffer();
                    if (ws && ws.readyState === WebSocket.OPEN) {
                        ws.send(arrayBuffer);
                        micStatus.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Analyse...';
                    }
                    stream.getTracks().forEach(t => t.stop());
                };

                mediaRecorder.start();
                micBtn.classList.remove('btn-danger');
                micBtn.classList.add('btn-warning');
                micBtn.innerHTML = '<i class="fas fa-stop fa-2x"></i>';
                micStatus.innerHTML = '<i class="fas fa-microphone me-1 text-danger"></i> Enregistrement... Parlez';

                // Arrêter automatiquement après 30 secondes
                setTimeout(() => {
                    if (mediaRecorder && mediaRecorder.state === 'recording') {
                        stopRecording();
                    }
                }, 30000);

            } catch(error) {
                console.error('Erreur micro:', error);
                micStatus.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i> Erreur micro';
                micBtn.classList.remove('btn-warning');
                micBtn.classList.add('btn-danger');
            }
        }

        function stopRecording() {
            if (mediaRecorder && mediaRecorder.state === 'recording') {
                mediaRecorder.stop();
                micBtn.classList.remove('btn-warning');
                micBtn.classList.add('btn-danger');
                micBtn.innerHTML = '<i class="fas fa-microphone fa-2x"></i>';
                micStatus.innerHTML = '<i class="fas fa-check me-1"></i> Envoi en cours...';
            }
        }

        function sendText() {
            const text = textInput.value.trim();
            if (text && ws && ws.readyState === WebSocket.OPEN) {
                addMessage(text, true);
                ws.send(JSON.stringify({ type: 'answer', text: text }));
                textInput.value = '';
                micBtn.disabled = true;
            }
        }

        function showResults(data) {
            const finalScore = data.finalScore;
            let gradeText = 'À améliorer';
            let gradeColor = '#dc3545';

            if (finalScore >= 80) { gradeText = 'Excellent'; gradeColor = '#28a745'; }
            else if (finalScore >= 60) { gradeText = 'Très bien'; gradeColor = '#f59e0b'; }
            else if (finalScore >= 40) { gradeText = 'Bon'; gradeColor = '#fd7e14'; }

            let answersHtml = '';
            for (let i = 0; i < data.answers.length; i++) {
                const ans = data.answers[i];
                answersHtml += `
                <div class="mb-2 p-2 border rounded">
                    <strong>Question ${i+1}</strong> - Score: ${ans.evaluation.score}%
                    <div class="progress mt-1" style="height: 4px;">
                        <div class="progress-bar bg-${ans.evaluation.score >= 70 ? 'success' : 'warning'}" style="width: ${ans.evaluation.score}%"></div>
                    </div>
                    <small class="text-muted">${ans.evaluation.feedback}</small>
                </div>
            `;
            }

            document.getElementById('resultBody').innerHTML = `
            <div class="text-center">
                <div style="width: 120px; height: 120px; border-radius: 50%; background: conic-gradient(${gradeColor} ${finalScore * 3.6}deg, #e9ecef 0deg); margin: 0 auto; display: flex; align-items: center; justify-content: center;">
                    <span style="font-size: 28px; font-weight: bold;">${finalScore}%</span>
                </div>
                <h3 class="mt-3">${gradeText}</h3>
                ${answersHtml}
            </div>
        `;

            new bootstrap.Modal(document.getElementById('resultModal')).show();
            micBtn.disabled = true;
        }

        micBtn.addEventListener('click', () => {
            if (mediaRecorder && mediaRecorder.state === 'recording') {
                stopRecording();
            } else {
                startRecording();
            }
        });

        sendBtn.addEventListener('click', sendText);
        textInput.addEventListener('keypress', (e) => { if (e.key === 'Enter') sendText(); });

        // Démarrer
        connectWebSocket();
    </script>
{% endblock %}