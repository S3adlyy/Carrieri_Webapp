{# templates/FrontOffice/partials/_navbar_candidate.html.twig #}
{# Purdue-style navbar for authenticated candidates (same grid as _navbar_landing) #}
{% set route = app.request.attributes.get('_route') %}
{% set user = app.user %}
{% set display = user ? ((user.firstName|default('') ~ ' ' ~ user.lastName|default(''))|trim) : '' %}
{% if display is empty and user %}
    {% set display = user.email|default('Candidat') %}
{% endif %}
{% set initials = '' %}
{% if user %}
    {% if user.firstName|default('')|length > 0 %}{% set initials = initials ~ user.firstName|slice(0, 1)|upper %}{% endif %}
    {% if user.lastName|default('')|length > 0 %}{% set initials = initials ~ user.lastName|slice(0, 1)|upper %}{% endif %}
    {% if initials|length == 0 and user.email|default('')|length > 0 %}
        {% set initials = user.email|slice(0, 2)|upper %}
    {% endif %}
{% endif %}
{% if initials|length == 0 %}
    {% if display|length > 0 %}
        {% set initials = display|slice(0, 2)|upper %}
    {% else %}
        {% set initials = '?' %}
    {% endif %}
{% endif %}

<style>
    .notification-icon-wrapper {
        position: relative;
        margin-left: 15px;
    }

    .notification-bell {
        background: none;
        border: none;
        color: rgba(255,255,255,0.7);
        font-size: 20px;
        cursor: pointer;
        position: relative;
        transition: all 0.3s;
        padding: 5px;
    }

    .notification-bell:hover {
        color: white;
        transform: scale(1.05);
    }

    .notification-badge {
        position: absolute;
        top: -5px;
        right: -8px;
        background: #ef4444;
        color: white;
        font-size: 10px;
        font-weight: bold;
        padding: 2px 5px;
        border-radius: 10px;
        min-width: 18px;
        text-align: center;
    }

    .notification-dropdown {
        position: absolute;
        top: 40px;
        right: 0;
        width: 380px;
        max-height: 500px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        z-index: 1000;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .notification-header {
        padding: 15px 20px;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .notification-header h4 {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
        color: #1e293b;
    }

    .mark-read-btn {
        background: none;
        border: none;
        color: #3b82f6;
        font-size: 12px;
        cursor: pointer;
    }

    .mark-read-btn:hover {
        text-decoration: underline;
    }

    .notification-list {
        max-height: 400px;
        overflow-y: auto;
    }

    .notification-item {
        padding: 15px 20px;
        border-bottom: 1px solid #f1f5f9;
        cursor: pointer;
        transition: background 0.2s;
    }

    .notification-item:hover {
        background: #f8fafc;
    }

    .notification-item.unread {
        background: #eff6ff;
    }

    .notification-item.unread:hover {
        background: #dbeafe;
    }

    .notification-title {
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .notification-message {
        font-size: 13px;
        color: #64748b;
        margin-bottom: 8px;
    }

    .notification-time {
        font-size: 11px;
        color: #94a3b8;
    }

    .notification-action {
        margin-top: 10px;
    }

    .notification-btn {
        display: inline-block;
        padding: 6px 12px;
        background: #3b82f6;
        color: white;
        border-radius: 6px;
        text-decoration: none;
        font-size: 12px;
        transition: background 0.2s;
    }

    .notification-btn:hover {
        background: #2563eb;
        color: white;
    }

    .notification-empty {
        text-align: center;
        padding: 40px 20px;
        color: #94a3b8;
    }

    .notification-empty i {
        font-size: 48px;
        margin-bottom: 10px;
    }

    /* Make user pill clickable */
    .fo-user-pill-link {
        text-decoration: none;
        transition: opacity 0.2s;
        display: inline-flex;
    }

    .fo-user-pill-link:hover {
        opacity: 0.85;
        text-decoration: none;
    }

    .fo-user-pill-link .fo-user-pill {
        cursor: pointer;
    }
</style>

<div id="navigation" class="navbar-light bg-faded site-navigation">
    <div class="container">
        <div class="row">
            <div class="col-20 align-self-center">
                <a href="{{ path('app_candidate_main') }}" class="site-brand d-flex align-items-center flex-nowrap text-decoration-none">
					<span class="site-logo">
						<img src="{{ asset('FrontOffice/img/logo.png') }}" alt="" decoding="async">
					</span>
                    <span class="site-brand__name">Carrieri</span>
                </a>
            </div>
            <div class="col-60 d-flex align-items-center">
                <nav id="main-menu">
                    <ul>
                        <li><a href="{{ path('app_candidate_cours') }}" class="{{ route == 'app_candidate_cours' ? 'active' : '' }}">Cours</a></li>
                        <li><a href="{{ path('app_candidate_offres') }}" class="{{ route == 'app_candidate_offres' ? 'active' : '' }}">Offre d'emploi</a></li>
                        <!-- Mes Favoris (without heart) -->
                        <li>
                            <a href="{{ path('app_candidate_favorites') }}"
                               class="{{ route == 'app_candidate_favorites' ? 'active' : '' }}">
                                Mes Favoris
                            </a>
                        </li>
                        <li><a href="{{ path('app_candidate_postulations') }}" class="{{ route == 'app_candidate_postulations' ? 'active' : '' }}">Mes postulations</a></li>
                        <li><a href="{{ path('app_candidate_mission') }}" class="{{ route == 'app_candidate_mission' ? 'active' : '' }}">Mission</a></li>
                        <li><a href="{{ path('app_candidate_certificates') }}" class="{{ route starts with 'app_candidate_certificate' ? 'active' : '' }}">Certificats</a></li>
                        <li><a href="{{ path('app_candidate_reclamation') }}" class="{{ route == 'app_candidate_reclamation' ? 'active' : '' }}">Réclamation</a></li>
                        <li><a href="{{ path('app_candidate_messagerie') }}" class="{{ route == 'app_candidate_messagerie' ? 'active' : '' }}">Messagerie</a></li>
                        <li><a href="{{ path('app_candidate_my_results') }}" class="{{ route == 'app_candidate_my_results' ? 'active' : '' }}">Mes résultats</a></li>
                    </ul>
                </nav>
            </div>
            <div class="col-30 d-none d-xl-block text-end align-self-center">
                <div class="d-flex align-items-center justify-content-end flex-wrap">
                    <!-- Icône de notifications -->
                    <div class="notification-icon-wrapper">
                        <button class="notification-bell" id="notificationBell">
                            <i class="fas fa-bell"></i>
                            <span class="notification-badge" id="notificationBadge" style="display: none;">0</span>
                        </button>
                        <div class="notification-dropdown" id="notificationDropdown" style="display: none;">
                            <div class="notification-header">
                                <h4>Notifications</h4>
                                <button id="markAllRead" class="mark-read-btn">Tout marquer comme lu</button>
                            </div>
                            <div class="notification-list" id="notificationList">
                                <div class="notification-empty">
                                    <i class="fas fa-bell-slash"></i>
                                    <p>Aucune notification</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Clickable profile link - Updated to use app_my_profile route -->
                    <a href="{{ path('app_my_profile') }}" class="fo-user-pill-link me-2" title="{{ display }}">
                        <div class="fo-user-pill">
                            <span class="fo-user-pill__avatar" aria-hidden="true">{{ initials }}</span>
                            <span class="fo-user-pill__meta">
                                <span class="fo-user-pill__name">{{ display }}</span>
                                <span class="fo-user-pill__role">Candidat</span>
                            </span>
                        </div>
                    </a>

                    <div class="call_to_action">
                        <a class="btn_two fo-candidate-logout" href="{{ path('app_logout') }}">Déconnexion</a>
                    </div>
                </div>
            </div>
            <ul class="mobile_menu">
                <li class="fo-mobile-user-pill-wrap d-xl-none">
                    <a href="{{ path('app_my_profile') }}" class="text-decoration-none">
                        <span class="fo-user-pill fo-user-pill--mobile" title="{{ display }}">
                            <span class="fo-user-pill__avatar" aria-hidden="true">{{ initials }}</span>
                            <span class="fo-user-pill__meta">
                                <span class="fo-user-pill__name">{{ display }}</span>
                                <span class="fo-user-pill__role">Candidat</span>
                            </span>
                        </span>
                    </a>
                </li>
                <li><a href="{{ path('app_candidate_cours') }}">Cours</a></li>
                <li><a href="{{ path('app_candidate_offres') }}">Offre d'emploi</a></li>
                <li><a href="{{ path('app_candidate_favorites') }}">Mes Favoris</a></li>
                <li><a href="{{ path('app_candidate_postulations') }}">Mes postulations</a></li>
                <li><a href="{{ path('app_candidate_mission') }}">Mission</a></li>
                <li><a href="{{ path('app_candidate_certificates') }}">Certificats</a></li>
                <li><a href="{{ path('app_candidate_reclamation') }}">Réclamation</a></li>
                <li><a href="{{ path('app_candidate_messagerie') }}">Messagerie</a></li>
                <li><a href="{{ path('app_candidate_my_results') }}">Mes résultats</a></li>
                <li class="fo-mobile-logout"><a class="fo-candidate-logout" href="{{ path('app_logout') }}">Déconnexion</a></li>
            </ul>
        </div>
    </div>
</div>