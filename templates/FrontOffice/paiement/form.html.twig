{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Paiement du cours - {{ cours.titre }}{% endblock %}

{% block candidate_page_heading %}Paiement{% endblock %}

{% block candidate_breadcrumb %} / Paiement{% endblock %}

{% block candidate_content_col_class %}col-12{% endblock %}

{% block candidate_content %}
<div class="paiement-container">
    <div class="paiement-header">
        <h1>💰 Paiement sécurisé</h1>
        <p class="cours-title">{{ cours.titre }}</p>
        <p class="prix-affiche">{{ cours.prix|number_format(2, ',', ' ') }} €</p>
    </div>

    <div id="payment-form" class="payment-form-wrapper">
        <div id="payment-element"></div>

        <button id="submit-button" class="btn-payer">
            <span id="button-text">Payer maintenant</span>
            <span id="spinner" class="spinner" style="display: none;"></span>
        </button>

        <div id="error-message" class="error-message" role="alert"></div>
        <div id="success-message" class="success-message"></div>
    </div>

    <div class="paiement-info">
        <div class="info-box">
            <h3>🔒 Paiement sécurisé</h3>
            <p>Vos données de paiement sont protégées par Stripe, le leader mondial du paiement en ligne.</p>
        </div>

        <div class="info-box">
            <h3>✅ Accès immédiat</h3>
            <p>Après confirmation du paiement, vous accédez immédiatement au contenu du cours.</p>
        </div>

        <div class="info-box">
            <h3>📚 Accès illimité</h3>
            <p>L'accès au cours est valable pendant 1 an à partir de la date d'achat.</p>
        </div>
    </div>

    <!-- Bouton pour revenir au catalogue -->
    <div class="paiement-actions">
        <a href="{{ path('app_candidate_cours') }}" class="btn-annuler">
            🔙 Retour au catalogue
        </a>
    </div>
</div>

<!-- Scripts Stripe -->
<script src="https://js.stripe.com/v3/"></script>
<script>
document.addEventListener('DOMContentLoaded', async function() {
    const stripe = Stripe('{{ publishableKey|e('js') }}');
    const clientSecret = '{{ clientSecret|e('js') }}';

    const appearance = {
        theme: 'stripe',
        variables: {
            colorPrimary: '#5E548E',
            colorBackground: '#ffffff',
            colorText: '#231942',
            colorDanger: '#ff6b6b',
            fontFamily: 'Arial, sans-serif',
            borderRadius: '8px'
        }
    };

    const elements = stripe.elements({ clientSecret, appearance });
    const paymentElement = elements.create('payment');
    paymentElement.mount('#payment-element');

    // Gestion du bouton submit
    document.getElementById('submit-button').addEventListener('click', async function() {
        const button = document.getElementById('submit-button');
        const spinner = document.getElementById('spinner');
        const buttonText = document.getElementById('button-text');
        const errorDiv = document.getElementById('error-message');
        const successDiv = document.getElementById('success-message');

        button.disabled = true;
        spinner.style.display = 'block';
        buttonText.style.display = 'none';

        try {
            const { error, paymentIntent } = await stripe.confirmPayment({
                elements,
                confirmParams: {
                    return_url: '{{ absolute_url(path('paiement_succes', {'coursId': cours.id})) }}',
                },
                redirect: 'if_required'
            });

            if (error) {
                errorDiv.textContent = '❌ Erreur: ' + error.message;
                button.disabled = false;
                spinner.style.display = 'none';
                buttonText.style.display = 'block';
            } else {
                if (paymentIntent && paymentIntent.status === 'succeeded') {
                    await confirmerPaiement(paymentIntent.id);
                } else {
                    errorDiv.textContent = '❌ Le paiement n\'a pas été confirmé.';
                    button.disabled = false;
                    spinner.style.display = 'none';
                    buttonText.style.display = 'block';
                }
            }
        } catch (err) {
            errorDiv.textContent = '❌ Erreur de paiement: ' + err.message;
            button.disabled = false;
            spinner.style.display = 'none';
            buttonText.style.display = 'block';
        }
    });

    // Fonction pour confirmer le paiement via API
    async function confirmerPaiement(paymentIntentId) {
        const button = document.getElementById('submit-button');
        const spinner = document.getElementById('spinner');
        const buttonText = document.getElementById('button-text');

        try {
            const response = await fetch('{{ path('paiement_confirmer') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    paymentIntentId,
                    coursId: {{ cours.id }}
                })
            });

            const contentType = response.headers.get('content-type') || '';
            if (!contentType.includes('application/json')) {
                const raw = await response.text();
                throw new Error('Réponse serveur invalide (non JSON). ' + raw.slice(0, 120));
            }

            const data = await response.json();
            if (data.success) {
                document.getElementById('success-message').textContent = '✅ Paiement réussi! Redirection...';
                setTimeout(() => {
                    window.location.href = '{{ path('paiement_succes', {'coursId': cours.id}) }}';
                }, 2000);
            } else {
                document.getElementById('error-message').textContent = '❌ ' + data.error;
                button.disabled = false;
                spinner.style.display = 'none';
                buttonText.style.display = 'block';
            }
        } catch (err) {
            document.getElementById('error-message').textContent = '❌ Erreur: ' + err.message;
            button.disabled = false;
            spinner.style.display = 'none';
            buttonText.style.display = 'block';
        }
    }
});
</script>

<style>
.paiement-container {
    max-width: 600px;
    margin: 40px auto;
    padding: 20px;
}

.paiement-header {
    text-align: center;
    margin-bottom: 40px;
    padding: 20px;
    background: linear-gradient(135deg, #5E548E 0%, #231942 100%);
    color: white;
    border-radius: 15px;
}

.paiement-header h1 {
    margin: 0 0 10px 0;
    font-size: 28px;
}

.cours-title {
    font-size: 18px;
    font-weight: 600;
    margin: 10px 0;
}

.prix-affiche {
    font-size: 32px;
    font-weight: bold;
    margin: 15px 0 0 0;
}

.payment-form-wrapper {
    background: white;
    padding: 30px;
    border-radius: 15px;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
    margin-bottom: 30px;
}

#payment-element {
    margin-bottom: 24px;
}

.btn-payer {
    background: #5E548E;
    color: white;
    border: none;
    padding: 14px;
    width: 100%;
    border-radius: 25px;
    font-size: 16px;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
}

.btn-payer:hover:not(:disabled) {
    background: #231942;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(94, 84, 142, 0.3);
}

.btn-payer:disabled {
    background: #ccc;
    cursor: not-allowed;
}

.spinner {
    border: 3px solid #ffffff;
    border-radius: 50%;
    border-top: 3px solid transparent;
    width: 20px;
    height: 20px;
    animation: spin 1s linear infinite;
    margin-right: 8px;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

.error-message {
    color: #ff6b6b;
    margin-top: 15px;
    text-align: center;
    font-size: 14px;
    min-height: 20px;
}

.success-message {
    color: #10b981;
    text-align: center;
    font-size: 16px;
    margin-top: 20px;
    font-weight: bold;
}

.paiement-info {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.info-box {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 10px;
    border-left: 4px solid #5E548E;
}

.info-box h3 {
    margin: 0 0 10px 0;
    font-size: 16px;
    color: #231942;
}

.info-box p {
    margin: 0;
    font-size: 14px;
    color: #666;
}

.paiement-actions {
    text-align: center;
}

.btn-annuler {
    display: inline-block;
    padding: 12px 30px;
    background: #f0f0f0;
    color: #333;
    text-decoration: none;
    border-radius: 25px;
    transition: all 0.3s ease;
    font-weight: 600;
}

.btn-annuler:hover {
    background: #e0e0e0;
    transform: translateY(-2px);
}

@media (max-width: 600px) {
    .paiement-container {
        margin: 20px 10px;
    }

    .paiement-header h1 {
        font-size: 22px;
    }

    .prix-affiche {
        font-size: 24px;
    }

    .payment-form-wrapper {
        padding: 20px;
    }

    .paiement-info {
        grid-template-columns: 1fr;
    }
}
</style>
{% endblock %}





