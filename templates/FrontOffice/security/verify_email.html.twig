{% extends 'FrontOffice/base.html.twig' %}

{% block title %}Verify Your Email{% endblock %}

{% block body %}
    <div class="preloaders">
        <span class="loader">Loading</span>
    </div>

    <div class="top_header_banner">
        {% include 'FrontOffice/partials/_logo_contact.html.twig' %}
        {% include 'FrontOffice/partials/_navbar_landing.html.twig' with { show_back_nav: true, hide_login_cta: false } %}
    </div>

    <section class="fo-login-section section-padding">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-lg-6 col-xl-5">
                    <div class="fo-login-card">
                        <h1 class="fo-login-card__title">Verify Your Email</h1>
                        <p class="fo-login-card__lead">
                            We've sent a verification code to <strong>{{ email }}</strong>.<br>
                            Please enter the code below to complete your registration.
                        </p>

                        {% for message in app.flashes('danger') %}
                            <div class="alert alert-danger fo-login-alert" role="alert">{{ message }}</div>
                        {% endfor %}
                        {% for message in app.flashes('success') %}
                            <div class="alert alert-success fo-login-alert" role="alert">{{ message }}</div>
                        {% endfor %}

                        <form method="post" action="{{ path('app_verify_email') }}" class="fo-login-form">
                            <div class="fo-field">
                                <label for="verification_code" class="fo-label">Verification Code</label>
                                <input type="text"
                                       id="verification_code"
                                       name="verification_code"
                                       class="form-control fo-input text-center"
                                       placeholder="Enter 6-digit code"
                                       maxlength="6"
                                       pattern="[0-9]{6}"
                                       required
                                       autofocus>
                                <p class="fo-hint mt-2">The code expires in 15 minutes</p>
                            </div>

                            <div class="fo-login-actions fo-login-actions--stack mt-3">
                                <button type="submit" class="btn_one fo-btn-primary w-100">Verify & Create Account</button>

                                <form method="post" action="{{ resendUrl }}" class="mt-3">
                                    <button type="submit" class="btn-link text-decoration-none" style="background: none; border: none; cursor: pointer;">
                                        Didn't receive the code? Click here to resend
                                    </button>
                                </form>

                                <p class="fo-login-switch mt-3 mb-0">
                                    <a href="{{ path('app_register') }}">← Back to registration</a>
                                </p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {% include 'FrontOffice/partials/_footer_landing.html.twig' %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Auto-submit when code reaches 6 digits (optional)
        const codeInput = document.getElementById('verification_code');
        if (codeInput) {
            codeInput.addEventListener('input', function(e) {
                if (this.value.length === 6 && /^\d+$/.test(this.value)) {
                    this.form.submit();
                }
            });
        }
    </script>
{% endblock %}