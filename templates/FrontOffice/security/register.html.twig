{% extends 'FrontOffice/base.html.twig' %}

{% block title %}Create account{% endblock %}

{% block body %}
	<div class="preloaders">
		<span class="loader">Loading</span>
	</div>

	<div class="top_header_banner">
		{% include 'FrontOffice/partials/_logo_contact.html.twig' %}
		{% include 'FrontOffice/partials/_navbar_landing.html.twig' with { show_back_nav: true, hide_login_cta: false } %}
	</div>

	<section class="fo-login-section section-padding">
		<div class="container">
			<div class="row justify-content-center">
				<div class="col-12 col-lg-8 col-xl-7">
					<div class="fo-login-card fo-register-card">
						<h1 class="fo-login-card__title">Create your account</h1>
						<p class="fo-login-card__lead">Enter your details. Your password must be at least 8 characters.</p>

						{% for message in app.flashes('danger') %}
							<div class="alert alert-danger fo-login-alert" role="alert">{{ message }}</div>
						{% endfor %}

						<form class="fo-login-form fo-register-form" method="post" action="{{ path('app_register') }}">
							<input type="hidden" name="_token" value="{{ csrf_token('register') }}">

							<div class="row">
								<div class="col-md-6">
									<div class="fo-field">
										<label class="fo-label" for="register-firstName">First name</label>
										<input type="text" id="register-firstName" name="firstName" class="form-control fo-input" value="{{ form_data.firstName|default('') }}" autocomplete="given-name" required maxlength="255">
									</div>
								</div>
								<div class="col-md-6">
									<div class="fo-field">
										<label class="fo-label" for="register-lastName">Last name</label>
										<input type="text" id="register-lastName" name="lastName" class="form-control fo-input" value="{{ form_data.lastName|default('') }}" autocomplete="family-name" required maxlength="255">
									</div>
								</div>
							</div>

							<div class="fo-field">
								<label class="fo-label" for="register-email">Email</label>
								<input type="email" id="register-email" name="email" class="form-control fo-input" value="{{ form_data.email|default('') }}" autocomplete="email" required placeholder="you@example.com">
							</div>

							<div class="fo-field">
								<label class="fo-label" for="register-phone">Phone <span class="text-muted fw-normal">(optional)</span></label>
								<input type="text" id="register-phone" name="phone" class="form-control fo-input" value="{{ form_data.phone|default('') }}" autocomplete="tel" maxlength="30" placeholder="+216 …">
							</div>

							<div class="fo-field">
								<label class="fo-label" for="register-role">Account type</label>
								<select id="register-role" name="role" class="form-control fo-input fo-select" required>
									{% for key, label in allowed_roles %}
										<option value="{{ key }}" {% if (form_data.role|default('CANDIDATE')) == key %}selected{% endif %}>{{ label }}</option>
									{% endfor %}
								</select>
								<p class="fo-hint mb-0 mt-1">Candidat: job seeker · Recruteur: company / hiring</p>
							</div>

							<div class="row">
								<div class="col-md-6">
									<div class="fo-field">
										<label class="fo-label" for="register-password">Password</label>
										<input type="password" id="register-password" name="password" class="form-control fo-input" autocomplete="new-password" required minlength="8" placeholder="••••••••">
									</div>
								</div>
								<div class="col-md-6">
									<div class="fo-field">
										<label class="fo-label" for="register-password-confirm">Confirm password</label>
										<input type="password" id="register-password-confirm" name="password_confirm" class="form-control fo-input" autocomplete="new-password" required minlength="8" placeholder="••••••••">
									</div>
								</div>
							</div>

							<div class="fo-login-actions fo-login-actions--stack mt-2">
								<button type="submit" class="btn_one fo-btn-primary">Create account</button>
								<p class="fo-login-switch mb-0">Already have an account? <a href="{{ path('app_login') }}">Sign in</a></p>
							</div>
						</form>
					</div>
				</div>
			</div>
		</div>
	</section>

	{% include 'FrontOffice/partials/_footer_landing.html.twig' %}
{% endblock %}
