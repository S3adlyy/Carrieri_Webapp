{# templates/FrontOffice/workspace/_workspace_card.html.twig #}
{# Variables expected: workspace (entity or null), isOwner (bool), user (User entity) #}
<div class="wsc-shell fo-profile-item" id="wsc-root">

    {# ── Header bar ── #}
    <div class="wsc-header">
        <div class="wsc-header-left">
            <div class="wsc-header-icon">⚡</div>
            <div>
                <div class="wsc-header-title">My Workspace</div>
                <div class="wsc-header-sub">Projects · Experience · Education · Activities</div>
            </div>
        </div>
        {% if isOwner %}
            <button class="wsc-add-btn" id="wsc-add-track-btn">
                <span>+</span> New Track
            </button>
        {% endif %}
    </div>

    {# ── Loading skeleton ── #}
    <div id="wsc-loading" class="wsc-loading">
        <div class="wsc-skeleton"></div>
        <div class="wsc-skeleton" style="width:75%"></div>
        <div class="wsc-skeleton" style="width:60%"></div>
    </div>

    {# ── Empty state ── #}
    <div id="wsc-empty" class="wsc-empty" style="display:none">
        <div class="wsc-empty-art">🗂️</div>
        <div class="wsc-empty-title">Your workspace is empty</div>
        <div class="wsc-empty-sub">Create your first track — a project, skill, experience, or anything you're building.</div>
        {% if isOwner %}
            <button class="wsc-add-btn mt-3" onclick="openCreateTrack()">+ Create first track</button>
        {% endif %}
    </div>

    {# ── Track grid ── #}
    <div id="wsc-grid" class="wsc-grid" style="display:none"></div>

    {# ── Track detail panel (slides in) ── #}
    <div id="wsc-detail" class="wsc-detail" style="display:none"></div>
</div>

{# ── Create / Edit Track Modal ── #}
<div id="wsc-modal-overlay" class="wsc-modal-overlay" style="display:none">
    <div class="wsc-modal" id="wsc-modal">
        <div class="wsc-modal-header">
            <span id="wsc-modal-title">New Track</span>
            <button class="wsc-modal-close" onclick="closeTrackModal()">✕</button>
        </div>
        <div class="wsc-modal-body">
            <div class="wsc-field">
                <label>Track name *</label>
                <input type="text" id="wsc-f-title" placeholder="e.g., Final Year Project, React Internship…" maxlength="60">
                <span class="wsc-field-error" id="wsc-e-title"></span>
            </div>
            <div class="wsc-field-row">
                <div class="wsc-field">
                    <label>Category</label>
                    <select id="wsc-f-category">
                        <option value="PROJECT">🛠 Project</option>
                        <option value="EXPERIENCE">💼 Experience</option>
                        <option value="EDUCATION">🎓 Education</option>
                        <option value="ACTIVITY">⚡ Activity</option>
                        <option value="OTHER">📌 Other</option>
                    </select>
                </div>
                <div class="wsc-field">
                    <label>Visibility</label>
                    <select id="wsc-f-visibility">
                        <option value="PRIVATE">🔒 Private</option>
                        <option value="PUBLIC">🌍 Public</option>
                    </select>
                </div>
            </div>
            <div class="wsc-field-row">
                <div class="wsc-field">
                    <label>Start date</label>
                    <input type="date" id="wsc-f-start">
                </div>
                <div class="wsc-field">
                    <label>End date</label>
                    <input type="date" id="wsc-f-end">
                </div>
            </div>
            <div class="wsc-field">
                <label>Description</label>
                <textarea id="wsc-f-desc" rows="3" placeholder="What is this track about?" maxlength="600"></textarea>
            </div>
            <div class="wsc-modal-error" id="wsc-modal-err" style="display:none"></div>
        </div>
        <div class="wsc-modal-footer">
            <button class="wsc-btn-ghost" onclick="closeTrackModal()">Cancel</button>
            <button class="wsc-btn-primary" id="wsc-modal-save" onclick="saveTrack()">Create Track</button>
        </div>
    </div>
</div>

{# ── Add Artifact Modal ── #}
<div id="wsc-art-overlay" class="wsc-modal-overlay" style="display:none">
    <div class="wsc-modal" id="wsc-art-modal">
        <div class="wsc-modal-header">
            <span>Add Artifact</span>
            <button class="wsc-modal-close" onclick="closeArtifactModal()">✕</button>
        </div>
        <div class="wsc-modal-body">
            <div class="wsc-field">
                <label>Name *</label>
                <input type="text" id="wsc-af-name" placeholder="e.g., README, main.py, demo link…" maxlength="60">
            </div>
            <div class="wsc-field-row">
                <div class="wsc-field">
                    <label>Type</label>
                    <select id="wsc-af-type" onchange="onArtifactTypeChange()">
                        <option value="CODE">📦 Code / ZIP</option>
                        <option value="DOCUMENT">📄 Document</option>
                        <option value="IMAGE">🖼 Image</option>
                        <option value="VIDEO">🎬 Video</option>
                        <option value="AUDIO">🎵 Audio</option>
                        <option value="TEXT">📝 Text note</option>
                        <option value="LINK">🔗 Link</option>
                    </select>
                </div>
                <div class="wsc-field" id="wsc-af-lang-row">
                    <label>Language (optional)</label>
                    <input type="text" id="wsc-af-language" placeholder="Java, Python, PHP…" maxlength="40">
                </div>
            </div>
            <div class="wsc-field" id="wsc-af-text-row" style="display:none">
                <label id="wsc-af-text-label">Text / URL</label>
                <textarea id="wsc-af-text" rows="4" maxlength="5000"></textarea>
            </div>
            <div class="wsc-field" id="wsc-af-file-row">
                <label id="wsc-af-file-label">File *</label>

                <input
                        type="file"
                        id="wsc-af-file"
                        style="display:none"
                >

                <div id="wsc-af-dropzone" class="wsc-dropzone" tabindex="0" role="button">
                    <div class="wsc-dropzone-icon">📂</div>
                    <div class="wsc-dropzone-label" id="wsc-af-dropzone-label">Drop a file here or click to browse</div>
                    <div class="wsc-dropzone-sub" id="wsc-af-dropzone-sub">Max 50 MB</div>
                </div>

                <div class="wsc-field-hint" id="wsc-af-selected-file" style="display:none"></div>
            </div>
            <div class="wsc-field">
                <label>Description (optional)</label>
                <textarea id="wsc-af-desc" rows="2" maxlength="600"></textarea>
            </div>
            <div class="wsc-modal-error" id="wsc-art-err" style="display:none"></div>
        </div>
        <div class="wsc-modal-footer">
            <button class="wsc-btn-ghost" onclick="closeArtifactModal()">Cancel</button>
            <button class="wsc-btn-primary" onclick="saveArtifact()">Add Artifact</button>
        </div>
    </div>
</div>

{# ── Snapshot Modal ── #}
<div id="wsc-snap-overlay" class="wsc-modal-overlay" style="display:none">
    <div class="wsc-modal" style="max-width:480px">
        <div class="wsc-modal-header">
            <span>📸 Take Snapshot</span>
            <button class="wsc-modal-close" onclick="closeSnapshotModal()">✕</button>
        </div>
        <div class="wsc-modal-body">
            <div class="wsc-field">
                <label>What did you accomplish? *</label>
                <textarea id="wsc-snap-msg" rows="4" maxlength="280" placeholder="Keep it short and specific — 1-2 sentences."></textarea>
                <span class="wsc-field-hint"><span id="wsc-snap-chars">0</span>/280</span>
            </div>
            <div class="wsc-modal-error" id="wsc-snap-err" style="display:none"></div>
        </div>
        <div class="wsc-modal-footer">
            <button class="wsc-btn-ghost" onclick="closeSnapshotModal()">Cancel</button>
            <button class="wsc-btn-primary" onclick="saveSnapshot()">📸 Save Snapshot</button>
        </div>
    </div>
</div>

<style>
    /* ═══════════════════════════════════════════════════════
       WORKSPACE CARD — Creative dark-glass design system
       Sits inside the existing profile page .fo-charte-ui
    ═══════════════════════════════════════════════════════ */

    .wsc-shell {
        background: linear-gradient(145deg, #0f0e1a 0%, #12111f 50%, #0e1628 100%);
        border-radius: 24px;
        border: 1px solid rgba(99, 102, 241, 0.18);
        overflow: hidden;
        box-shadow: 0 0 0 1px rgba(99,102,241,.06), 0 20px 60px rgba(0,0,0,.45);
        margin-top: 28px;
    }

    /* ── Header ── */
    .wsc-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 22px 28px;
        background: linear-gradient(135deg, rgba(99,102,241,.15) 0%, rgba(16,185,129,.08) 100%);
        border-bottom: 1px solid rgba(99,102,241,.15);
    }
    .wsc-header-left { display: flex; align-items: center; gap: 16px; }
    .wsc-header-icon {
        width: 48px; height: 48px; border-radius: 14px;
        background: linear-gradient(135deg, #6366f1, #10b981);
        display: flex; align-items: center; justify-content: center;
        font-size: 22px; box-shadow: 0 4px 18px rgba(99,102,241,.35);
    }
    .wsc-header-title { font-size: 1.2rem; font-weight: 800; color: #e2e8f0; }
    .wsc-header-sub   { font-size: .78rem; color: #94a3b8; margin-top: 2px; }

    /* ── Buttons ── */
    .wsc-add-btn {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff; border: none; padding: 9px 20px;
        border-radius: 25px; font-size: .85rem; font-weight: 700;
        cursor: pointer; display: flex; align-items: center; gap: 6px;
        transition: all .2s ease;
        box-shadow: 0 4px 14px rgba(99,102,241,.4);
    }
    .wsc-add-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(99,102,241,.55);
    }
    .wsc-btn-primary {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff; border: none; padding: 9px 22px;
        border-radius: 8px; font-size: .85rem; font-weight: 700;
        cursor: pointer; transition: all .2s;
    }
    .wsc-btn-primary:hover { opacity: .9; transform: translateY(-1px); }
    .wsc-btn-ghost {
        background: none; border: 1px solid rgba(255,255,255,.12);
        color: #94a3b8; padding: 9px 18px; border-radius: 8px;
        font-size: .85rem; cursor: pointer; transition: all .2s;
    }
    .wsc-btn-ghost:hover { background: rgba(255,255,255,.06); color: #e2e8f0; }
    .wsc-btn-sm {
        background: rgba(99,102,241,.15); border: 1px solid rgba(99,102,241,.25);
        color: #a5b4fc; padding: 5px 12px; border-radius: 6px; font-size: .75rem;
        cursor: pointer; transition: all .15s; white-space: nowrap;
    }
    .wsc-btn-sm:hover { background: rgba(99,102,241,.25); }
    .wsc-btn-danger { color: #f87171; background: rgba(239,68,68,.1); border-color: rgba(239,68,68,.25); }
    .wsc-btn-danger:hover { background: rgba(239,68,68,.2); }
    .wsc-btn-snap { color: #34d399; background: rgba(16,185,129,.1); border-color: rgba(16,185,129,.25); }
    .wsc-btn-snap:hover { background: rgba(16,185,129,.2); }

    /* ── Loading skeleton ── */
    .wsc-loading { padding: 28px; display: flex; flex-direction: column; gap: 12px; }
    .wsc-skeleton {
        height: 18px; border-radius: 6px;
        background: linear-gradient(90deg, rgba(255,255,255,.04) 25%, rgba(255,255,255,.08) 50%, rgba(255,255,255,.04) 75%);
        background-size: 200% 100%;
        animation: wsc-shimmer 1.5s ease-in-out infinite;
    }
    @keyframes wsc-shimmer {
        0%   { background-position: -200% 0; }
        100% { background-position:  200% 0; }
    }

    /* ── Empty state ── */
    .wsc-empty {
        padding: 60px 28px;
        text-align: center;
    }
    .wsc-empty-art   { font-size: 52px; margin-bottom: 14px; }
    .wsc-empty-title { font-size: 1.2rem; font-weight: 800; color: #e2e8f0; margin-bottom: 8px; }
    .wsc-empty-sub   { color: #64748b; font-size: .88rem; max-width: 420px; margin: 0 auto; }

    /* ── Track grid ── */
    .wsc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 18px;
        padding: 24px 28px;
    }

    /* ── Track card ── */
    .wsc-track-card {
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 16px;
        overflow: hidden;
        cursor: pointer;
        transition: all .22s ease;
        position: relative;
    }
    .wsc-track-card:hover {
        border-color: rgba(99,102,241,.4);
        transform: translateY(-3px);
        box-shadow: 0 12px 32px rgba(0,0,0,.3), 0 0 0 1px rgba(99,102,241,.2);
    }
    .wsc-track-top {
        height: 6px;
        background: linear-gradient(90deg, #6366f1, #10b981);
    }
    .wsc-track-card[data-cat="EXPERIENCE"] .wsc-track-top { background: linear-gradient(90deg, #f59e0b, #ef4444); }
    .wsc-track-card[data-cat="EDUCATION"]  .wsc-track-top { background: linear-gradient(90deg, #3b82f6, #8b5cf6); }
    .wsc-track-card[data-cat="ACTIVITY"]   .wsc-track-top { background: linear-gradient(90deg, #10b981, #06b6d4); }
    .wsc-track-card[data-cat="OTHER"]      .wsc-track-top { background: linear-gradient(90deg, #6b7280, #9ca3af); }

    .wsc-track-body { padding: 16px; }
    .wsc-track-name {
        font-weight: 800; font-size: .95rem; color: #e2e8f0;
        margin-bottom: 8px; white-space: nowrap;
        overflow: hidden; text-overflow: ellipsis;
    }
    .wsc-track-meta { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; margin-bottom: 10px; }
    .wsc-chip {
        display: inline-block; padding: 3px 10px; border-radius: 20px;
        font-size: .7rem; font-weight: 700; letter-spacing: .3px;
    }
    .wsc-chip-cat   { background: rgba(99,102,241,.18); color: #a5b4fc; border: 1px solid rgba(99,102,241,.25); }
    .wsc-chip-pub   { background: rgba(16,185,129,.15);  color: #6ee7b7; border: 1px solid rgba(16,185,129,.25); }
    .wsc-chip-priv  { background: rgba(100,116,139,.15); color: #94a3b8; border: 1px solid rgba(100,116,139,.25); }
    .wsc-track-dates { font-size: .72rem; color: #64748b; }
    .wsc-track-desc  { font-size: .78rem; color: #8892a4; line-height: 1.5; margin-top: 6px;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    .wsc-track-footer {
        display: flex; align-items: center; justify-content: space-between;
        padding: 10px 16px 14px; border-top: 1px solid rgba(255,255,255,.05);
    }
    .wsc-track-open { font-size: .75rem; color: #a5b4fc; font-weight: 600; }

    /* ── 3-dot menu ── */
    .wsc-more-btn {
        background: none; border: none; color: #64748b; cursor: pointer;
        padding: 4px 8px; border-radius: 6px; font-size: 18px; line-height: 1;
        transition: all .15s; position: relative;
    }
    .wsc-more-btn:hover { background: rgba(255,255,255,.06); color: #e2e8f0; }
    .wsc-dropdown {
        position: absolute; right: 0; bottom: calc(100% + 6px);
        background: #1e1e2e; border: 1px solid rgba(255,255,255,.1);
        border-radius: 10px; overflow: hidden; min-width: 150px;
        box-shadow: 0 8px 24px rgba(0,0,0,.5); z-index: 100;
        animation: wsc-pop .15s ease;
    }
    @keyframes wsc-pop { from { opacity:0; transform: scale(.95) translateY(4px); } to { opacity:1; transform: scale(1) translateY(0); } }
    .wsc-dropdown-item {
        display: flex; align-items: center; gap: 8px;
        padding: 10px 14px; font-size: .82rem; color: #c4cde0;
        cursor: pointer; transition: background .1s; border: none;
        background: none; width: 100%; text-align: left;
    }
    .wsc-dropdown-item:hover { background: rgba(255,255,255,.06); }
    .wsc-dropdown-item.danger { color: #f87171; }
    .wsc-dropdown-item.danger:hover { background: rgba(239,68,68,.1); }

    /* ── Track detail panel ── */
    .wsc-detail {
        background: rgba(0,0,0,.25);
        border-top: 1px solid rgba(99,102,241,.15);
        padding: 24px 28px;
        animation: wsc-slide-in .25s ease;
    }
    @keyframes wsc-slide-in {
        from { opacity:0; transform: translateY(12px); }
        to   { opacity:1; transform: translateY(0); }
    }
    .wsc-detail-header {
        display: flex; align-items: center; gap: 14px; margin-bottom: 20px;
    }
    .wsc-detail-back {
        background: none; border: 1px solid rgba(255,255,255,.1);
        color: #94a3b8; padding: 6px 14px; border-radius: 8px;
        cursor: pointer; font-size: .82rem; transition: all .15s;
    }
    .wsc-detail-back:hover { background: rgba(255,255,255,.06); color: #e2e8f0; }
    .wsc-detail-title { font-size: 1.1rem; font-weight: 800; color: #e2e8f0; }
    .wsc-detail-meta  { font-size: .78rem; color: #64748b; margin-top: 2px; }
    .wsc-detail-actions { margin-left: auto; display: flex; gap: 8px; }

    /* ── Mode tabs ── */
    .wsc-tabs {
        display: flex; gap: 4px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 10px; padding: 4px;
        width: fit-content; margin-bottom: 20px;
    }
    .wsc-tab {
        padding: 7px 18px; border-radius: 7px; font-size: .82rem; font-weight: 700;
        cursor: pointer; border: none; background: none; color: #64748b; transition: all .2s;
    }
    .wsc-tab.active {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff; box-shadow: 0 2px 10px rgba(99,102,241,.35);
    }

    /* ── Artifacts list ── */
    .wsc-artifacts { display: flex; flex-direction: column; gap: 6px; margin-bottom: 20px; }
    .wsc-artifact-row {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 14px; border-radius: 10px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.06);
        transition: all .15s;
    }
    .wsc-artifact-row:hover { border-color: rgba(99,102,241,.25); background: rgba(99,102,241,.05); }
    .wsc-art-icon  { font-size: 18px; flex-shrink: 0; }
    .wsc-art-name  { font-weight: 700; color: #e2e8f0; font-size: .88rem; flex: 1; }
    .wsc-art-meta  { font-size: .72rem; color: #64748b; }
    .wsc-art-badge {
        padding: 2px 8px; border-radius: 5px; font-size: .68rem; font-weight: 700;
        background: rgba(99,102,241,.15); color: #a5b4fc;
        border: 1px solid rgba(99,102,241,.2);
    }
    .wsc-art-badge.no-file { background: rgba(100,116,139,.1); color: #64748b; border-color: rgba(100,116,139,.2); }
    .wsc-art-actions { display: flex; gap: 4px; flex-shrink: 0; }
    .wsc-art-group-header {
        font-size: .7rem; font-weight: 800; text-transform: uppercase;
        letter-spacing: .8px; color: #4b5563; padding: 8px 4px 4px;
    }

    /* ── Snapshot timeline ── */
    .wsc-timeline {
        display: flex; gap: 6px; align-items: center;
        overflow-x: auto; padding: 12px 0; margin-bottom: 16px;
        scrollbar-width: thin; scrollbar-color: rgba(99,102,241,.3) transparent;
    }
    .wsc-seg {
        flex-shrink: 0; padding: 6px 14px; border-radius: 20px;
        background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08);
        font-size: .72rem; color: #8892a4; cursor: pointer; transition: all .15s;
        white-space: nowrap;
    }
    .wsc-seg:hover  { border-color: rgba(99,102,241,.4); color: #a5b4fc; }
    .wsc-seg.active {
        background: linear-gradient(135deg, rgba(99,102,241,.3), rgba(16,185,129,.2));
        border-color: rgba(99,102,241,.5); color: #a5b4fc; font-weight: 700;
    }
    .wsc-snap-card {
        background: rgba(16,185,129,.06); border: 1px solid rgba(16,185,129,.18);
        border-radius: 12px; padding: 14px 18px; margin-bottom: 16px;
    }
    .wsc-snap-card-title { font-size: .9rem; font-weight: 700; color: #6ee7b7; margin-bottom: 4px; }
    .wsc-snap-card-meta  { font-size: .75rem; color: #4b5563; }

    /* ── Modals ── */
    .wsc-modal-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,.65);
        display: flex; align-items: center; justify-content: center;
        z-index: 9999; backdrop-filter: blur(4px);
    }
    .wsc-modal {
        background: #12111f;
        border: 1px solid rgba(99,102,241,.25);
        border-radius: 20px; width: 100%; max-width: 540px;
        max-height: 90vh; overflow-y: auto;
        box-shadow: 0 0 0 1px rgba(99,102,241,.1), 0 24px 60px rgba(0,0,0,.6);
        animation: wsc-pop .2s ease;
    }
    .wsc-modal-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 20px 24px; border-bottom: 1px solid rgba(255,255,255,.07);
        font-size: 1rem; font-weight: 800; color: #e2e8f0;
    }
    .wsc-modal-close {
        background: none; border: none; color: #64748b; cursor: pointer;
        font-size: 18px; padding: 4px 8px; border-radius: 6px; transition: all .15s;
    }
    .wsc-modal-close:hover { background: rgba(255,255,255,.06); color: #e2e8f0; }
    .wsc-modal-body   { padding: 20px 24px; display: flex; flex-direction: column; gap: 14px; }
    .wsc-modal-footer { display: flex; justify-content: flex-end; gap: 10px; padding: 16px 24px;
        border-top: 1px solid rgba(255,255,255,.07); }
    .wsc-modal-error  { background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.2);
        color: #fca5a5; padding: 10px 14px; border-radius: 8px; font-size: .82rem; }

    /* ── Form fields ── */
    .wsc-field { display: flex; flex-direction: column; gap: 6px; }
    .wsc-field label { font-size: .8rem; font-weight: 700; color: #94a3b8; }
    .wsc-field input,
    .wsc-field select,
    .wsc-field textarea {
        background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1);
        color: #e2e8f0; padding: 9px 12px; border-radius: 8px; font-size: .85rem;
        outline: none; transition: border-color .15s;
    }
    .wsc-field input:focus,
    .wsc-field select:focus,
    .wsc-field textarea:focus { border-color: rgba(99,102,241,.5); box-shadow: 0 0 0 3px rgba(99,102,241,.12); }
    .wsc-field select option { background: #1e1e2e; }
    .wsc-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .wsc-field-error { color: #f87171; font-size: .75rem; }
    .wsc-field-hint  { font-size: .72rem; color: #64748b; }

    /* ── Upload drop zone ── */
    .wsc-dropzone {
        border: 2px dashed rgba(99,102,241,.3); border-radius: 12px;
        padding: 28px; text-align: center; cursor: pointer; transition: all .2s;
        background: rgba(99,102,241,.03);
    }
    .wsc-dropzone:hover, .wsc-dropzone.drag-over {
        border-color: rgba(99,102,241,.7); background: rgba(99,102,241,.08);
    }
    .wsc-dropzone-icon  { font-size: 32px; margin-bottom: 8px; }
    .wsc-dropzone-label { font-size: .85rem; color: #94a3b8; }
    .wsc-dropzone-sub   { font-size: .72rem; color: #4b5563; margin-top: 4px; }

    /* ── Upload progress bar ── */
    .wsc-progress-bar {
        height: 4px; background: rgba(255,255,255,.06); border-radius: 2px; overflow: hidden;
        margin-top: 8px;
    }
    .wsc-progress-fill {
        height: 100%; background: linear-gradient(90deg, #6366f1, #10b981);
        border-radius: 2px; transition: width .3s ease; width: 0%;
    }

    /* ── Toasts ── */
    #wsc-toast-container {
        position: fixed; bottom: 28px; right: 28px; z-index: 99999;
        display: flex; flex-direction: column; gap: 10px;
    }
    .wsc-toast {
        background: #1e1e2e; border: 1px solid rgba(255,255,255,.1);
        border-radius: 12px; padding: 12px 18px; font-size: .85rem; color: #e2e8f0;
        display: flex; align-items: center; gap: 10px;
        box-shadow: 0 8px 24px rgba(0,0,0,.4); min-width: 260px;
        animation: wsc-toast-in .25s ease;
    }
    @keyframes wsc-toast-in { from { opacity:0; transform: translateX(24px); } }
    .wsc-toast.success { border-color: rgba(16,185,129,.3); }
    .wsc-toast.error   { border-color: rgba(239,68,68,.3); }
</style>

{# ── Toast container ── #}
<div id="wsc-toast-container"></div>

<script>
    (() => {
        const WSC = {
            isOwner: {{ isOwner ? 'true' : 'false' }},
            userId: {{ user.id }},
            data: null,
            currentTrackId: null,
            currentTrackData: null,
            editTrackId: null,
            currentArtifactTrackId: null,
            debug: true,
            routes: {
                workspaceData: '{{ path('workspace_data') }}',
                trackCreate: '{{ path('workspace_track_create') }}',
                trackUpdateTemplate: '{{ path('workspace_track_update', { id: 999999 }) }}',
                trackDeleteTemplate: '{{ path('workspace_track_delete', { id: 999999 }) }}',
                artifactListTemplate: '/track/999999/artifacts',
                artifactCreateTemplate: '/track/999999/artifact/create',
                artifactRenameTemplate: '/track/artifact/999999/rename',
                artifactDeleteTemplate: '/track/artifact/999999/delete',
                artifactUploadTemplate: '/track/artifact/999999/upload',
                fileDownloadTemplate: '/track/fileobject/999999/download',
                snapshotListTemplate: '/snapshot/list/999999',
                snapshotCreateTemplate: '/snapshot/create/999999',
                codeViewerTemplate: '{{ path('codeviewer', { artifactId: 999999 }) }}',
                codeRawViewerTemplate: '{{ path('codeviewer', { artifactId: 999999 }) }}'
            }
        };

        const els = {
            loading: () => document.getElementById('wsc-loading'),
            empty: () => document.getElementById('wsc-empty'),
            grid: () => document.getElementById('wsc-grid'),
            detail: () => document.getElementById('wsc-detail'),
            modalOverlay: () => document.getElementById('wsc-modal-overlay'),
            modalTitle: () => document.getElementById('wsc-modal-title'),
            modalSave: () => document.getElementById('wsc-modal-save'),
            modalErr: () => document.getElementById('wsc-modal-err'),
            artOverlay: () => document.getElementById('wsc-art-overlay'),
            artErr: () => document.getElementById('wsc-art-err'),
            snapOverlay: () => document.getElementById('wsc-snap-overlay'),
            snapErr: () => document.getElementById('wsc-snap-err'),
            toastContainer: () => document.getElementById('wsc-toast-container')
        };

        function log(...args) {
            if (WSC.debug) console.log('[WSC]', ...args);
        }

        function routeWithId(template, id) {
            return String(template).replace('999999', String(id));
        }

        function escHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        function qs(id) {
            return document.getElementById(id);
        }

        function getValue(id) {
            const el = qs(id);
            return el ? el.value : '';
        }

        function setVisible(el, visible, displayType = 'block') {
            if (!el) return;
            el.style.display = visible ? displayType : 'none';
        }

        function clearModalError(id) {
            const el = qs(id);
            if (!el) return;
            el.textContent = '';
            el.style.display = 'none';
        }

        function showModalError(id, msg) {
            const el = qs(id);
            if (!el) return;
            el.textContent = msg;
            el.style.display = 'block';
        }

        function wscToast(message, type = 'success') {
            const container = els.toastContainer();
            if (!container) return;
            const toast = document.createElement('div');
            toast.className = `wsc-toast ${type}`;
            toast.innerHTML = `<span>${type === 'success' ? '✅' : '❌'}</span><span>${escHtml(message)}</span>`;
            container.appendChild(toast);
            setTimeout(() => toast.remove(), 3500);
        }

        async function wscFetch(url, options = {}) {
            const finalUrl = String(url || '');

            if (/^https?:\/\//i.test(finalUrl)) {
                throw new Error('wscFetch() must only be used with app JSON routes, not direct file URLs.');
            }

            const headers = new Headers(options.headers || {});
            const isFormData = options.body instanceof FormData;

            if (!headers.has('X-Requested-With')) {
                headers.set('X-Requested-With', 'XMLHttpRequest');
            }

            if (!isFormData && !headers.has('Content-Type') && options.body != null) {
                headers.set('Content-Type', 'application/json');
            }

            const response = await fetch(finalUrl, {
                ...options,
                headers,
                credentials: 'same-origin'
            });

            const raw = await response.text();
            let data = null;

            try {
                data = raw ? JSON.parse(raw) : {};
            } catch (e) {
                throw new Error(`Expected JSON from app route, got: ${raw.slice(0, 180)}`);
            }

            if (!response.ok) {
                throw new Error(data?.error || `HTTP ${response.status}`);
            }

            return data;
        }

        function normalizeTrack(track) {
            return {
                id: Number(track?.id ?? 0),
                title: String(track?.title ?? ''),
                category: String(track?.category ?? 'OTHER').toUpperCase(),
                visibility: String(track?.visibility ?? 'PRIVATE').toUpperCase(),
                description: track?.description ?? '',
                startDate: track?.startDate ?? null,
                endDate: track?.endDate ?? null,
                createdAt: track?.createdAt ?? null
            };
        }

        function normalizeArtifact(item = {}) {
            return {
                id: Number(item.id ?? 0),
                name: String(item.name ?? ''),
                type: String(item.type ?? 'OTHER').toUpperCase(),
                language: item.language ?? null,
                textContent: item.textContent ?? null,
                description: item.description ?? '',
                createdAt: item.createdAt ?? null,
                hasFile: Boolean(item.hasFile),
                fileObjectId: item.fileObjectId ?? null
            };
        }

        function normalizeSnapshot(item) {
            return {
                id: Number(item?.id ?? 0),
                message: String(item?.message ?? item?.text ?? ''),
                createdAt: item?.createdAt ?? item?.date ?? ''
            };
        }

        async function loadWorkspaceData() {
            try {
                setVisible(els.loading(), true, 'flex');
                setVisible(els.empty(), false);
                setVisible(els.grid(), false);

                const data = await wscFetch(WSC.routes.workspaceData);
                WSC.data = {
                    workspace: data.workspace ?? null,
                    tracks: Array.isArray(data.tracks) ? data.tracks.map(normalizeTrack) : []
                };

                renderTrackGrid(WSC.data.tracks);
            } catch (e) {
                log('loadWorkspaceData error', e);
                wscToast('Could not load workspace: ' + e.message, 'error');
                setVisible(els.loading(), false);
            }
        }

        function renderTrackGrid(tracks) {
            const loading = els.loading();
            const empty = els.empty();
            const grid = els.grid();

            setVisible(loading, false);

            if (!Array.isArray(tracks) || tracks.length === 0) {
                setVisible(empty, true, 'block');
                setVisible(grid, false);
                grid.innerHTML = '';
                return;
            }

            setVisible(empty, false);
            setVisible(grid, true, 'grid');

            grid.innerHTML = tracks.map(trackCardHtml).join('');
        }

        function trackCardHtml(track) {
            const catLabelMap = {
                PROJECT: '🛠 Project',
                EXPERIENCE: '💼 Experience',
                EDUCATION: '🎓 Education',
                ACTIVITY: '⚡ Activity',
                OTHER: '📌 Other'
            };

            const catLabel = catLabelMap[track.category] || escHtml(track.category);
            const visChip = track.visibility === 'PUBLIC'
                ? '<span class="wsc-chip wsc-chip-pub">🌍 Public</span>'
                : '<span class="wsc-chip wsc-chip-priv">🔒 Private</span>';

            const dateStr = [track.startDate, track.endDate].filter(Boolean).join(' → ');
            const desc = track.description ? `<div class="wsc-track-desc">${escHtml(track.description)}</div>` : '';
            const actions = WSC.isOwner
                ? `<button class="wsc-more-btn" type="button" data-track-menu="${track.id}">⋯</button>`
                : '';

            return `
            <div class="wsc-track-card" data-id="${track.id}" data-cat="${escHtml(track.category)}">
                <div class="wsc-track-top"></div>
                <div class="wsc-track-body">
                    <div class="wsc-track-name">${escHtml(track.title)}</div>
                    <div class="wsc-track-meta">
                        <span class="wsc-chip wsc-chip-cat">${catLabel}</span>
                        ${visChip}
                    </div>
                    ${dateStr ? `<div class="wsc-track-dates">${escHtml(dateStr)}</div>` : ''}
                    ${desc}
                </div>
                <div class="wsc-track-footer">
                    <span class="wsc-track-open">View track →</span>
                    ${actions}
                </div>
            </div>
        `;
        }

        function getTrackById(trackId) {
            return (WSC.data?.tracks || []).find(t => Number(t.id) === Number(trackId)) || null;
        }

        async function openTrackDetail(trackId) {
            WSC.currentTrackId = Number(trackId);
            WSC.currentTrackData = getTrackById(trackId);

            const detail = els.detail();
            if (!detail) return;

            setVisible(detail, true);
            detail.innerHTML = `<div class="wsc-loading"><div class="wsc-skeleton"></div><div class="wsc-skeleton" style="width:70%"></div></div>`;
            detail.scrollIntoView({ behavior: 'smooth', block: 'start' });

            try {
                const [artifactData, snapshotData] = await Promise.all([
                    wscFetch(routeWithId(WSC.routes.artifactListTemplate, trackId)),
                    wscFetch(routeWithId(WSC.routes.snapshotListTemplate, trackId))
                ]);

                const artifacts = Array.isArray(artifactData.artifacts) ? artifactData.artifacts.map(normalizeArtifact) : [];
                const snapshots = Array.isArray(snapshotData.snapshots) ? snapshotData.snapshots.map(normalizeSnapshot) : [];
                renderTrackDetail(WSC.currentTrackData, artifacts, snapshots);
            } catch (e) {
                detail.innerHTML = `<div style="color:#f87171; padding:20px;">Error loading track: ${escHtml(e.message)}</div>`;
            }
        }

        function renderTrackDetail(track, artifacts, snapshots) {
            const detail = els.detail();
            if (!detail || !track) return;

            const addArtBtn = WSC.isOwner
                ? `<button class="wsc-btn-sm" type="button" onclick="openArtifactModal(${track.id})">+ Add artifact</button>`
                : '';

            const snapBtn = WSC.isOwner
                ? `<button class="wsc-btn-sm wsc-btn-snap" type="button" onclick="openSnapshotModal(${track.id})">📸 Snapshot</button>`
                : '';

            detail.innerHTML = `
            <div class="wsc-detail-header">
                <button class="wsc-detail-back" type="button" onclick="closeDetail()">← Back</button>
                <div>
                    <div class="wsc-detail-title">${escHtml(track.title)}</div>
                    <div class="wsc-detail-meta">${artifacts.length} artifact${artifacts.length !== 1 ? 's' : ''} · ${snapshots.length} snapshot${snapshots.length !== 1 ? 's' : ''}</div>
                </div>
                <div class="wsc-detail-actions">${addArtBtn} ${snapBtn}</div>
            </div>

            <div class="wsc-tabs">
                <button class="wsc-tab active" id="wsc-tab-current" type="button" onclick="switchMode('current')">Current</button>
                <button class="wsc-tab" id="wsc-tab-progress" type="button" onclick="switchMode('progress')">Progress (${snapshots.length})</button>
            </div>

            <div id="wsc-panel-current">${renderArtifactsHtml(artifacts)}</div>
            <div id="wsc-panel-progress" style="display:none">${renderTimelineHtml(snapshots)}</div>
        `;
        }

        function renderArtifactsHtml(artifacts) {
            if (!Array.isArray(artifacts) || artifacts.length === 0) {
                return `
                <div class="wsc-empty" style="padding:40px 0">
                    <div class="wsc-empty-art" style="font-size:36px">📭</div>
                    <div class="wsc-empty-title" style="font-size:1rem">No artifacts yet</div>
                    <div class="wsc-empty-sub">Add files, notes, links, or code to this track.</div>
                </div>
            `;
            }

            const typeOrder = ['CODE', 'DOCUMENT', 'IMAGE', 'VIDEO', 'AUDIO', 'LINK', 'TEXT', 'OTHER'];
            const typeLabel = {
                CODE: '📦 Code',
                DOCUMENT: '📄 Documents',
                IMAGE: '🖼 Images',
                VIDEO: '🎬 Videos',
                AUDIO: '🎵 Audio',
                LINK: '🔗 Links',
                TEXT: '📝 Notes',
                OTHER: '📌 Other'
            };

            const groups = {};
            artifacts.forEach(artifact => {
                const groupKey = artifact.type || 'OTHER';
                if (!groups[groupKey]) groups[groupKey] = [];
                groups[groupKey].push(artifact);
            });

            return `
            <div class="wsc-artifacts">
                ${typeOrder
                .filter(type => groups[type]?.length)
                .map(type => `
                        <div class="wsc-art-group-header">${typeLabel[type] || escHtml(type)}</div>
                        ${groups[type].map(artifact => artifactRowHtml(artifact)).join('')}
                    `)
                .join('')}
            </div>
        `;
        }

        function artifactRowHtml(artifact) {
            const iconMap = {
                CODE: '💻',
                DOCUMENT: '📄',
                IMAGE: '🖼️',
                VIDEO: '🎬',
                AUDIO: '🎵',
                LINK: '🔗',
                TEXT: '📝',
                OTHER: '📦'
            };

            const fileBadge = artifact.hasFile
                ? `<span class="wsc-art-badge">File</span>`
                : `<span class="wsc-art-badge no-file">No file</span>`;

            const previewBtn = artifact.fileObjectId
                ? `<button class="wsc-btn-sm" type="button" onclick="event.stopPropagation(); previewArtifact(${artifact.id}, '${escHtml(artifact.type)}', ${artifact.fileObjectId})">Preview</button>`
                : '';

            const downloadBtn = artifact.fileObjectId
                ? `<button class="wsc-btn-sm" type="button" onclick="event.stopPropagation(); downloadArtifact(${artifact.fileObjectId})">Download</button>`
                : '';

            const textPreview = artifact.textContent
                ? `<div class="wsc-art-meta">${escHtml(String(artifact.textContent).slice(0, 120))}${String(artifact.textContent).length > 120 ? '…' : ''}</div>`
                : '';

            const ownerActions = WSC.isOwner ? `
        <div class="wsc-art-actions">
            ${previewBtn}
            ${downloadBtn}
            <button class="wsc-btn-sm" type="button" onclick="event.stopPropagation(); renameArtifact(${artifact.id})">Rename</button>
            <button class="wsc-btn-sm" type="button" onclick="event.stopPropagation(); uploadVersion(${artifact.id})">Upload</button>
            <button class="wsc-btn-sm wsc-btn-danger" type="button" onclick="event.stopPropagation(); deleteArtifact(${artifact.id})">Delete</button>
        </div>
    ` : `
        <div class="wsc-art-actions">
            ${previewBtn}
            ${downloadBtn}
        </div>
    `;

            const rowClick = artifact.fileObjectId
                ? `onclick="previewArtifact(${artifact.id}, '${escHtml(artifact.type)}', ${artifact.fileObjectId})"`
                : '';

            return `
        <div class="wsc-artifact-row" data-artifact-id="${artifact.id}" ${rowClick} style="${artifact.fileObjectId ? 'cursor:pointer' : ''}">
            <div class="wsc-art-icon">${iconMap[artifact.type] || '📦'}</div>
            <div style="flex:1; min-width:0;">
                <div class="wsc-art-name">${escHtml(artifact.name)}</div>
                <div class="wsc-art-meta">
                    ${escHtml(artifact.type)}
                    ${artifact.language ? ' · ' + escHtml(artifact.language) : ''}
                    ${artifact.createdAt ? ' · ' + escHtml(artifact.createdAt) : ''}
                </div>
                ${artifact.description ? `<div class="wsc-art-meta">${escHtml(artifact.description)}</div>` : ''}
                ${textPreview}
            </div>
            ${fileBadge}
            ${ownerActions}
        </div>
    `;
        }

        function renderTimelineHtml(snapshots) {
            if (!Array.isArray(snapshots) || snapshots.length === 0) {
                return `
                <div class="wsc-empty" style="padding:40px 0">
                    <div class="wsc-empty-art" style="font-size:36px">📸</div>
                    <div class="wsc-empty-title" style="font-size:1rem">No snapshots yet</div>
                    <div class="wsc-empty-sub">Save progress updates for this track.</div>
                </div>
            `;
            }

            return `
            <div class="wsc-timeline">
                ${snapshots.map((snap, index) => `
                    <button class="wsc-seg ${index === 0 ? 'active' : ''}" type="button" onclick="showSnapshot(${snap.id})" data-snapshot-id="${snap.id}">
                        ${escHtml(snap.createdAt || ('Snapshot #' + snap.id))}
                    </button>
                `).join('')}
            </div>
            <div id="wsc-snapshot-panels">
                ${snapshots.map((snap, index) => `
                    <div class="wsc-snap-card" data-snapshot-panel="${snap.id}" style="${index === 0 ? '' : 'display:none'}">
                        <div class="wsc-snap-card-title">${escHtml(snap.createdAt || 'Snapshot')}</div>
                        <div class="wsc-snap-card-meta">${escHtml(snap.message)}</div>
                    </div>
                `).join('')}
            </div>
        `;
        }

        function switchMode(mode) {
            const currentTab = qs('wsc-tab-current');
            const progressTab = qs('wsc-tab-progress');
            const currentPanel = qs('wsc-panel-current');
            const progressPanel = qs('wsc-panel-progress');

            if (!currentTab || !progressTab || !currentPanel || !progressPanel) return;

            const showCurrent = mode === 'current';
            currentTab.classList.toggle('active', showCurrent);
            progressTab.classList.toggle('active', !showCurrent);
            setVisible(currentPanel, showCurrent);
            setVisible(progressPanel, !showCurrent);
        }




        function showSnapshot(snapshotId) {
            document.querySelectorAll('.wsc-seg').forEach(seg => {
                seg.classList.toggle('active', Number(seg.dataset.snapshotId) === Number(snapshotId));
            });

            document.querySelectorAll('[data-snapshot-panel]').forEach(panel => {
                panel.style.display = Number(panel.dataset.snapshotPanel) === Number(snapshotId) ? 'block' : 'none';
            });
        }

        function openCreateTrack() {
            WSC.editTrackId = null;
            clearTrackForm();
            if (els.modalTitle()) els.modalTitle().textContent = 'New Track';
            if (els.modalSave()) els.modalSave().textContent = 'Create Track';
            setVisible(els.modalOverlay(), true, 'flex');
        }

        function openEditTrack(trackId) {
            const track = getTrackById(trackId);
            if (!track) {
                wscToast('Track data not found.', 'error');
                return;
            }

            WSC.editTrackId = Number(trackId);
            clearTrackForm();

            qs('wsc-modal-title').textContent = 'Edit Track';
            qs('wsc-modal-save').textContent = 'Save Changes';
            qs('wsc-f-title').value = track.title ?? '';
            qs('wsc-f-category').value = track.category ?? 'PROJECT';
            qs('wsc-f-visibility').value = track.visibility ?? 'PRIVATE';
            qs('wsc-f-start').value = track.startDate ?? '';
            qs('wsc-f-end').value = track.endDate ?? '';
            qs('wsc-f-desc').value = track.description ?? '';

            setVisible(qs('wsc-modal-overlay'), true, 'flex');
            qs('wsc-f-title')?.focus();
        }

        function closeTrackModal() {
            setVisible(qs('wsc-modal-overlay'), false);
            clearTrackForm();
            WSC.editTrackId = null;
        }


        function clearTrackForm() {
            ['wsc-f-title', 'wsc-f-start', 'wsc-f-end', 'wsc-f-desc'].forEach((id) => {
                const el = qs(id);
                if (el) el.value = '';
            });

            if (qs('wsc-f-category')) qs('wsc-f-category').value = 'PROJECT';
            if (qs('wsc-f-visibility')) qs('wsc-f-visibility').value = 'PRIVATE';

            clearModalError('wsc-modal-err');
            const titleError = qs('wsc-e-title');
            if (titleError) titleError.textContent = '';
        }

        async function saveTrack() {
            const title = getValue('wsc-f-title').trim();
            const category = getValue('wsc-f-category') || 'PROJECT';
            const visibility = getValue('wsc-f-visibility') || 'PRIVATE';
            const startDate = getValue('wsc-f-start') || null;
            const endDate = getValue('wsc-f-end') || null;
            const description = getValue('wsc-f-desc').trim() || null;

            clearModalError('wsc-modal-err');
            const titleError = qs('wsc-e-title');
            if (titleError) titleError.textContent = '';

            if (!title) {
                if (titleError) titleError.textContent = 'Title is required.';
                showModalError('wsc-modal-err', 'Please fill in the track name.');
                return;
            }

            const payload = { title, category, visibility, startDate, endDate, description };
            const url = WSC.editTrackId
                ? routeWithId(WSC.routes.trackUpdateTemplate, WSC.editTrackId)
                : WSC.routes.trackCreate;

            try {
                await wscFetch(url, {
                    method: 'POST',
                    body: JSON.stringify(payload)
                });

                closeTrackModal();
                wscToast(WSC.editTrackId ? 'Track updated ✓' : 'Track created ✓', 'success');
                await loadWorkspaceData();
            } catch (e) {
                showModalError('wsc-modal-err', e.message);
            }
        }

        async function deleteTrack(trackId) {
            if (!confirm('Delete this track? This cannot be undone.')) return;

            try {
                await wscFetch(routeWithId(WSC.routes.trackDeleteTemplate, trackId), { method: 'POST' });
                wscToast('Track deleted', 'success');
                closeDetail();
                await loadWorkspaceData();
            } catch (e) {
                wscToast(e.message, 'error');
            }
        }


        function closeDetail() {
            WSC.currentTrackId = null;
            WSC.currentTrackData = null;
            const detail = els.detail();
            if (!detail) return;
            detail.innerHTML = '';
            setVisible(detail, false);
        }

        function openArtifactModal(trackId) {
            WSC.currentArtifactTrackId = Number(trackId);
            clearArtifactForm();
            setVisible(els.artOverlay(), true, 'flex');
        }

        function closeArtifactModal() {
            setVisible(els.artOverlay(), false);
            clearArtifactForm();
            WSC.currentArtifactTrackId = null;

        }

        function clearArtifactForm() {
            ['wsc-af-name', 'wsc-af-language', 'wsc-af-text', 'wsc-af-desc', 'wsc-af-file'].forEach(id => {
                const el = qs(id);
                if (el) el.value = '';
            });

            const selectedFile = qs('wsc-af-selected-file');
            if (selectedFile) {
                selectedFile.textContent = '';
                selectedFile.style.display = 'none';
            }

            if (qs('wsc-af-type')) qs('wsc-af-type').value = 'CODE';
            clearModalError('wsc-art-err');
            onArtifactTypeChange();
        }

        function onArtifactTypeChange() {
            const type = getValue('wsc-af-type').trim().toUpperCase();
            const isText = type === 'TEXT' || type === 'LINK';
            const isCode = type === 'CODE';
            const needsFile = !isText;

            setVisible(qs('wsc-af-text-row'), isText);
            setVisible(qs('wsc-af-lang-row'), isCode, 'flex');
            setVisible(qs('wsc-af-file-row'), needsFile);

            const textLabel = qs('wsc-af-text-label');
            if (textLabel) {
                textLabel.textContent = type === 'LINK' ? 'URL *' : 'Text content *';
            }

            const fileInput = qs('wsc-af-file');
            const fileLabel = qs('wsc-af-file-label');
            const dropLabel = qs('wsc-af-dropzone-label');
            const dropSub = qs('wsc-af-dropzone-sub');

            if (needsFile && fileInput) {
                const config = getArtifactUploadConfig(type);
                fileInput.setAttribute('accept', config.accept);

                if (fileLabel) fileLabel.textContent = config.label;
                if (dropLabel) dropLabel.textContent = 'Drop a file here or click to browse';
                if (dropSub) dropSub.textContent = config.hint;
            }

            updateSelectedFileLabel();
        }
        function updateSelectedFileLabel(file = null) {
            const label = qs('wsc-af-selected-file');
            const input = qs('wsc-af-file');
            if (!label || !input) return;

            const selected = file || (input.files && input.files.length ? input.files[0] : null);

            if (!selected) {
                label.textContent = '';
                label.style.display = 'none';
                return;
            }

            const sizeMb = (selected.size / (1024 * 1024)).toFixed(2);
            label.textContent = `Selected: ${selected.name} (${sizeMb} MB)`;
            label.style.display = 'block';
        }

        function setFileInputFiles(files) {
            const input = qs('wsc-af-file');
            if (!input || !files || !files.length) return;

            const dt = new DataTransfer();
            dt.items.add(files[0]);
            input.files = dt.files;
            updateSelectedFileLabel(files[0]);
        }

        function validateSelectedFile(file, type) {
            if (!file) return 'Please select a file.';
            if (file.size > 50 * 1024 * 1024) return 'File too large (max 50 MB).';

            const config = getArtifactUploadConfig(type);
            if (!config.accept) return null;

            const allowedExts = config.accept
                .split(',')
                .map(x => x.trim().toLowerCase())
                .filter(Boolean);

            const lowerName = file.name.toLowerCase();
            const matches = allowedExts.some(ext => lowerName.endsWith(ext));

            return matches ? null : `Invalid file type for ${type.toLowerCase()}.`;
        }

        function initArtifactDropzone() {
            const dropzone = qs('wsc-af-dropzone');
            const input = qs('wsc-af-file');
            if (!dropzone || !input) return;

            dropzone.addEventListener('click', () => input.click());
            dropzone.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    input.click();
                }
            });

            input.addEventListener('change', () => {
                const file = input.files && input.files.length ? input.files[0] : null;
                updateSelectedFileLabel(file);
            });

            ['dragenter', 'dragover'].forEach(evt => {
                dropzone.addEventListener(evt, (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    dropzone.classList.add('drag-over');
                });
            });

            ['dragleave', 'dragend', 'drop'].forEach(evt => {
                dropzone.addEventListener(evt, (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    dropzone.classList.remove('drag-over');
                });
            });

            dropzone.addEventListener('drop', (e) => {
                const files = e.dataTransfer && e.dataTransfer.files ? e.dataTransfer.files : null;
                if (!files || !files.length) return;
                setFileInputFiles(files);
            });
        }

        async function saveArtifact() {
            const name = getValue('wsc-af-name').trim();
            const type = getValue('wsc-af-type').trim().toUpperCase();
            const language = getValue('wsc-af-language').trim() || null;
            const textContent = getValue('wsc-af-text').trim() || null;
            const description = getValue('wsc-af-desc').trim() || '';
            const fileInput = qs('wsc-af-file');
            const file = fileInput && fileInput.files && fileInput.files.length ? fileInput.files[0] : null;

            if (!WSC.currentArtifactTrackId) {
                showModalError('wsc-art-err', 'No track selected.');
                return;
            }

            if (!name) {
                showModalError('wsc-art-err', 'Name is required.');
                return;
            }

            if ((type === 'TEXT' || type === 'LINK') && !textContent) {
                showModalError('wsc-art-err', type === 'LINK' ? 'URL is required.' : 'Text content is required.');
                return;
            }

            if (!(type === 'TEXT' || type === 'LINK')) {
                const fileError = validateSelectedFile(file, type);
                if (fileError) {
                    showModalError('wsc-art-err', fileError);
                    return;
                }
            }

            try {
                const createRes = await wscFetch(routeWithId(WSC.routes.artifactCreateTemplate, WSC.currentArtifactTrackId), {
                    method: 'POST',
                    body: JSON.stringify({ name, type, language, textContent, description })
                });

                const artifactId = Number(createRes?.artifact?.id ?? 0);
                if (!artifactId) {
                    throw new Error('Artifact created but upload target is missing.');
                }

                if (file) {
                    const fd = new FormData();
                    fd.append('file', file);

                    await wscFetch(routeWithId(WSC.routes.artifactUploadTemplate, artifactId), {
                        method: 'POST',
                        body: fd
                    });
                }

                closeArtifactModal();
                wscToast(file ? 'Artifact and file uploaded ✓' : 'Artifact added ✓', 'success');

                closeDetail();
                await loadWorkspaceData();
            } catch (e) {
                showModalError('wsc-art-err', e.message);
            }
        }


        async function renameArtifact(artifactId) {
            const newName = prompt('New name:');
            if (!newName || !newName.trim()) return;

            try {
                await wscFetch(routeWithId(WSC.routes.artifactRenameTemplate, artifactId), {
                    method: 'POST',
                    body: JSON.stringify({ name: newName.trim() })
                });
                wscToast('Renamed ✓', 'success');

                if (WSC.currentTrackId) {
                    await openTrackDetail(WSC.currentTrackId);
                }
            } catch (e) {
                wscToast(e.message, 'error');
            }
        }

        async function deleteArtifact(artifactId) {
            if (!confirm('Delete this artifact?')) return;

            try {
                await wscFetch(routeWithId(WSC.routes.artifactDeleteTemplate, artifactId), { method: 'POST' });
                wscToast('Artifact deleted', 'success');

                if (WSC.currentTrackId) {
                    await openTrackDetail(WSC.currentTrackId);
                }
            } catch (e) {
                wscToast(e.message, 'error');
            }
        }

        function uploadVersion(artifactId) {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '*/*';

            input.addEventListener('change', async () => {
                const file = input.files && input.files.length ? input.files[0] : null;
                if (!file) return;

                if (file.size > 50 * 1024 * 1024) {
                    wscToast('File too large (max 50 MB)', 'error');
                    return;
                }

                const fd = new FormData();
                fd.append('file', file);

                wscToast('Uploading…', 'success');

                try {
                    await wscFetch(routeWithId(WSC.routes.artifactUploadTemplate, artifactId), {
                        method: 'POST',
                        body: fd
                    });

                    wscToast('Upload complete ✓', 'success');
                    await openTrackDetail(WSC.currentTrackId);
                } catch (e) {
                    wscToast('Upload failed: ' + e.message, 'error');
                }
            });

            input.click();
        }

        function downloadArtifact(fileObjectId) {
            const url = routeWithId(WSC.routes.fileDownloadTemplate, fileObjectId);
            const a = document.createElement('a');
            a.href = url;
            a.setAttribute('download', '');
            document.body.appendChild(a);
            a.click();
            a.remove();
        }
        function previewArtifact(artifactId, type, fileObjectId) {
            const upperType = String(type || '').toUpperCase();
            const baseUrl = routeWithId(WSC.routes.codeViewerTemplate, artifactId);

            if (!fileObjectId) {
                wscToast('No file attached to this artifact.', 'error');
                return;
            }

            if (upperType === 'CODE') {
                window.open(`${baseUrl}?fo=${fileObjectId}`, '_blank');
                return;
            }

            if (upperType === 'DOCUMENT' || upperType === 'IMAGE' || upperType === 'VIDEO' || upperType === 'AUDIO' || upperType === 'OTHER') {
                window.open(`${baseUrl}?fo=${fileObjectId}&mode=preview`, '_blank');
                return;
            }

            wscToast('This artifact type has no file preview.', 'error');
        }

        function openSnapshotModal(trackId) {
            WSC.currentTrackId = Number(trackId);
            if (qs('wsc-snap-msg')) qs('wsc-snap-msg').value = '';
            if (qs('wsc-snap-chars')) qs('wsc-snap-chars').textContent = '0';
            clearModalError('wsc-snap-err');
            setVisible(qs('wsc-snap-overlay'), true, 'flex');
            qs('wsc-snap-msg')?.focus();
        }

        function closeSnapshotModal() {
            setVisible(qs('wsc-snap-overlay'), false);
            clearModalError('wsc-snap-err');
        }

        async function saveSnapshot() {
            const msg = getValue('wsc-snap-msg').trim();

            if (!WSC.currentTrackId) {
                showModalError('wsc-snap-err', 'No track selected.');
                return;
            }

            if (!msg) {
                showModalError('wsc-snap-err', 'Message is required.');
                return;
            }

            if (msg.length > 280) {
                showModalError('wsc-snap-err', 'Max 280 characters.');
                return;
            }

            try {
                await wscFetch(routeWithId(WSC.routes.snapshotCreateTemplate, WSC.currentTrackId), {
                    method: 'POST',
                    body: JSON.stringify({ message: msg })
                });

                closeSnapshotModal();
                wscToast('Snapshot saved 📸', 'success');
                await openTrackDetail(WSC.currentTrackId);
            } catch (e) {
                showModalError('wsc-snap-err', e.message);
            }
        }

        function getArtifactUploadConfig(type) {
            const map = {
                CODE: {
                    accept: '.zip,.rar,.7z,.tar,.gz,.bz2,.xz,.c,.cpp,.cc,.h,.hpp,.java,.py,.js,.ts,.jsx,.tsx,.php,.html,.css,.scss,.sass,.json,.xml,.yml,.yaml,.sql,.sh,.bat,.md,.txt',
                    label: 'Code file or ZIP *',
                    hint: 'Upload source files or a ZIP archive for a full project/folder. Max 50 MB.'
                },
                DOCUMENT: {
                    accept: '.pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.csv,.txt,.rtf,.odt',
                    label: 'Document *',
                    hint: 'Accepted: PDF, Word, PowerPoint, Excel, CSV, TXT, RTF, ODT. Max 50 MB.'
                },
                IMAGE: {
                    accept: '.jpg,.jpeg,.png,.gif,.webp,.bmp,.svg',
                    label: 'Image *',
                    hint: 'Accepted: JPG, PNG, GIF, WEBP, BMP, SVG. Max 50 MB.'
                },
                VIDEO: {
                    accept: '.mp4,.webm,.mov,.avi,.mkv,.m4v',
                    label: 'Video *',
                    hint: 'Accepted: MP4, WEBM, MOV, AVI, MKV, M4V. Max 50 MB.'
                },
                AUDIO: {
                    accept: '.mp3,.wav,.ogg,.m4a,.aac,.flac',
                    label: 'Audio *',
                    hint: 'Accepted: MP3, WAV, OGG, M4A, AAC, FLAC. Max 50 MB.'
                },
                OTHER: {
                    accept: '',
                    label: 'File *',
                    hint: 'Upload one file. Max 50 MB.'
                }
            };

            return map[type] || map.OTHER;
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadWorkspaceData();

            qs('wsc-add-track-btn')?.addEventListener('click', openCreateTrack);

            qs('wsc-snap-msg')?.addEventListener('input', function () {
                if (qs('wsc-snap-chars')) {
                    qs('wsc-snap-chars').textContent = String(this.value.length);
                }
            });

            document.addEventListener('click', event => {
                const menuButton = event.target.closest('[data-track-menu]');
                const card = event.target.closest('.wsc-track-card');

                document.querySelectorAll('.wsc-dropdown').forEach(d => d.remove());

                if (menuButton) {
                    event.stopPropagation();
                    const trackId = Number(menuButton.dataset.trackMenu);
                    const menu = document.createElement('div');
                    menu.className = 'wsc-dropdown';
                    menu.innerHTML = `
                    <button class="wsc-dropdown-item" type="button" data-action="edit" data-track-id="${trackId}">✏️ Edit</button>
                    <button class="wsc-dropdown-item wsc-btn-snap" type="button" data-action="snapshot" data-track-id="${trackId}">📸 Snapshot</button>
                    <button class="wsc-dropdown-item danger" type="button" data-action="delete" data-track-id="${trackId}">🗑 Delete</button>
                `;
                    menuButton.appendChild(menu);
                    return;
                }

                const actionButton = event.target.closest('[data-action][data-track-id]');
                if (actionButton) {
                    event.stopPropagation();
                    const action = actionButton.dataset.action;
                    const trackId = Number(actionButton.dataset.trackId);

                    if (action === 'edit') openEditTrack(trackId);
                    if (action === 'snapshot') openSnapshotModal(trackId);
                    if (action === 'delete') deleteTrack(trackId);
                    return;
                }

                if (card) {
                    const trackId = Number(card.dataset.id);
                    if (trackId) openTrackDetail(trackId);
                }
            });
        });

        window.openCreateTrack = openCreateTrack;
        window.closeTrackModal = closeTrackModal;
        window.saveTrack = saveTrack;
        window.closeDetail = closeDetail;
        window.openArtifactModal = openArtifactModal;
        window.closeArtifactModal = closeArtifactModal;
        window.onArtifactTypeChange = onArtifactTypeChange;
        window.saveArtifact = saveArtifact;
        window.renameArtifact = renameArtifact;
        window.deleteArtifact = deleteArtifact;
        window.uploadVersion = uploadVersion;
        window.downloadArtifact = downloadArtifact;
        window.openSnapshotModal = openSnapshotModal;
        window.closeSnapshotModal = closeSnapshotModal;
        window.saveSnapshot = saveSnapshot;
        window.switchMode = switchMode;
        window.showSnapshot = showSnapshot;
        window.previewArtifact = previewArtifact;

        initArtifactDropzone();
        onArtifactTypeChange();
    })();


</script>