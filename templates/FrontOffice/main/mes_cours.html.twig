{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Mes cours{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('FrontOffice/css/front-overrides.css') }}?v=20260405-1">
{% endblock %}

{% block candidate_page_heading %}Mes cours{% endblock %}

{% block candidate_breadcrumb %} / Mes cours{% endblock %}

{% block candidate_content_container_class %}container-fluid px-3 px-md-4 px-lg-5{% endblock %}

{% block candidate_content_row_class %}row{% endblock %}

{% block candidate_content_col_class %}col-12{% endblock %}

{% block candidate_content %}
    <div class="w-100 text-start fo-charte-ui fo-fxml-catalog fo-shell-root position-relative">
        {% set my_courses = my_courses|default([]) %}
        {% set my_courses_stats = my_courses_stats|default({'total': 0, 'in_progress': 0, 'completed': 0, 'hours': 0}) %}
        {% set my_filters = my_filters|default({'q': '', 'state': 'all'}) %}

        <div class="fo-catalog-header mb-3 position-relative">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <div>
                    <h3 class="mb-1">Mes cours</h3>
                    <p class="mb-0">{{ my_courses_stats.total|default(0) }} cours suivis</p>
                </div>
                <a href="{{ path('app_candidate_cours') }}" class="btn fo-search-button mt-2 mt-md-0">Catalogue</a>
            </div>
        </div>

        <div class="row text-center mb-3 position-relative">
            <div class="col-md-3 col-6 mb-3 mb-md-0"><div class="fo-charte-card fo-stat-card"><small>Mes cours</small><strong>{{ my_courses_stats.total|default(0) }}</strong></div></div>
            <div class="col-md-3 col-6 mb-3 mb-md-0"><div class="fo-charte-card fo-stat-card"><small>En cours</small><strong>{{ my_courses_stats.in_progress|default(0) }}</strong></div></div>
            <div class="col-md-3 col-6 mb-3 mb-md-0"><div class="fo-charte-card fo-stat-card"><small>Complétés</small><strong>{{ my_courses_stats.completed|default(0) }}</strong></div></div>
            <div class="col-md-3 col-6"><div class="fo-charte-card fo-stat-card"><small>Heures suivies</small><strong>{{ my_courses_stats.hours|default(0) }}h</strong></div></div>
        </div>

        <form method="get" class="mb-4 position-relative">
            <div class="fo-charte-card fo-glass-card p-3 p-md-4 mb-3">
                <div class="d-flex flex-wrap align-items-center justify-content-between mb-3">
                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" name="my_state" value="all" class="btn btn-sm {{ my_filters.state == 'all' ? 'fo-btn-state-active' : 'fo-btn-state' }}">Tous</button>
                        <button type="submit" name="my_state" value="in_progress" class="btn btn-sm {{ my_filters.state == 'in_progress' ? 'fo-btn-state-active' : 'fo-btn-state' }}">En cours</button>
                        <button type="submit" name="my_state" value="completed" class="btn btn-sm {{ my_filters.state == 'completed' ? 'fo-btn-state-active' : 'fo-btn-state' }}">Terminés</button>
                    </div>
                    <a href="{{ path('app_candidate_mes_cours') }}" class="fo-reset-link">Reset</a>
                </div>
                <div class="fo-search-wrap">
                    <label for="my-course-search" class="sr-only">Rechercher dans mes cours</label>
                    <input id="my-course-search" type="text" name="my_q" class="form-control fo-search-input" placeholder="Rechercher dans mes cours..." value="{{ my_filters.q|default('') }}">
                    <button type="submit" class="btn fo-search-button">Filtrer</button>
                </div>
            </div>
        </form>

        {% if my_courses is empty %}
            <div class="alert alert-light border mb-0">Aucun cours correspondant dans Mes cours.</div>
        {% else %}
            <div class="row position-relative fo-courses-grid mb-2">
                {% for c in my_courses %}
                    {% set state = my_course_states[c.id]|default({}) %}
                    {% set progress = state.progress|default(0) %}
                    {% set level_class = c.niveau in ['Debutant', 'Débutant'] ? 'fo-level-badge--beginner' : (c.niveau in ['Intermediaire', 'Intermédiaire'] ? 'fo-level-badge--intermediate' : 'fo-level-badge--advanced') %}
                    {% set category = c.competencesVisees ? (c.competencesVisees|split(',')|first|trim) : 'Général' %}
                    <div class="col-xl-4 col-md-6 mb-4">
                        <div class="card h-100 fo-charte-card fo-course-card">
                            <div class="fo-course-cover">
                                {% if c.imageCouverture %}
                                    <img src="{{ path('app_candidate_cours_image', {id: c.id}) }}" class="card-img-top" alt="{{ c.titre|default('Cours') }}">
                                {% endif %}
                            </div>
                            <div class="card-body d-flex flex-column">
                                <div class="mb-2 d-flex align-items-center flex-wrap fo-card-badges">
                                    <span class="badge fo-level-badge {{ level_class }} mr-2">{{ c.niveau|default('Niveau') }}</span>
                                    <span class="badge fo-category-badge">{{ category }}</span>
                                </div>
                                <h5 class="card-title mb-2 fo-course-title">{{ c.titre|default('Cours') }}</h5>
                                <div class="fo-my-progress-wrap mb-3">
                                    <div class="progress fo-my-progress-bar">
                                        <div class="progress-bar" role="progressbar" style="width: {{ progress }}%" aria-valuenow="{{ progress }}" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mt-1">
                                        <small class="text-muted">Progression</small>
                                        <small class="font-weight-bold">{{ progress }}%</small>
                                    </div>
                                </div>
                                <div class="fo-meta-row mb-3">
                                    <div class="fo-meta-item"><span class="mr-1">⏱</span><small>{{ c.duree|default('0') }} heures</small></div>
                                    <div class="fo-meta-item"><span class="mr-1">{{ progress >= 100 ? '✅' : '📖' }}</span><small>{{ progress >= 100 ? 'Terminé' : 'En cours' }}</small></div>
                                </div>
                                <div class="mt-auto">
                                    {% if state.continue_lesson is defined and state.continue_lesson %}
                                        <a href="{{ path('app_candidate_lecon_show', {cours: c.id, id: state.continue_lesson.id}) }}" class="btn btn-primary btn-sm btn-block fo-btn-commencer">{{ progress >= 100 ? 'Revoir le cours' : 'Continuer' }}</a>
                                    {% else %}
                                        <a href="{{ path('app_candidate_cours_show', {id: c.id}) }}" class="btn btn-primary btn-sm btn-block fo-btn-commencer">{{ progress >= 100 ? 'Revoir le cours' : 'Accéder' }}</a>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}

