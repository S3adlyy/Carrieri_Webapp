{# templates/FrontOffice/main/mission_show.html.twig #}
{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Mission - {{ mission.type }}{% endblock %}

{% block candidate_page_heading %}Détails de la mission{% endblock %}

{% block candidate_breadcrumb %} / <a href="{{ path('app_candidate_mission') }}">Missions</a> / {{ mission.type }}{% endblock %}

{% block candidate_content %}
    <div class="mission-details-content">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="mission-details-card">
                        <div class="mission-details-header">
                            <div class="mission-type-badge">
                                <i class="fas fa-briefcase"></i>
                                {{ mission.type }}
                            </div>
                            <div class="mission-score-badge">
                                <span class="score-number">{{ mission.scoreMin }}</span>
                                <span class="score-text">points minimum requis</span>
                            </div>
                        </div>

                        <div class="mission-details-body">
                            <h2 class="mission-title">{{ mission.type }}</h2>

                            <div class="mission-info-grid">
                                <div class="info-item">
                                    <i class="fas fa-calendar-alt"></i>
                                    <div>
                                        <strong>Date de publication</strong>
                                        <span>{{ mission.createdAt|date('d/m/Y à H:i') }}</span>
                                    </div>
                                </div>
                                <div class="info-item">
                                    <i class="fas fa-chart-line"></i>
                                    <div>
                                        <strong>Score requis</strong>
                                        <span>{{ mission.scoreMin }} points</span>
                                    </div>
                                </div>
                                <div class="info-item">
                                    <i class="fas fa-user"></i>
                                    <div>
                                        <strong>Publié par</strong>
                                        <span>{% set u = mission.user %}{{ u ? (u.firstName ~ ' ' ~ u.lastName)|trim ?: u.email : 'Administration' }}</span>
                                    </div>
                                </div>
                            </div>

                            <div class="mission-description-section">
                                <h3>Description de la mission</h3>
                                <div class="mission-description">
                                    {{ mission.description|nl2br }}
                                </div>
                            </div>
                        </div>

                        <div class="mission-details-footer">
                            <a href="{{ path('app_candidate_mission') }}" class="btn-back">
                                <i class="fas fa-arrow-left"></i>
                                Retour aux missions
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .mission-details-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        }

        .mission-details-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .mission-type-badge {
            background: rgba(255,255,255,0.2);
            padding: 10px 24px;
            border-radius: 50px;
            color: white;
            font-size: 16px;
            font-weight: 500;
        }

        .mission-type-badge i {
            margin-right: 8px;
        }

        .mission-score-badge {
            text-align: center;
            background: rgba(255,255,255,0.15);
            padding: 10px 24px;
            border-radius: 16px;
        }

        .score-number {
            font-size: 28px;
            font-weight: bold;
            color: white;
            display: block;
            line-height: 1;
        }

        .score-text {
            font-size: 12px;
            color: rgba(255,255,255,0.9);
        }

        .mission-details-body {
            padding: 30px;
        }

        .mission-title {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 24px;
            color: #333;
        }

        .mission-info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
            padding: 20px;
            background: #f8f9fa;
            border-radius: 16px;
        }

        .info-item {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .info-item i {
            font-size: 24px;
            color: #667eea;
        }

        .info-item div {
            display: flex;
            flex-direction: column;
        }

        .info-item strong {
            font-size: 12px;
            color: #888;
            font-weight: 500;
        }

        .info-item span {
            font-size: 14px;
            color: #333;
            font-weight: 500;
        }

        .mission-description-section {
            margin-top: 20px;
        }

        .mission-description-section h3 {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 16px;
            color: #333;
        }

        .mission-description {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 16px;
            line-height: 1.8;
            color: #555;
        }

        .mission-details-footer {
            padding: 20px 30px 30px;
            border-top: 1px solid #f0f0f0;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            background: #f0f0f0;
            color: #666;
            text-decoration: none;
            border-radius: 50px;
            transition: all 0.3s ease;
        }

        .btn-back:hover {
            background: #667eea;
            color: white;
            text-decoration: none;
        }

        @media (max-width: 768px) {
            .mission-details-header {
                padding: 20px;
                flex-direction: column;
                text-align: center;
            }

            .mission-details-body {
                padding: 20px;
            }

            .mission-title {
                font-size: 22px;
            }

            .mission-info-grid {
                grid-template-columns: 1fr;
                gap: 15px;
            }
        }
    </style>
{% endblock %}