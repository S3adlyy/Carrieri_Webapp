                                {% else %}—{% endif %}
                            </div>
                        </div>
                        <div class="fo-info-row">
                            <div class="fo-info-label"><i class="fas fa-globe"></i> Portfolio:</div>
                            <div class="fo-info-value">
                                {% if user.portfolioUrl|default(false) %}
