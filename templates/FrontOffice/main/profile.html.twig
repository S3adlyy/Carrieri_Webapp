{% block javascripts %}
    {{ parent() }}
    <script>
        function openEditModal(section) {
            const url = new URL(window.location.href);
            url.searchParams.set('edit', section);
            window.location.href = url.toString();
        }

        function closeEditModal() {
            const url = new URL(window.location.href);
            url.searchParams.delete('edit');
            window.location.href = url.toString();
        }

        function closeEditModalOnBackdrop(event) {
            if (event.target.id === 'fo-edit-modal-backdrop') {
                closeEditModal();
            }
        }

        function connectWithUser(userId) {
            console.log('Connect with user:', userId);
            alert('Connection request sent!');
        }

        function showAllSuggestions() {
            console.log('Show all suggestions');
            alert('All suggestions feature coming soon!');
        }

        let enrollVideo = null;
        let enrollStream = null;

        function startEnrollCamera() {
            return navigator.mediaDevices.getUserMedia({ video: true });
        }

        document.getElementById('enrollFaceBtn')?.addEventListener('click', async () => {
            const modal = new bootstrap.Modal(document.getElementById('enrollFaceModal'));
            modal.show();

            try {
                enrollStream = await startEnrollCamera();
                enrollVideo = document.getElementById('enrollVideo');
                enrollVideo.srcObject = enrollStream;
            } catch (err) {
                document.getElementById('enrollStatus').innerHTML = '<div class="alert alert-danger">Camera access denied</div>';
            }
        });

        document.getElementById('enrollCaptureBtn')?.addEventListener('click', async () => {
            const video = document.getElementById('enrollVideo');
            const canvas = document.getElementById('enrollCanvas');
            const context = canvas.getContext('2d');

            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            context.drawImage(video, 0, 0, canvas.width, canvas.height);

            const imageData = canvas.toDataURL('image/jpeg', 0.8);

            document.getElementById('enrollStatus').innerHTML = '<div class="spinner-border text-primary"></div> Enrolling face...';

            const response = await fetch('{{ path('face_enroll') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ image: imageData })
            });

            const result = await response.json();

            if (result.success) {
                document.getElementById('enrollStatus').innerHTML = '<div class="alert alert-success">Face enrolled successfully!</div>';
                if (enrollStream) enrollStream.getTracks().forEach(track => track.stop());
                setTimeout(() => location.reload(), 1500);
            } else {
                document.getElementById('enrollStatus').innerHTML = '<div class="alert alert-danger">' + result.error + '</div>';
            }
        });

        document.getElementById('disableFaceBtn')?.addEventListener('click', async () => {
            if (confirm('Are you sure you want to disable Face ID login?')) {
                const response = await fetch('{{ path('face_disable') }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const result = await response.json();
                if (result.success) location.reload();
            }
        });
    </script>
{% endblock %}