{# templates/FrontOffice/main/my_results.html.twig #}
{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Mes résultats{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('FrontOffice/css/front-overrides.css') }}?v=20260405-1">
    <style>
        .fo-candidate-content {
            padding: 0 !important;
            margin: 0 !important;
            max-width: 100% !important;
        }
        .container { max-width: 100% !important; padding: 0 !important; margin: 0 !important; }
        .row { margin: 0 !important; }
        .col-12 { padding: 0 !important; }
        .section-top, .section-top-title { display: none !important; }

        /* Styles spécifiques aux résultats - intégration avec la charte FXML */
        .fo-charte-ui .r-table-card {
            background: #fff;
            border-radius: 24px;
            border: 1px solid rgba(216, 201, 240, 0.65);
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
        }

        .fo-charte-ui .r-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 36px 48px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            flex-wrap: wrap;
            border-bottom: 1px solid rgba(255,255,255,.1);
        }

        .fo-charte-ui .r-header-left h1 {
            font-family: 'Sora', sans-serif;
            font-size: 26px;
            font-weight: 800;
            color: #fff;
            margin: 0 0 6px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .fo-charte-ui .r-header-left h1 .h-icon {
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,.15);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        .fo-charte-ui .r-header-left p {
            font-size: 14px;
            color: rgba(255,255,255,.75);
            margin: 0;
        }

        .fo-charte-ui .r-kpi-row {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .fo-charte-ui .r-kpi {
            background: rgba(255,255,255,.1);
            border: 1px solid rgba(255,255,255,.2);
            border-radius: 16px;
            padding: 14px 20px;
            min-width: 110px;
            text-align: center;
            backdrop-filter: blur(4px);
            transition: all 0.25s ease;
        }

        .fo-charte-ui .r-kpi:hover {
            background: rgba(255,255,255,.18);
            transform: translateY(-2px);
        }

        .fo-charte-ui .r-kpi-num {
            font-family: 'Sora', sans-serif;
            font-size: 24px;
            font-weight: 800;
            color: #fff;
            line-height: 1;
            margin-bottom: 4px;
        }

        .fo-charte-ui .r-kpi-num.clr-success { color: #a7f3d0; }
        .fo-charte-ui .r-kpi-num.clr-danger  { color: #fecaca; }
        .fo-charte-ui .r-kpi-num.clr-warning { color: #fde68a; }
        .fo-charte-ui .r-kpi-num.clr-indigo  { color: #c7d2fe; }

        .fo-charte-ui .r-kpi-label {
            font-size: 11px;
            color: rgba(255,255,255,.7);
            font-weight: 600;
            letter-spacing: .5px;
            text-transform: uppercase;
        }

        .fo-charte-ui .r-body {
            padding: 32px 48px 48px;
        }

        .fo-charte-ui .r-toolbar {
            display: flex;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .fo-charte-ui .r-search {
            flex: 1;
            min-width: 200px;
            position: relative;
        }

        .fo-charte-ui .r-search i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 13px;
            pointer-events: none;
        }

        .fo-charte-ui .r-search input {
            width: 100%;
            padding: 10px 14px 10px 38px;
            border: 2px solid #e2e8f0;
            border-radius: 50px;
            font-size: 13.5px;
            font-family: 'DM Sans', sans-serif;
            background: #fff;
            color: #1f2937;
            outline: none;
            transition: all 0.3s ease;
        }

        .fo-charte-ui .r-search input:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.15);
        }

        .fo-charte-ui .r-filter-chips {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .fo-charte-ui .r-chip {
            padding: 8px 16px;
            border: 1.5px solid #e2e8f0;
            border-radius: 50px;
            font-size: 12.5px;
            font-weight: 600;
            color: #64748b;
            background: #fff;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s ease;
            font-family: 'DM Sans', sans-serif;
        }

        .fo-charte-ui .r-chip:hover {
            border-color: #667eea;
            color: #667eea;
            background: #f0f4ff;
        }

        .fo-charte-ui .r-chip.active {
            border-color: #667eea;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #fff;
        }

        .fo-charte-ui .r-count-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .fo-charte-ui .r-count-label {
            font-size: 13px;
            color: #64748b;
            font-weight: 500;
        }

        .fo-charte-ui .r-count-label strong {
            color: #1f2937;
            font-weight: 700;
        }

        .fo-charte-ui .r-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13.5px;
        }

        .fo-charte-ui .r-table thead th {
            padding: 14px 18px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
            white-space: nowrap;
        }

        .fo-charte-ui .r-table tbody td {
            padding: 16px 18px;
            border-bottom: 1px solid #e2e8f0;
            vertical-align: middle;
            color: #1f2937;
        }

        .fo-charte-ui .r-table tbody tr:last-child td {
            border-bottom: none;
        }

        .fo-charte-ui .r-table tbody tr {
            transition: background 0.15s ease;
        }

        .fo-charte-ui .r-table tbody tr:hover {
            background: #f8faff;
        }

        .fo-charte-ui .cell-mission {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .fo-charte-ui .cell-mission strong {
            font-weight: 700;
            font-size: 14px;
            color: #1f2937;
        }

        .fo-charte-ui .cell-mission span {
            font-size: 11.5px;
            color: #64748b;
        }

        .fo-charte-ui .cell-date {
            white-space: nowrap;
            color: #64748b;
            font-size: 13px;
        }

        .fo-charte-ui .lang-pill {
            display: inline-block;
            padding: 4px 12px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #fff;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .fo-charte-ui .cell-score {
            min-width: 110px;
        }

        .fo-charte-ui .score-top {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 6px;
        }

        .fo-charte-ui .score-pct {
            font-family: 'Sora', sans-serif;
            font-size: 14px;
            font-weight: 700;
        }

        .fo-charte-ui .score-pct.ok {
            color: #10b981;
        }

        .fo-charte-ui .score-pct.bad {
            color: #ef4444;
        }

        .fo-charte-ui .score-bar {
            height: 6px;
            background: #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
            width: 100%;
        }

        .fo-charte-ui .score-fill {
            height: 100%;
            border-radius: 10px;
            transition: width 0.4s ease;
        }

        .fo-charte-ui .score-fill.ok {
            background: linear-gradient(90deg, #34d399, #10b981);
        }

        .fo-charte-ui .score-fill.bad {
            background: linear-gradient(90deg, #f87171, #ef4444);
        }

        .fo-charte-ui .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 5px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            white-space: nowrap;
        }

        .fo-charte-ui .status-pill i {
            font-size: 11px;
        }

        .fo-charte-ui .pill-accepted {
            background: #ecfdf5;
            color: #059669;
        }

        .fo-charte-ui .pill-rejected {
            background: #fef2f2;
            color: #dc2626;
        }

        .fo-charte-ui .pill-pending {
            background: #fffbeb;
            color: #d97706;
        }

        .fo-charte-ui .btn-detail {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 10px;
            color: #fff;
            font-size: 12px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s ease;
            font-family: 'DM Sans', sans-serif;
            white-space: nowrap;
        }

        .fo-charte-ui .btn-detail:hover {
            transform: scale(1.02);
            box-shadow: 0 4px 14px rgba(102, 126, 234, 0.4);
            color: #fff;
            text-decoration: none;
        }

        .fo-charte-ui .r-empty {
            text-align: center;
            padding: 80px 40px;
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 24px;
        }

        .fo-charte-ui .r-empty-icon {
            width: 72px;
            height: 72px;
            background: #f8fafc;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 18px;
        }

        .fo-charte-ui .r-empty-icon i {
            font-size: 30px;
            color: #94a3b8;
        }

        .fo-charte-ui .r-empty h3 {
            font-family: 'Sora', sans-serif;
            font-size: 18px;
            color: #1f2937;
            margin-bottom: 8px;
        }

        .fo-charte-ui .r-empty p {
            font-size: 13.5px;
            color: #64748b;
            margin-bottom: 24px;
        }

        .fo-charte-ui .btn-go-missions {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #fff;
            border-radius: 50px;
            font-size: 13.5px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s ease;
            font-family: 'DM Sans', sans-serif;
        }

        .fo-charte-ui .btn-go-missions:hover {
            transform: scale(1.03);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.35);
            color: #fff;
            text-decoration: none;
        }

        .fo-charte-ui .r-no-results {
            text-align: center;
            padding: 40px;
            color: #64748b;
            font-size: 14px;
        }

        /* Responsive */
        @media (max-width: 900px) {
            .fo-charte-ui .r-header { padding: 26px 28px; }
            .fo-charte-ui .r-body { padding: 24px 28px 40px; }
        }

        @media (max-width: 640px) {
            .fo-charte-ui .r-header { flex-direction: column; align-items: flex-start; padding: 22px 20px; }
            .fo-charte-ui .r-body { padding: 20px 16px 36px; }
            .fo-charte-ui .r-kpi-row { width: 100%; }
            .fo-charte-ui .r-kpi { flex: 1; min-width: 80px; }
            .fo-charte-ui .r-table thead th:nth-child(2),
            .fo-charte-ui .r-table tbody td:nth-child(2) { display: none; }
        }
    </style>
{% endblock %}

{% block candidate_page_heading %}{% endblock %}
{% block candidate_breadcrumb %}{% endblock %}

{% block candidate_content %}
    <div class="w-100 text-start fo-charte-ui">

        {# Header avec gradient FXML #}
        <div class="r-header">
            <div class="r-header-left">
                <h1>
                    <span class="h-icon"><i class="fas fa-chart-line"></i></span>
                    Mes résultats
                </h1>
                <p>Retrouvez ici toutes vos soumissions et leurs statuts</p>
            </div>

            {% if soumissions|length > 0 %}
                <div class="r-kpi-row">
                    <div class="r-kpi">
                        <div class="r-kpi-num clr-indigo">{{ soumissions|length }}</div>
                        <div class="r-kpi-label">Total</div>
                    </div>
                    <div class="r-kpi">
                        <div class="r-kpi-num clr-success">{{ soumissions|filter(s => s.statut == 'accepte')|length }}</div>
                        <div class="r-kpi-label">Acceptées</div>
                    </div>
                    <div class="r-kpi">
                        <div class="r-kpi-num clr-danger">{{ soumissions|filter(s => s.statut == 'refuse')|length }}</div>
                        <div class="r-kpi-label">Refusées</div>
                    </div>
                    <div class="r-kpi">
                        <div class="r-kpi-num clr-warning">{{ soumissions|filter(s => s.statut == 'en_attente')|length }}</div>
                        <div class="r-kpi-label">En attente</div>
                    </div>
                </div>
            {% endif %}
        </div>

        {# Body #}
        <div class="r-body">

            {% if soumissions|length > 0 %}

                {# Toolbar #}
                <div class="r-toolbar">
                    <div class="r-search">
                        <i class="fas fa-search"></i>
                        <input type="text" id="r-search-input" placeholder="Rechercher une mission...">
                    </div>
                    <div class="r-filter-chips">
                        <button class="r-chip active" data-filter="all">
                            <i class="fas fa-th-large"></i> Toutes
                        </button>
                        <button class="r-chip" data-filter="accepte">
                            <i class="fas fa-check-circle"></i> Acceptées
                        </button>
                        <button class="r-chip" data-filter="refuse">
                            <i class="fas fa-times-circle"></i> Refusées
                        </button>
                        <button class="r-chip" data-filter="en_attente">
                            <i class="fas fa-hourglass-half"></i> En attente
                        </button>
                    </div>
                </div>

                <div class="r-count-row">
                    <div class="r-count-label"><strong id="r-visible-count">{{ soumissions|length }}</strong> soumission(s) affichée(s)</div>
                </div>

                {# Table #}
                <div class="r-table-card">
                    <div class="table-responsive">
                        <table class="r-table" id="r-table">
                            <thead>
                            <tr>
                                <th>Mission</th>
                                <th>Date</th>
                                <th>Langage</th>
                                <th>Score</th>
                                <th>Statut</th>
                                <th>Action</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for soumission in soumissions %}
                                {% set isOk = soumission.score >= soumission.mission.scoreMin %}
                                <tr class="r-row"
                                    data-statut="{{ soumission.statut }}"
                                    data-mission="{{ soumission.mission.type|lower }}"
                                    data-mission-name="{{ soumission.mission.type|lower }}">
                                    <td>
                                        <div class="cell-mission">
                                            <strong>{{ soumission.mission.type }}</strong>
                                            <span>#{{ soumission.mission.id }}</span>
                                        </div>
                                    </td>
                                    <td class="cell-date">
                                        {{ soumission.dateRendu|date('d/m/Y') }}<br>
                                        <span style="font-size:11px;color:#64748b;">{{ soumission.dateRendu|date('H:i') }}</span>
                                    </td>
                                    <td>
                                        <span class="lang-pill">{{ soumission.langue|upper }}</span>
                                    </td>
                                    <td>
                                        <div class="cell-score">
                                            <div class="score-top">
                                                <span class="score-pct {{ isOk ? 'ok' : 'bad' }}">
                                                    {{ soumission.score|default(0)|round }}%
                                                </span>
                                            </div>
                                            <div class="score-bar">
                                                <div class="score-fill {{ isOk ? 'ok' : 'bad' }}"
                                                     style="width: {{ soumission.score|default(0)|round }}%"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        {% if soumission.statut == 'accepte' %}
                                            <span class="status-pill pill-accepted">
                                                <i class="fas fa-check-circle"></i> Acceptée
                                            </span>
                                        {% elseif soumission.statut == 'refuse' %}
                                            <span class="status-pill pill-rejected">
                                                <i class="fas fa-times-circle"></i> Refusée
                                            </span>
                                        {% else %}
                                            <span class="status-pill pill-pending">
                                                <i class="fas fa-hourglass-half"></i> En attente
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <a href="{{ path('app_candidate_rendu_status', {'id': soumission.id}) }}"
                                           class="btn-detail">
                                            <i class="fas fa-eye"></i> Détails
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                            <tr id="r-no-results" style="display:none;">
                                <td colspan="6" class="r-no-results">
                                    <i class="fas fa-search" style="font-size:22px;display:block;margin-bottom:8px;color:#94a3b8;"></i>
                                    Aucune soumission ne correspond à votre recherche.
                                </td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            {% else %}

                <div class="r-empty">
                    <div class="r-empty-icon"><i class="fas fa-inbox"></i></div>
                    <h3>Aucune soumission</h3>
                    <p>Vous n'avez pas encore soumis de mission.</p>
                    <a href="{{ path('app_candidate_mission') }}" class="btn-go-missions">
                        <i class="fas fa-briefcase"></i> Découvrir les missions
                    </a>
                </div>

            {% endif %}
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const searchInput  = document.getElementById('r-search-input');
            const chips        = document.querySelectorAll('.r-chip');
            const rows         = document.querySelectorAll('.r-row');
            const countEl      = document.getElementById('r-visible-count');
            const noResultsRow = document.getElementById('r-no-results');

            let currentFilter = 'all';
            let currentSearch = '';

            function applyFilters() {
                let visible = 0;
                rows.forEach(row => {
                    const statut  = row.dataset.statut || '';
                    const mission = row.dataset.missionName || row.dataset.mission || '';
                    const filterMatch = currentFilter === 'all' || statut === currentFilter;
                    const searchMatch = currentSearch === '' || mission.includes(currentSearch);
                    if (filterMatch && searchMatch) {
                        row.style.display = '';
                        visible++;
                    } else {
                        row.style.display = 'none';
                    }
                });
                if (countEl) countEl.textContent = visible;
                if (noResultsRow) noResultsRow.style.display = visible === 0 ? '' : 'none';
            }

            if (searchInput) {
                let timer;
                searchInput.addEventListener('input', function () {
                    clearTimeout(timer);
                    currentSearch = this.value.trim().toLowerCase();
                    timer = setTimeout(applyFilters, 260);
                });
            }

            chips.forEach(chip => {
                chip.addEventListener('click', function () {
                    chips.forEach(c => c.classList.remove('active'));
                    this.classList.add('active');
                    currentFilter = this.dataset.filter;
                    applyFilters();
                });
            });
        });
    </script>

{% endblock %}