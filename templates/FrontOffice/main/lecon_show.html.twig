{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}{{ lecon.titre|default('Leçon')|trans_lang }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('FrontOffice/css/front-overrides.css') }}?v=20260409-1">
{% endblock %}

{% block candidate_page_heading %}{{ lecon.titre|default('Leçon')|trans_lang }}{% endblock %}

{% block candidate_breadcrumb %}
    / <a href="{{ path('app_candidate_cours_show', {id: cours.id}) }}">{{ cours.titre|default('Cours')|trans_lang }}</a> / {{ 'Leçon'|trans_lang }}
{% endblock %}

{% block candidate_content %}
    <div class="w-100 text-start fo-charte-ui">
        <div class="d-flex justify-content-between align-items-center flex-wrap mb-3">
            <a href="{{ path('app_candidate_cours_show', {id: cours.id}) }}" class="btn btn-outline-secondary btn-sm mb-2">
                {{ 'Retour au cours'|trans_lang }}
            </a>
            <div class="text-muted mb-2">{{ 'Progression'|trans_lang }} : <strong>{{ progress|default(0) }}%</strong></div>
        </div>

        <div class="row g-4 fo-player-layout">
            <div class="col-lg-3 fo-player-layout__left">
                {% include 'FrontOffice/main/partials/_course_sidebar.html.twig' with {
                    cours: cours,
                    modules: modules,
                    lessons_by_module: lessons_by_module,
                    viewed_lesson_ids: viewed_lesson_ids,
                    active_lesson_id: lecon.id
                } only %}
            </div>

            <div class="col-lg-9">
                <div class="card shadow-sm fo-charte-card mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap">
                            <div>
                                <h3 class="mb-1">{{ lecon.titre|default('Leçon')|trans_lang }}</h3>
                                <p class="text-muted mb-0">
                                    <strong>{{ 'Cours'|trans_lang }} :</strong> {{ cours.titre|default('—')|trans_lang }}
                                    &nbsp;|&nbsp;
                                    <strong>{{ 'Module'|trans_lang }} :</strong> {{ lecon.module ? lecon.module.titre|trans_lang : '—' }}
                                </p>
                            </div>
                            {% if viewed_lesson_ids[lecon.id]|default(false) %}
                                <span class="badge badge-success">{{ 'Vue'|trans_lang }}</span>
                            {% endif %}
                        </div>

                        {% if lecon.video %}
                            <div class="mb-3">
                                <video controls class="w-100" style="max-height: 460px;">
                                    <source src="{{ path('app_candidate_lecon_video', {cours: cours.id, id: lecon.id}) }}" type="video/mp4">
                                    {{ 'Votre navigateur ne supporte pas la lecture vidéo.'|trans_lang }}
                                </video>
                            </div>
                        {% endif %}

                        <!-- TTS UI Controls -->
                        <div class="d-flex justify-content-end mb-2 align-items-center">
                            <span class="text-muted small me-2 d-none" id="tts-status"></span>
                            <button id="tts-play-btn" class="btn btn-sm btn-outline-primary me-2">
                                🔊 {{ 'Écouter'|trans_lang }}
                            </button>
                            <button id="tts-stop-btn" class="btn btn-sm btn-outline-danger d-none">
                                ⏹ {{ 'Arrêter'|trans_lang }}
                            </button>
                        </div>

                        <div class="p-3 bg-light rounded" id="lesson-content-text" data-lang="{{ current_lang() }}">
                            {{ lecon.contenu|default('—')|trans_lang|nl2br }}
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm fo-charte-card">
                    <div class="card-body d-flex justify-content-between align-items-center flex-wrap">
                        <div class="mb-2 mb-md-0">
                            <strong>{{ 'Progression globale'|trans_lang }} :</strong> {{ progress|default(0) }}%
                            <div class="progress mt-2" style="height: 10px; min-width: 260px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width: {{ progress|default(0) }}%;" aria-valuenow="{{ progress|default(0) }}" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>

                        {% if continue_lesson is defined and continue_lesson %}
                            <a href="{{ path('app_candidate_lecon_show', {cours: cours.id, id: continue_lesson.id}) }}" class="btn btn-primary">
                                {{ 'Continuer'|trans_lang }}
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const playBtn = document.getElementById('tts-play-btn');
            const stopBtn = document.getElementById('tts-stop-btn');
            const statusText = document.getElementById('tts-status');
            const contentDiv = document.getElementById('lesson-content-text');
            
            if (!playBtn || !contentDiv || !('speechSynthesis' in window)) {
                if (playBtn) playBtn.style.display = 'none'; // Not supported
                return;
            }

            let utterance = null;
            let isPlaying = false;
            let isPaused = false;
            let textChunks = [];
            let currentChunkIndex = 0;

            const langMap = {
                'fr': 'fr-FR', 'en': 'en-US', 'ar': 'ar-SA',
                'es': 'es-ES', 'de': 'de-DE', 'it': 'it-IT'
            };

            const currentLang = contentDiv.getAttribute('data-lang') || 'fr';
            const bcpLang = langMap[currentLang] || 'fr-FR';

            // Chrome/Safari load voices asynchronously
            let voices = window.speechSynthesis.getVoices();
            window.speechSynthesis.onvoiceschanged = function() {
                voices = window.speechSynthesis.getVoices();
            };

            function chunkText(text) {
                // Couper le texte aux points, points d'interrogation, exclamation ou saut de ligne
                // Tout en gardant la ponctuation pour que l'intonation soit naturelle
                return text.match(/[^.!?\n]+[.!?\n]+/g) || [text];
            }

            function playNextChunk() {
                if (currentChunkIndex >= textChunks.length || !isPlaying) {
                    resetUI();
                    return;
                }

                let chunk = textChunks[currentChunkIndex].trim();
                if (chunk === '') {
                    currentChunkIndex++;
                    return playNextChunk();
                }

                utterance = new SpeechSynthesisUtterance(chunk);
                utterance.lang = bcpLang;
                utterance.rate = 1.0;
                utterance.pitch = 1.0;

                if (voices.length > 0) {
                    const matchedVoice = voices.find(voice => voice.lang.startsWith(currentLang));
                    // Check base lang if local variant (like en-GB vs en-US) isn't explicitly found
                    const fallbackVoice = voices.find(voice => voice.lang.startsWith(currentLang.split('-')[0]));
                    if (matchedVoice) {
                        utterance.voice = matchedVoice;
                    } else if (fallbackVoice) {
                        utterance.voice = fallbackVoice;
                    }
                }

                utterance.onend = function() {
                    currentChunkIndex++;
                    playNextChunk(); // Chain next sentence
                };
                
                utterance.onerror = function(e) {
                    if (e.error !== 'canceled' && e.error !== 'interrupted') {
                        console.error('TTS Error:', e);
                    }
                };

                window.speechSynthesis.speak(utterance);
            }

            function resetUI() {
                isPlaying = false;
                isPaused = false;
                currentChunkIndex = 0;
                playBtn.innerHTML = '🔊 ' + "{{ 'Écouter'|trans_lang|escape('js') }}";
                stopBtn.classList.add('d-none');
                statusText.classList.add('d-none');
            }

            playBtn.addEventListener('click', function() {
                if (isPlaying) {
                    if (isPaused) {
                        window.speechSynthesis.resume();
                        isPaused = false;
                        playBtn.innerHTML = '⏸ ' + "{{ 'Pause'|trans_lang|escape('js') }}";
                        statusText.textContent = "{{ 'Lecture en cours...'|trans_lang|escape('js') }}";
                    } else {
                        window.speechSynthesis.pause();
                        isPaused = true;
                        playBtn.innerHTML = '▶ ' + "{{ 'Reprendre'|trans_lang|escape('js') }}";
                        statusText.textContent = "{{ 'En pause'|trans_lang|escape('js') }}";
                    }
                } else {
                    // C'est vital de cancel() avant de relancer sous Windows
                    window.speechSynthesis.cancel();
                    
                    const textToSpeak = (contentDiv.innerText || contentDiv.textContent || '').trim();
                    if (!textToSpeak) return;

                    textChunks = chunkText(textToSpeak);
                    currentChunkIndex = 0;
                    isPlaying = true;
                    isPaused = false;
                    
                    playBtn.innerHTML = '⏸ ' + "{{ 'Pause'|trans_lang|escape('js') }}";
                    stopBtn.classList.remove('d-none');
                    statusText.classList.remove('d-none');
                    statusText.textContent = "{{ 'Lecture en cours...'|trans_lang|escape('js') }}";
                    
                    // Lancer la lecture par morceaux
                    playNextChunk();
                }
            });

            stopBtn.addEventListener('click', function() {
                isPlaying = false;
                window.speechSynthesis.cancel();
                resetUI();
            });
            
            // Clean up when leaving page
            window.addEventListener('beforeunload', function() {
                window.speechSynthesis.cancel();
            });
        });
    </script>
{% endblock %}
