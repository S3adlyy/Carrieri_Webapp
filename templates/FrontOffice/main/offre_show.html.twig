</style>

<script>
    function toggleMissions() {
        const block = document.getElementById('missionsBlock');
        const btn = document.getElementById('missionToggleBtn');
        if (block.style.display === 'none') {
            block.style.display = 'block';
            btn.style.transform = 'rotate(180deg)';
        } else {
            block.style.display = 'none';
            btn.style.transform = 'rotate(0deg)';
        }
    }

    // OpenStreetMap with Leaflet.js
    let map = null;

    document.querySelectorAll('.map-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            const location = this.getAttribute('data-location');
            openMap(location);
        });
    });

    function openMap(location) {
        const modal = document.getElementById('mapModal');
        modal.style.display = 'flex';

        fetch('https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(location))
            .then(response => response.json())
            .then(data => {
                if (data && data.length > 0) {
                    const lat = parseFloat(data[0].lat);
                    const lon = parseFloat(data[0].lon);

                    if (map) {
                        map.remove();
                        map = null;
                    }

                    map = L.map('map').setView([lat, lon], 13);

                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
                    }).addTo(map);

                    L.marker([lat, lon])
                        .addTo(map)
                        .bindPopup('<strong>' + location + '</strong>')
                        .openPopup();
                } else {
                    document.getElementById('map').innerHTML =
                        '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#6b7280;font-weight:600;">Localisation introuvable sur la carte.</div>';
                }
            })
            .catch(() => {
                document.getElementById('map').innerHTML =
                    '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#6b7280;font-weight:600;">Erreur de chargement de la carte.</div>';
            });
    }

    function closeMap() {
        document.getElementById('mapModal').style.display = 'none';
        if (map) {
            map.remove();
            map = null;
        }
    }

    document.getElementById('mapModal').addEventListener('click', function(e) {
        if (e.target === this) closeMap();
    });
</script>

{# Leaflet.js CSS + JS #}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>

<script>
    function openQrModal() {
        const modal = document.getElementById('qrModal');
        if (modal) {
            modal.style.display = 'flex';
        }
    }

    function closeQrModal() {
        const modal = document.getElementById('qrModal');
        if (modal) {
            modal.style.display = 'none';
        }
    }

    function printQrCode() {
        const qrImage = document.getElementById('offerQrImage');
        if (!qrImage) {
            return;
        }

        const printWindow = window.open('', '_blank', 'width=700,height=800');

        printWindow.document.write(`
            <html>
                <head>
                    <title>QR Code - Offre</title>
                    <style>
                        body {
                            font-family: Arial, sans-serif;
                            text-align: center;
                            padding: 30px;
                        }
                        img {
                            width: 320px;
                            max-width: 100%;
                            margin-bottom: 20px;
                        }
                        h2 {
                            margin-bottom: 10px;
                        }
                        p {
                            color: #444;
                        }
                    </style>
                </head>
                <body>
                    <h2>{{ offre.titre|e('js') }}</h2>
                    <p>{{ offre.entreprise|e('js') }} - {{ offre.localisation|e('js') }}</p>
                    <img src="${qrImage.src}" alt="QR Code">
                </body>
            </html>
        `);

        printWindow.document.close();
        printWindow.focus();
        printWindow.print();
    }

    window.addEventListener('click', function (event) {
        const modal = document.getElementById('qrModal');
        if (event.target === modal) {
            closeQrModal();
        }
    });
</script>

<div id="qrModal" class="fo-qr-modal" style="display:none;">
    <div class="fo-qr-modal-content">
        <div class="fo-qr-modal-header">
            <h4>
                <i class="fas fa-qrcode"></i>
                QR Code - {{ offre.titre }}
            </h4>
            <button type="button" class="fo-qr-close" onclick="closeQrModal()">&times;</button>
        </div>

        <div class="fo-qr-body">
            <div class="fo-qr-image-wrap">
                <img
                    id="offerQrImage"
                    src="{{ qr_code_data_uri(qrText, 'custom') }}"
                    alt="QR Code de l'offre {{ offre.titre }}"
                    class="fo-qr-image"
                >
            </div>

            <p class="fo-qr-note">
                Scannez ce QR code pour récupérer les informations principales de l'offre.
            </p>

            <div class="fo-qr-actions">
                <a
                    id="downloadQrBtn"
                    href="{{ qr_code_data_uri(qrText, 'custom') }}"
                    download="offre-{{ offre.id }}-qr.svg"
                    class="fo-qr-action-btn fo-qr-download"
                >
                    <i class="fas fa-download"></i>
                    Télécharger
                </a>

                <button type="button" class="fo-qr-action-btn fo-qr-print" onclick="printQrCode()">
                    <i class="fas fa-print"></i>
                    Imprimer
                </button>
            </div>
        </div>
    </div>
</div>

{% endblock %}