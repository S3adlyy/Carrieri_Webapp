{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Détail de l'offre{% endblock %}

{% block candidate_page_heading %}Détail de l'offre{% endblock %}

{% block candidate_breadcrumb %} / Détail{% endblock %}

{% block candidate_content %}

<div class="fo-offre-detail">

    <div class="fo-offre-detail-card">

        <div class="fo-offre-detail-header">
            <h2 class="fo-title">{{ offre.titre }}</h2>
            <span class="fo-badge
                {% if offre.typeContrat == 'CDI' %}
                    fo-badge-cdi
                {% elseif offre.typeContrat == 'CDD' %}
                    fo-badge-cdd
                {% elseif offre.typeContrat == 'Stage' %}
                    fo-badge-stage
                {% else %}
                    fo-badge-other
                {% endif %}
            ">
                {{ offre.typeContrat }}
            </span>
        </div>

        <div class="fo-company">{{ offre.entreprise }}</div>

        {# ===== STATS ===== #}
        <div class="fo-stats-grid">
            <div class="fo-stat-card fo-stat-salary">
                <span class="fo-stat-label">Salaire</span>
                <strong class="fo-stat-value">{{ offre.salaire }} DT</strong>
            </div>

            <div class="fo-stat-card fo-stat-days">
                <span class="fo-stat-label">Jours restants</span>
                <strong class="fo-stat-value">
                    {{ joursRestants is not null ? joursRestants : '—' }}
                </strong>
            </div>

            <div class="fo-stat-card fo-stat-missions">
                <span class="fo-stat-label">Missions</span>
                <strong class="fo-stat-value">{{ missionsCount }}</strong>
            </div>

            <div class="fo-stat-card {% if alreadyApplied %}
                {% if postulationStatus == 'Acceptée' %}
                    fo-stat-accepted
                {% elseif postulationStatus == 'Refusée' %}
                    fo-stat-refused
                {% else %}
                    fo-stat-pending
                {% endif %}
            {% else %}
                fo-stat-not-applied
            {% endif %}">
                <span class="fo-stat-label">Candidature</span>
                <strong class="fo-stat-value">
                    {% if alreadyApplied %}
                        {% if postulationStatus == 'Acceptée' %}
                            Acceptée
                        {% elseif postulationStatus == 'Refusée' %}
                            Refusée
                        {% else %}
                            En attente
                        {% endif %}
                    {% else %}
                        Pas encore postulé
                    {% endif %}
                </strong>
            </div>
        </div>

        <div class="fo-meta-grid">

            <div class="fo-meta-box">
                <span>Localisation</span>
                <strong>{{ offre.localisation }}</strong>
            </div>

            <div class="fo-meta-box">
                <span>Qualification</span>
                <strong>{{ offre.niveauQualification }}</strong>
            </div>

            <div class="fo-meta-box">
                <span>Expérience</span>
                <strong>{{ offre.experienceRequise }}</strong>
            </div>

            <div class="fo-meta-box">
                <span>Expiration</span>
                <strong>
                    {{ offre.dateExpiration ? offre.dateExpiration|date('d/m/Y H:i') : '—' }}
                </strong>
            </div>

            <div class="fo-meta-box">
                <span>Contact</span>
                <strong>{{ offre.contactRecruteur }}</strong>
            </div>

            <div class="fo-meta-box">
                <span>Secteur</span>
                <strong>{{ offre.secteurActivite }}</strong>
            </div>

        </div>

        <div class="fo-description">
            <h4>Description</h4>
            <p>{{ offre.description|nl2br }}</p>
        </div>

        <div class="fo-missions-section">
            <div class="fo-missions-header">
                <h4>Exemples de Missions associées à cet offre</h4>
                <button type="button" class="fo-toggle-btn" id="missionToggleBtn" onclick="toggleMissions()">
                    ↓
                </button>
            </div>

            <div id="missionsBlock" class="fo-missions-list" style="display: none;">
                {% if missions is defined and missions|length > 0 %}
                    {% for mission in missions %}
                        <div class="fo-mission-card">
                            <div class="fo-mission-top">
                                <span class="fo-mission-type">
                                    {{ mission.type ?: 'Mission' }}
                                </span>
                                <span class="fo-mission-score">
                                    Score min : {{ mission.scoreMin ?: '—' }}
                                </span>
                            </div>

                            <div class="fo-mission-description">
                                {{ mission.description ?: 'Aucune description.' }}
                            </div>

                            <div class="fo-mission-date">
                                Créée le :
                                {{ mission.createdAt ? mission.createdAt|date('d/m/Y H:i') : '—' }}
                            </div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="fo-no-missions">
                        Aucune mission liée à ce recruteur.
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="fo-actions">
            <a href="{{ path('app_candidate_offres') }}" class="fo-btn-secondary">
                Retour aux offres
            </a>

            {% if alreadyApplied %}
                <span class="fo-btn-disabled">Déjà postulé</span>
            {% else %}
                <a href="{{ path('app_candidate_offre_apply', {'id': offre.id}) }}" class="fo-btn-primary">
                    Postuler
                </a>
            {% endif %}
        </div>

    </div>

</div>

<style>
    .fo-offre-detail-card {
        background: rgba(255,255,255,0.95);
        border-radius: 22px;
        padding: 40px;
        box-shadow: 0 12px 35px rgba(31, 55, 120, 0.10);
        text-align: left;
    }

    .fo-offre-detail-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 10px;
    }

    .fo-title {
        font-size: 34px;
        font-weight: 800;
        color: #1f3470;
    }

    .fo-company {
        font-size: 16px;
        font-weight: 700;
        color: #6b7280;
        margin-bottom: 25px;
    }

    .fo-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
        margin-bottom: 30px;
    }

    .fo-stat-card {
        border-radius: 18px;
        padding: 18px;
        text-align: center;
        box-shadow: 0 10px 22px rgba(31, 55, 120, 0.08);
        border: 1px solid transparent;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .fo-stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 28px rgba(31, 55, 120, 0.12);
    }

    .fo-stat-label {
        display: block;
        font-size: 13px;
        font-weight: 800;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

    .fo-stat-value {
        font-size: 20px;
        font-weight: 800;
    }

    .fo-stat-salary {
        background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
        border-color: #bfdbfe;
    }

    .fo-stat-salary .fo-stat-label,
    .fo-stat-salary .fo-stat-value {
        color: #1d4ed8;
    }

    .fo-stat-days {
        background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
        border-color: #fdba74;
    }

    .fo-stat-days .fo-stat-label,
    .fo-stat-days .fo-stat-value {
        color: #c2410c;
    }

    .fo-stat-missions {
        background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%);
        border-color: #c4b5fd;
    }

    .fo-stat-missions .fo-stat-label,
    .fo-stat-missions .fo-stat-value {
        color: #6d28d9;
    }

    .fo-stat-applied {
        background: linear-gradient(135deg, #d1fae5 0%, #bbf7d0 100%);
        border-color: #86efac;
    }

    .fo-stat-applied .fo-stat-label,
    .fo-stat-applied .fo-stat-value {
        color: #15803d;
    }

    .fo-stat-pending {
        background: linear-gradient(135deg, #fff7ed 0%, #feebc8 100%);
        border-color: #fef08a;
    }

    .fo-stat-pending .fo-stat-label,
    .fo-stat-pending .fo-stat-value {
        color: #f59e0b;
    }

    .fo-stat-refused {
        background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
        border-color: #fca5a5;
    }

    .fo-stat-refused .fo-stat-label,
    .fo-stat-refused .fo-stat-value {
        color: #b91c1c;
    }

    .fo-stat-not-applied {
        background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
        border-color: #fca5a5;
    }

    .fo-stat-not-applied .fo-stat-label,
    .fo-stat-not-applied .fo-stat-value {
        color: #b91c1c;
    }

    .fo-meta-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin-bottom: 30px;
    }

    .fo-meta-box {
        background: #f8fbff;
        border: 1px solid #e6eefc;
        border-radius: 12px;
        padding: 15px;
    }

    .fo-meta-box span {
        font-size: 13px;
        color: #3b82f6;
        font-weight: 700;
        display: block;
        margin-bottom: 5px;
    }

    .fo-meta-box strong {
        font-size: 15px;
        color: #1f2937;
    }

    .fo-description {
        margin-bottom: 30px;
    }

    .fo-description h4 {
        color: #223a7a;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .fo-description p {
        color: #5f6780;
        line-height: 1.8;
    }

    .fo-missions-section {
        margin-top: 20px;
        margin-bottom: 30px;
        background: #f9fbff;
        border: 1px solid #e6eefc;
        border-radius: 18px;
        padding: 22px;
    }

    .fo-missions-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 15px;
    }

    .fo-missions-header h4 {
        margin: 0;
        color: #223a7a;
        font-weight: 800;
    }

    .fo-toggle-btn {
        background: linear-gradient(90deg, #3b82f6, #2563eb);
        color: #fff;
        border: none;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        font-size: 18px;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.3s ease;
    }

    .fo-missions-list {
        margin-top: 15px;
    }

    .fo-mission-card {
        background: #fff;
        border: 1px solid #e5edf9;
        border-radius: 14px;
        padding: 16px;
        margin-bottom: 14px;
        box-shadow: 0 6px 18px rgba(31, 55, 120, 0.06);
    }

    .fo-mission-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 10px;
    }

    .fo-mission-type {
        display: inline-block;
        background: rgba(59, 130, 246, 0.12);
        color: #2563eb;
        border-radius: 999px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 700;
    }

    .fo-mission-score {
        color: #1f3470;
        font-size: 14px;
        font-weight: 700;
    }

    .fo-mission-description {
        color: #5f6780;
        line-height: 1.7;
        margin-bottom: 8px;
    }

    .fo-mission-date {
        color: #6b7280;
        font-size: 13px;
        font-weight: 600;
    }

    .fo-no-missions {
        color: #6b7280;
        font-weight: 600;
        padding: 10px 0;
    }

    .fo-actions {
        margin-top: 30px;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }

    .fo-btn-primary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%);
            color: white;
            border: none;
            border-radius: 999px;
            padding: 12px 24px;
            font-weight: 700;
            text-decoration: none;
        }

    .fo-btn-secondary {
        background: #e5e7eb;
        color: #1f2937;
        padding: 12px 25px;
        border-radius: 999px;
        font-weight: 700;
        text-decoration: none;
    }

    .fo-btn-disabled {
        background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
        color: #166534;
        padding: 12px 25px;
        border-radius: 999px;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #86efac;
    }

    .fo-badge-cdi { background: #dbeafe; color: #2563eb; padding: 8px 12px; border-radius: 999px; }
    .fo-badge-cdd { background: #fef3c7; color: #d97706; padding: 8px 12px; border-radius: 999px; }
    .fo-badge-stage { background: #d1fae5; color: #059669; padding: 8px 12px; border-radius: 999px; }
    .fo-badge-other { background: #ede9fe; color: #7c3aed; padding: 8px 12px; border-radius: 999px; }

    @media (max-width: 991px) {
        .fo-stats-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 768px) {
        .fo-meta-grid,
        .fo-stats-grid {
            grid-template-columns: 1fr;
        }

        .fo-mission-top {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<script>
    function toggleMissions() {
        const block = document.getElementById('missionsBlock');
        const btn = document.getElementById('missionToggleBtn');

        if (block.style.display === 'none') {
            block.style.display = 'block';
            btn.style.transform = 'rotate(180deg)';
        } else {
            block.style.display = 'none';
            btn.style.transform = 'rotate(0deg)';
        }
    }
</script>

{% endblock %}