                };

                // Fonction pour basculer le mode plein écran
                function toggleFullscreen() {
                    if (!isFullscreen) {
                        editorPanel.classList.add('fullscreen-mode');
                        fullscreenBtn.innerHTML = '<i class="fas fa-compress"></i>';
                        fullscreenBtn.title = "Quitter le mode plein écran";
                        setTimeout(() => editor.refresh(), 300);
                    } else {
                        editorPanel.classList.remove('fullscreen-mode');
                        fullscreenBtn.innerHTML = '<i class="fas fa-expand"></i>';
                        fullscreenBtn.title = "Mode plein écran";
                        setTimeout(() => editor.refresh(), 300);
                    }
                    isFullscreen = !isFullscreen;
                }

                fullscreenBtn.addEventListener('click', toggleFullscreen);

                document.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape' && isFullscreen) {
                        toggleFullscreen();
                    }
                });

                // Changer de langage
                languageSelect.addEventListener('change', function() {
                    const lang = this.value;
                    selectedLangue.value = lang;

                    const modes = {
                        php: 'php',
                        javascript: 'javascript',
                        python: 'python',
                        java: 'text/x-java',
                        cpp: 'text/x-c++src'
                    };
                    editor.setOption('mode', modes[lang] || 'python');

                    if (defaultCodes[lang]) {
                        editor.setValue(defaultCodes[lang]);
                    }
                });

                // Réinitialiser le code
                const resetBtn = document.getElementById('resetCode');
                resetBtn.addEventListener('click', () => {
                    const currentLang = languageSelect.value;
                    editor.setValue(defaultCodes[currentLang] || defaultCodes.python);
                });

                // Fonction pour échapper le HTML
                function escapeHtml(text) {
                    const div = document.createElement('div');
                    div.textContent = text;
                    return div.innerHTML;
                }

                // Exécuter le code avec le backend
                const runBtn = document.getElementById('runCode');
                const resultsPanel = document.getElementById('resultsPanel');
                const resultsContent = document.getElementById('resultsContent');

                runBtn.addEventListener('click', async function() {
                    const code = editor.getValue();
                    const language = languageSelect.value;

                    // Afficher le terminal
                    resultsPanel.style.display = 'block';

                    // Afficher l'état d'exécution
                    resultsContent.innerHTML = `
                        <div class="test-results">
                            <div class="test-summary">
                                <h4><i class="fas fa-spinner fa-spin"></i> Exécution en cours...</h4>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 50%"></div>
                                </div>
                            </div>
                            <div class="test-details">
                                <div class="test-item">
                                    <div class="test-message">Compilation et exécution du code ${language.toUpperCase()}...</div>
                                </div>
                            </div>
                        </div>
                    `;

                    try {
                        // Détecter le mode d'exécution
                        let mode = 'free';

                        if (language === 'python') {
                            // Mode test seulement si la fonction twoSum est définie ET qu'il n'y a pas de print
                            const hasTwoSum = code.includes('def twoSum');
                            const hasPrint = code.includes('print(');
                            if (hasTwoSum && !hasPrint && !code.includes('print')) {
                                mode = 'test';
                            }
                        } else if (language === 'javascript') {
                            const hasTwoSum = code.includes('function twoSum') || code.includes('var twoSum') || code.includes('const twoSum');
                            const hasConsoleLog = code.includes('console.log');
                            if (hasTwoSum && !hasConsoleLog) {
                                mode = 'test';
                            }
                        }

                        const response = await fetch('/execute-code', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({
                                code: code,
                                language: language,
                                mode: mode
                            })
                        });

                        const result = await response.json();

                        if (mode === 'free') {
                            // Mode exécution libre
                            if (result.success) {
                                resultsContent.innerHTML = `
                                    <div class="test-results">
                                        <div class="test-summary">
                                            <h4 style="color: #00ff9d;">
                                                <i class="fas fa-check-circle"></i> Exécution réussie
                                            </h4>
                                        </div>
                                        <div class="test-details">
                                            <div class="test-item test-success">
                                                <div class="test-header">📤 Sortie du programme</div>
                                                <div class="test-message">
                                                    <pre>${escapeHtml(result.output)}</pre>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                `;
                            } else {
                                resultsContent.innerHTML = `
                                    <div class="test-results">
                                        <div class="test-summary">
                                            <h4 style="color: #ff4757;">
                                                <i class="fas fa-exclamation-triangle"></i> Erreur d'exécution
                                            </h4>
                                        </div>
                                        <div class="test-details">
                                            <div class="test-item test-error">
                                                <div class="test-header">❌ Erreur</div>
                                                <div class="test-message">
                                                    <pre style="color: #ff4757;">${escapeHtml(result.error)}</pre>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                `;
                            }
                        } else {
                            // Mode test Two Sum
                            if (result.success) {
                                const percentage = (result.passedTests / result.totalTests) * 100;
                                let testsHtml = '';

                                result.results.forEach((test, index) => {
                                    testsHtml += `
                                        <div class="test-item ${test.passed ? 'test-success' : 'test-error'}">
                                            <div class="test-header">${test.passed ? '✓' : '✗'} Test ${index + 1}</div>
                                            <div class="test-message">
                                                ${test.message}
                                                ${!test.passed && test.expected ? `<br><small style="color: #ffc107;">Attendu: ${JSON.stringify(test.expected)}</small>` : ''}
                                            </div>
                                        </div>
                                    `;
                                });

                                resultsContent.innerHTML = `
                                    <div class="test-results">
                                        <div class="test-summary">
                                            <h4 style="color: #00ff9d;">
                                                ${result.passedTests === result.totalTests ? '✓' : '⚠'} ${result.passedTests}/${result.totalTests} tests passés
                                                ${result.score ? ` (Score: ${result.score}/100)` : ''}
                                            </h4>
                                            <div class="progress-bar">
                                                <div class="progress-fill" style="width: ${percentage}%; background: linear-gradient(90deg, #00ff9d, #00ffff);"></div>
                                            </div>
                                        </div>
                                        <div class="test-details">
                                            ${testsHtml}
                                        </div>
                                    </div>
                                `;
                            } else {
                                resultsContent.innerHTML = `
                                    <div class="test-results">
                                        <div class="test-summary">
                                            <h4 style="color: #ff4757;">✗ ${result.passedTests || 0}/${result.totalTests || 3} tests passés</h4>
                                            <div class="progress-bar">
                                                <div class="progress-fill" style="width: ${(result.passedTests || 0) / (result.totalTests || 3) * 100}%; background: #ff4757;"></div>
                                            </div>
                                        </div>
                                        <div class="test-details">
                                            ${result.results ? result.results.map((test, index) => `
                                                <div class="test-item ${test.passed ? 'test-success' : 'test-error'}">
                                                    <div class="test-header">${test.passed ? '✓' : '✗'} Test ${index + 1}</div>
                                                    <div class="test-message">${test.message}</div>
                                                </div>
                                            `).join('') : `
                                                <div class="test-item test-error">
                                                    <div class="test-header">✗ Erreur</div>
                                                    <div class="test-message">${result.message || "Une erreur s'est produite"}</div>
                                                </div>
                                            `}
                                        </div>
                                    </div>
                                `;
                            }
                        }
                    } catch (error) {
                        resultsContent.innerHTML = `
                            <div class="test-results">
                                <div class="test-summary">
                                    <h4 style="color: #ff4757;">✗ Erreur de connexion</h4>
                                    <div class="progress-bar">
                                        <div class="progress-fill" style="width: 0%; background: #ff4757;"></div>
                                    </div>
                                </div>
                                <div class="test-details">
                                    <div class="test-item test-error">
                                        <div class="test-header">✗ Erreur</div>
                                        <div class="test-message">Impossible de contacter le serveur: ${error.message}</div>
                                    </div>
                                </div>
                            </div>
                        `;
                    }
                });

                // Fermer les résultats
                const closeResults = document.getElementById('closeResults');
                closeResults.addEventListener('click', () => resultsPanel.style.display = 'none');

                // Soumettre le formulaire
                const form = document.getElementById('codeForm');
                form.addEventListener('submit', function() {
                    editor.save();
                    resultsPanel.style.display = 'block';
                    resultsContent.innerHTML = `
                        <div class="test-results">
                            <div class="test-summary">
                                <h4><i class="fas fa-spinner fa-spin"></i> Soumission en cours...</h4>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 50%"></div>
                                </div>
                            </div>
                            <div class="test-details">
                                <div class="test-item">
                                    <div class="test-message">Envoi du code au serveur pour évaluation...</div>
                                </div>
                            </div>
                        </div>
                    `;
                });
            });
        </script>
    {% endblock %}
{% endblock %}