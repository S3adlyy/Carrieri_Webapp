{# templates/FrontOffice/main/rendu_mission.html.twig #}
{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Mission - {{ mission.type }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/codemirror.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/theme/dracula.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        /* Reset des marges pour prendre tout l'espace */
        .fo-candidate-content {
            padding: 0 !important;
            margin: 0 !important;
            max-width: 100% !important;
            position: relative;
            z-index: 2;
        }

        .container {
            max-width: 100% !important;
            padding: 0 !important;
            margin: 0 !important;
        }

        .row {
            margin: 0 !important;
        }

        .col-lg-8, .col-md-10 {
            max-width: 100% !important;
            flex: 0 0 100% !important;
        }

        /* Cacher le breadcrumb */
        .section-top, .section-top-title {
            display: none !important;
        }

        body {
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            overflow: hidden;
        }

        /* Container Spline 3D en arrière-plan */
        .spline-background {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
            opacity: 0.3;
        }

        spline-viewer {
            width: 100%;
            height: 100%;
        }

        /* S'assurer que la navbar reste au-dessus */
        .top_header_banner {
            position: relative;
            z-index: 10 !important;
        }

        .logo-contact, #navigation {
            position: relative;
            z-index: 10 !important;
        }

        /* Mode plein écran */
        .fullscreen-mode {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            right: 0 !important;
            bottom: 0 !important;
            width: 100% !important;
            height: 100% !important;
            z-index: 9999 !important;
            background: rgba(20, 20, 30, 0.98) !important;
            backdrop-filter: blur(20px) !important;
        }

        .fullscreen-mode .leetcode-panel-right {
            width: 100% !important;
        }

        .fullscreen-mode .leetcode-panel-left {
            display: none !important;
        }
    </style>
{% endblock %}

{% block candidate_page_heading %}{% endblock %}
{% block candidate_breadcrumb %}{% endblock %}

{% block candidate_content %}
    <!-- Spline 3D Background -->
    <div class="spline-background">
        <spline-viewer url="https://prod.spline.design/mlkMZXmoLQbdGmeF/scene.splinecode"></spline-viewer>
    </div>

    <div class="leetcode-container">
        <div class="leetcode-panels">
            <!-- Panneau gauche - Description -->
            <div class="leetcode-panel-left">
                <div class="problem-content">
                    <div class="problem-header">
                        <div class="problem-title-section">
                            <span class="problem-number">
                                <i class="fas fa-code"></i> Mission #{{ mission.id }}
                            </span>
                            <h1 class="problem-title">{{ mission.type }}</h1>
                        </div>
                        <div class="problem-meta">
                            <span class="score-badge">
                                <i class="fas fa-star"></i> Score requis: {{ mission.scoreMin }}
                            </span>
                        </div>
                    </div>

                    <div class="problem-description">
                        <p>{{ mission.description|nl2br }}</p>
                    </div>

                    <div class="problem-examples">
                        <h3><i class="fas fa-file-alt"></i> Exemples</h3>

                        <div class="example">
                            <div class="example-title">
                                <i class="fas fa-play-circle"></i> Exemple 1:
                            </div>
                            <div class="example-content">
                                <div><strong>Input:</strong> nums = [2,7,11,15], target = 9</div>
                                <div><strong>Output:</strong> [0,1]</div>
                                <div><strong>Explanation:</strong> Because nums[0] + nums[1] == 9, we return [0, 1].</div>
                            </div>
                        </div>

                        <div class="example">
                            <div class="example-title">
                                <i class="fas fa-play-circle"></i> Exemple 2:
                            </div>
                            <div class="example-content">
                                <div><strong>Input:</strong> nums = [3,2,4], target = 6</div>
                                <div><strong>Output:</strong> [1,2]</div>
                            </div>
                        </div>

                        <div class="example">
                            <div class="example-title">
                                <i class="fas fa-play-circle"></i> Exemple 3:
                            </div>
                            <div class="example-content">
                                <div><strong>Input:</strong> nums = [3,3], target = 6</div>
                                <div><strong>Output:</strong> [0,1]</div>
                            </div>
                        </div>
                    </div>

                    <div class="problem-constraints">
                        <h3><i class="fas fa-exclamation-triangle"></i> Contraintes</h3>
                        <ul>
                            <li>2 ≤ nums.length ≤ 10⁴</li>
                            <li>-10⁹ ≤ nums[i] ≤ 10⁹</li>
                            <li>-10⁹ ≤ target ≤ 10⁹</li>
                        </ul>
                    </div>

                    {% if existingRendu %}
                        <div class="previous-submission">
                            <h3><i class="fas fa-history"></i> Dernière soumission</h3>
                            <div class="submission-details">
                                <div><span class="label">Date:</span> {{ existingRendu.dateRendu|date('d/m/Y H:i') }}</div>
                                <div><span class="label">Score:</span> <span class="score">{{ existingRendu.score|default(0)|round }}/100</span></div>
                                <div><span class="label">Langage:</span> {{ existingRendu.langue|upper }}</div>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Panneau droit - Éditeur de code -->
            <div class="leetcode-panel-right" id="editorPanel">
                <div class="editor-header">
                    <div class="language-selector">
                        <label for="language">
                            <i class="fas fa-code"></i> Langage
                        </label>
                        <select id="language" class="language-select">
                            <option value="python" selected>Python</option>
                            <option value="javascript">JavaScript</option>
                            <option value="php">PHP</option>
                            <option value="java">Java</option>
                            <option value="cpp">C++</option>
                        </select>
                    </div>
                    <div class="editor-actions">
                        <button class="fullscreen-btn" id="fullscreenBtn" title="Mode plein écran">
                            <i class="fas fa-expand"></i>
                        </button>
                        <button class="reset-btn" id="resetCode" title="Réinitialiser le code">
                            <i class="fas fa-undo-alt"></i> Réinitialiser
                        </button>
                    </div>
                </div>

                <form method="post" id="codeForm" class="editor-form">
                <textarea id="codeEditor" name="code"># Solution Python pour Two Sum
# Essayez votre code ici !

def twoSum(nums, target):
    """
    :type nums: List[int]
    :type target: int
    :rtype: List[int]
    """
    seen = {}
    for i, num in enumerate(nums):
        complement = target - num
        if complement in seen:
            return [seen[complement], i]
        seen[num] = i
    return []

# Testez votre code avec print
print("Bienvenue dans l'éditeur de code!")
print("Exemple d'utilisation:")
result = twoSum([2, 7, 11, 15], 9)
print(f"twoSum([2, 7, 11, 15], 9) = {result}")</textarea>
                    <input type="hidden" name="langue" id="selectedLangue" value="python">

                    <div class="editor-footer">
                        <button type="button" class="run-btn" id="runCode">
                            <i class="fas fa-play"></i> Exécuter
                        </button>
                        <button type="submit" class="submit-btn" id="submitCode">
                            <i class="fas fa-paper-plane"></i> Soumettre
                        </button>
                    </div>
                </form>

                <!-- Résultats - Terminal unique -->
                <div class="results-container" id="resultsPanel" style="display: none;">
                    <div class="results-header">
                        <h3>
                            <i class="fas fa-terminal"></i> Terminal - Résultats
                        </h3>
                        <button class="close-results" id="closeResults" title="Fermer">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div class="results-content" id="resultsContent">
                        <div class="test-results">
                            <div class="test-summary">
                                <h4>Prêt à exécuter</h4>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 0%"></div>
                                </div>
                            </div>
                            <div class="test-details">
                                <div class="test-item">
                                    <div class="test-message" style="color: rgba(255,255,255,0.6);">
                                        <i class="fas fa-code"></i> Cliquez sur "Exécuter" pour tester votre code
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        /* Container principal - prend tout l'espace sous la navbar */
        .leetcode-container {
            position: relative;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: transparent;
            overflow: hidden;
            z-index: 2;
            height: calc(100vh - 140px);
            margin-top: 0;
        }

        .leetcode-panels {
            display: flex;
            width: 100%;
            height: 100%;
            gap: 0;
        }

        /* Panneau gauche - Description améliorée */
        .leetcode-panel-left {
            width: 45%;
            background: rgba(15, 25, 45, 0.65);
            backdrop-filter: blur(20px);
            overflow-y: auto;
            padding: 28px 32px;
            border-right: 1px solid rgba(0, 255, 255, 0.15);
            scroll-behavior: smooth;
            box-shadow: 4px 0 20px rgba(0, 0, 0, 0.3);
        }

        .problem-content {
            max-width: 800px;
            margin: 0 auto;
        }

        .problem-header {
            margin-bottom: 28px;
            padding-bottom: 20px;
            border-bottom: 2px solid rgba(0, 255, 255, 0.2);
        }

        .problem-title-section {
            margin-bottom: 12px;
        }

        .problem-number {
            font-size: 13px;
            color: #00ffff;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-weight: 600;
        }

        .problem-title {
            font-size: 28px;
            font-weight: 800;
            background: linear-gradient(135deg, #ffffff, #00ffff);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin: 0;
            text-shadow: 0 2px 10px rgba(0, 255, 255, 0.2);
        }

        .problem-meta {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .score-badge {
            font-size: 12px;
            padding: 5px 14px;
            background: linear-gradient(135deg, rgba(255, 193, 7, 0.2), rgba(255, 152, 0, 0.2));
            border: 1px solid rgba(255, 193, 7, 0.4);
            color: #ffc107;
            border-radius: 20px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .problem-description {
            margin-bottom: 28px;
        }

        .problem-description p {
            color: rgba(255, 255, 255, 0.9);
            line-height: 1.7;
            font-size: 15px;
            text-shadow: 0 1px 2px rgba(0,0,0,0.1);
        }

        .problem-examples h3,
        .problem-constraints h3 {
            font-size: 18px;
            font-weight: 700;
            background: linear-gradient(135deg, #ffffff, #00ffff);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .example {
            background: rgba(0, 255, 255, 0.08);
            border-radius: 12px;
            padding: 16px 20px;
            margin-bottom: 16px;
            border: 1px solid rgba(0, 255, 255, 0.2);
            transition: all 0.3s ease;
        }

        .example:hover {
            background: rgba(0, 255, 255, 0.12);
            transform: translateX(4px);
            border-color: rgba(0, 255, 255, 0.4);
        }

        .example-title {
            font-weight: 700;
            color: #00ffff;
            margin-bottom: 10px;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .example-content {
            font-family: 'Monaco', 'Courier New', monospace;
            font-size: 13px;
            color: rgba(255, 255, 255, 0.85);
            line-height: 1.6;
        }

        .example-content div {
            margin-bottom: 5px;
        }

        .example-content strong {
            color: #ffc107;
        }

        .problem-constraints ul {
            margin: 0;
            padding-left: 20px;
        }

        .problem-constraints li {
            color: rgba(255, 255, 255, 0.85);
            margin-bottom: 8px;
            font-size: 13px;
        }

        .previous-submission {
            margin-top: 32px;
            padding: 20px;
            background: linear-gradient(135deg, rgba(0, 255, 255, 0.08), rgba(0, 150, 255, 0.08));
            border-radius: 12px;
            border: 1px solid rgba(0, 255, 255, 0.2);
        }

        .previous-submission h3 {
            font-size: 16px;
            font-weight: 700;
            color: #00ffff;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .submission-details {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .submission-details div {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.85);
        }

        .submission-details .label {
            font-weight: 600;
            color: #00ffff;
            margin-right: 12px;
        }

        .submission-details .score {
            color: #ffc107;
            font-weight: 700;
        }

        /* Panneau droit - Éditeur amélioré */
        .leetcode-panel-right {
            width: 55%;
            background: rgba(10, 20, 30, 0.75);
            backdrop-filter: blur(20px);
            display: flex;
            flex-direction: column;
            height: 100%;
            transition: all 0.3s ease;
        }

        .editor-header {
            padding: 12px 24px;
            background: rgba(0, 0, 0, 0.3);
            border-bottom: 1px solid rgba(0, 255, 255, 0.15);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .language-selector {
            display: flex;
            align-items: center;
            gap: 12px;
            color: rgba(255, 255, 255, 0.9);
            font-size: 13px;
            font-weight: 500;
        }

        .language-selector label {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .language-select {
            padding: 6px 12px;
            background: rgba(0, 255, 255, 0.1);
            border: 1px solid rgba(0, 255, 255, 0.3);
            border-radius: 8px;
            color: #00ffff;
            font-size: 13px;
            cursor: pointer;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .language-select:hover {
            background: rgba(0, 255, 255, 0.2);
            border-color: #00ffff;
        }

        .language-select:focus {
            outline: none;
            border-color: #00ffff;
            box-shadow: 0 0 10px rgba(0, 255, 255, 0.3);
        }

        .editor-actions {
            display: flex;
            gap: 12px;
        }

        .fullscreen-btn, .reset-btn {
            padding: 6px 12px;
            background: rgba(0, 255, 255, 0.1);
            border: 1px solid rgba(0, 255, 255, 0.3);
            border-radius: 8px;
            color: #00ffff;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .fullscreen-btn:hover, .reset-btn:hover {
            background: rgba(0, 255, 255, 0.2);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0, 255, 255, 0.2);
        }

        .editor-form {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 0;
        }

        #codeEditor {
            display: none;
        }

        .CodeMirror {
            flex: 1;
            height: auto !important;
            font-size: 14px;
            font-family: 'Monaco', 'Courier New', monospace;
            background: rgba(0, 0, 0, 0.4) !important;
            border-radius: 0;
        }

        .CodeMirror-gutters {
            background: rgba(0, 0, 0, 0.5) !important;
            border-right: 1px solid rgba(0, 255, 255, 0.1);
        }

        .editor-footer {
            padding: 12px 24px;
            background: rgba(0, 0, 0, 0.3);
            display: flex;
            gap: 15px;
            justify-content: flex-end;
            border-top: 1px solid rgba(0, 255, 255, 0.15);
        }

        .run-btn, .submit-btn {
            padding: 10px 24px;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
        }

        .run-btn {
            background: linear-gradient(135deg, rgba(0, 255, 255, 0.2), rgba(0, 150, 255, 0.2));
            border: 1px solid #00ffff;
            color: #00ffff;
        }

        .run-btn:hover {
            background: linear-gradient(135deg, #00ffff, #0099ff);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 255, 255, 0.3);
        }

        .submit-btn {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
        }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }

        /* Résultats - Terminal amélioré */
        .results-container {
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(10px);
            border-top: 1px solid rgba(0, 255, 255, 0.3);
            max-height: 320px;
            overflow-y: auto;
            border-radius: 0;
        }

        .results-header {
            padding: 12px 24px;
            background: linear-gradient(135deg, rgba(0, 255, 255, 0.1), rgba(0, 150, 255, 0.05));
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(0, 255, 255, 0.2);
