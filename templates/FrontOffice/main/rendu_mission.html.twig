                    </div>
                    <div class="rm-editor-bar-right">
                        <button class="rm-tool-btn" id="resetCode" title="Réinitialiser">
                            <i class="fas fa-undo-alt"></i> Reset
                        </button>
                        <button class="rm-tool-btn" id="fullscreenBtn" title="Plein écran">
                            <i class="fas fa-expand"></i>
                        </button>
                    </div>
                </div>

                {# CodeMirror editor form #}
                <form method="post" id="codeForm" style="flex:1;display:flex;flex-direction:column;min-height:0">
                    <div class="rm-cm-shell">
                    <textarea id="codeEditor" name="code"># Solution Python pour Two Sum
# Essayez votre code ici !

def twoSum(nums, target):
    """
    :type nums: List[int]
    :type target: int
    :rtype: List[int]
    """
    seen = {}
    for i, num in enumerate(nums):
        complement = target - num
        if complement in seen:
            return [seen[complement], i]
        seen[num] = i
    return []

# Testez votre code avec print
print("Bienvenue dans l'éditeur de code!")
print("Exemple d'utilisation:")
result = twoSum([2, 7, 11, 15], 9)
print(f"twoSum([2, 7, 11, 15], 9) = {result}")</textarea>
                    </div>
                    <input type="hidden" name="langue" id="selectedLangue" value="python">

                    {# Footer actions #}
                    <div class="rm-editor-footer">
                        <div class="rm-footer-left">
                        <span class="rm-footer-hint">
                            <kbd>Ctrl</kbd>+<kbd>Enter</kbd> Exécuter
                        </span>
                        </div>
                        <div class="rm-footer-right">
                            <button type="button" class="rm-btn-run" id="runCode">
                                <i class="fas fa-play"></i> Exécuter
                            </button>
                            <button type="submit" class="rm-btn-submit" id="submitCode">
                                <i class="fas fa-paper-plane"></i> Soumettre
                            </button>
                        </div>
                    </div>
                </form>

                {# Terminal / Results #}
                <div class="rm-terminal" id="resultsPanel">
                    <div class="rm-terminal-bar">
                        <div style="display:flex;align-items:center;gap:10px">
                            <div class="rm-terminal-dots">
                                <div class="rm-dot rm-dot-red"></div>
                                <div class="rm-dot rm-dot-yellow"></div>
                                <div class="rm-dot rm-dot-green"></div>
                            </div>
                            <div class="rm-terminal-title">
                                <i class="fas fa-terminal"></i> Terminal
                            </div>
                        </div>
                        <button class="rm-terminal-close" id="closeResults" title="Fermer">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div class="rm-terminal-body" id="resultsContent">
                        <div class="test-results">
                            <div class="test-summary">
                                <h4 style="color:rgba(255,255,255,.4)">Prêt à exécuter</h4>
                                <div class="progress-bar"><div class="progress-fill" style="width:0%"></div></div>
                            </div>
                            <div class="test-details">
                                <div class="test-item">
                                    <div class="test-message">
                                        <i class="fas fa-code"></i> Cliquez sur « Exécuter » pour tester votre code
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>{# end editor panel #}
        </div>{# end layout #}
    </div>{# end root #}

    {% block javascripts %}
        {{ parent() }}
        <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/codemirror.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/javascript/javascript.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/php/php.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/python/python.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/clike/clike.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const textarea      = document.getElementById('codeEditor');
                const languageSelect = document.getElementById('language');
                const selectedLangue = document.getElementById('selectedLangue');
                const editorPanel   = document.getElementById('editorPanel');
                const fullscreenBtn = document.getElementById('fullscreenBtn');
                const resultsPanel  = document.getElementById('resultsPanel');
                const resultsContent = document.getElementById('resultsContent');
                let isFullscreen = false;

                // ── Init CodeMirror ──
                let editor = CodeMirror.fromTextArea(textarea, {
                    lineNumbers:   true,
                    mode:          'python',
                    theme:         'dracula',
                    matchBrackets: true,
                    indentUnit:    4,
                    tabSize:       4,
                    lineWrapping:  true,
                    gutters:       ['CodeMirror-linenumbers']
                });
                setTimeout(() => editor.refresh(), 100);
                window.addEventListener('resize', () => editor.refresh());

                // ── Default code templates ──
                const defaultCodes = {
                    python: `# Solution Python pour Two Sum
# Essayez votre code ici !

def twoSum(nums, target):
    """
    :type nums: List[int]
    :type target: int
    :rtype: List[int]
    """
    seen = {}
    for i, num in enumerate(nums):
        complement = target - num
        if complement in seen:
            return [seen[complement], i]
        seen[num] = i
    return []

# Testez votre code avec print
print("Bienvenue dans l'éditeur de code!")
print("Exemple d'utilisation:")
result = twoSum([2, 7, 11, 15], 9)
print(f"twoSum([2, 7, 11, 15], 9) = {result}")`,
                    javascript: `/**
 * Solution JavaScript pour Two Sum
 * @param {number[]} nums
 * @param {number} target
 * @return {number[]}
 */
var twoSum = function(nums, target) {
    const map = new Map();
    for (let i = 0; i < nums.length; i++) {
        const complement = target - nums[i];
        if (map.has(complement)) {
            return [map.get(complement), i];
        }
        map.set(nums[i], i);
    }
    return [];
};

// Test
console.log("Bienvenue dans l'éditeur de code!");
console.log("twoSum([2, 7, 11, 15], 9) =", twoSum([2, 7, 11, 15], 9));`,
                    php: `<?php
/**
 * Solution PHP pour Two Sum
 */
function twoSum($nums, $target) {
    $map = [];
    for ($i = 0; $i < count($nums); $i++) {
        $complement = $target - $nums[$i];
        if (isset($map[$complement])) {
            return [$map[$complement], $i];
        }
        $map[$nums[$i]] = $i;
    }
    return [];
}

echo "Bienvenue dans l'éditeur de code!\\n";
echo "twoSum([2, 7, 11, 15], 9) = ";
print_r(twoSum([2, 7, 11, 15], 9));
?>`,
                    java: `import java.util.*;

class Solution {
    public int[] twoSum(int[] nums, int target) {
        Map<Integer, Integer> map = new HashMap<>();
        for (int i = 0; i < nums.length; i++) {
            int complement = target - nums[i];
            if (map.containsKey(complement)) {
                return new int[] { map.get(complement), i };
            }
            map.put(nums[i], i);
        }
        return new int[] {};
    }

    public static void main(String[] args) {
        Solution sol = new Solution();
        int[] result = sol.twoSum(new int[]{2, 7, 11, 15}, 9);
        System.out.println("twoSum([2, 7, 11, 15], 9) = " + Arrays.toString(result));
    }
}`,
                    cpp: `#include <iostream>
#include <vector>
#include <unordered_map>
using namespace std;

class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int, int> map;
        for (int i = 0; i < nums.size(); i++) {
            int complement = target - nums[i];
            if (map.find(complement) != map.end()) {
                return {map[complement], i};
            }
            map[nums[i]] = i;
        }
        return {};
    }
};

int main() {
    Solution sol;
    vector<int> nums = {2, 7, 11, 15};
    int target = 9;
    vector<int> result = sol.twoSum(nums, target);
    cout << "twoSum([2, 7, 11, 15], 9) = [" << result[0] << "," << result[1] << "]" << endl;
    return 0;
}`
                };

                // ── Fullscreen ──
                function toggleFullscreen() {
                    if (!isFullscreen) {
                        editorPanel.classList.add('fullscreen-mode');
                        fullscreenBtn.innerHTML = '<i class="fas fa-compress"></i>';
                        fullscreenBtn.title = "Quitter le plein écran";
                        setTimeout(() => editor.refresh(), 300);
                    } else {
                        editorPanel.classList.remove('fullscreen-mode');
                        fullscreenBtn.innerHTML = '<i class="fas fa-expand"></i>';
                        fullscreenBtn.title = "Plein écran";
                        setTimeout(() => editor.refresh(), 300);
                    }
                    isFullscreen = !isFullscreen;
                }
                fullscreenBtn.addEventListener('click', toggleFullscreen);
                document.addEventListener('keydown', e => { if (e.key === 'Escape' && isFullscreen) toggleFullscreen(); });

                // Ctrl+Enter shortcut to run
                document.addEventListener('keydown', e => {
                    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                        e.preventDefault();
                        document.getElementById('runCode').click();
                    }
                });

                // ── Language change ──
                languageSelect.addEventListener('change', function () {
                    const lang = this.value;
                    selectedLangue.value = lang;
                    const modes = { php: 'php', javascript: 'javascript', python: 'python', java: 'text/x-java', cpp: 'text/x-c++src' };
                    editor.setOption('mode', modes[lang] || 'python');
                    if (defaultCodes[lang]) editor.setValue(defaultCodes[lang]);
                });

                // ── Reset ──
                document.getElementById('resetCode').addEventListener('click', () => {
                    const lang = languageSelect.value;
                    editor.setValue(defaultCodes[lang] || defaultCodes.python);
                });

                // ── Helper ──
                function escapeHtml(text) {
                    const div = document.createElement('div');
                    div.textContent = text;
                    return div.innerHTML;
                }

                function openTerminal() {
                    resultsPanel.classList.add('open');
                }

                // ── Run code ──
                document.getElementById('runCode').addEventListener('click', async function () {
                    const code = editor.getValue();
                    const language = languageSelect.value;
                    openTerminal();
                    resultsContent.innerHTML = `
                    <div class="test-results">
                        <div class="test-summary">
                            <h4><i class="fas fa-spinner fa-spin"></i> Exécution en cours...</h4>
                            <div class="progress-bar"><div class="progress-fill" style="width:50%"></div></div>
                        </div>
                        <div class="test-details">
                            <div class="test-item"><div class="test-message">Compilation et exécution du code ${language.toUpperCase()}...</div></div>
                        </div>
                    </div>`;

                    try {
                        let mode = 'free';
                        if (language === 'python') {
                            const hasTwoSum = code.includes('def twoSum');
                            const hasPrint  = code.includes('print(');
                            if (hasTwoSum && !hasPrint && !code.includes('print')) mode = 'test';
                        } else if (language === 'javascript') {
                            const hasTwoSum     = code.includes('function twoSum') || code.includes('var twoSum') || code.includes('const twoSum');
                            const hasConsoleLog = code.includes('console.log');
                            if (hasTwoSum && !hasConsoleLog) mode = 'test';
                        }

                        const response = await fetch('/execute-code', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ code, language, mode })
                        });
                        const result = await response.json();

                        if (mode === 'free') {
                            if (result.success) {
                                resultsContent.innerHTML = `
                                <div class="test-results">
                                    <div class="test-summary">
                                        <h4 style="color:#6ee7b7"><i class="fas fa-check-circle"></i> Exécution réussie</h4>
                                    </div>
                                    <div class="test-details">
                                        <div class="test-item test-success">
                                            <div class="test-header">📤 Sortie</div>
                                            <div class="test-message"><pre>${escapeHtml(result.output)}</pre></div>
                                        </div>
                                    </div>
                                </div>`;
                            } else {
                                resultsContent.innerHTML = `
                                <div class="test-results">
                                    <div class="test-summary">
                                        <h4 style="color:#fca5a5"><i class="fas fa-exclamation-triangle"></i> Erreur d'exécution</h4>
                                    </div>
                                    <div class="test-details">
                                        <div class="test-item test-error">
                                            <div class="test-header">❌ Erreur</div>
                                            <div class="test-message"><pre style="color:#fca5a5">${escapeHtml(result.error)}</pre></div>
                                        </div>
                                    </div>
                                </div>`;
                            }
                        } else {
                            if (result.success) {
                                const pct = (result.passedTests / result.totalTests) * 100;
                                let testsHtml = '';
                                result.results.forEach((test, i) => {
                                    testsHtml += `
                                    <div class="test-item ${test.passed ? 'test-success' : 'test-error'}">
                                        <div class="test-header">${test.passed ? '✓' : '✗'} Test ${i + 1}</div>
                                        <div class="test-message">${test.message}${!test.passed && test.expected ? `<br><small style="color:#fcd34d">Attendu : ${JSON.stringify(test.expected)}</small>` : ''}</div>
                                    </div>`;
                                });
                                resultsContent.innerHTML = `
                                <div class="test-results">
                                    <div class="test-summary">
                                        <h4 style="color:#6ee7b7">${result.passedTests === result.totalTests ? '✓' : '⚠'} ${result.passedTests}/${result.totalTests} tests passés${result.score ? ` · Score : ${result.score}/100` : ''}</h4>
                                        <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
                                    </div>
                                    <div class="test-details">${testsHtml}</div>
                                </div>`;
                            } else {
                                const pct = ((result.passedTests || 0) / (result.totalTests || 3)) * 100;
                                const testsHtml = result.results
                                    ? result.results.map((t, i) => `
                                    <div class="test-item ${t.passed ? 'test-success' : 'test-error'}">
                                        <div class="test-header">${t.passed ? '✓' : '✗'} Test ${i + 1}</div>
                                        <div class="test-message">${t.message}</div>
                                    </div>`).join('')
                                    : `<div class="test-item test-error"><div class="test-header">✗ Erreur</div><div class="test-message">${result.message || "Une erreur s'est produite"}</div></div>`;
                                resultsContent.innerHTML = `
                                <div class="test-results">
                                    <div class="test-summary">
                                        <h4 style="color:#fca5a5">✗ ${result.passedTests || 0}/${result.totalTests || 3} tests passés</h4>
                                        <div class="progress-bar"><div class="progress-fill" style="width:${pct}%;background:#ef4444"></div></div>
                                    </div>
                                    <div class="test-details">${testsHtml}</div>
                                </div>`;
                            }
                        }
                    } catch (err) {
                        resultsContent.innerHTML = `
                        <div class="test-results">
                            <div class="test-summary">
                                <h4 style="color:#fca5a5">✗ Erreur de connexion</h4>
                                <div class="progress-bar"><div class="progress-fill" style="width:0%;background:#ef4444"></div></div>
                            </div>
                            <div class="test-details">
                                <div class="test-item test-error">
                                    <div class="test-header">✗ Erreur</div>
                                    <div class="test-message">Impossible de contacter le serveur : ${err.message}</div>
                                </div>
                            </div>
                        </div>`;
                    }
                });

                // ── Close terminal ──
                document.getElementById('closeResults').addEventListener('click', () => {
                    resultsPanel.classList.remove('open');
                });

                // ── Submit ──
                document.getElementById('codeForm').addEventListener('submit', function () {
                    editor.save();
                    openTerminal();
                    resultsContent.innerHTML = `
                    <div class="test-results">
                        <div class="test-summary">
                            <h4><i class="fas fa-spinner fa-spin"></i> Soumission en cours...</h4>
                            <div class="progress-bar"><div class="progress-fill" style="width:50%"></div></div>
                        </div>
                        <div class="test-details">
                            <div class="test-item"><div class="test-message">Envoi du code au serveur pour évaluation...</div></div>
                        </div>
                    </div>`;
                });
            });
        </script>
    {% endblock %}
{% endblock %}
