            border-radius: 10px;
            height: 8px;
            overflow: hidden;
        }

        .progress-fill {
            background: linear-gradient(90deg, #00ffff, #0099ff);
            height: 100%;
            transition: width 0.5s ease;
            border-radius: 10px;
        }

        .test-details {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .test-item {
