        }

        .fa-spinner {
            animation: spin 1s linear infinite;
        }

        @media (max-width: 992px) {
            .rendu-mission-root .leetcode-panels {
                flex-direction: column;
                min-height: 0;
            }

            .rendu-mission-root .leetcode-panel-left,
            .rendu-mission-root .leetcode-panel-right {
                width: 100% !important;
                border-right: none !important;
            }

            /* DOM : éditeur puis énoncé */
            .rendu-mission-root .leetcode-panel-right {
                min-height: 42vh;
            }

            .rendu-mission-root .leetcode-panel-left {
