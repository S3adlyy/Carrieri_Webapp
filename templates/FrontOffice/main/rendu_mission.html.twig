                                            <div class="progress-bar">
                                                <div class="progress-fill" style="width: ${(result.passedTests || 0) / (result.totalTests || 3) * 100}%; background: #ff4757;"></div>
                                            </div>
                                        </div>
                                        <div class="test-details">
                                            ${result.results ? result.results.map((test, index) => `
                                                <div class="test-item ${test.passed ? 'test-success' : 'test-error'}">
                                                    <div class="test-header">${test.passed ? '✓' : '✗'} Test ${index + 1}</div>
                                                    <div class="test-message">${test.message}</div>
                                                </div>
                                            `).join('') : `
                                                <div class="test-item test-error">
                                                    <div class="test-header">✗ Erreur</div>
                                                    <div class="test-message">${result.message || "Une erreur s'est produite"}</div>
                                                </div>
                                            `}
                                        </div>
                                    </div>
                                `;
                            }
                        }
                    } catch (error) {
                        resultsContent.innerHTML = `
                            <div class="test-results">
                                <div class="test-summary">
                                    <h4 style="color: #ff4757;">✗ Erreur de connexion</h4>
                                    <div class="progress-bar">
                                        <div class="progress-fill" style="width: 0%; background: #ff4757;"></div>
                                    </div>
                                </div>
                                <div class="test-details">
                                    <div class="test-item test-error">
                                        <div class="test-header">✗ Erreur</div>
                                        <div class="test-message">Impossible de contacter le serveur: ${error.message}</div>
                                    </div>
                                </div>
                            </div>
                        `;
                    }
                });

                // Fermer les résultats
                const closeResults = document.getElementById('closeResults');
                closeResults.addEventListener('click', () => resultsPanel.style.display = 'none');

                // Soumettre le formulaire
                const form = document.getElementById('codeForm');
                form.addEventListener('submit', function() {
                    editor.save();
                    resultsPanel.style.display = 'block';
                    resultsContent.innerHTML = `
                        <div class="test-results">
                            <div class="test-summary">
                                <h4><i class="fas fa-spinner fa-spin"></i> Soumission en cours...</h4>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 50%"></div>
                                </div>
                            </div>
                            <div class="test-details">
                                <div class="test-item">
                                    <div class="test-message">Envoi du code au serveur pour évaluation...</div>
                                </div>
                            </div>
                        </div>
                    `;
                });
            });
        </script>
