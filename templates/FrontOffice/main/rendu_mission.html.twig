    {% block javascripts %}
        {{ parent() }}
        <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/codemirror.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/javascript/javascript.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/php/php.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/python/python.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/clike/clike.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                // ========== RÉCUPÉRATION DES DONNÉES ==========
                const root = document.getElementById('rendumissionroot');
                const missionId = root.dataset.missionId;
                const sessionToken = root.dataset.sessionToken;
                let timeRemaining = parseInt(root.dataset.timeRemaining);
                let remainingExecutions = parseInt(root.dataset.remainingExecutions);

                // ========== RÉFÉRENCES DOM ==========
                const textarea = document.getElementById('codeEditor');
                const languageSelect = document.getElementById('language');
                const selectedLangue = document.getElementById('selectedLangue');
                const editorPanel = document.getElementById('editorPanel');
                const fullscreenBtn = document.getElementById('fullscreenBtn');
                const resultsPanel = document.getElementById('resultsPanel');
                const resultsContent = document.getElementById('resultsContent');
                const runBtn = document.getElementById('runCode');
                const submitBtn = document.getElementById('submitCode');
                const execCountSpan = document.getElementById('execCount');
                const timerTextSpan = document.getElementById('timerText');
                const timerDisplay = document.getElementById('timerDisplay');
                const execCounter = document.getElementById('execCounter');

                let isFullscreen = false;
                let timerInterval = null;
                let isSubmitting = false;
                let isLeaving = false;

                // ========== 1. INITIALISATION CODEMIRROR ==========
                let editor = CodeMirror.fromTextArea(textarea, {
                    lineNumbers: true,
                    mode: 'python',
                    theme: 'dracula',
                    matchBrackets: true,
                    indentUnit: 4,
                    tabSize: 4,
                    lineWrapping: true,
                    gutters: ['CodeMirror-linenumbers']
                });
                setTimeout(() => editor.refresh(), 100);
                window.addEventListener('resize', () => editor.refresh());

                // ========== 2. BLOCK COPY-PASTE ==========
                function blockCopyPaste() {
                    // Bloquer Ctrl+C, Ctrl+V, Ctrl+X
                    document.addEventListener('keydown', function(e) {
                        if ((e.ctrlKey || e.metaKey) && (e.key === 'c' || e.key === 'v' || e.key === 'x')) {
                            e.preventDefault();
                            showToast('⚠️ Copier/coller est désactivé pour cette mission', 'warning');
                            return false;
                        }
                        // Bloquer Ctrl+S
                        if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                            e.preventDefault();
                            showToast('⚠️ La sauvegarde manuelle est désactivée', 'warning');
                            return false;
                        }
                    });

                    // Bloquer le clic droit
                    document.addEventListener('contextmenu', function(e) {
                        e.preventDefault();
                        showToast('⚠️ Le clic droit est désactivé', 'warning');
                        return false;
                    });

                    // Bloquer le drag & drop
                    document.addEventListener('dragstart', function(e) {
                        e.preventDefault();
                        return false;
                    });

                    // Désactiver la sélection de texte
                    document.body.style.userSelect = 'none';
                    document.body.style.webkitUserSelect = 'none';
                }

                // ========== 3. TIMER COUNTDOWN ==========
                function formatTime(seconds) {
                    const mins = Math.floor(seconds / 60);
                    const secs = seconds % 60;
                    return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
                }

                function updateTimerDisplay() {
                    timerTextSpan.textContent = formatTime(timeRemaining);
                    if (timeRemaining <= 300) { // Moins de 5 minutes
                        timerDisplay.classList.add('warning');
                    }
                    if (timeRemaining <= 60) {
                        timerDisplay.style.animation = 'pulseWarning 0.5s infinite';
                    }
                }

                function startTimer() {
                    updateTimerDisplay();

                    timerInterval = setInterval(async () => {
                        if (timeRemaining <= 0) {
                            clearInterval(timerInterval);
                            await autoSubmit('Temps écoulé (30 minutes)');
                            return;
                        }
                        timeRemaining--;
                        updateTimerDisplay();
                        sessionStorage.setItem('timeRemaining', timeRemaining);
                    }, 1000);
                }

                // ========== 4. EXÉCUTION LIMITÉE ==========
                function updateExecCounter() {
                    execCountSpan.textContent = remainingExecutions;
                    if (remainingExecutions === 1) {
                        execCounter.classList.add('warning');
                    } else if (remainingExecutions === 0) {
                        execCounter.classList.add('danger');
                        if (runBtn) runBtn.disabled = true;
                    }
                }

                async function executeCode() {
                    if (remainingExecutions <= 0) {
                        showToast('❌ Vous avez atteint la limite de 3 exécutions', 'error');
                        if (runBtn) runBtn.disabled = true;
                        return;
                    }

                    const code = editor.getValue();
                    const language = languageSelect.value;

                    openTerminal();
                    resultsContent.innerHTML = `
                        <div class="test-results">
                            <div class="test-summary">
                                <h4><i class="fas fa-spinner fa-spin"></i> Exécution en cours...</h4>
                                <div class="progress-bar"><div class="progress-fill" style="width:50%"></div></div>
                            </div>
                            <div class="test-details">
                                <div class="test-item">
                                    <div class="test-message">Exécution du code ${language.toUpperCase()}... (${remainingExecutions - 1}/3 restants)</div>
                                </div>
                            </div>
                        </div>
                    `;

                    try {
                        const response = await fetch(`/candidat/rendu-mission/execute/${missionId}`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ code, language, token: sessionToken })
                        });

                        const result = await response.json();

                        if (result.success) {
                            remainingExecutions = result.remainingExecutions;
                            updateExecCounter();
                            showToast(`✅ Exécution réussie ! Plus que ${remainingExecutions} exécution(s)`, 'success');
                            resultsContent.innerHTML = `
                                <div class="test-results">
                                    <div class="test-summary">
                                        <h4 style="color:#6ee7b7"><i class="fas fa-check-circle"></i> Exécution réussie</h4>
                                        <div class="progress-bar"><div class="progress-fill" style="width:100%"></div></div>
                                    </div>
                                    <div class="test-details">
                                        <div class="test-item test-success">
                                            <div class="test-header">📤 Sortie</div>
                                            <div class="test-message"><pre>${escapeHtml(result.output || 'Code exécuté avec succès')}</pre></div>
                                        </div>
                                        <div class="test-item">
                                            <div class="test-header">⚡ Exécutions restantes</div>
                                            <div class="test-message">${remainingExecutions}/3</div>
                                        </div>
                                    </div>
                                </div>
                            `;
                        } else {
                            showToast(result.error || 'Erreur lors de l\'exécution', 'error');
                            resultsContent.innerHTML = `
                                <div class="test-results">
                                    <div class="test-summary">
                                        <h4 style="color:#fca5a5"><i class="fas fa-exclamation-triangle"></i> Erreur</h4>
                                    </div>
                                    <div class="test-details">
                                        <div class="test-item test-error">
                                            <div class="test-header">❌ Erreur</div>
                                            <div class="test-message"><pre>${escapeHtml(result.error)}</pre></div>
                                        </div>
                                    </div>
                                </div>
                            `;
                        }
                    } catch (err) {
                        showToast('Erreur de connexion au serveur', 'error');
                        resultsContent.innerHTML = `
                            <div class="test-results">
                                <div class="test-summary">
                                    <h4 style="color:#fca5a5">✗ Erreur de connexion</h4>
                                </div>
                                <div class="test-details">
                                    <div class="test-item test-error">
                                        <div class="test-header">✗ Erreur</div>
                                        <div class="test-message">${escapeHtml(err.message)}</div>
                                    </div>
                                </div>
                            </div>
                        `;
                    }
                }

                // ========== 5. AUTO-SUBMIT ==========
                async function autoSubmit(reason) {
                    if (isSubmitting || isLeaving) return;
                    isLeaving = true;

                    const code = editor.getValue();
                    const language = languageSelect.value;

                    try {
                        const response = await fetch(`/candidat/rendu-mission/auto-submit/${missionId}`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                code,
                                language,
                                token: sessionToken,
                                reason: reason
                            })
                        });

                        const result = await response.json();
                        if (result.success && result.redirect) {
                            window.location.href = result.redirect;
                        }
                    } catch (err) {
                        console.error('Auto-submit error:', err);
                        window.location.href = `/candidat/rendu-mission/mes-resultats`;
                    }
                }

                // ========== 6. SOUMISSION ==========
                async function submitCode() {
                    if (isSubmitting) return;
                    isSubmitting = true;

                    const code = editor.getValue();
                    const language = languageSelect.value;

                    if (submitBtn) {
                        submitBtn.disabled = true;
                        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Soumission...';
                    }

                    openTerminal();
                    resultsContent.innerHTML = `
                        <div class="test-results">
                            <div class="test-summary">
                                <h4><i class="fas fa-spinner fa-spin"></i> Évaluation en cours...</h4>
                                <div class="progress-bar"><div class="progress-fill" style="width:50%"></div></div>
                            </div>
                            <div class="test-details">
                                <div class="test-item"><div class="test-message">Analyse du code par l'IA...</div></div>
                            </div>
                        </div>
                    `;

                    try {
                        const response = await fetch(`/candidat/rendu-mission/submit/${missionId}`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ code, language, token: sessionToken })
                        });

                        const result = await response.json();

                        if (result.success && result.redirect) {
                            if (timerInterval) clearInterval(timerInterval);
                            window.location.href = result.redirect;
                        } else {
                            showToast(result.error || 'Erreur lors de la soumission', 'error');
                            isSubmitting = false;
                            if (submitBtn) {
                                submitBtn.disabled = false;
                                submitBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Soumettre';
                            }
                        }
                    } catch (err) {
                        showToast('Erreur de connexion', 'error');
                        isSubmitting = false;
                        if (submitBtn) {
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Soumettre';
                        }
                    }
                }

                // ========== 7. GESTION DE DÉPART ==========
                function showLeaveWarning() {
                    const modal = document.getElementById('leaveModal');
                    if (modal) modal.style.display = 'block';
                }

                // Détection de fermeture de page
                window.addEventListener('beforeunload', function(e) {
                    if (!isSubmitting && timeRemaining > 0 && remainingExecutions >= 0) {
                        e.preventDefault();
                        e.returnValue = '';
                        autoSubmit('Page fermée');
                        return '';
                    }
                });

                // Lien de retour
                const backLink = document.getElementById('backLink');
                if (backLink) {
                    backLink.addEventListener('click', function(e) {
                        e.preventDefault();
                        showLeaveWarning();
                    });
                }

                // Boutons du modal
                const stayBtn = document.getElementById('stayOnPage');
                const leaveBtn = document.getElementById('confirmLeave');

                if (stayBtn) {
                    stayBtn.addEventListener('click', function() {
                        document.getElementById('leaveModal').style.display = 'none';
                    });
                }

                if (leaveBtn) {
                    leaveBtn.addEventListener('click', async function() {
                        document.getElementById('leaveModal').style.display = 'none';
                        await autoSubmit('Page quittée volontairement');
                    });
                }

                // Bloquer F5 et Ctrl+R
                window.addEventListener('keydown', function(e) {
                    if (e.key === 'F5' || ((e.ctrlKey || e.metaKey) && (e.key === 'r' || e.key === 'R'))) {
                        e.preventDefault();
                        showLeaveWarning();
                        return false;
                    }
                });

                // ========== 8. UTILITAIRES ==========
                function showToast(message, type = 'info') {
                    const toast = document.createElement('div');
                    toast.className = `toast-notification toast-${type}`;
                    toast.textContent = message;
                    document.body.appendChild(toast);
                    setTimeout(() => toast.remove(), 3000);
                }

                function escapeHtml(text) {
                    const div = document.createElement('div');
                    div.textContent = text;
                    return div.innerHTML;
                }

                function openTerminal() {
                    resultsPanel.classList.add('open');
                }

                // ========== 9. TEMPLATES PAR DÉFAUT ==========
                const defaultCodes = {
                    python: `# Solution Python pour Two Sum
def twoSum(nums, target):
    seen = {}
    for i, num in enumerate(nums):
        complement = target - num
        if complement in seen:
            return [seen[complement], i]
        seen[num] = i
    return []

# Test
print(twoSum([2, 7, 11, 15], 9))`,
                    javascript: `/**
 * Solution JavaScript pour Two Sum
 */
var twoSum = function(nums, target) {
    const map = new Map();
    for (let i = 0; i < nums.length; i++) {
        const complement = target - nums[i];
        if (map.has(complement)) {
            return [map.get(complement), i];
        }
        map.set(nums[i], i);
    }
    return [];
};

console.log(twoSum([2, 7, 11, 15], 9));`,
                    php: `<?php
function twoSum($nums, $target) {
    $map = [];
    for ($i = 0; $i < count($nums); $i++) {
        $complement = $target - $nums[$i];
        if (isset($map[$complement])) {
            return [$map[$complement], $i];
        }
        $map[$nums[$i]] = $i;
    }
    return [];
}

print_r(twoSum([2, 7, 11, 15], 9));
?>`,
                    java: `import java.util.*;

class Solution {
    public int[] twoSum(int[] nums, int target) {
        Map<Integer, Integer> map = new HashMap<>();
        for (int i = 0; i < nums.length; i++) {
            int complement = target - nums[i];
            if (map.containsKey(complement)) {
                return new int[] { map.get(complement), i };
            }
            map.put(nums[i], i);
        }
        return new int[] {};
    }
}`,
                    cpp: `#include <iostream>
#include <vector>
#include <unordered_map>
using namespace std;

class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int, int> map;
        for (int i = 0; i < nums.size(); i++) {
            int complement = target - nums[i];
            if (map.find(complement) != map.end()) {
                return {map[complement], i};
            }
            map[nums[i]] = i;
        }
        return {};
    }
};`
                };

                // ========== 10. ÉVÉNEMENTS UI ==========
                // Fullscreen
                function toggleFullscreen() {
                    if (!isFullscreen) {
                        editorPanel.classList.add('fullscreen-mode');
                        fullscreenBtn.innerHTML = '<i class="fas fa-compress"></i>';
                        setTimeout(() => editor.refresh(), 300);
                    } else {
                        editorPanel.classList.remove('fullscreen-mode');
                        fullscreenBtn.innerHTML = '<i class="fas fa-expand"></i>';
                        setTimeout(() => editor.refresh(), 300);
                    }
                    isFullscreen = !isFullscreen;
                }
                fullscreenBtn.addEventListener('click', toggleFullscreen);
                document.addEventListener('keydown', e => { if (e.key === 'Escape' && isFullscreen) toggleFullscreen(); });

                // Ctrl+Enter
                document.addEventListener('keydown', e => {
                    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                        e.preventDefault();
                        if (runBtn && !runBtn.disabled) runBtn.click();
                    }
                });

                // Changement de langue
                languageSelect.addEventListener('change', function () {
                    const lang = this.value;
                    selectedLangue.value = lang;
                    const modes = { php: 'php', javascript: 'javascript', python: 'python', java: 'text/x-java', cpp: 'text/x-c++src' };
                    editor.setOption('mode', modes[lang] || 'python');
                    if (defaultCodes[lang]) editor.setValue(defaultCodes[lang]);
                });

                // Reset
                document.getElementById('resetCode').addEventListener('click', () => {
                    const lang = languageSelect.value;
                    editor.setValue(defaultCodes[lang] || defaultCodes.python);
                    showToast('Code réinitialisé', 'success');
                });

                // Fermeture terminal
                document.getElementById('closeResults').addEventListener('click', () => {
                    resultsPanel.classList.remove('open');
                });

                // Boutons
                if (runBtn) runBtn.addEventListener('click', executeCode);
                if (submitBtn) submitBtn.addEventListener('click', submitCode);

                // ========== 11. INITIALISATION FINALE ==========
                blockCopyPaste();
                startTimer();
                updateExecCounter();

                // Restaurer le code sauvegardé
                const savedCode = sessionStorage.getItem('code_backup');
                if (savedCode && editor) {
                    if (confirm('Voulez-vous restaurer votre code précédent ?')) {
                        editor.setValue(savedCode);
                    }
                }

                // Sauvegarde automatique
                setInterval(() => {
                    if (editor) {
                        sessionStorage.setItem('code_backup', editor.getValue());
                    }
                }, 30000);

                console.log('✅ Système de contrôle initialisé');
                console.log(`⏱️ Temps restant: ${formatTime(timeRemaining)}`);
                console.log(`⚡ Exécutions restantes: ${remainingExecutions}`);
            });
        </script>
    {% endblock %}
{% endblock %}