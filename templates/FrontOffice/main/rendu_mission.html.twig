            margin: 0;
            font-size: 14px;
            font-weight: 700;
            color: #00ff9d;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .close-results {
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.6);
            cursor: pointer;
            font-size: 18px;
            transition: all 0.3s ease;
            padding: 4px 8px;
            border-radius: 6px;
        }

        .close-results:hover {
            color: #ff4757;
            background: rgba(255, 71, 87, 0.1);
            transform: rotate(90deg);
        }

        .results-content {
            padding: 20px 24px;
        }

        .test-results {
            font-family: 'Monaco', 'Courier New', monospace;
            font-size: 13px;
        }

        .test-summary {
            margin-bottom: 20px;
            padding-bottom: 16px;
            border-bottom: 1px solid rgba(0, 255, 255, 0.2);
        }

