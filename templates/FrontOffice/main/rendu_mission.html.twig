{# templates/FrontOffice/main/rendu_mission.html.twig #}
{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Mission - {{ mission.type }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/codemirror.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/theme/dracula.css">
    <style>
        /* Aligné sur mission.html.twig + front-overrides (candidat) */
        .rendu-mission-root {
            --rm-primary: #667eea;
            --rm-secondary: #764ba2;
            --rm-accent: #2c7aff;
            --rm-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --rm-text: #2d3748;
            --rm-muted: #718096;
            --rm-border: #e2e8f0;
            --rm-surface: #ffffff;
            --rm-soft: #f7fafc;
            --rm-code-bg: #282a36;
            --rendu-nav-offset: 132px;
            width: 100%;
            flex: 1;
            min-height: 0;
            display: flex;
            flex-direction: column;
            background: linear-gradient(to left, rgb(228, 242, 254), rgb(255, 238, 254));
        }

        .fo-candidate-content.login_register {
            position: relative;
            z-index: 2;
        }

        /* Plein écran sous la navbar (style LeetCode), charte inchangée */
        body:has(.rendu-mission-root) .section-top {
            display: none !important;
        }

        body:has(.rendu-mission-root) section.login_register.fo-candidate-content.section-padding {
            padding: 0 !important;
            margin: 0 !important;
            min-height: calc(100dvh - var(--rendu-nav-offset, 132px));
            display: flex;
            flex-direction: column;
        }

        body:has(.rendu-mission-root) section.login_register.fo-candidate-content > .container {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 0;
            width: 100%;
            max-width: 100% !important;
        }

        body:has(.rendu-mission-root) section.login_register.fo-candidate-content .row {
            flex: 1;
            min-height: 0;
            display: flex;
        }

        body:has(.rendu-mission-root) section.login_register.fo-candidate-content [class*="col-"] {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 0;
        }

        body:has(.rendu-mission-root) .rendu-mission-root .container {
            max-width: 100% !important;
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        body:has(.rendu-mission-root) .rendu-mission-root .row {
            margin-left: 0 !important;
            margin-right: 0 !important;
        }

        body:has(.rendu-mission-root) .rendu-mission-root .col-lg-8,
        body:has(.rendu-mission-root) .rendu-mission-root .col-md-10 {
            max-width: 100% !important;
            flex: 0 0 100% !important;
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        .rendu-mission-topbar {
            flex-shrink: 0;
            display: flex;
            align-items: center;
            padding: 0.5rem 1rem;
            border-bottom: 1px solid rgba(226, 232, 240, 0.9);
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(8px);
        }

        .rendu-back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--rm-accent);
            text-decoration: none;
            transition: color 0.2s;
        }

        .rendu-back-link:hover {
            color: #0b104a;
            text-decoration: none;
        }

        .rendu-back-link i {
            font-size: 0.85rem;
        }

        /* Mode plein écran — focus éditeur */
        .fullscreen-mode {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            right: 0 !important;
            bottom: 0 !important;
            width: 100% !important;
            height: 100% !important;
            z-index: 9999 !important;
            background: rgba(15, 23, 42, 0.92) !important;
            backdrop-filter: blur(12px) !important;
        }

        .fullscreen-mode .leetcode-panel-right {
            width: 100% !important;
            border-radius: 0 !important;
        }

        .fullscreen-mode .leetcode-panel-left {
            display: none !important;
        }
    </style>
{% endblock %}

{% block candidate_page_heading %}Rendu de mission{% endblock %}
{% block candidate_breadcrumb %} / Missions / {{ mission.type }}{% endblock %}

{% block candidate_content %}
    <div class="rendu-mission-root">
    <div class="rendu-mission-topbar">
        <a href="{{ path('app_candidate_mission') }}" class="rendu-back-link">
            <i class="fas fa-arrow-left"></i> Retour aux missions
        </a>
    </div>

    <div class="leetcode-container">
        <div class="leetcode-panels">
            <!-- Panneau gauche — Éditeur (ordre DOM / LeetCode) -->
            <div class="leetcode-panel-right" id="editorPanel">
                <div class="editor-header">
                    <div class="language-selector">
                        <label for="language">
                            <i class="fas fa-code"></i> Langage
                        </label>
                        <select id="language" class="language-select">
                            <option value="python" selected>Python</option>
                            <option value="javascript">JavaScript</option>
                            <option value="php">PHP</option>
                            <option value="java">Java</option>
                            <option value="cpp">C++</option>
                        </select>
                    </div>
                    <div class="editor-actions">
                        <button class="fullscreen-btn" id="fullscreenBtn" title="Mode plein écran">
                            <i class="fas fa-expand"></i>
                        </button>
                        <button class="reset-btn" id="resetCode" title="Réinitialiser le code">
                            <i class="fas fa-undo-alt"></i> Réinitialiser
                        </button>
                    </div>
                </div>

                <form method="post" id="codeForm" class="editor-form">
                <div class="rendu-cm-shell">
                <textarea id="codeEditor" name="code"># Solution Python pour Two Sum
# Essayez votre code ici !

def twoSum(nums, target):
    """
    :type nums: List[int]
    :type target: int
    :rtype: List[int]
    """
    seen = {}
    for i, num in enumerate(nums):
        complement = target - num
        if complement in seen:
            return [seen[complement], i]
        seen[num] = i
    return []

# Testez votre code avec print
print("Bienvenue dans l'éditeur de code!")
print("Exemple d'utilisation:")
result = twoSum([2, 7, 11, 15], 9)
print(f"twoSum([2, 7, 11, 15], 9) = {result}")</textarea>
                </div>
                    <input type="hidden" name="langue" id="selectedLangue" value="python">

                    <div class="editor-footer">
                        <button type="button" class="run-btn" id="runCode">
                            <i class="fas fa-play"></i> Exécuter
                        </button>
                        <button type="submit" class="submit-btn" id="submitCode">
                            <i class="fas fa-paper-plane"></i> Soumettre
                        </button>
                    </div>
                </form>

                <!-- Résultats - Terminal unique -->
                <div class="results-container" id="resultsPanel" style="display: none;">
                    <div class="results-header">
                        <h3>
                            <i class="fas fa-terminal"></i> Terminal - Résultats
                        </h3>
                        <button class="close-results" id="closeResults" title="Fermer">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div class="results-content" id="resultsContent">
                        <div class="test-results">
                            <div class="test-summary">
                                <h4>Prêt à exécuter</h4>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 0%"></div>
                                </div>
                            </div>
                            <div class="test-details">
                                <div class="test-item">
                                    <div class="test-message" style="color: #718096;">
                                        <i class="fas fa-code"></i> Cliquez sur « Exécuter » pour tester votre code
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Panneau droit — Description -->
            <div class="leetcode-panel-left">
                <div class="problem-content">
                    <div class="problem-header">
                        <div class="problem-title-section">
                            <span class="problem-number">
                                <i class="fas fa-code"></i> Mission #{{ mission.id }}
                            </span>
                            <h1 class="problem-title">{{ mission.type }}</h1>
                        </div>
                        <div class="problem-meta">
                            <span class="score-badge">
                                <i class="fas fa-star"></i> Score requis: {{ mission.scoreMin }}
                            </span>
                        </div>
                    </div>

                    <div class="problem-description">
                        <p>{{ mission.description|nl2br }}</p>
                    </div>

                    <div class="problem-examples">
                        <h3><i class="fas fa-file-alt"></i> Exemples</h3>

                        <div class="example">
                            <div class="example-title">
                                <i class="fas fa-play-circle"></i> Exemple 1:
                            </div>
                            <div class="example-content">
                                <div><strong>Input:</strong> nums = [2,7,11,15], target = 9</div>
                                <div><strong>Output:</strong> [0,1]</div>
                                <div><strong>Explanation:</strong> Because nums[0] + nums[1] == 9, we return [0, 1].</div>
                            </div>
                        </div>

                        <div class="example">
                            <div class="example-title">
                                <i class="fas fa-play-circle"></i> Exemple 2:
                            </div>
                            <div class="example-content">
                                <div><strong>Input:</strong> nums = [3,2,4], target = 6</div>
                                <div><strong>Output:</strong> [1,2]</div>
                            </div>
                        </div>

                        <div class="example">
                            <div class="example-title">
                                <i class="fas fa-play-circle"></i> Exemple 3:
                            </div>
                            <div class="example-content">
                                <div><strong>Input:</strong> nums = [3,3], target = 6</div>
                                <div><strong>Output:</strong> [0,1]</div>
                            </div>
                        </div>
                    </div>

                    <div class="problem-constraints">
                        <h3><i class="fas fa-exclamation-triangle"></i> Contraintes</h3>
                        <ul>
                            <li>2 ≤ nums.length ≤ 10⁴</li>
                            <li>-10⁹ ≤ nums[i] ≤ 10⁹</li>
                            <li>-10⁹ ≤ target ≤ 10⁹</li>
                        </ul>
                    </div>

                    {% if existingRendu %}
                        <div class="previous-submission">
                            <h3><i class="fas fa-history"></i> Dernière soumission</h3>
                            <div class="submission-details">
                                <div><span class="label">Date:</span> {{ existingRendu.dateRendu|date('d/m/Y H:i') }}</div>
                                <div><span class="label">Score:</span> <span class="score">{{ existingRendu.score|default(0)|round }}/100</span></div>
                                <div><span class="label">Langage:</span> {{ existingRendu.langue|upper }}</div>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    </div>

    <style>
