                function closePlayer() {
                    if (isPlaying) {
                        audio.pause();
                        playPauseBtn.innerHTML = '<i class="fas fa-play"></i>';
                        player.classList.remove('playing');
                        isPlaying = false;
                    }
                    isMinimized = false;
                    isClosed = true;
                    player.classList.remove('minimized');
                    player.classList.add('closed');
                    musicToggleBtn.style.display = 'flex';
                    localStorage.setItem('music_minimized', 'false');
                    localStorage.setItem('music_closed', 'true');
                }

                // Fonction pour ouvrir/restaurer le lecteur
                function openPlayer() {
                    isMinimized = false;
                    isClosed = false;
                    player.classList.remove('minimized');
                    player.classList.remove('closed');
                    musicToggleBtn.style.display = 'none';
                    localStorage.setItem('music_minimized', 'false');
                    localStorage.setItem('music_closed', 'false');
                }

                // ========== DRAG & DROP FUNCTIONS ==========
                function startDrag(e, element) {
                    isDragging = true;
                    const clientX = e.type === 'touchstart' ? e.touches[0].clientX : e.clientX;
                    const clientY = e.type === 'touchstart' ? e.touches[0].clientY : e.clientY;

                    dragStartX = clientX;
                    dragStartY = clientY;

                    const rect = element.getBoundingClientRect();
                    elementStartX = rect.left;
                    elementStartY = rect.top;

                    element.classList.add('dragging');
                    e.preventDefault();
                }

                function onDrag(e, element) {
                    if (!isDragging) return;

                    const clientX = e.type === 'touchmove' ? e.touches[0].clientX : e.clientX;
                    const clientY = e.type === 'touchmove' ? e.touches[0].clientY : e.clientY;

                    const deltaX = clientX - dragStartX;
                    const deltaY = clientY - dragStartY;

                    let newLeft = elementStartX + deltaX;
                    let newTop = elementStartY + deltaY;

                    // Limiter les bords de l'écran
                    const maxX = window.innerWidth - element.offsetWidth;
                    const maxY = window.innerHeight - element.offsetHeight;
                    newLeft = Math.max(0, Math.min(maxX, newLeft));
                    newTop = Math.max(0, Math.min(maxY, newTop));

                    element.style.left = newLeft + 'px';
                    element.style.top = newTop + 'px';
                    element.style.right = 'auto';
                    element.style.bottom = 'auto';
                }

                function stopDrag(element) {
                    if (!isDragging) return;
                    isDragging = false;
                    element.classList.remove('dragging');

                    // Sauvegarder la position
                    localStorage.setItem('music_player_left', element.style.left);
                    localStorage.setItem('music_player_top', element.style.top);
                }

                // Appliquer le drag & drop au player et au bouton toggle
                function makeDraggable(element) {
                    const onMouseDown = (e) => {
                        if (e.target.closest('.minimize-btn') || e.target.closest('.close-btn') ||
                            e.target.closest('.play-pause') || e.target.closest('#prevTrack') ||
                            e.target.closest('#nextTrack') || e.target.closest('.playlist-select') ||
                            e.target.closest('.volume-slider') || e.target.closest('.time-progress')) {
                            return;
                        }
                        startDrag(e, element);
                    };

                    const onMouseMove = (e) => onDrag(e, element);
                    const onMouseUp = () => stopDrag(element);

                    element.addEventListener('mousedown', onMouseDown);
                    element.addEventListener('mousemove', onMouseMove);
                    element.addEventListener('mouseup', onMouseUp);

                    element.addEventListener('touchstart', (e) => {
                        if (e.target.closest('.minimize-btn') || e.target.closest('.close-btn') ||
                            e.target.closest('.play-pause') || e.target.closest('#prevTrack') ||
                            e.target.closest('#nextTrack') || e.target.closest('.playlist-select') ||
                            e.target.closest('.volume-slider') || e.target.closest('.time-progress')) {
                            return;
                        }
                        startDrag(e, element);
                    });
                    element.addEventListener('touchmove', (e) => onDrag(e, element));
                    element.addEventListener('touchend', () => stopDrag(element));
                }

                // Restaurer la position sauvegardée
                const savedLeft = localStorage.getItem('music_player_left');
                const savedTop = localStorage.getItem('music_player_top');
                if (savedLeft && savedTop) {
                    player.style.left = savedLeft;
                    player.style.top = savedTop;
                    player.style.right = 'auto';
                    player.style.bottom = 'auto';
                }

                // Charger les préférences
                const savedPlaylist = localStorage.getItem('music_last_playlist');
                const savedTrack = localStorage.getItem('music_last_track');
                const savedVolume = localStorage.getItem('music_volume');
                const savedMinimized = localStorage.getItem('music_minimized');
                const savedClosed = localStorage.getItem('music_closed');

                if (savedPlaylist && playlists[savedPlaylist]) {
                    currentPlaylist = savedPlaylist;
                    playlistSelect.value = savedPlaylist;
                }
                if (savedTrack && playlists[currentPlaylist][parseInt(savedTrack)]) {
                    currentTrackIndex = parseInt(savedTrack);
                }
                if (savedVolume) {
                    audio.volume = parseFloat(savedVolume);
                    volumeLevel.style.width = (parseFloat(savedVolume) * 100) + '%';
                }

                // Restaurer l'état
                if (savedClosed === 'true') {
                    isClosed = true;
                    player.classList.add('closed');
                    musicToggleBtn.style.display = 'flex';
                } else if (savedMinimized === 'true') {
                    isMinimized = true;
                    player.classList.add('minimized');
                    musicToggleBtn.style.display = 'none';
                } else {
                    player.classList.remove('minimized', 'closed');
                    musicToggleBtn.style.display = 'none';
                }

                // Attacher les événements
                playPauseBtn.addEventListener('click', playPause);
                prevBtn.addEventListener('click', prevTrack);
                nextBtn.addEventListener('click', nextTrack);
                playlistSelect.addEventListener('change', changePlaylist);
                audio.addEventListener('timeupdate', updateProgress);
                audio.addEventListener('ended', nextTrack);
                audio.addEventListener('loadedmetadata', updateProgress);
                progressBar.addEventListener('click', setProgress);
                volumeSlider.addEventListener('click', setVolume);
                minimizeBtn.addEventListener('click', minimizePlayer);
                closePlayerBtn.addEventListener('click', closePlayer);
                musicToggleBtn.addEventListener('click', openPlayer);

                // Drag & drop
                makeDraggable(player);
                makeDraggable(musicToggleBtn);

                // Clic sur l'en-tête quand minimisé pour ouvrir
                togglePlayerHeader.addEventListener('click', function(e) {
                    if (e.target.closest('.minimize-btn') || e.target.closest('.close-btn')) {
                        return;
                    }
                    if (isMinimized) {
                        openPlayer();
                    }
                });

                // Clic sur le player quand minimisé
                player.addEventListener('click', function(e) {
                    if (isMinimized && (e.target === player || e.target.closest('.music-title'))) {
                        openPlayer();
                    }
                });

                // Charger le premier morceau
                loadTrack();
                console.log('🎵 Music player initialized - Mode: ' + (isClosed ? 'closed' : (isMinimized ? 'minimized' : 'open')));
            })();
        </script>
    {% endblock %}
{% endblock %}