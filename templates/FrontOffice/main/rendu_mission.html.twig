            </div>

            {# ── RIGHT: Editor ── #}
            <div class="rm-panel-editor" id="editorPanel">

                {# Editor bar #}
                <div class="rm-editor-bar">
                    <div class="rm-editor-bar-left">
                        <span class="rm-lang-label"><i class="fas fa-code"></i> Langage</span>
                        <select id="language" class="rm-lang-select">
                            <option value="python" selected>Python</option>
                            <option value="javascript">JavaScript</option>
                            <option value="php">PHP</option>
                            <option value="java">Java</option>
                            <option value="cpp">C++</option>
                        </select>
                    </div>
                    <div class="rm-editor-bar-right">
                        <button class="rm-tool-btn" id="resetCode" title="Réinitialiser">
