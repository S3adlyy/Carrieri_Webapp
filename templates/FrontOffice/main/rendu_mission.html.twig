        .test-message {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.7);
            line-height: 1.5;
        }

        .test-message pre {
            margin: 8px 0 0 0;
            padding: 10px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 6px;
            overflow-x: auto;
            font-family: 'Monaco', 'Courier New', monospace;
            font-size: 12px;
        }

        /* Scrollbar personnalisée */
        .leetcode-panel-left::-webkit-scrollbar,
        .results-container::-webkit-scrollbar,
        .CodeMirror-scroll::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        .leetcode-panel-left::-webkit-scrollbar-track,
        .results-container::-webkit-scrollbar-track,
        .CodeMirror-scroll::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 10px;
        }

        .leetcode-panel-left::-webkit-scrollbar-thumb,
        .results-container::-webkit-scrollbar-thumb,
        .CodeMirror-scroll::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #00ffff, #0099ff);
            border-radius: 10px;
        }

        .leetcode-panel-left::-webkit-scrollbar-thumb:hover,
        .results-container::-webkit-scrollbar-thumb:hover,
        .CodeMirror-scroll::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(135deg, #00ffff, #00ff9d);
        }

        /* Animation pour le chargement */
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .fa-spinner {
            animation: spin 1s linear infinite;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .leetcode-container {
                height: calc(100vh - 120px);
            }

            .leetcode-panels {
                flex-direction: column;
            }

            .leetcode-panel-left,
            .leetcode-panel-right {
                width: 100% !important;
            }

            .leetcode-panel-left {
                max-height: 40%;
                padding: 20px;
            }

            .leetcode-panel-right {
                min-height: 60%;
            }

            .problem-title {
                font-size: 22px;
            }

            .results-container {
                max-height: 200px;
            }
        }

        /* Transition pour le plein écran */
        .fullscreen-mode {
            transition: all 0.3s ease;
        }
