            border-radius: 8px;
            overflow-x: auto;
            font-size: 0.75rem;
        }

        .leetcode-panel-left::-webkit-scrollbar,
        .results-container::-webkit-scrollbar,
        .CodeMirror-scroll::-webkit-scrollbar {
            width: 8px;
