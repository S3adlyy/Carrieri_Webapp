        }
    </style>
{% endblock %}

{% block candidate_page_heading %}Rendu de mission{% endblock %}
{% block candidate_breadcrumb %} / Missions / {{ mission.type }}{% endblock %}

{% block candidate_content %}
    <div class="rendu-mission-root" id="rendumissionroot"
         data-session-token="{{ sessionToken|default('') }}"
         data-mission-id="{{ mission.id }}"
         data-time-remaining="{{ timeRemaining|default(1800) }}"
         data-remaining-executions="{{ remainingExecutions|default(3) }}">

        {# Modal de confirmation de départ #}
        <div id="leaveModal" class="modal">
            <div class="modal-content">
                <i class="fas fa-exclamation-triangle" style="font-size: 48px; color: #ef4444; margin-bottom: 20px;"></i>
                <h2 style="margin-bottom: 15px;">⚠️ Attention !</h2>
                <p style="margin-bottom: 20px; line-height: 1.6;">
                    Êtes-vous sûr de vouloir quitter cette page ?<br>
                    <strong style="color: #ef4444;">Vous recevrez un score de 0 et la mission sera automatiquement refusée.</strong>
                </p>
                <div class="modal-buttons">
                    <button class="modal-btn modal-btn-cancel" id="stayOnPage">Rester sur la page</button>
                    <button class="modal-btn modal-btn-confirm" id="confirmLeave">Quitter quand même</button>
                </div>
            </div>
        </div>

        {# ── Top bar ── #}
        <div class="rm-topbar">
            <div class="rm-topbar-left">
                <a href="#" class="rm-back-link" id="backLink">
                    <i class="fas fa-arrow-left"></i> Missions
                </a>
                <div class="rm-breadcrumb">
                    <i class="fas fa-chevron-right" style="font-size:9px"></i>
                    <span>{{ mission.type }}</span>
                </div>
            </div>
            <div class="rm-topbar-meta">
                <span class="exec-counter" id="execCounter">
                    <i class="fas fa-play-circle"></i> <span id="execCount">{{ remainingExecutions|default(3) }}</span>/3 exécutions
                </span>
                <span class="timer-display" id="timerDisplay">
                    <i class="fas fa-clock"></i> <span id="timerText">30:00</span>
                </span>
                <span class="rm-badge rm-badge-id"><i class="fas fa-hashtag" style="font-size:9px"></i> {{ mission.id }}</span>
                <span class="rm-badge rm-badge-score"><i class="fas fa-star" style="font-size:9px"></i> Score requis : {{ mission.scoreMin }}</span>
            </div>
        </div>

        {# ── Split layout ── #}
        <div class="rm-layout">

            {# ── LEFT: Problem description ── #}
            <div class="rm-panel-desc">
                <div class="rm-desc-header">
                    <div class="rm-mission-label">
                        <i class="fas fa-code"></i> Mission #{{ mission.id }}
                    </div>
                    <h1 class="rm-mission-title">{{ mission.type }}</h1>
                    <span class="rm-mission-score-pill">
                        <i class="fas fa-star"></i> Score requis : {{ mission.scoreMin }} pts
                    </span>
                </div>

                <div class="rm-desc-body">
                    {# Description #}
                    <div class="rm-section-title">
                        <i class="fas fa-align-left"></i> Description
                    </div>
                    <div class="rm-description">
                        {{ mission.description|nl2br }}
                    </div>

                    {# Examples #}
                    <div class="rm-section-title" style="margin-bottom:12px">
                        <i class="fas fa-flask"></i> Exemples
                        <button class="rm-tool-btn rm-regenerate-btn" id="regenerateExamples" title="Régénérer les exemples avec l'IA">
                            <i class="fas fa-sync-alt"></i> Régénérer
                        </button>
                    </div>

                    {% if missionData.examples is defined and missionData.examples|length > 0 %}
                        {% for example in missionData.examples %}
                            <div class="rm-example">
                                <div class="rm-example-label">
                                    <i class="fas fa-play-circle"></i> Exemple {{ loop.index }}
                                </div>
                                <div class="rm-example-body">
                                    <div><strong>Input :</strong> {{ example.input }}</div>
                                    <div><strong>Output :</strong> {{ example.output }}</div>
                                    {% if example.explanation is defined %}
                                        <div><strong>Explication :</strong> {{ example.explanation }}</div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="rm-example">
                            <div class="rm-example-body">
                                <div>Aucun exemple disponible</div>
                            </div>
                        </div>
                    {% endif %}

                    {# Contraintes générées dynamiquement #}
                    <div class="rm-constraints">
                        <div class="rm-section-title" style="margin-bottom:10px">
                            <i class="fas fa-exclamation-triangle"></i> Contraintes
                        </div>
                        {% if missionData.constraints is defined and missionData.constraints|length > 0 %}
                            <ul>
                                {% for constraint in missionData.constraints %}
                                    <li>{{ constraint }}</li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <ul>
                                <li>Aucune contrainte spécifique</li>
                            </ul>
                        {% endif %}
                    </div>

                    {# Informations sur la fonction #}
                    {% if missionData.function_name is defined %}
                        <div class="rm-constraints" style="margin-top: 15px;">
                            <div class="rm-section-title" style="margin-bottom:10px">
                                <i class="fas fa-code"></i> Signature de fonction
                            </div>
                            <div class="rm-example">
                                <div class="rm-example-body">
                                    <code>
                                        def {{ missionData.function_name }}({% for param in missionData.parameters %}{{ param }}{% if not loop.last %}, {% endif %}{% endfor %}) -> {{ missionData.return_type }}:
                                    </code>
                                </div>
                            </div>
                        </div>
                    {% endif %}

                    {# Previous submission #}
                    {% if existingRendu %}
                        <div class="rm-prev-sub">
                            <div class="rm-prev-sub-title">
                                <i class="fas fa-history"></i> Dernière soumission
                            </div>
                            <div class="rm-prev-sub-row">
                                <span>Date</span>
                                <strong>{{ existingRendu.dateRendu|date('d/m/Y H:i') }}</strong>
                            </div>
                            <div class="rm-prev-sub-row">
                                <span>Score</span>
                                <strong style="color:var(--indigo-light)">{{ existingRendu.score|default(0)|round }} / 100</strong>
                            </div>
                            <div class="rm-prev-sub-row">
                                <span>Langage</span>
                                <strong>{{ existingRendu.langue|upper }}</strong>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# ── RIGHT: Editor ── #}
            <div class="rm-panel-editor" id="editorPanel">

                {# Editor bar #}
                <div class="rm-editor-bar">
                    <div class="rm-editor-bar-left">
                        <span class="rm-lang-label"><i class="fas fa-code"></i> Langage</span>
                        <select id="language" class="rm-lang-select">
                            <option value="python" selected>Python</option>
                            <option value="javascript">JavaScript</option>
                            <option value="php">PHP</option>
                            <option value="java">Java</option>
                            <option value="cpp">C++</option>
                        </select>
                    </div>
                    <div class="rm-editor-bar-right">
                        <button class="rm-tool-btn" id="resetCode" title="Réinitialiser">
                            <i class="fas fa-undo-alt"></i> Reset
                        </button>
                        <button class="rm-tool-btn" id="fullscreenBtn" title="Plein écran">
                            <i class="fas fa-expand"></i>
                        </button>
                    </div>
                </div>

                {# CodeMirror editor form #}
                <form method="post" id="codeForm" style="flex:1;display:flex;flex-direction:column;min-height:0">
                    <div class="rm-cm-shell">
                        <textarea id="codeEditor" name="code"># Solution Python
# Écrivez votre solution ici

def solution(params):
    # Implémentez votre logique
    pass

# Test
print("Bienvenue dans l'éditeur de code!")
print("Écrivez votre solution pour la mission: {{ mission.type }}")</textarea>
                    </div>
                    <input type="hidden" name="langue" id="selectedLangue" value="python">

                    {# Footer actions #}
                    <div class="rm-editor-footer">
                        <div class="rm-footer-left">
                            <span class="rm-footer-hint">
                                <kbd>Ctrl</kbd>+<kbd>Enter</kbd> Exécuter
                            </span>
                        </div>
                        <div class="rm-footer-right">
                            <button type="button" class="rm-btn-run" id="runCode">
                                <i class="fas fa-play"></i> Exécuter
                            </button>
                            <button type="button" class="rm-btn-submit" id="submitCode">
                                <i class="fas fa-paper-plane"></i> Soumettre
                            </button>
                        </div>
                    </div>
                </form>

                {# Terminal / Results #}
                <div class="rm-terminal" id="resultsPanel">
                    <div class="rm-terminal-bar">
                        <div style="display:flex;align-items:center;gap:10px">
                            <div class="rm-terminal-dots">
                                <div class="rm-dot rm-dot-red"></div>
                                <div class="rm-dot rm-dot-yellow"></div>
                                <div class="rm-dot rm-dot-green"></div>
                            </div>
                            <div class="rm-terminal-title">
                                <i class="fas fa-terminal"></i> Terminal
                            </div>
                        </div>
                        <button class="rm-terminal-close" id="closeResults" title="Fermer">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div class="rm-terminal-body" id="resultsContent">
                        <div class="test-results">
                            <div class="test-summary">
                                <h4 style="color:rgba(255,255,255,.4)">Prêt à exécuter</h4>
                                <div class="progress-bar"><div class="progress-fill" style="width:0%"></div></div>
                            </div>
                            <div class="test-details">
                                <div class="test-item">
                                    <div class="test-message">
                                        <i class="fas fa-code"></i> Cliquez sur « Exécuter » pour tester votre code
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>{# end editor panel #}
        </div>{# end layout #}
    </div>{# end root #}

    {# ── MUSIC PLAYER ── #}
    <div class="music-player" id="musicPlayer">
        <div class="music-player-header" id="togglePlayer">
            <div class="music-title">
                <i class="fas fa-headphones"></i>
                <span>🎵 Focus Music</span>
            </div>
            <div style="display: flex; gap: 5px;">
                <button class="minimize-btn" id="minimizePlayer" title="Minimiser">
                    <i class="fas fa-minus"></i>
                </button>
                <button class="close-btn" id="closePlayer" title="Fermer">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>

        <div class="music-content" id="musicContent">
            <div class="music-info">
                <div class="current-track" id="currentTrack">Lo-fi Study Beat</div>
                <div class="current-artist" id="currentArtist">Concentration Mix</div>
            </div>

            <select class="playlist-select" id="playlistSelect">
                <option value="lofi">🎧 Lo-fi Study Beats</option>
                <option value="classical">🎹 Classical Piano</option>
