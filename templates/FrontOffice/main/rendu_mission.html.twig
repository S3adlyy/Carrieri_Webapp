                    {# Constraints #}
                    <div class="rm-constraints">
                        <div class="rm-section-title" style="margin-bottom:10px"><i class="fas fa-exclamation-triangle"></i> Contraintes</div>
                        <ul>
                            <li>2 ≤ nums.length ≤ 10⁴</li>
