{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Cours{% endblock %}

{% block candidate_page_heading %}Cours{% endblock %}

{% block candidate_breadcrumb %} / Cours{% endblock %}

{% block candidate_content %}
	<div class="w-100 text-start fo-charte-ui fo-fxml-catalog">
		<div class="fo-catalog-header mb-4">
			<h3 class="mb-1">Catalogue de cours</h3>
			<p class="mb-0 text-muted">{{ pagination.total|default(cours_list|length) }} cours disponibles</p>
		</div>

		<form method="get" class="mb-4">
			<div class="fo-charte-card p-3 p-md-4 mb-3">
				<div class="row align-items-end">
					<div class="col-md-5 mb-3 mb-md-0">
						<label for="course-level" class="d-block mb-2 font-weight-bold">Niveau</label>
						<select id="course-level" name="niveau" class="form-control fo-filter-combo">
							<option value="">Tous les niveaux</option>
							{% for n in niveaux %}
								<option value="{{ n }}" {{ filters.niveau == n ? 'selected' : '' }}>{{ n }}</option>
							{% endfor %}
						</select>
					</div>
					<div class="col-md-5 mb-3 mb-md-0">
						<label for="course-language" class="d-block mb-2 font-weight-bold">Langue</label>
						<select id="course-language" class="form-control fo-filter-combo" disabled>
							<option>Choisir une langue</option>
						</select>
					</div>
					<div class="col-md-2">
						<a href="{{ path('app_candidate_cours') }}" class="btn btn-outline-secondary btn-block">Reset</a>
					</div>
				</div>
			</div>

			<div class="fo-search-wrap mb-4">
				<label for="course-search" class="sr-only">Rechercher un cours</label>
				<input id="course-search" type="text" name="q" class="form-control fo-search-input" placeholder="Rechercher un cours par titre ou description..." value="{{ filters.q }}">
				<button type="submit" class="btn btn-primary ml-2">Rechercher</button>
			</div>
		</form>

		{% set en_cours = 0 %}
		{% set completes = 0 %}
		{% for c in cours_list %}
			{% set p = course_states[c.id].progress|default(0) %}
			{% if p >= 100 %}
				{% set completes = completes + 1 %}
			{% elseif p > 0 %}
				{% set en_cours = en_cours + 1 %}
			{% endif %}
		{% endfor %}

		<div class="row text-center mb-4">
			<div class="col-md-4 mb-3 mb-md-0"><div class="fo-charte-card fo-stat-card"><small>Cours disponibles</small><strong>{{ pagination.total|default(cours_list|length) }}</strong></div></div>
			<div class="col-md-4 mb-3 mb-md-0"><div class="fo-charte-card fo-stat-card"><small>En cours</small><strong>{{ en_cours }}</strong></div></div>
			<div class="col-md-4"><div class="fo-charte-card fo-stat-card"><small>Completes</small><strong>{{ completes }}</strong></div></div>
		</div>

		{% if cours_list is empty %}
			<div class="alert alert-light border mb-0">Aucun cours n'est disponible pour le moment.</div>
		{% else %}
			<div class="row">
				{% for c in cours_list %}
					{% set state = course_states[c.id]|default({}) %}
					{% set niveau_class = c.niveau in ['Debutant', 'Débutant'] ? 'success' : (c.niveau in ['Intermediaire', 'Intermédiaire'] ? 'warning' : 'danger') %}
					{% set category = c.competencesVisees ? (c.competencesVisees|split(',')|first|trim) : 'General' %}
					<div class="col-xl-4 col-md-6 mb-4">
						<div class="card h-100 fo-charte-card fo-course-card">
							<div class="fo-course-cover">
								{% if c.imageCouverture %}
									<img src="{{ path('app_candidate_cours_image', {id: c.id}) }}" class="card-img-top" alt="{{ c.titre|default('Cours') }}">
								{% endif %}
							</div>
							<div class="card-body d-flex flex-column">
								<div class="mb-2 d-flex align-items-center flex-wrap">
									<span class="badge badge-{{ niveau_class }} mr-2">{{ c.niveau|default('Niveau') }}</span>
									<span class="badge badge-light">{{ category }}</span>
								</div>
								<h5 class="card-title mb-2">{{ c.titre|default('Cours') }}</h5>
								<p class="card-text text-muted mb-3">{{ c.description|default('Aucune description')|slice(0, 120) }}{% if c.description and c.description|length > 120 %}...{% endif %}</p>
								<div class="d-flex align-items-center text-muted mb-2"><span class="mr-1">⏱</span><small>{{ c.duree|default('0') }} heures</small></div>
								{% if c.estPayant and c.prix and c.prix > 0 %}
									<div class="d-flex align-items-center mb-2"><span class="mr-1">TND</span><strong class="text-primary">{{ c.prix|number_format(2, '.', ' ') }} TND</strong></div>
								{% endif %}
								{% if c.estObligatoire %}
									<div class="d-flex align-items-center mb-2"><span class="mr-1">📌</span><small class="text-muted">Obligatoire</small></div>
								{% endif %}
								<div class="progress mb-3" style="height: 8px;"><div class="progress-bar" role="progressbar" style="width: {{ state.progress|default(0) }}%;" aria-valuenow="{{ state.progress|default(0) }}" aria-valuemin="0" aria-valuemax="100"></div></div>
								<div class="mt-auto">
									{% if c.estPayant and c.prix and c.prix > 0 %}
										<a href="{{ path('app_candidate_cours_show', {id: c.id}) }}" class="btn btn-warning btn-sm btn-block">Voir details et acheter</a>
									{% elseif state.continue_lesson is defined and state.continue_lesson %}
										<a href="{{ path('app_candidate_lecon_show', {cours: c.id, id: state.continue_lesson.id}) }}" class="btn btn-primary btn-sm btn-block">Continuer</a>
									{% else %}
										<a href="{{ path('app_candidate_cours_show', {id: c.id}) }}" class="btn btn-primary btn-sm btn-block">Commencer</a>
									{% endif %}
								</div>
							</div>
						</div>
					</div>
				{% endfor %}
			</div>

			{% if pagination.total_pages > 1 %}
				<nav aria-label="Pagination des cours" class="mt-2">
					<ul class="pagination justify-content-center mb-0">
						<li class="page-item {{ pagination.page <= 1 ? 'disabled' : '' }}"><a class="page-link" href="{{ path('app_candidate_cours', {page: pagination.page - 1, q: filters.q, niveau: filters.niveau}) }}">Precedent</a></li>
						{% for p in 1..pagination.total_pages %}
							<li class="page-item {{ p == pagination.page ? 'active' : '' }}"><a class="page-link" href="{{ path('app_candidate_cours', {page: p, q: filters.q, niveau: filters.niveau}) }}">{{ p }}</a></li>
						{% endfor %}
						<li class="page-item {{ pagination.page >= pagination.total_pages ? 'disabled' : '' }}"><a class="page-link" href="{{ path('app_candidate_cours', {page: pagination.page + 1, q: filters.q, niveau: filters.niveau}) }}">Suivant</a></li>
					</ul>
				</nav>
			{% endif %}
		{% endif %}
	</div>
{% endblock %}

