{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Cours{% endblock %}

{% block candidate_page_heading %}Cours{% endblock %}

{% block candidate_breadcrumb %} / Cours{% endblock %}

{% block candidate_content %}
	<div class="w-100 text-start">
		<h3 class="mb-3">Catalogue des cours</h3>

		<form method="get" class="card p-3 mb-4">
			<div class="row">
				<div class="col-md-5 mb-2 mb-md-0">
					<label for="course-search" class="sr-only">Rechercher un cours</label>
					<input id="course-search" type="text" name="q" class="form-control" placeholder="Rechercher par titre, description, compétences..." value="{{ filters.q }}">
				</div>
				<div class="col-md-3 mb-2 mb-md-0">
					<label for="course-level" class="sr-only">Filtrer par niveau</label>
					<select id="course-level" name="niveau" class="form-control">
						<option value="">Tous les niveaux</option>
						{% for n in niveaux %}
							<option value="{{ n }}" {{ filters.niveau == n ? 'selected' : '' }}>{{ n }}</option>
						{% endfor %}
					</select>
				</div>
				<div class="col-md-4 d-flex">
					<button type="submit" class="btn btn-primary mr-2">Filtrer</button>
					<a href="{{ path('app_candidate_cours') }}" class="btn btn-outline-secondary">Réinitialiser</a>
				</div>
			</div>
		</form>

		{% if cours_list is empty %}
			<div class="alert alert-light border mb-0">
				Aucun cours n'est disponible pour le moment.
			</div>
		{% else %}
			<div class="row">
				{% for c in cours_list %}
					<div class="col-md-6 mb-3">
						<div class="card h-100 shadow-sm">
							{% if c.imageCouverture %}
								<img src="{{ c.imageCouverture }}" class="card-img-top" alt="{{ c.titre|default('Cours') }}" style="height: 180px; object-fit: cover;">
							{% endif %}
							<div class="card-body d-flex flex-column">
								<h5 class="card-title mb-2">{{ c.titre|default('Cours') }}</h5>
								<p class="mb-2">
									<span class="badge badge-{{ c.niveau == 'Débutant' ? 'success' : (c.niveau == 'Intermédiaire' ? 'warning' : 'danger') }}">{{ c.niveau|default('Niveau non défini') }}</span>
								</p>
								<p class="card-text text-muted mb-3">
									{{ c.description|default('Aucune description')|slice(0, 120) }}{% if c.description and c.description|length > 120 %}...{% endif %}
								</p>
								<div class="mt-auto d-flex justify-content-between align-items-center">
									<small class="text-muted">{{ c.duree|default('—') }} h</small>
									<a href="{{ path('app_candidate_cours_show', {id: c.id}) }}" class="btn btn-sm btn-primary">Voir détail</a>
								</div>
							</div>
						</div>
					</div>
				{% endfor %}
			</div>

			{% if pagination.total_pages > 1 %}
				<nav aria-label="Pagination des cours" class="mt-2">
					<ul class="pagination justify-content-center mb-0">
						<li class="page-item {{ pagination.page <= 1 ? 'disabled' : '' }}">
							<a class="page-link" href="{{ path('app_candidate_cours', {page: pagination.page - 1, q: filters.q, niveau: filters.niveau}) }}">Précédent</a>
						</li>
						{% for p in 1..pagination.total_pages %}
							<li class="page-item {{ p == pagination.page ? 'active' : '' }}">
								<a class="page-link" href="{{ path('app_candidate_cours', {page: p, q: filters.q, niveau: filters.niveau}) }}">{{ p }}</a>
							</li>
						{% endfor %}
						<li class="page-item {{ pagination.page >= pagination.total_pages ? 'disabled' : '' }}">
							<a class="page-link" href="{{ path('app_candidate_cours', {page: pagination.page + 1, q: filters.q, niveau: filters.niveau}) }}">Suivant</a>
						</li>
					</ul>
				</nav>
			{% endif %}
		{% endif %}
	</div>
{% endblock %}

