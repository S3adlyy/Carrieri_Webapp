{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Mes postulations{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('FrontOffice/css/front-overrides.css') }}?v=20260406-1">
{% endblock %}

{% block candidate_page_heading %}Mes postulations{% endblock %}

{% block candidate_breadcrumb %} / Mes postulations{% endblock %}

{% block candidate_content_container_class %}container-fluid px-3 px-md-4 px-lg-5{% endblock %}

{% block candidate_content_row_class %}row{% endblock %}

{% block candidate_content_col_class %}col-12{% endblock %}

{% block candidate_content %}
    <div class="w-100 text-start fo-charte-ui fo-fxml-catalog fo-shell-root position-relative">

        <div class="fo-bg-orb fo-bg-orb-1"></div>
        <div class="fo-bg-orb fo-bg-orb-2"></div>
        <div class="fo-bg-orb fo-bg-orb-3"></div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show fo-auto-hide-alert" role="alert">
                {{ message }}
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show fo-auto-hide-alert" role="alert">
                {{ message }}
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        {% endfor %}

        <div class="fo-catalog-header mb-4 position-relative">
            <h3 class="mb-1">Mes postulations</h3>
            <p class="mb-0">Suivez l'état de vos candidatures</p>
        </div>

        {# STATS - style original #}
        <div class="fo-stats-row">
            <div class="fo-stat-card">
                <div class="fo-stat-icon" style="background:rgba(59,130,246,0.12);color:#2563eb"><i class="fas fa-file-alt"></i></div>
                <div><span class="fo-stat-value">{{ stats.total ?? 0 }}</span><span class="fo-stat-label">Total Postulations</span></div>
            </div>
            <div class="fo-stat-card">
                <div class="fo-stat-icon" style="background:rgba(16,185,129,0.12);color:#059669"><i class="fas fa-check-circle"></i></div>
                <div><span class="fo-stat-value">{{ stats.accepted ?? 0 }}</span><span class="fo-stat-label">Acceptées</span></div>
            </div>
            <div class="fo-stat-card">
                <div class="fo-stat-icon" style="background:rgba(245,158,11,0.12);color:#d97706"><i class="fas fa-clock"></i></div>
                <div><span class="fo-stat-value">{{ stats.pending ?? 0 }}</span><span class="fo-stat-label">En attente</span></div>
            </div>
            <div class="fo-stat-card">
                <div class="fo-stat-icon" style="background:rgba(239,68,68,0.12);color:#dc2626"><i class="fas fa-times-circle"></i></div>
                <div><span class="fo-stat-value">{{ stats.refused ?? 0 }}</span><span class="fo-stat-label">Refusées</span></div>
            </div>
        </div>

        {# Formulaire de filtre #}
        <form method="get" class="mb-4 position-relative">
            <div class="fo-charte-card fo-glass-card p-3 p-md-4 mb-3">
                <div class="row align-items-end">
                    <div class="col-md-4 mb-3 mb-md-0">
                        <label class="d-block mb-2 font-weight-bold">Recherche</label>
                        <input type="text" name="keyword" class="form-control fo-filter-combo" placeholder="Offre, entreprise, motivation..." value="{{ app.request.get('keyword') }}">
                    </div>
                    <div class="col-md-4 mb-3 mb-md-0">
                        <label class="d-block mb-2 font-weight-bold">Statut</label>
                        <select name="statut" class="form-control fo-filter-combo">
                            <option value="">Tous les statuts</option>
                            <option value="En attente" {{ app.request.get('statut') == 'En attente' ? 'selected' : '' }}>En attente</option>
                            <option value="Acceptée" {{ app.request.get('statut') == 'Acceptée' ? 'selected' : '' }}>Acceptée</option>
                            <option value="Refusée" {{ app.request.get('statut') == 'Refusée' ? 'selected' : '' }}>Refusée</option>
                        </select>
                    </div>
                    <div class="col-md-4 mb-3 mb-md-0">
                        <label class="d-block mb-2 font-weight-bold">Nom de l'offre</label>
                        <input type="text" name="offre" class="form-control fo-filter-combo" placeholder="Nom de l'offre" value="{{ app.request.get('offre') }}">
                    </div>
                </div>
            </div>
            <div class="d-flex justify-content-end">
                <button type="submit" class="btn fo-search-button mr-2">Filtrer</button>
                <a href="{{ path('app_candidate_postulations') }}" class="btn btn-outline-secondary">Réinitialiser</a>
            </div>
        </form>

        {# Postulations list #}
        {% if postulations is defined and postulations|length > 0 %}
            <div class="row position-relative fo-courses-grid">
                {% for postulation in postulations %}
                    {% set status_class = postulation.statut == 'Acceptée' ? 'badge-success' : (postulation.statut == 'Refusée' ? 'badge-danger' : 'badge-warning') %}
                    <div class="col-xl-4 col-md-6 mb-4">
                        <div class="card h-100 fo-charte-card fo-course-card">
                            <div class="card-body d-flex flex-column">
                                <div class="mb-2 d-flex align-items-center flex-wrap fo-card-badges">
                                    <span class="badge {{ status_class }} mr-2">{{ postulation.statut }}</span>
                                    <span class="badge fo-category-badge">
                                    {{ postulation.datePostulation ? postulation.datePostulation|date('d/m/Y') : '—' }}
                                </span>
                                </div>
                                <h5 class="card-title mb-2 fo-course-title">
                                    {{ postulation.offreEmploi ? postulation.offreEmploi.titre : 'Offre indisponible' }}
                                </h5>
                                <p class="card-text text-muted mb-2">
                                    <strong>{{ postulation.offreEmploi and postulation.offreEmploi.entreprise ? postulation.offreEmploi.entreprise : '—' }}</strong>
                                </p>
                                <div class="fo-meta-row mb-3">
                                    <div class="fo-meta-item"><span class="mr-1">📍</span><small>{{ postulation.offreEmploi and postulation.offreEmploi.localisation ? postulation.offreEmploi.localisation : '—' }}</small></div>
                                    <div class="fo-meta-item"><span class="mr-1">📄</span><small>{{ postulation.offreEmploi and postulation.offreEmploi.typeContrat ? postulation.offreEmploi.typeContrat : '—' }}</small></div>
                                    <div class="fo-meta-item"><span class="mr-1">📎</span><small>{{ postulation.cvPath ? 'CV joint' : 'Sans CV' }}</small></div>
                                </div>
                                <p class="card-text mb-3 fo-course-description" style="white-space: normal; word-wrap: break-word; overflow: visible; max-height: none;">
                                    {{ postulation.motivationCandidature }}
                                </p>
                                <div class="mt-auto">
                                    {% if postulation.offreEmploi %}
                                        <a href="{{ path('app_candidate_offre_show', {'id': postulation.offreEmploi.id}) }}" class="btn btn-primary btn-sm btn-block fo-btn-commencer">
                                            Voir l'offre
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="alert alert-light border text-center py-5 mb-0">
                <h5 class="mb-2">Aucune postulation trouvée</h5>
                <p class="mb-0">Aucune postulation ne correspond à vos critères de recherche.</p>
            </div>
        {% endif %}
    </div>

    <style>
        .fo-stats-row {
            display: flex;
            gap: 16px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }
        .fo-stat-card {
            flex: 1;
            min-width: 140px;
            display: flex;
            align-items: center;
            gap: 14px;
            background: rgba(255,255,255,0.92);
            border-radius: 18px;
            padding: 18px 20px;
            box-shadow: 0 8px 24px rgba(31,55,120,0.08);
        }
        .fo-stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }
        .fo-stat-value {
            display: block;
            font-size: 28px;
            font-weight: 800;
            color: #1f3470;
            line-height: 1;
        }
        .fo-stat-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #6b7280;
            margin-top: 4px;
        }
    </style>

    <script>
        setTimeout(function () {
            document.querySelectorAll('.fo-auto-hide-alert').forEach(function (alertBox) {
                alertBox.style.opacity = '0';
                alertBox.style.transition = 'opacity 0.6s ease';
                setTimeout(function () {
                    alertBox.remove();
                }, 600);
            });
        }, 10000);
    </script>
{% endblock %}