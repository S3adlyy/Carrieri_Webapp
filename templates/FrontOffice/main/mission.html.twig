{# templates/FrontOffice/main/mission.html.twig #}
{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Missions disponibles{% endblock %}

{% block candidate_page_heading %}Missions disponibles{% endblock %}

{% block candidate_breadcrumb %} / Missions{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('FrontOffice/css/front-overrides.css') }}?v=20260405-1">
    <style>
        /* Styles spécifiques aux missions - intégration avec la charte FXML */
        .fo-charte-ui .fo-mission-card {
            background: #fff;
            border-radius: 24px;
            border: 1px solid rgba(216, 201, 240, 0.65);
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            transition: transform 0.25s ease, box-shadow 0.25s ease;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .fo-charte-ui .fo-mission-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 40px rgba(94, 84, 142, 0.2);
        }

        .fo-charte-ui .fo-mission-cover {
            height: 140px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
        }

        .fo-charte-ui .fo-mission-cover i {
            font-size: 48px;
        }

        .fo-charte-ui .fo-mission-type-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 20px;
            letter-spacing: 0.3px;
        }

        .fo-charte-ui .fo-mission-title {
            font-weight: 800;
            color: #1f2937;
            font-size: 1.1rem;
            margin-bottom: 0.5rem;
        }

        .fo-charte-ui .fo-mission-description {
            line-height: 1.45;
            color: #6b7280;
            font-size: 0.85rem;
            margin-bottom: 1rem;
            min-height: 60px;
        }

        .fo-charte-ui .fo-mission-meta {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px 16px;
            color: #6b7280;
            font-size: 0.8rem;
            margin-bottom: 1rem;
        }

        .fo-charte-ui .fo-mission-meta i {
            width: 16px;
            color: #5e548e;
        }

        .fo-charte-ui .fo-score-ring {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #f8fafc;
            padding: 6px 12px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 700;
            color: #5e548e;
        }

        .fo-charte-ui .fo-score-ring i {
            font-size: 14px;
        }

        .fo-charte-ui .fo-btn-mission {
            border-radius: 999px;
            padding: 0.52rem 1rem;
            font-weight: 700;
            width: 100%;
            text-align: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            color: #fff;
            transition: all 0.3s ease;
        }

        .fo-charte-ui .fo-btn-mission:hover,
        .fo-charte-ui .fo-btn-mission:focus {
            transform: scale(1.02);
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.35);
            color: #fff;
        }

        .fo-charte-ui .fo-mission-stats {
            display: flex;
            justify-content: space-between;
            margin-bottom: 1rem;
            padding-top: 0.5rem;
            border-top: 1px solid #f0f0f0;
        }

        /* Animation */
        @keyframes foSlideIn {
            from { opacity: 0; transform: translateY(18px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .fo-charte-ui .fo-mission-item {
            animation: foSlideIn 0.45s ease both;
        }
    </style>
{% endblock %}

{% block candidate_content_container_class %}container-fluid px-3 px-md-4 px-lg-5{% endblock %}

{% block candidate_content_row_class %}row{% endblock %}

{% block candidate_content_col_class %}col-12{% endblock %}

{% block candidate_content %}
    <div class="w-100 text-start fo-charte-ui fo-fxml-catalog fo-shell-root position-relative">

        {# Orbes décoratifs (comme dans cours) #}
        <div class="fo-bg-orb fo-bg-orb-1"></div>
        <div class="fo-bg-orb fo-bg-orb-2"></div>
        <div class="fo-bg-orb fo-bg-orb-3"></div>

        {# En-tête #}
        <div class="fo-catalog-header mb-4 position-relative">
            <h3 class="mb-1">Missions professionnelles</h3>
            <p class="mb-0">{{ missions|length }} missions disponibles pour booster votre carrière</p>
        </div>

        {# Barre de recherche et filtres - style identique aux cours #}
        <form method="get" class="mb-4 position-relative" id="mission-filter-form">
            <div class="fo-charte-card fo-glass-card p-3 p-md-4 mb-3">
                <div class="row align-items-end">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label for="mission-type" class="d-block mb-2 font-weight-bold">Catégorie</label>
                        <select id="mission-type" name="type" class="form-control fo-filter-combo">
                            <option value="">Toutes les catégories</option>
                            {% set types = [] %}
                            {% for mission in missions %}
                                {% if mission.type not in types %}
                                    {% set types = types|merge([mission.type]) %}
                                {% endif %}
                            {% endfor %}
                            {% for type in types %}
                                <option value="{{ type|lower|replace({' ': '-', 'é': 'e', 'è': 'e', 'ê': 'e'}) }}">{{ type }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-6 mb-3 mb-md-0">
                        <div class="fo-langue-wrap">
                            <label for="mission-sort" class="d-block mb-2 font-weight-bold">Trier par</label>
                            <select id="mission-sort" class="form-control fo-filter-combo">
                                <option value="recent">Plus récentes</option>
                                <option value="score">Score minimum (croissant)</option>
                                <option value="score-desc">Score minimum (décroissant)</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="fo-search-wrap mb-4">
                <label for="mission-search" class="sr-only">Rechercher une mission</label>
                <input id="mission-search" type="text" name="q" class="form-control fo-search-input" placeholder="Rechercher une mission par titre ou description..." value="{{ app.request.query.get('q', '') }}">
                <button type="submit" class="btn fo-search-button ml-2">Rechercher</button>
            </div>
            <div class="text-right mb-1">
                <a href="{{ path('app_candidate_mission') }}" class="fo-reset-link">Reset</a>
            </div>
        </form>

        {# Statistiques - style identique aux cours #}
        <div class="row text-center mb-4 position-relative">
            <div class="col-md-4 mb-3 mb-md-0">
                <div class="fo-charte-card fo-stat-card">
                    <small>Missions disponibles</small>
                    <strong id="total-missions">{{ missions|length }}</strong>
                </div>
            </div>
            <div class="col-md-4 mb-3 mb-md-0">
                <div class="fo-charte-card fo-stat-card">
                    <small>Catégories</small>
                    <strong>{{ missions|reduce((unique, m) => m.type not in unique ? unique|merge([m.type]) : unique, [])|length }}</strong>
                </div>
            </div>
            <div class="col-md-4">
                <div class="fo-charte-card fo-stat-card">
                    <small>Score maximum requis</small>
                    <strong>{{ missions|reduce((max, m) => m.scoreMin > max ? m.scoreMin : max, 0) }}</strong>
                </div>
            </div>
        </div>

        {# Grille des missions - style identique aux cours #}
        {% if missions is empty %}
            <div class="alert alert-light border mb-0 text-center py-5">
                <i class="fas fa-briefcase fa-3x mb-3" style="color: #cbd5e1;"></i>
                <h5>Aucune mission disponible</h5>
                <p class="mb-0">Revenez plus tard pour découvrir de nouvelles opportunités professionnelles.</p>
            </div>
        {% else %}
            <div class="row position-relative fo-courses-grid" id="mission-grid">
                {% for mission in missions %}
                    {% set typeSlug = mission.type|lower|replace({' ': '-', 'é': 'e', 'è': 'e', 'ê': 'e'}) %}
                    {% set iconMap = {
                        'Développement': 'fa-code',
                        'Design':        'fa-paintbrush',
                        'Marketing':     'fa-chart-simple',
                        'Data':          'fa-database',
                        'Cloud':         'fa-cloud',
                        'Security':      'fa-shield-halved'
                    } %}
                    <div class="col-xl-4 col-md-6 mb-4 fo-mission-item"
                         data-type="{{ typeSlug }}"
                         data-title="{{ mission.description|lower }}"
                         data-score="{{ mission.scoreMin }}">
                        <div class="card h-100 fo-charte-card fo-mission-card">
                            <div class="fo-mission-cover position-relative">
                                <i class="fas {{ iconMap[mission.type]|default('fa-briefcase') }}"></i>
                                {% if mission.createdAt and mission.createdAt|date('U') > date('-7 days')|date('U') %}
                                    <span class="fo-mission-type-badge">
                                        <i class="fas fa-star"></i> Nouveau
                                    </span>
                                {% endif %}
                            </div>
                            <div class="card-body d-flex flex-column">
                                <div class="mb-2 d-flex align-items-center flex-wrap fo-card-badges">
                                    <span class="badge fo-level-badge--intermediate mr-2">{{ mission.type|default('Mission') }}</span>
                                </div>
                                <h5 class="fo-mission-title">{{ mission.type|default('Mission') }}</h5>
                                <p class="fo-mission-description">{{ mission.description|length > 120 ? mission.description|slice(0, 117) ~ '…' : mission.description }}</p>

                                <div class="fo-mission-meta">
                                    <span><i class="fas fa-calendar-alt"></i> {{ mission.createdAt|date('d/m/Y') }}</span>
                                    <span><i class="fas fa-circle-check"></i> Disponible</span>
                                </div>

                                <div class="fo-mission-stats">
                                    <span class="fo-score-ring">
                                        <i class="fas fa-trophy"></i> Score min: {{ mission.scoreMin }} pts
                                    </span>
                                </div>

                                <div class="mt-auto">
                                    <a href="{{ path('app_candidate_rendu_mission', {'id': mission.id}) }}" class="btn fo-btn-mission">
                                        Commencer <i class="fas fa-arrow-right ml-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {# Message "aucun résultat" dynamique #}
            <div id="no-results-message" class="text-center py-5" style="display: none;">
                <div class="fo-charte-card p-5">
                    <i class="fas fa-search fa-3x mb-3" style="color: #cbd5e1;"></i>
                    <h5>Aucune mission trouvée</h5>
                    <p class="mb-0">Aucune mission ne correspond à vos critères de recherche.</p>
                    <button class="btn btn-link mt-3 fo-reset-link" onclick="resetFilters()">Réinitialiser les filtres</button>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('mission-search');
            const typeSelect = document.getElementById('mission-type');
            const sortSelect = document.getElementById('mission-sort');
            const missionItems = document.querySelectorAll('.fo-mission-item');
            const totalSpan = document.getElementById('total-missions');
            const noResultsDiv = document.getElementById('no-results-message');
            const missionGrid = document.getElementById('mission-grid');

            function filterAndSortMissions() {
                const searchTerm = searchInput ? searchInput.value.trim().toLowerCase() : '';
                const selectedType = typeSelect ? typeSelect.value : '';
                const sortBy = sortSelect ? sortSelect.value : 'recent';

                let visibleCount = 0;
                let visibleItems = [];

                missionItems.forEach(item => {
                    const title = item.dataset.title || '';
                    const type = item.dataset.type || '';

                    const matchesSearch = searchTerm === '' || title.includes(searchTerm);
                    const matchesType = selectedType === '' || type === selectedType;

                    if (matchesSearch && matchesType) {
                        item.style.display = '';
                        visibleCount++;
                        visibleItems.push(item);
                    } else {
                        item.style.display = 'none';
                    }
                });

                // Tri des éléments visibles
                if (sortBy === 'score') {
                    visibleItems.sort((a, b) => (parseFloat(a.dataset.score) || 0) - (parseFloat(b.dataset.score) || 0));
                } else if (sortBy === 'score-desc') {
                    visibleItems.sort((a, b) => (parseFloat(b.dataset.score) || 0) - (parseFloat(a.dataset.score) || 0));
                }
                // Pour 'recent', on garde l'ordre original (basé sur l'ID ou la date)

                // Réordonner dans le DOM
                if (missionGrid && (sortBy === 'score' || sortBy === 'score-desc')) {
                    visibleItems.forEach(item => {
                        missionGrid.appendChild(item);
                    });
                }

                // Mise à jour du compteur
                if (totalSpan) totalSpan.textContent = visibleCount;

                // Affichage du message "aucun résultat"
                if (noResultsDiv) {
                    noResultsDiv.style.display = visibleCount === 0 ? 'block' : 'none';
                }
            }

            // Événements avec debounce pour la recherche
            let timer;
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    clearTimeout(timer);
                    timer = setTimeout(filterAndSortMissions, 300);
                });
            }
            if (typeSelect) {
                typeSelect.addEventListener('change', filterAndSortMissions);
            }
            if (sortSelect) {
                sortSelect.addEventListener('change', filterAndSortMissions);
            }

            // Initialisation
            filterAndSortMissions();
        });

        function resetFilters() {
            const searchInput = document.getElementById('mission-search');
            const typeSelect = document.getElementById('mission-type');
            const sortSelect = document.getElementById('mission-sort');

            if (searchInput) searchInput.value = '';
            if (typeSelect) typeSelect.value = '';
            if (sortSelect) sortSelect.value = 'recent';

            // Déclencher le filtre
            if (typeof filterAndSortMissions === 'function') {
                filterAndSortMissions();
            } else {
                window.location.href = '{{ path('app_candidate_mission') }}';
            }
        }
    </script>
{% endblock %}