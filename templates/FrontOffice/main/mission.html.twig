{# templates/FrontOffice/main/mission.html.twig #}
{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Missions disponibles{% endblock %}

{% block candidate_page_heading %}Missions disponibles{% endblock %}

{% block candidate_breadcrumb %} / Missions{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('FrontOffice/css/front-overrides.css') }}?v=20260405-1">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Styles spécifiques aux missions - intégration avec la charte FXML */
        .fo-charte-ui .fo-mission-card {
            background: #fff;
            border-radius: 24px;
            border: 1px solid rgba(216, 201, 240, 0.65);
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            transition: transform 0.25s ease, box-shadow 0.25s ease;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .fo-charte-ui .fo-mission-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 40px rgba(94, 84, 142, 0.2);
        }

        .fo-charte-ui .fo-mission-cover {
            height: 140px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            position: relative;
        }

        .fo-charte-ui .fo-mission-cover i {
            font-size: 48px;
        }

        .fo-charte-ui .fo-mission-type-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 20px;
            letter-spacing: 0.3px;
        }

        .fo-charte-ui .fo-mission-title {
            font-weight: 800;
            color: #1f2937;
            font-size: 1.1rem;
            margin-bottom: 0.5rem;
        }

        .fo-charte-ui .fo-mission-description {
            line-height: 1.45;
            color: #6b7280;
            font-size: 0.85rem;
            margin-bottom: 1rem;
            min-height: 60px;
        }

        .fo-charte-ui .fo-mission-meta {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px 16px;
            color: #6b7280;
            font-size: 0.8rem;
            margin-bottom: 1rem;
        }

        .fo-charte-ui .fo-mission-meta i {
            width: 16px;
            color: #5e548e;
        }

        .fo-charte-ui .fo-score-ring {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #f8fafc;
            padding: 6px 12px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 700;
            color: #5e548e;
        }

        .fo-charte-ui .fo-score-ring i {
            font-size: 14px;
        }

        .fo-charte-ui .fo-btn-mission {
            border-radius: 999px;
            padding: 0.52rem 1rem;
            font-weight: 700;
            width: 100%;
            text-align: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            color: #fff;
            transition: all 0.3s ease;
            display: inline-block;
            text-decoration: none;
        }

        .fo-charte-ui .fo-btn-mission:hover,
        .fo-charte-ui .fo-btn-mission:focus {
            transform: scale(1.02);
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.35);
            color: #fff;
            text-decoration: none;
        }

        .fo-charte-ui .fo-mission-stats {
            display: flex;
            justify-content: space-between;
            margin-bottom: 1rem;
            padding-top: 0.5rem;
            border-top: 1px solid #f0f0f0;
        }

        /* Form styles */
        .fo-charte-ui .fo-glass-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 20px;
        }

        .fo-charte-ui .fo-filter-combo {
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            padding: 10px 12px;
            font-size: 0.9rem;
        }

        .fo-charte-ui .fo-search-wrap {
            position: relative;
            display: flex;
            gap: 10px;
        }

        .fo-charte-ui .fo-search-input {
            flex: 1;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            padding: 12px 16px;
            font-size: 0.9rem;
        }

        .fo-charte-ui .fo-search-button {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #fff;
            border: none;
            padding: 12px 24px;
            border-radius: 12px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .fo-charte-ui .fo-search-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
        }

        .fo-charte-ui .fo-reset-link {
            color: #6b7280;
            text-decoration: none;
            font-size: 0.85rem;
        }

        .fo-charte-ui .fo-reset-link:hover {
            color: #5e548e;
        }

        .fo-charte-ui .fo-stat-card {
            background: #fff;
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            border: 1px solid rgba(216, 201, 240, 0.65);
        }

        .fo-charte-ui .fo-stat-card small {
            display: block;
            color: #6b7280;
            font-size: 0.75rem;
            margin-bottom: 8px;
        }

        .fo-charte-ui .fo-stat-card strong {
            font-size: 1.8rem;
            color: #5e548e;
            font-weight: 800;
        }

        /* Orbes décoratifs */
        .fo-bg-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            z-index: 0;
            pointer-events: none;
        }

        .fo-bg-orb-1 {
            width: 300px;
            height: 300px;
            background: rgba(102, 126, 234, 0.15);
            top: -100px;
            left: -100px;
        }

        .fo-bg-orb-2 {
            width: 400px;
            height: 400px;
            background: rgba(118, 75, 162, 0.1);
            bottom: -100px;
            right: -100px;
        }

        .fo-bg-orb-3 {
            width: 250px;
            height: 250px;
            background: rgba(240, 147, 251, 0.1);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        /* Animation */
        @keyframes foSlideIn {
            from { opacity: 0; transform: translateY(18px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .fo-charte-ui .fo-mission-item {
            animation: foSlideIn 0.45s ease both;
        }
    </style>
{% endblock %}

{% block candidate_content_container_class %}container-fluid px-3 px-md-4 px-lg-5{% endblock %}

{% block candidate_content_row_class %}row{% endblock %}

{% block candidate_content_col_class %}col-12{% endblock %}

{% block candidate_content %}
    <div class="w-100 text-start fo-charte-ui fo-fxml-catalog fo-shell-root position-relative">

        {# Orbes décoratifs #}
        <div class="fo-bg-orb fo-bg-orb-1"></div>
        <div class="fo-bg-orb fo-bg-orb-2"></div>
        <div class="fo-bg-orb fo-bg-orb-3"></div>

        {# En-tête #}
        <div class="fo-catalog-header mb-4 position-relative">
            <h3 class="mb-1">Missions professionnelles</h3>
            <p class="mb-0">{{ missions|length }} missions disponibles pour booster votre carrière</p>
        </div>

        {# Barre de recherche et filtres #}
        <form method="get" class="mb-4 position-relative" id="mission-filter-form">
            <div class="fo-charte-card fo-glass-card p-3 p-md-4 mb-3">
                <div class="row align-items-end">
                    <div class="col-md-4 mb-3 mb-md-0">
                        <label for="mission-type" class="d-block mb-2 font-weight-bold">Catégorie</label>
                        <select id="mission-type" name="type" class="form-control fo-filter-combo">
                            <option value="">Toutes les catégories</option>
                            {% for type in types %}
                                <option value="{{ type }}" {% if currentType == type %}selected{% endif %}>
                                    {{ type }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-4 mb-3 mb-md-0">
                        <div class="fo-langue-wrap">
                            <label for="mission-sort" class="d-block mb-2 font-weight-bold">Trier par</label>
                            <select id="mission-sort" name="sort" class="form-control fo-filter-combo">
                                <option value="recent" {% if currentSort == 'recent' %}selected{% endif %}>
                                    <i class="fas fa-calendar"></i> Plus récentes
                                </option>
                                <option value="score_asc" {% if currentSort == 'score_asc' %}selected{% endif %}>
                                    <i class="fas fa-arrow-up"></i> Score minimum (croissant)
                                </option>
                                <option value="score_desc" {% if currentSort == 'score_desc' %}selected{% endif %}>
                                    <i class="fas fa-arrow-down"></i> Score minimum (décroissant)
                                </option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="d-block mb-2 font-weight-bold">&nbsp;</label>
                        <button type="submit" class="btn fo-search-button w-100">
                            <i class="fas fa-filter"></i> Appliquer les filtres
                        </button>
                    </div>
                </div>
            </div>

            <div class="fo-search-wrap mb-4">
                <label for="mission-search" class="sr-only">Rechercher une mission</label>
                <input id="mission-search" type="text" name="q" class="form-control fo-search-input"
                       placeholder="Rechercher une mission par description..."
                       value="{{ currentSearch }}">
                <button type="submit" class="btn fo-search-button">
                    <i class="fas fa-search"></i> Rechercher
                </button>
            </div>
            <div class="text-right mb-1">
                <a href="{{ path('app_candidate_mission') }}" class="fo-reset-link">
                    <i class="fas fa-undo-alt"></i> Réinitialiser tous les filtres
                </a>
            </div>
        </form>

        {# Statistiques #}
        <div class="row text-center mb-4 position-relative">
            <div class="col-md-4 mb-3 mb-md-0">
                <div class="fo-charte-card fo-stat-card">
                    <small>Missions disponibles</small>
                    <strong>{{ missions|length }}</strong>
                </div>
            </div>
            <div class="col-md-4 mb-3 mb-md-0">
                <div class="fo-charte-card fo-stat-card">
                    <small>Catégories</small>
                    <strong>{{ types|length }}</strong>
                </div>
            </div>
            <div class="col-md-4">
                <div class="fo-charte-card fo-stat-card">
                    <small>Score maximum requis</small>
                    <strong>{{ missions|reduce((max, m) => m.scoreMin > max ? m.scoreMin : max, 0) }}</strong>
                </div>
            </div>
        </div>

        {# Grille des missions #}
        {% if missions is empty %}
            <div class="alert alert-light border mb-0 text-center py-5">
                <i class="fas fa-briefcase fa-3x mb-3" style="color: #cbd5e1;"></i>
                <h5>Aucune mission disponible</h5>
                <p class="mb-0">Revenez plus tard pour découvrir de nouvelles opportunités professionnelles.</p>
                {% if currentSearch or currentType %}
                    <button class="btn btn-link mt-3 fo-reset-link" onclick="resetAllFilters()">
                        <i class="fas fa-undo-alt"></i> Réinitialiser les filtres
                    </button>
                {% endif %}
            </div>
        {% else %}
            <div class="row position-relative fo-courses-grid">
                {% for mission in missions %}
                    {% set iconMap = {
                        'Développement': 'fa-code',
                        'Design': 'fa-paintbrush',
                        'Marketing': 'fa-chart-simple',
                        'Data': 'fa-database',
                        'Cloud': 'fa-cloud',
                        'Security': 'fa-shield-halved'
                    } %}
                    <div class="col-xl-4 col-md-6 mb-4 fo-mission-item">
                        <div class="card h-100 fo-charte-card fo-mission-card">
                            <div class="fo-mission-cover position-relative">
                                <i class="fas {{ iconMap[mission.type]|default('fa-briefcase') }}"></i>
                                {% if mission.createdAt and mission.createdAt|date('U') > date('-7 days')|date('U') %}
                                    <span class="fo-mission-type-badge">
                                        <i class="fas fa-star"></i> Nouveau
                                    </span>
                                {% endif %}
                            </div>
                            <div class="card-body d-flex flex-column">
                                <div class="mb-2 d-flex align-items-center flex-wrap fo-card-badges">
                                    <span class="badge fo-level-badge--intermediate mr-2">{{ mission.type|default('Mission') }}</span>
                                </div>
                                <h5 class="fo-mission-title">{{ mission.type|default('Mission') }}</h5>
                                <p class="fo-mission-description">{{ mission.description|length > 120 ? mission.description|slice(0, 117) ~ '…' : mission.description }}</p>

                                <div class="fo-mission-meta">
                                    <span><i class="fas fa-calendar-alt"></i> {{ mission.createdAt|date('d/m/Y') }}</span>
                                    <span><i class="fas fa-circle-check"></i> Disponible</span>
                                </div>

                                <div class="fo-mission-stats">
                                    <span class="fo-score-ring">
                                        <i class="fas fa-trophy"></i> Score min: {{ mission.scoreMin }} pts
                                    </span>
                                </div>

                                <div class="mt-auto">
                                    <a href="{{ path('app_candidate_rendu_mission', {'id': mission.id}) }}" class="btn fo-btn-mission">
                                        Commencer <i class="fas fa-arrow-right ml-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function resetAllFilters() {
            window.location.href = '{{ path('app_candidate_mission') }}';
        }

        // Auto-submit form when filters change (optional)
        document.addEventListener('DOMContentLoaded', function() {
            const typeSelect = document.getElementById('mission-type');
            const sortSelect = document.getElementById('mission-sort');
            const form = document.getElementById('mission-filter-form');

            if (typeSelect) {
                typeSelect.addEventListener('change', function() {
                    form.submit();
                });
            }

            if (sortSelect) {
                sortSelect.addEventListener('change', function() {
                    form.submit();
                });
            }
        });
    </script>
{% endblock %}