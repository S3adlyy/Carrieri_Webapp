{# templates/FrontOffice/main/mission.html.twig #}
{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Missions disponibles{% endblock %}

{% block candidate_page_heading %}Missions disponibles{% endblock %}

{% block candidate_breadcrumb %} / Missions{% endblock %}

{% block candidate_content %}

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap');

        :root {
            --indigo:       #4f46e5;
            --indigo-light: #6366f1;
            --indigo-dark:  #3730a3;
            --violet:       #7c3aed;
            --surface:      #ffffff;
            --bg:           #f1f5f9;
            --sidebar-bg:   #0f172a;
            --sidebar-text: #94a3b8;
            --sidebar-active: #e0e7ff;
            --text-primary: #0f172a;
            --text-secondary: #64748b;
            --border:       #e2e8f0;
            --success:      #10b981;
            --warning:      #f59e0b;
            --danger:       #ef4444;
            --radius-lg:    16px;
            --radius-md:    10px;
            --radius-sm:    6px;
            --shadow-sm:    0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
            --shadow-md:    0 4px 16px rgba(0,0,0,.08);
            --shadow-lg:    0 12px 40px rgba(79,70,229,.14);
        }

        /* ── Page shell ── */
        .m-page {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            min-height: 100vh;
            color: var(--text-primary);
        }

        /* ── Top KPI bar ── */
        .kpi-bar {
            display: flex;
            gap: 16px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .kpi-card {
            flex: 1;
            min-width: 160px;
            background: var(--surface);
            border-radius: var(--radius-lg);
            padding: 18px 22px;
            display: flex;
            align-items: center;
            gap: 14px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
            transition: box-shadow .25s, transform .25s;
        }
        .kpi-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-2px);
        }

        .kpi-icon {
            width: 46px; height: 46px;
            border-radius: var(--radius-md);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            font-size: 18px;
        }
        .kpi-icon.indigo  { background: #eef2ff; color: var(--indigo); }
        .kpi-icon.violet  { background: #f5f3ff; color: var(--violet); }
        .kpi-icon.success { background: #ecfdf5; color: var(--success); }

        .kpi-info { line-height: 1.2; }
        .kpi-number {
            font-family: 'Sora', sans-serif;
            font-size: 26px; font-weight: 700;
            color: var(--text-primary);
        }
        .kpi-label {
            font-size: 12px; color: var(--text-secondary);
            font-weight: 500; margin-top: 2px;
        }

        /* ── Toolbar (search + filters in one row) ── */
        .toolbar {
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            padding: 14px 20px;
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
            flex-wrap: wrap;
            box-shadow: var(--shadow-sm);
        }

        .toolbar-search {
            flex: 1;
            min-width: 220px;
            position: relative;
            display: flex;
            align-items: center;
        }
        .toolbar-search i.icon-left {
            position: absolute; left: 14px;
            color: var(--text-secondary); font-size: 14px;
            pointer-events: none;
        }
        .toolbar-search input {
            width: 100%;
            padding: 9px 36px 9px 38px;
            border: 1px solid var(--border);
            border-radius: 50px;
            font-size: 13.5px;
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            outline: none;
            transition: border-color .2s, box-shadow .2s;
        }
        .toolbar-search input:focus {
            border-color: var(--indigo-light);
            box-shadow: 0 0 0 3px rgba(99,102,241,.15);
            background: #fff;
        }
        .btn-clear-search {
            position: absolute; right: 12px;
            background: none; border: none;
            color: var(--text-secondary); cursor: pointer;
            font-size: 13px; display: none;
            padding: 2px; border-radius: 50%;
            transition: color .2s;
        }
        .btn-clear-search:hover { color: var(--danger); }

        .toolbar-divider {
            width: 1px; height: 28px;
            background: var(--border);
            flex-shrink: 0;
        }

        .filter-chips {
            display: flex; flex-wrap: wrap; gap: 8px;
            align-items: center;
        }
        .filter-chip {
            padding: 6px 14px;
            border: 1.5px solid var(--border);
            border-radius: 50px;
            font-size: 12.5px; font-weight: 500;
            color: var(--text-secondary);
            background: transparent;
            cursor: pointer;
            display: inline-flex; align-items: center; gap: 6px;
            transition: all .2s;
            font-family: 'DM Sans', sans-serif;
        }
        .filter-chip:hover {
            border-color: var(--indigo-light);
            color: var(--indigo);
            background: #eef2ff;
        }
        .filter-chip.active {
            border-color: var(--indigo);
            background: var(--indigo);
            color: #fff;
        }
        .filter-chip .chip-count {
            background: rgba(255,255,255,.22);
            padding: 1px 7px;
            border-radius: 20px;
            font-size: 11px;
            color: inherit;
        }
        .filter-chip:not(.active) .chip-count {
            background: rgba(0,0,0,.07);
        }

        /* ── Layout: sidebar + main (horizontal) ── */
        .m-layout {
            display: flex;
            gap: 20px;
            align-items: flex-start;
        }

        /* ── Mission list (right, takes rest of space) ── */
        .mission-list-area {
            flex: 1;
            min-width: 0;
        }

        .missions-count-row {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 16px;
        }
        .missions-count-label {
            font-size: 13px; color: var(--text-secondary); font-weight: 500;
        }
        .missions-count-label span { font-weight: 700; color: var(--text-primary); }

        .view-toggle { display: flex; gap: 6px; }
        .view-btn {
            width: 32px; height: 32px;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            background: var(--surface);
            color: var(--text-secondary);
            cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            font-size: 13px;
            transition: all .2s;
        }
        .view-btn.active, .view-btn:hover {
            border-color: var(--indigo);
            color: var(--indigo);
            background: #eef2ff;
        }

        /* ── Mission cards – horizontal card style ── */
        .mission-grid {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .mission-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            display: flex;
            align-items: stretch;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            transition: box-shadow .25s, transform .25s, border-color .25s;
            animation: slideIn .45s ease both;
            position: relative;
        }
        .mission-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-2px);
            border-color: var(--indigo-light);
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(18px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Left accent strip */
        .mission-card__accent {
            width: 5px;
            flex-shrink: 0;
            background: linear-gradient(180deg, var(--indigo) 0%, var(--violet) 100%);
        }

        /* Icon column */
        .mission-card__icon-col {
            width: 80px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f8faff;
            border-right: 1px solid var(--border);
        }
        .mission-type-icon {
            width: 44px; height: 44px;
            border-radius: var(--radius-md);
            background: linear-gradient(135deg, var(--indigo) 0%, var(--violet) 100%);
            display: flex; align-items: center; justify-content: center;
            color: #fff;
            font-size: 18px;
        }

        /* Body */
        .mission-card__body {
            flex: 1;
            padding: 18px 20px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            min-width: 0;
        }

        .mission-card__top {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 6px;
        }
        .mission-card__title {
            font-family: 'Sora', sans-serif;
            font-size: 15.5px;
            font-weight: 700;
            color: var(--text-primary);
            flex: 1;
            line-height: 1.3;
        }
        .badge-new {
            flex-shrink: 0;
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            padding: 3px 9px;
            border-radius: 20px;
            letter-spacing: .3px;
            white-space: nowrap;
        }

        .mission-card__desc {
            font-size: 13px;
            color: var(--text-secondary);
            line-height: 1.55;
            margin-bottom: 12px;
        }

        .mission-card__meta {
            display: flex;
            align-items: center;
            gap: 16px;
            flex-wrap: wrap;
        }
        .meta-tag {
            display: inline-flex; align-items: center; gap: 5px;
            font-size: 12px; color: var(--text-secondary); font-weight: 500;
        }
        .meta-tag i { color: var(--indigo-light); font-size: 11px; }

        /* Score col */
        .mission-card__score-col {
            width: 110px;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            border-left: 1px solid var(--border);
            padding: 18px 12px;
            gap: 6px;
        }

        .score-ring-wrap {
            position: relative;
            width: 58px; height: 58px;
        }
        .score-ring-wrap svg { transform: rotate(-90deg); }
        .score-num {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            font-family: 'Sora', sans-serif;
            font-size: 15px; font-weight: 800;
            color: var(--text-primary);
            line-height: 1;
            text-align: center;
        }
        .score-num small { font-size: 9px; font-weight: 400; color: var(--text-secondary); display: block; }
        .score-label { font-size: 10.5px; color: var(--text-secondary); font-weight: 500; }

        /* Action col */
        .mission-card__action-col {
            width: 130px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 18px 16px;
            border-left: 1px solid var(--border);
        }

        .btn-start {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            padding: 10px 18px;
            background: var(--indigo);
            color: #fff;
            font-size: 12.5px;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            border-radius: 50px;
            text-decoration: none;
            white-space: nowrap;
            transition: background .2s, box-shadow .2s, transform .2s;
            border: none;
            cursor: pointer;
        }
        .btn-start:hover {
            background: var(--indigo-dark);
            box-shadow: 0 6px 20px rgba(79,70,229,.35);
            transform: scale(1.04);
            color: #fff;
            text-decoration: none;
        }
        .btn-start i { font-size: 11px; transition: transform .2s; }
        .btn-start:hover i { transform: translateX(3px); }

        /* ── Empty state ── */
        .empty-state {
            text-align: center;
            padding: 70px 20px;
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
        }
        .empty-state-icon {
            width: 72px; height: 72px;
            border-radius: 50%;
            background: var(--bg);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 18px;
        }
        .empty-state-icon i { font-size: 30px; color: var(--text-secondary); }
        .empty-state h4 { font-family: 'Sora', sans-serif; font-size: 18px; color: var(--text-primary); margin-bottom: 8px; }
        .empty-state p  { font-size: 13.5px; color: var(--text-secondary); max-width: 320px; margin: 0 auto; }

        /* ── No-results inline ── */
        .no-results-msg {
            display: none;
            text-align: center;
            padding: 40px;
            color: var(--text-secondary);
            font-size: 14px;
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
        }

        /* ── Responsive ── */
        @media (max-width: 820px) {
            .mission-card__score-col { width: 80px; }
            .mission-card__action-col { width: 100px; }
            .btn-start span { display: none; }
            .btn-start { padding: 10px 12px; }
        }

        @media (max-width: 640px) {
            .kpi-bar { gap: 10px; }
            .kpi-card { padding: 14px 16px; }
            .kpi-number { font-size: 22px; }
            .toolbar { flex-direction: column; align-items: stretch; gap: 12px; }
            .toolbar-divider { display: none; }
            .mission-card { flex-direction: column; }
            .mission-card__icon-col { width: 100%; height: 52px; border-right: none; border-bottom: 1px solid var(--border); flex-direction: row; gap: 12px; justify-content: flex-start; padding-left: 18px; }
            .mission-card__score-col { width: 100%; flex-direction: row; border-left: none; border-top: 1px solid var(--border); padding: 12px 18px; }
            .mission-card__action-col { width: 100%; border-left: none; border-top: 1px solid var(--border); padding: 12px 18px; }
            .btn-start { width: 100%; justify-content: center; }
            .btn-start span { display: inline; }
        }
    </style>

    <div class="m-page">
        <div class="container-fluid px-0">

            {# ── KPI bar ── #}
            <div class="kpi-bar">
                <div class="kpi-card">
                    <div class="kpi-icon indigo"><i class="fas fa-briefcase"></i></div>
                    <div class="kpi-info">
                        <div class="kpi-number">{{ missions|length }}</div>
                        <div class="kpi-label">Missions disponibles</div>
                    </div>
                </div>

                <div class="kpi-card">
                    <div class="kpi-icon violet"><i class="fas fa-layer-group"></i></div>
                    <div class="kpi-info">
                        {% set typesCount = [] %}
                        {% for mission in missions %}
                            {% if mission.type not in typesCount %}
                                {% set typesCount = typesCount|merge([mission.type]) %}
                            {% endif %}
                        {% endfor %}
                        <div class="kpi-number">{{ typesCount|length }}</div>
                        <div class="kpi-label">Catégories</div>
                    </div>
                </div>

                <div class="kpi-card">
                    <div class="kpi-icon success"><i class="fas fa-trophy"></i></div>
                    <div class="kpi-info">
                        <div class="kpi-number">{{ missions|reduce((max, m) => m.scoreMin > max ? m.scoreMin : max, 0) }}</div>
                        <div class="kpi-label">Score maximum</div>
                    </div>
                </div>
            </div>

            {# ── Toolbar: search + filters in one horizontal bar ── #}
            <div class="toolbar">
                <div class="toolbar-search">
                    <i class="fas fa-search icon-left"></i>
                    <input type="text"
                           id="mission-search"
                           placeholder="Rechercher une mission..."
                           aria-label="Rechercher une mission">
                    <button class="btn-clear-search" id="clear-search" aria-label="Effacer">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <div class="toolbar-divider"></div>

                <div class="filter-chips" id="filter-chips">
                    <button class="filter-chip active" data-filter="all">
                        <i class="fas fa-th-large"></i> Toutes
                        <span class="chip-count">{{ missions|length }}</span>
                    </button>
                    {% set types = [] %}
                    {% for mission in missions %}
                        {% if mission.type not in types %}
                            {% set types = types|merge([mission.type]) %}
                        {% endif %}
                    {% endfor %}
                    {% for type in types %}
                        {% set count = missions|filter(m => m.type == type)|length %}
                        <button class="filter-chip"
                                data-filter="{{ type|lower|replace({' ': '-', 'é': 'e', 'è': 'e', 'ê': 'e'}) }}">
                            <i class="fas fa-tag"></i> {{ type }}
                            <span class="chip-count">{{ count }}</span>
                        </button>
                    {% endfor %}
                </div>
            </div>

            {# ── Mission list area ── #}
            <div class="mission-list-area">
                <div class="missions-count-row">
                    <div class="missions-count-label"><span id="visible-count">{{ missions|length }}</span> mission(s) affichée(s)</div>
                    <div class="view-toggle">
                        <button class="view-btn active" title="Vue liste"><i class="fas fa-list"></i></button>
                    </div>
                </div>

                {# Mission cards #}
                <div class="mission-grid" id="mission-grid">
                    {% for mission in missions %}
                        {% set typeSlug = mission.type|lower|replace({' ': '-', 'é': 'e', 'è': 'e', 'ê': 'e'}) %}
                        {% set iconMap = {
                            'Développement': 'fa-code',
                            'Design':        'fa-paintbrush',
                            'Marketing':     'fa-chart-simple',
                            'Data':          'fa-database',
                            'Cloud':         'fa-cloud',
                            'Security':      'fa-shield-halved'
                        } %}
                        <div class="mission-card mission-item"
                             data-type="{{ typeSlug }}"
                             data-title="{{ mission.description|lower }}"
                             data-type-search="{{ mission.type|lower }}"
                             style="animation-delay: {{ loop.index0 * 0.05 }}s">

                            <div class="mission-card__accent"></div>

                            <div class="mission-card__icon-col">
                                <div class="mission-type-icon">
                                    <i class="fas {{ iconMap[mission.type]|default('fa-briefcase') }}"></i>
                                </div>
                            </div>

                            <div class="mission-card__body">
                                <div class="mission-card__top">
                                    <div class="mission-card__title">{{ mission.type }}</div>
                                    {% if mission.createdAt and mission.createdAt|date('U') > date('-7 days')|date('U') %}
                                        <span class="badge-new"><i class="fas fa-star"></i> Nouveau</span>
                                    {% endif %}
                                </div>

                                <div class="mission-card__desc">
                                    {{ mission.description|length > 130 ? mission.description|slice(0, 127) ~ '…' : mission.description }}
                                </div>

                                <div class="mission-card__meta">
                                <span class="meta-tag">
                                    <i class="fas fa-calendar-alt"></i>
                                    {{ mission.createdAt|date('d/m/Y') }}
                                </span>
                                    <span class="meta-tag">
                                    <i class="fas fa-circle-check"></i>
                                    Disponible
                                </span>
                                    <span class="meta-tag">
                                    <i class="fas fa-tag"></i>
                                    {{ mission.type }}
                                </span>
                                </div>
                            </div>

                            <div class="mission-card__score-col">
                                <div class="score-ring-wrap">
                                    <svg width="58" height="58" viewBox="0 0 58 58">
                                        <circle cx="29" cy="29" r="24" fill="none" stroke="#e2e8f0" stroke-width="4"/>
                                        <circle cx="29" cy="29" r="24" fill="none"
                                                stroke="url(#sg{{ loop.index }})" stroke-width="4"
                                                stroke-linecap="round"
                                                stroke-dasharray="{{ (mission.scoreMin * 150.80 / 100) }}, 150.80"/>
                                        <defs>
                                            <linearGradient id="sg{{ loop.index }}" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#6366f1"/>
                                                <stop offset="100%" stop-color="#7c3aed"/>
                                            </linearGradient>
                                        </defs>
                                    </svg>
                                    <div class="score-num">
                                        {{ mission.scoreMin }}<small>pts</small>
                                    </div>
                                </div>
                                <div class="score-label">Score min.</div>
                            </div>

                            <div class="mission-card__action-col">
                                <a href="{{ path('app_candidate_rendu_mission', {'id': mission.id}) }}" class="btn-start">
                                    <span>Commencer</span>
                                    <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    {% else %}
                        <div class="empty-state">
                            <div class="empty-state-icon"><i class="fas fa-briefcase"></i></div>
                            <h4>Aucune mission disponible</h4>
                            <p>Revenez plus tard pour découvrir de nouvelles opportunités professionnelles.</p>
                        </div>
                    {% endfor %}

                    <div class="no-results-msg" id="no-results">
                        <i class="fas fa-search" style="font-size:24px;margin-bottom:10px;display:block;color:#94a3b8;"></i>
                        Aucune mission ne correspond à votre recherche.
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const searchInput   = document.getElementById('mission-search');
            const clearBtn      = document.getElementById('clear-search');
            const filterChips   = document.querySelectorAll('.filter-chip');
            const missionItems  = document.querySelectorAll('.mission-item');
            const visibleCount  = document.getElementById('visible-count');
            const noResults     = document.getElementById('no-results');

            let currentFilter = 'all';
            let currentSearch = '';

            function filterMissions() {
                let count = 0;
                missionItems.forEach(item => {
                    const typeMatch   = currentFilter === 'all' || item.dataset.type === currentFilter;
                    const searchText  = (item.dataset.title + ' ' + item.dataset.typeSearch).toLowerCase();
                    const searchMatch = currentSearch === '' || searchText.includes(currentSearch);

                    if (typeMatch && searchMatch) {
                        item.style.display = '';
                        count++;
                    } else {
                        item.style.display = 'none';
                    }
                });

                if (visibleCount) visibleCount.textContent = count;
                if (noResults) noResults.style.display = count === 0 ? 'block' : 'none';

                // Update "Toutes" chip count
                const allChip = document.querySelector('.filter-chip[data-filter="all"] .chip-count');
                if (allChip) allChip.textContent = count;
            }

            // Search with debounce
            let timer;
            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    clearTimeout(timer);
                    currentSearch = this.value.trim().toLowerCase();
                    if (clearBtn) clearBtn.style.display = currentSearch ? 'block' : 'none';
                    timer = setTimeout(filterMissions, 280);
                });
            }

            if (clearBtn) {
                clearBtn.addEventListener('click', function () {
                    searchInput.value = '';
                    currentSearch = '';
                    clearBtn.style.display = 'none';
                    filterMissions();
                    searchInput.focus();
                });
            }

            filterChips.forEach(chip => {
                chip.addEventListener('click', function () {
                    filterChips.forEach(c => c.classList.remove('active'));
                    this.classList.add('active');
                    currentFilter = this.dataset.filter;
                    filterMissions();
                });
            });
        });
    </script>

{% endblock %}
