{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Offres d'emploi{% endblock %}

{% block candidate_page_heading %}Offres d'emploi{% endblock %}

{% block candidate_breadcrumb %} / Offres d'emploi{% endblock %}

{% block candidate_content %}
    {% for message in app.flashes('success') %}
        <div class="fo-alert fo-alert-success fo-auto-hide-alert">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="fo-alert fo-alert-danger fo-auto-hide-alert">
            {{ message }}
        </div>
    {% endfor %}

    <div class="fo-stats-row">
        <div class="fo-stat-card">
            <div class="fo-stat-icon" style="background:rgba(59,130,246,0.12);color:#2563eb"><i class="fas fa-briefcase"></i></div>
            <div><span class="fo-stat-value">{{ stats.total }}</span><span class="fo-stat-label">Offres actives</span></div>
        </div>
        <div class="fo-stat-card">
            <div class="fo-stat-icon" style="background:rgba(16,185,129,0.12);color:#059669"><i class="fas fa-file-contract"></i></div>
            <div><span class="fo-stat-value">{{ stats.CDI }}</span><span class="fo-stat-label">CDI</span></div>
        </div>
        <div class="fo-stat-card">
            <div class="fo-stat-icon" style="background:rgba(245,158,11,0.12);color:#d97706"><i class="fas fa-clock"></i></div>
            <div><span class="fo-stat-value">{{ stats.CDD }}</span><span class="fo-stat-label">CDD</span></div>
        </div>
        <div class="fo-stat-card">
            <div class="fo-stat-icon" style="background:rgba(139,92,246,0.12);color:#7c3aed"><i class="fas fa-graduation-cap"></i></div>
            <div><span class="fo-stat-value">{{ stats.Stage }}</span><span class="fo-stat-label">Stage</span></div>
        </div>
        <div class="fo-stat-card">
            <div class="fo-stat-icon" style="background:rgba(236,72,153,0.12);color:#db2777"><i class="fas fa-laptop-code"></i></div>
            <div><span class="fo-stat-value">{{ stats.Freelance }}</span><span class="fo-stat-label">Freelance</span></div>
        </div>
    </div>

    <form method="get" class="fo-filter-bar">
        <input
            type="text"
            name="keyword"
            placeholder="Rechercher..."
            value="{{ app.request.get('keyword') }}"
        >

        <select name="type">
            <option value="">Type</option>
            <option value="CDI" {{ app.request.get('type') == 'CDI' ? 'selected' : '' }}>CDI</option>
            <option value="CDD" {{ app.request.get('type') == 'CDD' ? 'selected' : '' }}>CDD</option>
            <option value="Stage" {{ app.request.get('type') == 'Stage' ? 'selected' : '' }}>Stage</option>
            <option value="Freelance" {{ app.request.get('type') == 'Freelance' ? 'selected' : '' }}>Freelance</option>
        </select>

        <input
            type="text"
            name="localisation"
            placeholder="Localisation"
            value="{{ app.request.get('localisation') }}"
        >

        <input
            type="number"
            name="salaire"
            placeholder="Salaire min"
            value="{{ app.request.get('salaire') }}"
        >

        <div class="fo-filter-actions">
            <button type="submit">Filtrer</button>
            <a href="{{ path('app_candidate_offres') }}" class="fo-reset-btn">Réinitialiser</a>
        </div>
    </form>

    <div class="fo-offres-page">
        <div class="fo-offres-intro text-center">
            <p class="fo-offres-intro__text">
                Découvrez les opportunités disponibles et trouvez l’offre qui correspond à votre profil.
            </p>
        </div>

        {% if offres is defined and offres|length > 0 %}
            <div class="row">
                {% for offre in offres %}
                    <div class="col-lg-6 col-md-12 mb-4">
                        <div class="fo-offre-card text-start">
                            <div class="fo-offre-card__top">
                                <div>
                                    <h3 class="fo-offre-card__title">{{ offre.titre }}</h3>
                                    <div class="fo-offre-card__company">{{ offre.entreprise }}</div>
                                </div>

                                <span class="fo-offre-card__badge
                                    {% if offre.typeContrat == 'CDI' %}
                                        fo-badge-cdi
                                    {% elseif offre.typeContrat == 'CDD' %}
                                        fo-badge-cdd
                                    {% elseif offre.typeContrat == 'Stage' %}
                                        fo-badge-stage
                                    {% else %}
                                        fo-badge-other
                                    {% endif %}
                                ">
                                    {{ offre.typeContrat }}
                                </span>
                            </div>

                            <div class="fo-offre-card__meta">
                                <div class="fo-meta-item">
                                    <span class="fo-meta-item__label">Localisation</span>
                                    <span class="fo-meta-item__value">{{ offre.localisation }}</span>
                                </div>

                                <div class="fo-meta-item">
                                    <span class="fo-meta-item__label">Salaire</span>
                                    <span class="fo-meta-item__value">{{ offre.salaire }} DT</span>
                                </div>

                                <div class="fo-meta-item">
                                    <span class="fo-meta-item__label">Qualification</span>
                                    <span class="fo-meta-item__value">{{ offre.niveauQualification }}</span>
                                </div>

                                <div class="fo-meta-item">
                                    <span class="fo-meta-item__label">Expérience</span>
                                    <span class="fo-meta-item__value">{{ offre.experienceRequise }}</span>
                                </div>

                                <div class="fo-meta-item">
                                    <span class="fo-meta-item__label">Expiration</span>
                                    <span class="fo-meta-item__value">
                                        {{ offre.dateExpiration ? offre.dateExpiration|date('d/m/Y H:i') : '—' }}
                                    </span>
                                </div>

                                <div class="fo-meta-item">
                                    <span class="fo-meta-item__label">Contact</span>
                                    <span class="fo-meta-item__value">{{ offre.contactRecruteur }}</span>
                                </div>
                            </div>

                            <div class="fo-offre-card__description">
                                {{
                                    offre.description|length > 180
                                        ? offre.description|slice(0, 180) ~ '...'
                                        : offre.description
                                }}
                            </div>

                            <div class="fo-offre-card__actions">
                                <a href="{{ path('app_candidate_offre_show', {'id': offre.id}) }}" class="fo-offre-btn">
                                    Voir plus
                                </a>

                                <form method="post" action="{{ path('app_candidate_favorite_toggle', {'id': offre.id}) }}" class="fo-favorite-form">
                                    <button type="submit" class="fo-favorite-btn" title="{{ offre.id in favoriteIds ? 'Retirer des favoris' : 'Ajouter aux favoris' }}">
                                        {% if offre.id in favoriteIds %}
                                            <i class="fas fa-heart"></i>
                                        {% else %}
                                            <i class="far fa-heart"></i>
                                        {% endif %}
                                    </button>
                                </form>
                            </div>
                                                    </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="fo-empty-box">
                <h3>Aucune offre disponible</h3>
                <p class="mb-0">Il n'y a actuellement aucune offre d'emploi active.</p>
            </div>
        {% endif %}
    </div>

    <style>

            .fo-offre-card__actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .fo-favorite-form {
            margin: 0;
        }

        .fo-favorite-btn {
            width: 46px;
            height: 46px;
            border: none;
            border-radius: 50%;
            background: rgba(239, 68, 68, 0.10);
            color: #dc2626;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            transition: all 0.25s ease;
            cursor: pointer;
        }

        .fo-favorite-btn:hover {
            transform: scale(1.08);
            background: rgba(239, 68, 68, 0.18);
        }
        .fo-candidate-content {
            background: linear-gradient(90deg, #f7eef9 0%, #eef6ff 100%);
        }

        .fo-alert {
            border-radius: 14px;
            padding: 14px 18px;
            margin-bottom: 18px;
            font-weight: 600;
            text-align: left;
            transition: opacity 0.6s ease, transform 0.6s ease;
        }

        .fo-alert-success {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #bbf7d0;
        }

        .fo-alert-danger {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

        .fo-alert-hide {
            opacity: 0;
            transform: translateY(-8px);
        }

        .fo-filter-bar {
            display: grid;
            grid-template-columns: 2fr 1fr 1.5fr 1.3fr auto;
            gap: 12px;
            margin-bottom: 28px;
            background: rgba(255,255,255,0.92);
            padding: 18px;
            border-radius: 18px;
            box-shadow: 0 10px 28px rgba(31, 55, 120, 0.08);
        }

        .fo-filter-bar input,
        .fo-filter-bar select {
            border: 1px solid #dbe4f3;
            border-radius: 12px;
            padding: 12px 14px;
            font-size: 14px;
            background: #fff;
            color: #1f2937;
            width: 100%;
        }

        .fo-filter-bar button {
            border: none;
            border-radius: 12px;
            padding: 12px 18px;
            font-weight: 700;
            background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%);
            color: #fff;
            cursor: pointer;
        }

        .fo-filter-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .fo-reset-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            padding: 12px 18px;
            font-weight: 700;
            background: #e5e7eb;
            color: #1f2937;
            text-decoration: none;
            white-space: nowrap;
        }

        .fo-reset-btn:hover {
            text-decoration: none;
            color: #1f2937;
            background: #d1d5db;
        }

        .fo-offres-page {
            width: 100%;
        }

        .fo-offres-intro {
            margin-bottom: 35px;
        }

        .fo-offres-intro__text {
            max-width: 760px;
            margin: 0 auto;
            color: #5b647d;
            font-size: 17px;
            line-height: 1.8;
        }

        .fo-offre-card {
            height: 100%;
            border-radius: 22px;
            background: rgba(255,255,255,0.92);
            box-shadow: 0 12px 35px rgba(31, 55, 120, 0.10);
            transition: all 0.25s ease;
            overflow: hidden;
            padding: 28px;
            text-align: left;
        }

        .fo-offre-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 18px 40px rgba(31, 55, 120, 0.16);
        }

        .fo-offre-card__top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 22px;
        }

        .fo-offre-card__title {
            font-size: 30px;
            font-weight: 800;
            color: #1f3470;
            line-height: 1.2;
            margin-bottom: 8px;
        }

        .fo-offre-card__company {
            font-size: 15px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            color: #6b7280;
        }

        .fo-offre-card__badge {
            display: inline-block;
            padding: 10px 16px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 700;
            margin-top: 4px;
        }

        .fo-badge-cdi {
            background: rgba(59, 130, 246, 0.12);
            color: #2563eb;
        }

        .fo-badge-cdd {
            background: rgba(245, 158, 11, 0.15);
            color: #d97706;
        }

        .fo-badge-stage {
            background: rgba(16, 185, 129, 0.15);
            color: #059669;
        }

        .fo-badge-other {
            background: rgba(139, 92, 246, 0.14);
            color: #7c3aed;
        }

        .fo-offre-card__meta {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            margin-bottom: 24px;
        }

        .fo-meta-item {
            background: #f8fbff;
            border: 1px solid #e6eefc;
            border-radius: 14px;
            padding: 14px 16px;
        }

        .fo-meta-item__label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            color: #3b82f6;
            margin-bottom: 4px;
        }

        .fo-meta-item__value {
            display: block;
            font-size: 15px;
            font-weight: 600;
            color: #1f2937;
        }

        .fo-offre-card__description {
            color: #5f6780;
            font-size: 15px;
            line-height: 1.8;
            background: #fcfcff;
            border-left: 4px solid #3b82f6;
            padding: 14px 16px;
            border-radius: 10px;
            margin-bottom: 24px;
        }

        .fo-offre-card__actions {
            display: flex;
            justify-content: flex-end;
        }

        .fo-offre-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%);
            color: white;
            border: none;
            border-radius: 999px;
            padding: 11px 24px;
            font-weight: 700;
            box-shadow: 0 10px 20px rgba(37, 99, 235, 0.20);
            transition: 0.25s ease;
            text-decoration: none;
        }

        .fo-offre-btn:hover {
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
            box-shadow: 0 14px 24px rgba(37, 99, 235, 0.28);
        }

        .fo-empty-box {
            max-width: 720px;
            margin: 0 auto;
            background: rgba(255,255,255,0.92);
            border-radius: 22px;
            padding: 50px 30px;
            box-shadow: 0 12px 35px rgba(31, 55, 120, 0.10);
            color: #5b647d;
            text-align: center;
        }

        .fo-empty-box h3 {
            color: #223a7a;
            font-weight: 800;
            margin-bottom: 12px;
        }

        @media (max-width: 991px) {
            .fo-filter-bar {
                grid-template-columns: 1fr;
            }

            .fo-filter-actions {
                flex-direction: column;
            }

            .fo-reset-btn,
            .fo-filter-bar button {
                width: 100%;
            }

            .fo-offre-card__title {
                font-size: 24px;
            }

            .fo-offre-card__meta {
                grid-template-columns: 1fr;
            }
        }

        .fo-stats-row {
            display: flex;
            gap: 16px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }
        .fo-stat-card {
            flex: 1;
            min-width: 140px;
            display: flex;
            align-items: center;
            gap: 14px;
            background: rgba(255,255,255,0.92);
            border-radius: 18px;
            padding: 18px 20px;
            box-shadow: 0 8px 24px rgba(31,55,120,0.08);
        }
        .fo-stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }
        .fo-stat-value {
            display: block;
            font-size: 28px;
            font-weight: 800;
            color: #1f3470;
            line-height: 1;
        }
        .fo-stat-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #6b7280;
            margin-top: 4px;
        }
    </style>

    <script>
        setTimeout(function () {
            document.querySelectorAll('.fo-auto-hide-alert').forEach(function (alertBox) {
                alertBox.classList.add('fo-alert-hide');

                setTimeout(function () {
                    alertBox.remove();
                }, 600);
            });
        }, 10000);
    </script>
{% endblock %}