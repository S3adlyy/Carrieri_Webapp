{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Postuler{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('FrontOffice/css/front-overrides.css') }}?v=20260406-1">
{% endblock %}

{% block candidate_page_heading %}Postuler à une offre{% endblock %}

{% block candidate_breadcrumb %} / <a href="{{ path('app_candidate_offres') }}">Offres</a> / <a href="{{ path('app_candidate_offre_show', {'id': offre.id}) }}">{{ offre.titre }}</a> / Postuler{% endblock %}

{% block candidate_content_container_class %}container-fluid px-3 px-md-4 px-lg-5{% endblock %}

{% block candidate_content_row_class %}row justify-content-center{% endblock %}

{% block candidate_content_col_class %}col-lg-8 col-md-10 col-12{% endblock %}

{% block candidate_content %}
    <div class="w-100 text-start fo-charte-ui">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        {% endfor %}

        <div class="card shadow-sm fo-charte-card">
            <div class="card-header fo-charte-header">
                <h5 class="mb-0">{{ offre.titre }}</h5>
                <small>{{ offre.entreprise }}</small>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-4 mb-3">
                        <div class="bg-light p-3 rounded text-center">
                            <small class="text-muted d-block">📍 Localisation</small>
                            <strong>{{ offre.localisation }}</strong>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="bg-light p-3 rounded text-center">
                            <small class="text-muted d-block">📄 Type de contrat</small>
                            <strong>{{ offre.typeContrat }}</strong>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="bg-light p-3 rounded text-center">
                            <small class="text-muted d-block">⏰ Date d'expiration</small>
                            <strong>{{ offre.dateExpiration ? offre.dateExpiration|date('d/m/Y') : '—' }}</strong>
                        </div>
                    </div>
                </div>

                <form method="post" enctype="multipart/form-data">
                    <div class="form-group mb-4">
                        <label class="font-weight-bold">Motivation</label>
                        <textarea name="motivation" class="form-control" rows="6" placeholder="Écrivez ici votre motivation..." required>{{ motivation|default('') }}</textarea>
                        <small class="text-muted">Minimum 20 caractères, maximum 2000 caractères.</small>
                    </div>

                    <div class="form-group mb-4">
                        <label class="font-weight-bold">CV</label>
                        <div class="custom-file">
                            <input type="file" name="cv" class="custom-file-input" id="cvFile" accept=".pdf,.doc,.docx">
                            <label class="custom-file-label" for="cvFile">Choisir un fichier...</label>
                        </div>
                        <small class="text-muted">Formats autorisés : PDF, DOC, DOCX. Taille max : 2 Mo.</small>
                    </div>

                    <hr>
                    <div class="d-flex justify-content-between flex-wrap">
                        <a href="{{ path('app_candidate_offre_show', {'id': offre.id}) }}" class="btn btn-outline-secondary">
                            Retour
                        </a>
                        <button type="submit" class="btn btn-primary">
                            Envoyer ma candidature
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        document.querySelector('.custom-file-input')?.addEventListener('change', function(e) {
            const fileName = e.target.files[0]?.name || 'Choisir un fichier...';
            const label = e.target.nextElementSibling;
            if (label) label.innerText = fileName;
        });
    </script>
{% endblock %}