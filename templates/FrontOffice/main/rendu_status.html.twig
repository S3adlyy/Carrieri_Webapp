{# templates/FrontOffice/main/rendu_status.html.twig #}
{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Statut de votre soumission - {{ mission.type }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('FrontOffice/css/front-overrides.css') }}?v=20260405-1">
    <style>
        .fo-candidate-content { padding: 0 !important; margin: 0 !important; max-width: 100% !important; }
        .container { max-width: 100% !important; padding: 0 !important; margin: 0 !important; }
        .row { margin: 0 !important; }
        .col-lg-8, .col-md-10 { max-width: 100% !important; flex: 0 0 100% !important; padding: 0 !important; }
        .section-top, .section-top-title { display: none !important; }

        /* Styles spécifiques - intégration avec la charte FXML */
        .fo-charte-ui .s-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 36px 48px;
            display: flex;
            align-items: center;
            gap: 28px;
            flex-wrap: wrap;
            border-bottom: 1px solid rgba(255,255,255,.1);
        }

        .fo-charte-ui .s-status-icon {
            width: 72px;
            height: 72px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            flex-shrink: 0;
        }

        .fo-charte-ui .s-status-icon.accepted { background: rgba(255,255,255,.15); color: #a7f3d0; }
        .fo-charte-ui .s-status-icon.rejected { background: rgba(255,255,255,.15); color: #fecaca; }
        .fo-charte-ui .s-status-icon.pending  { background: rgba(255,255,255,.15); color: #fde68a; }

        .fo-charte-ui .s-header-text h1 {
            font-family: 'Sora', sans-serif;
            font-size: 24px;
            font-weight: 800;
            color: #fff;
            margin: 0 0 6px;
            line-height: 1.2;
        }

        .fo-charte-ui .s-header-text p {
            font-size: 13.5px;
            color: rgba(255,255,255,.7);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .fo-charte-ui .s-header-stats {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            flex-shrink: 0;
        }

        .fo-charte-ui .s-hstat {
            background: rgba(255,255,255,.1);
            border: 1px solid rgba(255,255,255,.2);
            border-radius: 16px;
            padding: 13px 18px;
            min-width: 100px;
            text-align: center;
            backdrop-filter: blur(4px);
            transition: all 0.25s ease;
        }

        .fo-charte-ui .s-hstat:hover {
            background: rgba(255,255,255,.18);
            transform: translateY(-2px);
        }

        .fo-charte-ui .s-hstat-num {
            font-family: 'Sora', sans-serif;
            font-size: 22px;
            font-weight: 800;
            color: #fff;
            line-height: 1;
            margin-bottom: 4px;
        }

        .fo-charte-ui .s-hstat-num.ok     { color: #a7f3d0; }
        .fo-charte-ui .s-hstat-num.bad    { color: #fecaca; }
        .fo-charte-ui .s-hstat-num.neutral{ color: #c7d2fe; }

        .fo-charte-ui .s-hstat-label {
            font-size: 10.5px;
            color: rgba(255,255,255,.6);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .4px;
        }

        /* Breadcrumb */
        .fo-charte-ui .s-nav {
            padding: 14px 48px;
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
        }

        .fo-charte-ui .s-nav a {
            color: #667eea;
            text-decoration: none;
            font-weight: 500;
        }

        .fo-charte-ui .s-nav a:hover {
            text-decoration: underline;
            color: #764ba2;
        }

        /* Cards */
        .fo-charte-ui .s-card {
            background: #fff;
            border: 1px solid rgba(216, 201, 240, 0.65);
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            margin-bottom: 20px;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

        .fo-charte-ui .s-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 18px 40px rgba(94, 84, 142, 0.15);
        }

        .fo-charte-ui .s-card-header {
            padding: 14px 20px;
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            gap: 9px;
            font-size: 13px;
            font-weight: 700;
            color: #1f2937;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .fo-charte-ui .s-card-header i {
            color: #667eea;
            font-size: 13px;
        }

        .fo-charte-ui .s-card-body {
            padding: 20px;
        }

        /* Info rows */
        .fo-charte-ui .s-info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 11px 0;
            border-bottom: 1px solid #f1f5f9;
            gap: 12px;
        }

        .fo-charte-ui .s-info-row:last-child {
            border-bottom: none;
        }

        .fo-charte-ui .s-info-label {
            font-size: 13px;
            color: #64748b;
            font-weight: 500;
            white-space: nowrap;
        }

        .fo-charte-ui .s-info-value {
            font-size: 13.5px;
            color: #1f2937;
            font-weight: 600;
            text-align: right;
        }

        .fo-charte-ui .lang-pill {
            display: inline-block;
            padding: 4px 12px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #fff;
            border-radius: 20px;
            font-size: 11.5px;
            font-weight: 700;
            letter-spacing: .5px;
        }

        .fo-charte-ui .score-pill {
            display: inline-block;
            padding: 4px 14px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 700;
        }

        .fo-charte-ui .score-pill.ok {
            background: #ecfdf5;
            color: #059669;
        }

        .fo-charte-ui .score-pill.bad {
            background: #fef2f2;
            color: #dc2626;
        }

        /* Score progression */
        .fo-charte-ui .s-score-label {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 10px;
            font-size: 13px;
            font-weight: 600;
            color: #1f2937;
        }

        .fo-charte-ui .s-score-pct {
            font-family: 'Sora', sans-serif;
            font-size: 28px;
            font-weight: 800;
            color: #667eea;
        }

        .fo-charte-ui .s-score-track {
            background: #e2e8f0;
            border-radius: 10px;
            height: 10px;
            overflow: visible;
            position: relative;
            margin-bottom: 18px;
        }

        .fo-charte-ui .s-score-fill {
            height: 100%;
            border-radius: 10px;
            transition: width 1s cubic-bezier(.4, 0, .2, 1);
            position: relative;
        }

        .fo-charte-ui .s-score-fill.ok {
            background: linear-gradient(90deg, #34d399, #10b981);
        }

        .fo-charte-ui .s-score-fill.bad {
            background: linear-gradient(90deg, #f87171, #ef4444);
        }

        .fo-charte-ui .s-threshold-line {
            position: absolute;
            top: -5px;
            bottom: -5px;
            width: 2px;
            background: #ef4444;
            border-radius: 2px;
        }

        .fo-charte-ui .s-threshold-label {
            position: absolute;
            top: -22px;
            font-size: 10.5px;
            font-weight: 700;
            color: #ef4444;
            white-space: nowrap;
            transform: translateX(-50%);
        }

        .fo-charte-ui .s-score-compare {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 4px;
        }

        .fo-charte-ui .s-score-compare-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: #64748b;
        }

        .fo-charte-ui .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .fo-charte-ui .dot-score {
            background: #667eea;
        }

        .fo-charte-ui .dot-threshold {
            background: #ef4444;
        }

        /* Status result */
        .fo-charte-ui .s-result-block {
            display: flex;
            align-items: flex-start;
            gap: 16px;
        }

        .fo-charte-ui .s-result-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            flex-shrink: 0;
        }

        .fo-charte-ui .s-result-icon.accepted {
            background: #ecfdf5;
            color: #10b981;
        }

        .fo-charte-ui .s-result-icon.rejected {
            background: #fef2f2;
            color: #ef4444;
        }

        .fo-charte-ui .s-result-icon.pending {
            background: #fffbeb;
            color: #f59e0b;
        }

        .fo-charte-ui .status-banner {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 18px;
            border-radius: 50px;
            font-size: 13.5px;
            font-weight: 700;
            margin-bottom: 14px;
        }

        .fo-charte-ui .banner-accepted {
            background: #ecfdf5;
            color: #059669;
            border: 1px solid #6ee7b7;
        }

        .fo-charte-ui .banner-rejected {
            background: #fef2f2;
            color: #dc2626;
            border: 1px solid #fca5a5;
        }

        .fo-charte-ui .banner-pending {
            background: #fffbeb;
            color: #d97706;
            border: 1px solid #fcd34d;
        }

        /* Feedback */
        .fo-charte-ui .s-feedback-box {
            background: linear-gradient(135deg, #f5f3ff 0%, #eef2ff 100%);
            border: 1px solid #ddd6fe;
            border-radius: 16px;
            padding: 20px 20px 20px 28px;
            position: relative;
        }

        .fo-charte-ui .s-feedback-box::before {
            content: '"';
            position: absolute;
            left: 14px;
            top: 10px;
            font-size: 42px;
            font-weight: 900;
            color: #764ba2;
            opacity: .2;
            line-height: 1;
            font-family: Georgia, serif;
        }

        /* Interview */
        .fo-charte-ui .s-interview-row {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 16px 0;
            border-bottom: 1px solid #e2e8f0;
        }

        .fo-charte-ui .s-interview-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .fo-charte-ui .s-iv-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: #eef2ff;
            color: #667eea;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .fo-charte-ui .btn-join {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 22px;
            width: 100%;
            justify-content: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #fff;
            border-radius: 50px;
            text-decoration: none;
            font-size: 13.5px;
            font-weight: 600;
            transition: all 0.2s ease;
            margin-top: 16px;
            border: none;
        }

        .fo-charte-ui .btn-join:hover {
            transform: scale(1.02);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.35);
            color: #fff;
            text-decoration: none;
        }

        .fo-charte-ui .btn-calendar {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 8px 18px;
            width: 100%;
            justify-content: center;
            background: #fff;
            color: #667eea;
            border: 1.5px solid #667eea;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            margin-top: 12px;
        }

        .fo-charte-ui .btn-calendar:hover {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #fff;
            border-color: transparent;
        }

        /* Test results */
        .fo-charte-ui .s-results-code {
            background: #0f172a;
            padding: 20px;
            overflow-x: auto;
            font-size: 13px;
            line-height: 1.6;
            color: #e2e8f0;
            border-radius: 0 0 24px 24px;
        }

        /* Actions */
        .fo-charte-ui .s-actions {
            grid-column: 1 / -1;
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
            padding: 8px 0 12px;
        }

        .fo-charte-ui .btn-action {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 11px 24px;
            border-radius: 50px;
            font-size: 13.5px;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.2s ease;
            white-space: nowrap;
        }

        .fo-charte-ui .btn-back {
            background: #fff;
            color: #64748b;
            border: 1px solid #e2e8f0;
        }

        .fo-charte-ui .btn-back:hover {
            background: #f8fafc;
            color: #1f2937;
            text-decoration: none;
        }

        .fo-charte-ui .btn-retry {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #fff;
            border: none;
        }

        .fo-charte-ui .btn-retry:hover {
            transform: scale(1.03);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.35);
            color: #fff;
            text-decoration: none;
        }

        .fo-charte-ui .btn-missions {
            background: #fff;
            color: #667eea;
            border: 1.5px solid #667eea;
        }

        .fo-charte-ui .btn-missions:hover {
            background: #eef2ff;
            text-decoration: none;
            color: #667eea;
        }

        /* Responsive */
        @media (max-width: 960px) {
            .fo-charte-ui .s-body { grid-template-columns: 1fr; padding: 24px 28px 36px; }
            .fo-charte-ui .s-header { padding: 26px 28px; }
            .fo-charte-ui .s-nav { padding: 12px 28px; }
        }

        @media (max-width: 640px) {
            .fo-charte-ui .s-header { padding: 22px 18px; gap: 18px; flex-direction: column; align-items: flex-start; }
            .fo-charte-ui .s-body { padding: 18px 16px 32px; }
            .fo-charte-ui .s-nav { padding: 10px 18px; }
            .fo-charte-ui .s-header-stats { width: 100%; }
            .fo-charte-ui .s-hstat { flex: 1; }
            .fo-charte-ui .s-actions { flex-direction: column; }
            .fo-charte-ui .btn-action { justify-content: center; }
        }
    </style>
{% endblock %}

{% block candidate_page_heading %}{% endblock %}
{% block candidate_breadcrumb %}{% endblock %}

{% block candidate_content %}
    {% set isOk      = rendu.score >= mission.scoreMin %}
    {% set statut    = rendu.statut %}
    {% set statusCls = statut == 'accepte' ? 'accepted' : (statut == 'refuse' ? 'rejected' : 'pending') %}

    <div class="w-100 text-start fo-charte-ui">

        {# Header avec gradient FXML #}
        <div class="s-header">
            <div class="s-status-icon {{ statusCls }}">
                {% if statut == 'accepte' %}
                    <i class="fas fa-check-circle"></i>
                {% elseif statut == 'refuse' %}
                    <i class="fas fa-times-circle"></i>
                {% else %}
                    <i class="fas fa-hourglass-half"></i>
                {% endif %}
            </div>

            <div class="s-header-text">
                <h1>
                    {% if statut == 'accepte' %}Soumission acceptée !
                    {% elseif statut == 'refuse' %}Soumission refusée
                    {% else %}Soumission en attente{% endif %}
                </h1>
                <p>
                    <span><i class="fas fa-briefcase"></i> {{ mission.type }}</span>
                    <span style="color:rgba(255,255,255,.3)">·</span>
                    <span><i class="fas fa-calendar-alt"></i> {{ rendu.dateRendu|date('d/m/Y à H:i') }}</span>
                    <span style="color:rgba(255,255,255,.3)">·</span>
                    <span><i class="fas fa-code"></i> {{ rendu.langue|upper }}</span>
                </p>
            </div>

            <div class="s-header-stats">
                <div class="s-hstat">
                    <div class="s-hstat-num {{ isOk ? 'ok' : 'bad' }}">{{ rendu.score|default(0)|round }}%</div>
                    <div class="s-hstat-label">Score obtenu</div>
                </div>
                <div class="s-hstat">
                    <div class="s-hstat-num neutral">{{ mission.scoreMin }}%</div>
                    <div class="s-hstat-label">Score requis</div>
                </div>
            </div>
        </div>

        {# Breadcrumb - CORRECTED #}
        <div class="s-nav">
            <a href="{{ path('app_candidate_mission') }}"><i class="fas fa-th-large"></i> Missions</a>
            <span>›</span>
            <a href="{{ path('app_candidate_mission_detail', {'id': mission.id}) }}">{{ mission.type }}</a>
            <span>›</span>
            <span class="current" style="color:#1f2937;font-weight:600;">Résultat #{{ rendu.id }}</span>
        </div>

        {# Two-column body #}
        <div class="s-body" style="display:grid;grid-template-columns:1fr 1fr;gap:20px;padding:32px 48px 48px;">
            {% if isOk is defined %}{% endif %}

            {# LEFT COLUMN #}
            <div class="s-col-left">

                {# Info mission #}
                <div class="s-card">
                    <div class="s-card-header">
                        <i class="fas fa-info-circle"></i> Informations de la soumission
                    </div>
                    <div class="s-card-body">
                        <div class="s-info-row">
                            <span class="s-info-label">Mission</span>
                            <span class="s-info-value">{{ mission.type }}</span>
                        </div>
                        <div class="s-info-row">
                            <span class="s-info-label">Date de soumission</span>
                            <span class="s-info-value">{{ rendu.dateRendu|date('d/m/Y à H:i') }}</span>
                        </div>
                        <div class="s-info-row">
                            <span class="s-info-label">Langage utilisé</span>
                            <span class="s-info-value"><span class="lang-pill">{{ rendu.langue|upper }}</span></span>
                        </div>
                        <div class="s-info-row">
                            <span class="s-info-label">Score obtenu</span>
                            <span class="s-info-value">
                                <span class="score-pill {{ isOk ? 'ok' : 'bad' }}">
                                    {{ rendu.score|default(0)|round }} / 100
                                </span>
                            </span>
                        </div>
                        <div class="s-info-row">
                            <span class="s-info-label">Score requis</span>
                            <span class="s-info-value">{{ mission.scoreMin }} points</span>
                        </div>
                    </div>
                </div>

                {# Score progression #}
                <div class="s-card">
                    <div class="s-card-header">
                        <i class="fas fa-chart-line"></i> Progression du score
                    </div>
                    <div class="s-card-body">
                        <div class="s-score-label">
                            <span>Votre score</span>
                            <span class="s-score-pct">{{ rendu.score|default(0)|round }}%</span>
                        </div>
                        <div class="s-score-track">
                            <div class="s-score-fill {{ isOk ? 'ok' : 'bad' }}"
                                 style="width: {{ rendu.score|default(0)|round }}%"></div>
                            <div class="s-threshold-line" style="left: {{ mission.scoreMin }}%">
                                <div class="s-threshold-label">{{ mission.scoreMin }}%</div>
                            </div>
                        </div>
                        <div class="s-score-compare">
                            <div class="s-score-compare-item">
                                <div class="dot dot-score"></div>
                                Votre score : {{ rendu.score|default(0)|round }}%
                            </div>
                            <div class="s-score-compare-item">
                                <div class="dot dot-threshold"></div>
                                Seuil requis : {{ mission.scoreMin }}%
                            </div>
                        </div>
                    </div>
                </div>

                {# Statut détaillé #}
                <div class="s-card">
                    <div class="s-card-header">
                        <i class="fas fa-flag-checkered"></i> Décision finale
                    </div>
                    <div class="s-card-body">
                        <div class="s-result-block">
                            <div class="s-result-icon {{ statusCls }}">
                                {% if statut == 'accepte' %}<i class="fas fa-check-circle"></i>
                                {% elseif statut == 'refuse' %}<i class="fas fa-times-circle"></i>
                                {% else %}<i class="fas fa-hourglass-half"></i>{% endif %}
                            </div>
                            <div class="s-result-text">
                                <div class="status-banner banner-{{ statusCls }}">
                                    {% if statut == 'accepte' %}
                                        <i class="fas fa-check-circle"></i> Acceptée
                                    {% elseif statut == 'refuse' %}
                                        <i class="fas fa-times-circle"></i> Refusée
                                    {% else %}
                                        <i class="fas fa-hourglass-half"></i> En attente
                                    {% endif %}
                                </div>
                                <p>
                                    {% if statut == 'accepte' %}
                                        Félicitations ! Votre solution a été acceptée par le recruteur. Consultez les prochaines étapes dans le panneau de droite.
                                    {% elseif statut == 'refuse' %}
                                        Votre solution n'a pas été retenue. N'hésitez pas à revoir votre approche et soumettre une nouvelle version.
                                    {% else %}
                                        Votre soumission est en cours d'examen par le recruteur. Vous serez notifié dès qu'une décision sera prise.
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            {# RIGHT COLUMN #}
            <div class="s-col-right">

                {# Feedback #}
                {% if rendu.feedback %}
                    <div class="s-card">
                        <div class="s-card-header">
                            <i class="fas fa-comment-dots"></i> Feedback du recruteur
                        </div>
                        <div class="s-card-body">
                            <div class="s-feedback-box">
                                <p>{{ rendu.feedback|nl2br }}</p>
                            </div>
                        </div>
                    </div>
                {% endif %}

                {# Entretien #}
                {% if rendu.entretiens|length > 0 %}
                    {% set entretien = rendu.entretiens|first %}
                    <div class="s-card">
                        <div class="s-card-header">
                            <i class="fas fa-calendar-alt"></i> Entretien programmé
                        </div>
                        <div class="s-card-body">
                            <div class="s-interview-row">
                                <div class="s-iv-icon"><i class="fas fa-video"></i></div>
                                <div class="s-iv-info">
                                    <strong>{{ entretien.type }}</strong>
                                    <span>Visioconférence</span>
                                </div>
                            </div>

                            <div class="s-interview-row">
                                <div class="s-iv-icon"><i class="fas fa-calendar-day"></i></div>
                                <div class="s-iv-info">
                                    <strong>{{ entretien.dateEntretien|date('l d/m/Y') }}</strong>
                                    <span>Date de l'entretien</span>
                                </div>
                            </div>

                            <div class="s-interview-row">
                                <div class="s-iv-icon"><i class="fas fa-clock"></i></div>
                                <div class="s-iv-info">
                                    <strong>{{ entretien.dateEntretien|date('H:i') }}</strong>
                                    <span>Heure de début</span>
                                </div>
                            </div>

                            {% if entretien.notes %}
                                <div class="s-notes-box" style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;padding:14px 16px;margin-top:14px;">
                                    <strong><i class="fas fa-sticky-note"></i> Notes du recruteur</strong>
                                    {{ entretien.notes|nl2br }}
                                </div>
                            {% endif %}

                            {% if entretien.lien %}
                                <a href="{{ entretien.lien }}" target="_blank" class="btn-join">
                                    <i class="fas fa-video"></i> Rejoindre la visioconférence
                                </a>
                            {% endif %}

                            <button class="btn-calendar" onclick="addToCalendar({{ entretien.id }})">
                                <i class="fas fa-calendar-plus"></i> Ajouter à mon calendrier
                            </button>
                        </div>
                    </div>
                {% endif %}

                {# Test results #}
                {% if rendu.resultat %}
                    <div class="s-card">
                        <div class="s-card-header">
                            <i class="fas fa-vial"></i> Résultats des tests
                        </div>
                        <div class="s-results-code">
                            {{ rendu.resultat|raw }}
                        </div>
                    </div>
                {% endif %}

                {# Placeholder if right column is empty #}
                {% if not rendu.feedback and rendu.entretiens|length == 0 and not rendu.resultat %}
                    <div class="s-card">
                        <div class="s-card-body" style="text-align:center;padding:40px 20px;color:#64748b;">
                            <i class="fas fa-inbox" style="font-size:32px;margin-bottom:12px;display:block;color:#cbd5e1;"></i>
                            <p style="margin:0;font-size:14px;">Aucun feedback ni entretien pour le moment.</p>
                        </div>
                    </div>
                {% endif %}

            </div>

            {# Actions - CORRECTED #}
            <div class="s-actions" style="grid-column:1/-1;display:flex;gap:12px;justify-content:center;flex-wrap:wrap;padding:8px 0 12px;">
                <a href="{{ path('app_candidate_mission_detail', {'id': mission.id}) }}" class="btn-action btn-back">
                    <i class="fas fa-arrow-left"></i> Retour à la mission
                </a>
                <a href="{{ path('app_candidate_rendu_mission', {'id': mission.id}) }}" class="btn-action btn-retry">
                    <i class="fas fa-redo-alt"></i> Nouvelle version
                </a>
                <a href="{{ path('app_candidate_mission') }}" class="btn-action btn-missions">
                    <i class="fas fa-th-large"></i> Toutes les missions
                </a>
            </div>

        </div>
    </div>

    <script>
        function addToCalendar(entretienId) {
            fetch(`/candidat/entretien/${entretienId}/ics`)
                .then(r => r.blob())
                .then(blob => {
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url; a.download = 'entretien.ics';
                    document.body.appendChild(a); a.click();
                    document.body.removeChild(a);
                    window.URL.revokeObjectURL(url);
                })
                .catch(() => alert('Impossible de générer le fichier calendrier'));
        }
    </script>

{% endblock %}