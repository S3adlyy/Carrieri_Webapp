{# templates/FrontOffice/main/rendu_status.html.twig #}
{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Statut de votre soumission - {{ mission.type }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .fo-candidate-content { padding: 0 !important; margin: 0 !important; max-width: 100% !important; }
        .container { max-width: 100% !important; padding: 0 !important; margin: 0 !important; }
        .row { margin: 0 !important; }
        .col-lg-8, .col-md-10 { max-width: 100% !important; flex: 0 0 100% !important; padding: 0 !important; }
        .section-top, .section-top-title { display: none !important; }
    </style>
{% endblock %}

{% block candidate_page_heading %}{% endblock %}
{% block candidate_breadcrumb %}{% endblock %}

{% block candidate_content %}

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap');

        :root {
            --indigo:       #4f46e5;
            --indigo-light: #6366f1;
            --indigo-dark:  #3730a3;
            --violet:       #7c3aed;
            --success:      #10b981;
            --success-bg:   #ecfdf5;
            --success-border:#6ee7b7;
            --danger:       #ef4444;
            --danger-bg:    #fef2f2;
            --danger-border:#fca5a5;
            --warning:      #f59e0b;
            --warning-bg:   #fffbeb;
            --warning-border:#fcd34d;
            --surface:      #ffffff;
            --bg:           #f1f5f9;
            --text-primary: #0f172a;
            --text-secondary:#64748b;
            --border:       #e2e8f0;
            --radius-lg:    16px;
            --radius-md:    10px;
            --radius-sm:    6px;
            --shadow-sm:    0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
            --shadow-md:    0 4px 16px rgba(0,0,0,.08);
            --shadow-lg:    0 12px 40px rgba(79,70,229,.14);
        }

        /* ── Page ── */
        .s-page {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            min-height: 100vh;
            color: var(--text-primary);
        }

        /* ── Header banner ── */
        .s-header {
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 60%, #312e81 100%);
            padding: 36px 48px;
            display: flex;
            align-items: center;
            gap: 28px;
            flex-wrap: wrap;
        }

        /* Big status icon */
        .s-status-icon {
            width: 72px; height: 72px;
            border-radius: 20px;
            display: flex; align-items: center; justify-content: center;
            font-size: 30px;
            flex-shrink: 0;
        }
        .s-status-icon.accepted { background: rgba(16,185,129,.18); color: #6ee7b7; }
        .s-status-icon.rejected { background: rgba(239,68,68,.18);  color: #fca5a5; }
        .s-status-icon.pending  { background: rgba(245,158,11,.18); color: #fcd34d; }

        .s-header-text { flex: 1; min-width: 0; }
        .s-header-text h1 {
            font-family: 'Sora', sans-serif;
            font-size: 24px; font-weight: 800;
            color: #fff; margin: 0 0 6px;
            line-height: 1.2;
        }
        .s-header-text p {
            font-size: 13.5px; color: rgba(255,255,255,.55); margin: 0;
            display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        }
        .s-header-text p span {
            display: inline-flex; align-items: center; gap: 5px;
        }

        /* Header mini-stats */
        .s-header-stats {
            display: flex; gap: 10px; flex-wrap: wrap; flex-shrink: 0;
        }
        .s-hstat {
            background: rgba(255,255,255,.07);
            border: 1px solid rgba(255,255,255,.1);
            border-radius: var(--radius-md);
            padding: 13px 18px;
            min-width: 100px;
            text-align: center;
        }
        .s-hstat-num {
            font-family: 'Sora', sans-serif;
            font-size: 22px; font-weight: 800;
            color: #fff; line-height: 1; margin-bottom: 4px;
        }
        .s-hstat-num.ok     { color: #6ee7b7; }
        .s-hstat-num.bad    { color: #fca5a5; }
        .s-hstat-num.neutral{ color: #a5b4fc; }
        .s-hstat-label {
            font-size: 10.5px; color: rgba(255,255,255,.5);
            font-weight: 500; text-transform: uppercase; letter-spacing: .4px;
        }

        /* ── Breadcrumb nav ── */
        .s-nav {
            padding: 14px 48px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: 8px;
            font-size: 13px;
        }
        .s-nav a {
            color: var(--indigo); text-decoration: none; font-weight: 500;
        }
        .s-nav a:hover { text-decoration: underline; }
        .s-nav span { color: var(--text-secondary); }
        .s-nav .current { color: var(--text-primary); font-weight: 600; }

        /* ── Body ── */
        .s-body {
            padding: 32px 48px 48px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            align-items: start;
        }

        /* ── Cards ── */
        .s-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            margin-bottom: 20px;
            animation: fadeUp .4s ease both;
        }
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(14px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .s-card-header {
            padding: 14px 20px;
            background: #f8fafc;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: 9px;
            font-size: 13px; font-weight: 700;
            color: var(--text-primary);
            text-transform: uppercase; letter-spacing: .5px;
        }
        .s-card-header i { color: var(--indigo); font-size: 13px; }

        .s-card-body { padding: 20px; }
        .s-card-body.p0 { padding: 0; }

        /* ── Info rows ── */
        .s-info-row {
            display: flex; justify-content: space-between;
            align-items: center;
            padding: 11px 0;
            border-bottom: 1px solid #f1f5f9;
            gap: 12px;
        }
        .s-info-row:last-child { border-bottom: none; }
        .s-info-label {
            font-size: 13px; color: var(--text-secondary); font-weight: 500;
            white-space: nowrap;
        }
        .s-info-value {
            font-size: 13.5px; color: var(--text-primary); font-weight: 600;
            text-align: right;
        }

        .lang-pill {
            display: inline-block;
            padding: 3px 10px;
            background: #eef2ff; color: var(--indigo);
            border-radius: 20px; font-size: 11.5px; font-weight: 700; letter-spacing: .5px;
        }
        .score-pill {
            display: inline-block; padding: 3px 12px; border-radius: 20px;
            font-size: 13px; font-weight: 700;
        }
        .score-pill.ok  { background: var(--success-bg); color: #059669; }
        .score-pill.bad { background: var(--danger-bg);  color: #dc2626; }

        /* ── Score bar card ── */
        .s-score-label {
            display: flex; justify-content: space-between;
            align-items: baseline; margin-bottom: 10px;
            font-size: 13px; font-weight: 600; color: var(--text-primary);
        }
        .s-score-pct {
            font-family: 'Sora', sans-serif;
            font-size: 28px; font-weight: 800; color: var(--indigo);
        }
        .s-score-track {
            background: var(--border); border-radius: 10px;
            height: 10px; overflow: visible; position: relative; margin-bottom: 18px;
        }
        .s-score-fill {
            height: 100%; border-radius: 10px;
            transition: width 1s cubic-bezier(.4,0,.2,1);
            position: relative;
        }
        .s-score-fill.ok  { background: linear-gradient(90deg, #34d399, #10b981); }
        .s-score-fill.bad { background: linear-gradient(90deg, #f87171, #ef4444); }
        .s-threshold-line {
            position: absolute; top: -5px; bottom: -5px;
            width: 2px; background: var(--danger);
            border-radius: 2px;
        }
        .s-threshold-label {
            position: absolute; top: -22px;
            font-size: 10.5px; font-weight: 700; color: var(--danger);
            white-space: nowrap; transform: translateX(-50%);
        }
        .s-score-compare {
            display: flex; gap: 12px; flex-wrap: wrap; margin-top: 4px;
        }
        .s-score-compare-item {
            display: flex; align-items: center; gap: 6px;
            font-size: 12px; color: var(--text-secondary);
        }
        .dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
        .dot-score   { background: var(--indigo); }
        .dot-threshold { background: var(--danger); }

        /* ── Status result card ── */
        .s-result-block {
            display: flex; align-items: flex-start; gap: 16px;
        }
        .s-result-icon {
            width: 52px; height: 52px; border-radius: var(--radius-md);
            display: flex; align-items: center; justify-content: center;
            font-size: 22px; flex-shrink: 0;
        }
        .s-result-icon.accepted { background: var(--success-bg); color: var(--success); }
        .s-result-icon.rejected { background: var(--danger-bg);  color: var(--danger); }
        .s-result-icon.pending  { background: var(--warning-bg); color: var(--warning); }
        .s-result-text h3 {
            font-family: 'Sora', sans-serif;
            font-size: 17px; font-weight: 700; margin: 0 0 6px;
        }
        .s-result-text h3.accepted { color: var(--success); }
        .s-result-text h3.rejected { color: var(--danger);  }
        .s-result-text h3.pending  { color: var(--warning); }
        .s-result-text p {
            font-size: 13.5px; color: var(--text-secondary);
            margin: 0; line-height: 1.55;
        }

        /* Status pill banner */
        .status-banner {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 8px 18px; border-radius: 50px;
            font-size: 13.5px; font-weight: 700; margin-bottom: 14px;
        }
        .banner-accepted { background: var(--success-bg); color: #059669; border: 1px solid var(--success-border); }
        .banner-rejected { background: var(--danger-bg);  color: #dc2626; border: 1px solid var(--danger-border); }
        .banner-pending  { background: var(--warning-bg); color: #d97706; border: 1px solid var(--warning-border); }

        /* ── Feedback card ── */
        .s-feedback-box {
            background: linear-gradient(135deg, #f5f3ff 0%, #eef2ff 100%);
            border: 1px solid #ddd6fe;
            border-radius: var(--radius-md);
            padding: 20px 20px 20px 28px;
            position: relative;
        }
        .s-feedback-box::before {
            content: '"';
            position: absolute; left: 14px; top: 10px;
            font-size: 42px; font-weight: 900; color: var(--violet);
            opacity: .2; line-height: 1; font-family: Georgia, serif;
        }
        .s-feedback-box p {
            margin: 0; color: var(--text-primary);
            font-size: 14px; line-height: 1.65;
        }

        /* ── Interview card ── */
        .s-interview-row {
            display: flex; align-items: center; gap: 16px;
            padding: 16px 0; border-bottom: 1px solid var(--border);
        }
        .s-interview-row:last-child { border-bottom: none; padding-bottom: 0; }
        .s-iv-icon {
            width: 40px; height: 40px; border-radius: var(--radius-sm);
            background: #eef2ff; color: var(--indigo);
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; flex-shrink: 0;
        }
        .s-iv-info { flex: 1; min-width: 0; }
        .s-iv-info strong { font-size: 14px; color: var(--text-primary); display: block; margin-bottom: 2px; }
        .s-iv-info span   { font-size: 12.5px; color: var(--text-secondary); }

        .btn-join {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 10px 22px; width: 100%; justify-content: center;
            background: var(--indigo); color: #fff;
            border-radius: 50px; text-decoration: none;
            font-size: 13.5px; font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            transition: background .2s, box-shadow .2s, transform .2s;
            margin-top: 16px;
        }
        .btn-join:hover {
            background: var(--indigo-dark);
            box-shadow: var(--shadow-lg);
            transform: scale(1.02);
            color: #fff; text-decoration: none;
        }

        .s-notes-box {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 14px 16px; margin-top: 14px;
            font-size: 13px; color: var(--text-secondary); line-height: 1.6;
        }
        .s-notes-box strong { color: var(--text-primary); display: block; margin-bottom: 6px; font-size: 12px; text-transform: uppercase; letter-spacing: .4px; }

        .btn-calendar {
            display: inline-flex; align-items: center; gap: 7px;
            padding: 8px 18px; width: 100%; justify-content: center;
            background: var(--surface); color: var(--indigo);
            border: 1.5px solid var(--indigo);
            border-radius: 50px; font-size: 13px; font-weight: 600;
            cursor: pointer; transition: all .2s;
            font-family: 'DM Sans', sans-serif;
            margin-top: 12px;
        }
        .btn-calendar:hover { background: var(--indigo); color: #fff; }

        /* ── Test results card ── */
        .s-results-code {
            background: #0f172a;
            padding: 20px;
            overflow-x: auto;
            font-size: 13px;
            line-height: 1.6;
            color: #e2e8f0;
            border-radius: 0 0 var(--radius-lg) var(--radius-lg);
        }

        /* ── Actions bar ── */
        .s-actions {
            grid-column: 1 / -1;
            display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
            padding: 8px 0 12px;
        }

        .btn-action {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 11px 24px; border-radius: 50px;
            font-size: 13.5px; font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            text-decoration: none; cursor: pointer;
            border: none; transition: all .2s;
            white-space: nowrap;
        }
        .btn-back {
            background: var(--surface); color: var(--text-secondary);
            border: 1px solid var(--border);
        }
        .btn-back:hover { background: var(--bg); color: var(--text-primary); text-decoration: none; }

        .btn-retry {
            background: var(--indigo); color: #fff;
        }
        .btn-retry:hover {
            background: var(--indigo-dark);
            box-shadow: 0 6px 20px rgba(79,70,229,.35);
            transform: scale(1.03); color: #fff; text-decoration: none;
        }

        .btn-missions {
            background: var(--surface); color: var(--indigo);
            border: 1.5px solid var(--indigo);
        }
        .btn-missions:hover { background: #eef2ff; text-decoration: none; color: var(--indigo); }

        /* ── Responsive ── */
        @media (max-width: 960px) {
            .s-body   { grid-template-columns: 1fr; padding: 24px 28px 36px; }
            .s-header { padding: 26px 28px; }
            .s-nav    { padding: 12px 28px; }
            .s-actions { grid-column: 1; }
        }
        @media (max-width: 640px) {
            .s-header { padding: 22px 18px; gap: 18px; }
            .s-body   { padding: 18px 16px 32px; gap: 0; }
            .s-nav    { padding: 10px 18px; }
            .s-header-stats { width: 100%; }
            .s-hstat { flex: 1; }
            .s-actions { flex-direction: column; }
            .btn-action { justify-content: center; }
        }
    </style>

    {% set isOk      = rendu.score >= mission.scoreMin %}
    {% set statut    = rendu.statut %}
    {% set statusCls = statut == 'accepte' ? 'accepted' : (statut == 'refuse' ? 'rejected' : 'pending') %}

    <div class="s-page">

        {# ── Header ── #}
        <div class="s-header">
            <div class="s-status-icon {{ statusCls }}">
                {% if statut == 'accepte' %}
                    <i class="fas fa-check-circle"></i>
                {% elseif statut == 'refuse' %}
                    <i class="fas fa-times-circle"></i>
                {% else %}
                    <i class="fas fa-hourglass-half"></i>
                {% endif %}
            </div>

            <div class="s-header-text">
                <h1>
                    {% if statut == 'accepte' %}Soumission acceptée !
                    {% elseif statut == 'refuse' %}Soumission refusée
                    {% else %}Soumission en attente{% endif %}
                </h1>
                <p>
                    <span><i class="fas fa-briefcase"></i> {{ mission.type }}</span>
                    <span style="color:rgba(255,255,255,.25)">·</span>
                    <span><i class="fas fa-calendar-alt"></i> {{ rendu.dateRendu|date('d/m/Y à H:i') }}</span>
                    <span style="color:rgba(255,255,255,.25)">·</span>
                    <span><i class="fas fa-code"></i> {{ rendu.langue|upper }}</span>
                </p>
            </div>

            <div class="s-header-stats">
                <div class="s-hstat">
                    <div class="s-hstat-num {{ isOk ? 'ok' : 'bad' }}">{{ rendu.score|default(0)|round }}%</div>
                    <div class="s-hstat-label">Score obtenu</div>
                </div>
                <div class="s-hstat">
                    <div class="s-hstat-num neutral">{{ mission.scoreMin }}%</div>
                    <div class="s-hstat-label">Score requis</div>
                </div>
            </div>
        </div>

        {# ── Breadcrumb nav ── #}
        <div class="s-nav">
            <a href="{{ path('app_candidate_mission') }}"><i class="fas fa-th-large"></i> Missions</a>
            <span>›</span>
            <a href="{{ path('app_candidate_mission_show', {'id': mission.id}) }}">{{ mission.type }}</a>
            <span>›</span>
            <span class="current">Résultat #{{ rendu.id }}</span>
        </div>

        {# ── Two-column body ── #}
        <div class="s-body">

            {# ── LEFT COLUMN ── #}
            <div class="s-col-left">

                {# Info mission #}
                <div class="s-card" style="animation-delay:.05s">
                    <div class="s-card-header">
                        <i class="fas fa-info-circle"></i> Informations de la soumission
                    </div>
                    <div class="s-card-body">
                        <div class="s-info-row">
                            <span class="s-info-label">Mission</span>
                            <span class="s-info-value">{{ mission.type }}</span>
                        </div>
                        <div class="s-info-row">
                            <span class="s-info-label">Date de soumission</span>
                            <span class="s-info-value">{{ rendu.dateRendu|date('d/m/Y à H:i') }}</span>
                        </div>
                        <div class="s-info-row">
                            <span class="s-info-label">Langage utilisé</span>
                            <span class="s-info-value"><span class="lang-pill">{{ rendu.langue|upper }}</span></span>
                        </div>
                        <div class="s-info-row">
                            <span class="s-info-label">Score obtenu</span>
                            <span class="s-info-value">
                            <span class="score-pill {{ isOk ? 'ok' : 'bad' }}">
                                {{ rendu.score|default(0)|round }} / 100
                            </span>
                        </span>
                        </div>
                        <div class="s-info-row">
                            <span class="s-info-label">Score requis</span>
                            <span class="s-info-value">{{ mission.scoreMin }} points</span>
                        </div>
                    </div>
                </div>

                {# Score progression #}
                <div class="s-card" style="animation-delay:.1s">
                    <div class="s-card-header">
                        <i class="fas fa-chart-line"></i> Progression du score
                    </div>
                    <div class="s-card-body">
                        <div class="s-score-label">
                            <span>Votre score</span>
                            <span class="s-score-pct">{{ rendu.score|default(0)|round }}%</span>
                        </div>
                        <div class="s-score-track">
                            <div class="s-score-fill {{ isOk ? 'ok' : 'bad' }}"
                                 style="width: {{ rendu.score|default(0)|round }}%"></div>
                            <div class="s-threshold-line" style="left: {{ mission.scoreMin }}%">
                                <div class="s-threshold-label">{{ mission.scoreMin }}%</div>
                            </div>
                        </div>
                        <div class="s-score-compare">
                            <div class="s-score-compare-item">
                                <div class="dot {{ isOk ? 'dot-score' : '' }}" style="{{ isOk ? '' : 'background:var(--danger)' }}"></div>
                                Votre score : {{ rendu.score|default(0)|round }}%
                            </div>
                            <div class="s-score-compare-item">
                                <div class="dot dot-threshold"></div>
                                Seuil requis : {{ mission.scoreMin }}%
                            </div>
                        </div>
                    </div>
                </div>

                {# Statut détaillé #}
                <div class="s-card" style="animation-delay:.15s">
                    <div class="s-card-header">
                        <i class="fas fa-flag-checkered"></i> Décision finale
                    </div>
                    <div class="s-card-body">
                        <div class="s-result-block">
                            <div class="s-result-icon {{ statusCls }}">
                                {% if statut == 'accepte' %}<i class="fas fa-check-circle"></i>
                                {% elseif statut == 'refuse' %}<i class="fas fa-times-circle"></i>
                                {% else %}<i class="fas fa-hourglass-half"></i>{% endif %}
                            </div>
                            <div class="s-result-text">
                                <div class="status-banner banner-{{ statusCls }}">
                                    {% if statut == 'accepte' %}
                                        <i class="fas fa-check-circle"></i> Acceptée
                                    {% elseif statut == 'refuse' %}
                                        <i class="fas fa-times-circle"></i> Refusée
                                    {% else %}
                                        <i class="fas fa-hourglass-half"></i> En attente
                                    {% endif %}
                                </div>
                                <p>
                                    {% if statut == 'accepte' %}
                                        Félicitations ! Votre solution a été acceptée par le recruteur. Consultez les prochaines étapes dans le panneau de droite.
                                    {% elseif statut == 'refuse' %}
                                        Votre solution n'a pas été retenue. N'hésitez pas à revoir votre approche et soumettre une nouvelle version.
                                    {% else %}
                                        Votre soumission est en cours d'examen par le recruteur. Vous serez notifié dès qu'une décision sera prise.
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>{# end left col #}

            {# ── RIGHT COLUMN ── #}
            <div class="s-col-right">

                {# Feedback #}
                {% if rendu.feedback %}
                    <div class="s-card" style="animation-delay:.2s">
                        <div class="s-card-header">
                            <i class="fas fa-comment-dots"></i> Feedback du recruteur
                        </div>
                        <div class="s-card-body">
                            <div class="s-feedback-box">
                                <p>{{ rendu.feedback|nl2br }}</p>
                            </div>
                        </div>
                    </div>
                {% endif %}

                {# Entretien #}
                {% if rendu.entretiens|length > 0 %}
                    {% set entretien = rendu.entretiens|first %}
                    <div class="s-card" style="animation-delay:.25s">
                        <div class="s-card-header">
                            <i class="fas fa-calendar-alt"></i> Entretien programmé
                        </div>
                        <div class="s-card-body">

                            <div class="s-interview-row">
                                <div class="s-iv-icon"><i class="fas fa-video"></i></div>
                                <div class="s-iv-info">
                                    <strong>{{ entretien.type }}</strong>
                                    <span>Visioconférence</span>
                                </div>
                            </div>

                            <div class="s-interview-row">
                                <div class="s-iv-icon"><i class="fas fa-calendar-day"></i></div>
                                <div class="s-iv-info">
                                    <strong>{{ entretien.dateEntretien|date('l d/m/Y') }}</strong>
                                    <span>Date de l'entretien</span>
                                </div>
                            </div>

                            <div class="s-interview-row">
                                <div class="s-iv-icon"><i class="fas fa-clock"></i></div>
                                <div class="s-iv-info">
                                    <strong>{{ entretien.dateEntretien|date('H:i') }}</strong>
                                    <span>Heure de début</span>
                                </div>
                            </div>

                            {% if entretien.notes %}
                                <div class="s-notes-box">
                                    <strong><i class="fas fa-sticky-note"></i> Notes du recruteur</strong>
                                    {{ entretien.notes|nl2br }}
                                </div>
                            {% endif %}

                            {% if entretien.lien %}
                                <a href="{{ entretien.lien }}" target="_blank" class="btn-join">
                                    <i class="fas fa-video"></i> Rejoindre la visioconférence
                                </a>
                            {% endif %}

                            <button class="btn-calendar" onclick="addToCalendar({{ entretien.id }})">
                                <i class="fas fa-calendar-plus"></i> Ajouter à mon calendrier
                            </button>

                        </div>
                    </div>
                {% endif %}

                {# Test results #}
                {% if rendu.resultat %}
                    <div class="s-card" style="animation-delay:.3s">
                        <div class="s-card-header">
                            <i class="fas fa-vial"></i> Résultats des tests
                        </div>
                        <div class="s-results-code">
                            {{ rendu.resultat|raw }}
                        </div>
                    </div>
                {% endif %}

                {# Placeholder if right column is empty #}
                {% if not rendu.feedback and rendu.entretiens|length == 0 and not rendu.resultat %}
                    <div class="s-card" style="animation-delay:.2s">
                        <div class="s-card-body" style="text-align:center;padding:40px 20px;color:var(--text-secondary);">
                            <i class="fas fa-inbox" style="font-size:32px;margin-bottom:12px;display:block;color:#cbd5e1;"></i>
                            <p style="margin:0;font-size:14px;">Aucun feedback ni entretien pour le moment.</p>
                        </div>
                    </div>
                {% endif %}

            </div>{# end right col #}

            {# ── Actions ── #}
            <div class="s-actions">
                <a href="{{ path('app_candidate_mission_show', {'id': mission.id}) }}" class="btn-action btn-back">
                    <i class="fas fa-arrow-left"></i> Retour à la mission
                </a>
                <a href="{{ path('app_candidate_rendu_mission', {'id': mission.id}) }}" class="btn-action btn-retry">
                    <i class="fas fa-redo-alt"></i> Nouvelle version
                </a>
                <a href="{{ path('app_candidate_mission') }}" class="btn-action btn-missions">
                    <i class="fas fa-th-large"></i> Toutes les missions
                </a>
            </div>

        </div>{# end s-body #}
    </div>

    <script>
        function addToCalendar(entretienId) {
            fetch(`/candidat/entretien/${entretienId}/ics`)
                .then(r => r.blob())
                .then(blob => {
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url; a.download = 'entretien.ics';
                    document.body.appendChild(a); a.click();
                    document.body.removeChild(a);
                    window.URL.revokeObjectURL(url);
                })
                .catch(() => alert('Impossible de générer le fichier calendrier'));
        }
    </script>

{% endblock %}
