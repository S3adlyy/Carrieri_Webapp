{% extends 'BackOffice/base.html.twig' %}

{% block title %}Modifier le traitement #{{ traitement.id }}{% endblock %}

{% block page_title %}Modifier le traitement{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_dashboard_traitement_reclamations') }}">Réclamations</a></li>
    <li class="breadcrumb-item"><a href="{{ path('app_dashboard_traitement_index') }}">Mes traitements</a></li>
    <li class="breadcrumb-item active">Modifier #{{ traitement.id }}</li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header bg-warning text-white">
            <h3 class="card-title">Modifier le traitement #{{ traitement.id }}</h3>
        </div>
        <div class="card-body">
            <div class="alert alert-info mb-3">
                <strong>Réclamation concernée :</strong> {{ traitement.reclamation ? traitement.reclamation.objet : '—' }}
            </div>
            
            {{ form_start(form) }}
                <div class="row">
                    <div class="col-12">
                        {{ form_label(form.reponseAdmin) }}
                        {{ form_widget(form.reponseAdmin) }}
                        {{ form_errors(form.reponseAdmin) }}
                        <small class="text-muted">Minimum 10 caractères</small>
                    </div>
                    <div class="col-12 mt-3">
                        {{ form_label(form.statutFinal) }}
                        {{ form_widget(form.statutFinal) }}
                        {{ form_errors(form.statutFinal) }}
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-save"></i> Mettre à jour
                    </button>
                    <a href="{{ path('app_dashboard_traitement_index') }}" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Annuler
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}