{% extends 'BackOffice/base.html.twig' %}

{% block title %}Réclamations à traiter{% endblock %}

{% block page_title %}Réclamations à traiter{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item active">Réclamations</li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Liste des réclamations en attente</h3>
            <div class="card-tools">
                <a href="{{ path('app_dashboard_traitement_index') }}" class="btn btn-info btn-sm">
                    <i class="fas fa-list"></i> Mes traitements
                </a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Objet</th>
                            <th>Cours</th>
                            <th>Candidat</th>
                            <th>Description</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for r in reclamations %}
                            <tr>
                                <td>{{ r.id }}</td>
                                <td>{{ r.objet|slice(0, 50) }}...\n                                <td>{{ r.cours ? r.cours.titre : '—' }}</td>
                                <td>{{ r.user ? r.user.firstName ~ ' ' ~ r.user.lastName : '—' }}</td>
                                <td>{{ r.description|slice(0, 80) }}...\n                                <td>{{ r.dateCreation ? r.dateCreation|date('d/m/Y H:i') : '—' }}</td>
                                <td>
                                    <a href="{{ path('app_dashboard_traitement_traiter', {'id': r.id}) }}" class="btn btn-sm btn-primary">
                                        <i class="fas fa-check"></i> Traiter
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-center text-muted">Aucune réclamation en attente.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}