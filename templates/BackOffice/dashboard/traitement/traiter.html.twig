{% extends 'BackOffice/base.html.twig' %}

{% block title %}Traiter la réclamation{% endblock %}

{% block page_title %}Traiter la réclamation #{{ reclamation.id }}{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_dashboard_traitement_reclamations') }}">Réclamations</a></li>
    <li class="breadcrumb-item active">Traiter</li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h3 class="card-title">Détail de la réclamation</h3>
            {% if urgency_score is defined %}
                {% if urgency_score >= 80 %}
                    {% set badge_class = 'danger' %}
                    {% set icon = 'fa-skull-crosswalk' %}
                {% elseif urgency_score >= 60 %}
                    {% set badge_class = 'warning' %}
                    {% set icon = 'fa-arrow-up' %}
                {% elseif urgency_score >= 40 %}
                    {% set badge_class = 'info' %}
                    {% set icon = 'fa-minus' %}
                {% elseif urgency_score >= 20 %}
                    {% set badge_class = 'secondary' %}
                    {% set icon = 'fa-arrow-down' %}
                {% else %}
                    {% set badge_class = 'light' %}
                    {% set icon = 'fa-check' %}
                {% endif %}
                <span class="float-right badge badge-{{ badge_class }} p-2">
                    <i class="fas {{ icon }}"></i>
                    Niveau d'urgence : {{ urgency_level }} ({{ urgency_score }}%)
                </span>
            {% endif %}
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <tr>
                    <th style="width: 150px;">ID</th>
                    <td>{{ reclamation.id }}</td>
                </tr>
                <tr>
                    <th>Objet</th>
                    <td>{{ reclamation.objet }}</td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>{{ reclamation.description }}</td>
                </tr>
                <tr>
                    <th>Cours</th>
                    <td>{{ reclamation.cours ? reclamation.cours.titre : '—' }}</td>
                </tr>
                <tr>
                    <th>Candidat</th>
                    <td>{{ reclamation.user ? reclamation.user.firstName ~ ' ' ~ reclamation.user.lastName : '—' }}</td>
                </tr>
                <tr>
                    <th>Email candidat</th>
                    <td>{{ reclamation.email }}</td>
                </tr>
                <tr>
                    <th>Date de création</th>
                    <td>{{ reclamation.dateCreation ? reclamation.dateCreation|date('d/m/Y H:i') : '—' }}</td>
                </tr>
            </table>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-success text-white">
            <h3 class="card-title">Formulaire de traitement</h3>
        </div>
        <div class="card-body">
            {{ form_start(form) }}
                <div class="row">
                    <div class="col-12">
                        {{ form_label(form.emailDestinataire) }}
                        {{ form_widget(form.emailDestinataire) }}
                        {{ form_errors(form.emailDestinataire) }}
                        <small class="text-muted">Email du candidat qui recevra la réponse</small>
                    </div>
                    <div class="col-12 mt-3">
                        {{ form_label(form.reponseAdmin) }}
                        {{ form_widget(form.reponseAdmin) }}
                        {{ form_errors(form.reponseAdmin) }}
                        <small class="text-muted">Minimum 10 caractères</small>
                    </div>
                    <div class="col-12 mt-3">
                        {{ form_label(form.statutFinal) }}
                        {{ form_widget(form.statutFinal) }}
                        {{ form_errors(form.statutFinal) }}
                    </div>
                    
                    <!-- Section correction IA -->
                    <div class="col-12 mt-4">
                        <div class="alert alert-warning">
                            <strong>🤖 Intelligence Artificielle</strong><br>
                            L'IA a détecté un niveau d'urgence : <strong>{{ urgency_level }} ({{ urgency_score }}%)</strong>
                            <hr>
                            <div class="form-check">
                                <input type="checkbox" name="corriger_ia" id="corriger_ia" class="form-check-input" value="1">
                                <label class="form-check-label" for="corriger_ia">
                                    ❌ Cette classification est incorrecte
                                </label>
                            </div>
                            <div class="form-group mt-2" id="div_niveau_reel" style="display: none;">
                                <label>Quel est le niveau d'urgence réel ?</label>
                                <select name="niveau_reel" class="form-control">
                                    <option value="90">🔥 Critique (90%) - Urgence absolue</option>
                                    <option value="70">⚠️ Élevée (70%) - À traiter rapidement</option>
                                    <option value="50">📌 Moyenne (50%) - Normal</option>
                                    <option value="30">✅ Faible (30%) - Peu urgent</option>
                                    <option value="10">💚 Minimale (10%) - Non urgent</option>
                                </select>
                                <small class="text-muted">Votre correction permettra d'améliorer l'IA</small>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="alert alert-info mt-3">
                    <i class="fas fa-info-circle"></i> 
                    Une fois traitée, la réclamation sera marquée comme "Traité" et un email sera envoyé à l'adresse saisie.
                </div>
                
                <div class="mt-3">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Traiter la réclamation
                    </button>
                    <a href="{{ path('app_dashboard_traitement_reclamations') }}" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Annuler
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var checkbox = document.getElementById('corriger_ia');
            var divNiveau = document.getElementById('div_niveau_reel');
            
            if (checkbox) {
                checkbox.addEventListener('change', function() {
                    divNiveau.style.display = this.checked ? 'block' : 'none';
                });
            }
        });
    </script>
{% endblock %}