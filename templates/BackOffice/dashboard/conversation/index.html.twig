{% extends 'FrontOffice/main/base_candidate.html.twig' %}

{% block title %}Conversation - Carrieri{% endblock %}

{% block candidate_page_heading %}Conversation{% endblock %}

{% block candidate_breadcrumb %} / Messagerie / Conversation{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        .chat-wrapper {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: calc(100vh - 200px);
            padding: 20px;
            border-radius: 20px;
        }

        .chat-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            height: calc(100vh - 280px);
            display: flex;
            flex-direction: column;
        }

        .chat-card-header {
            padding: 15px 25px;
            background: white;
            border-bottom: 1px solid #e9ecef;
            display: flex;
            align-items: center;
            gap: 15px;
            justify-content: space-between;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .back-btn {
            background: #f8f9fa;
            border: none;
            border-radius: 12px;
            width: 40px;
            height: 40px;
            transition: all 0.3s;
        }

        .back-btn:hover {
            background: #e9ecef;
            transform: translateX(-2px);
        }

        .chat-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(135deg, #10b981, #34d399);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 700;
            color: white;
        }

        .chat-user-name {
            font-weight: 700;
            font-size: 18px;
            color: #1a1a2e;
            margin-bottom: 2px;
        }

        .chat-user-status {
            font-size: 12px;
            color: #10b981;
        }

        .archive-btn {
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 12px;
            padding: 8px 16px;
            font-size: 13px;
            transition: all 0.3s;
        }

        .archive-btn:hover {
            background: #fee2e2;
            border-color: #dc3545;
            color: #dc3545;
        }

        .messages-container {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            background: #f8f9fa;
        }

        .message {
            max-width: 65%;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .message.sent {
            align-self: flex-end;
        }

        .message.received {
            align-self: flex-start;
        }

        .bubble {
            padding: 10px 16px;
            border-radius: 18px;
            font-size: 13px;
            line-height: 1.4;
            word-wrap: break-word;
            position: relative;
        }

        .sent .bubble {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border-bottom-right-radius: 4px;
        }

        .received .bubble {
            background: white;
            color: #1a1a2e;
            border-bottom-left-radius: 4px;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }

        .message-actions {
            position: absolute;
            top: -5px;
            right: -30px;
            display: none;
            gap: 5px;
        }

        .message.sent:hover .message-actions {
            display: flex;
        }

        .edit-btn, .delete-btn {
            background: white;
            border: none;
            border-radius: 50%;
            width: 28px;
            height: 28px;
            font-size: 12px;
            cursor: pointer;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            transition: all 0.2s;
        }

        .edit-btn:hover {
            background: #667eea;
            color: white;
        }

        .delete-btn:hover {
            background: #dc3545;
            color: white;
        }

        .edited-badge {
            font-size: 9px;
            opacity: 0.6;
            margin-left: 5px;
        }

        .message-time {
            font-size: 10px;
            color: #adb5bd;
            margin-top: 4px;
            padding: 0 5px;
        }

        .sent .message-time {
            text-align: right;
        }

        .input-footer {
            padding: 15px 25px;
            background: white;
            border-top: 1px solid #e9ecef;
        }

        .input-group-custom {
            display: flex;
            gap: 10px;
            align-items: flex-end;
            background: #f8f9fa;
            border-radius: 24px;
            padding: 5px 5px 5px 18px;
        }

        .input-group-custom:focus-within {
            background: white;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .message-input-custom {
            flex: 1;
            border: none;
            background: transparent;
            padding: 10px 0;
            font-size: 13px;
            resize: none;
        }

        .message-input-custom:focus {
            outline: none;
        }

        .send-custom {
            background: linear-gradient(135deg, #667eea, #764ba2);
            border: none;
            border-radius: 30px;
            padding: 8px 22px;
            font-weight: 600;
            font-size: 13px;
        }

        .send-custom:hover {
            transform: scale(1.02);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
        }

        .info-text {
            font-size: 11px;
            color: #adb5bd;
            margin-top: 8px;
        }

        .edit-modal .modal-content {
            border-radius: 20px;
        }

        .edit-modal .modal-header {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border: none;
        }

        .edit-modal textarea {
            border-radius: 12px;
            border: 1px solid #e9ecef;
            padding: 12px;
        }

        .edit-modal textarea:focus {
            border-color: #667eea;
            outline: none;
        }

        .messages-container::-webkit-scrollbar {
            width: 4px;
        }

        .messages-container::-webkit-scrollbar-track {
            background: #f1f1f1;
        }

        .messages-container::-webkit-scrollbar-thumb {
            background: #c1c1c1;
            border-radius: 4px;
        }
    </style>
{% endblock %}

{% block candidate_content %}
    <div class="chat-wrapper">
        <div class="chat-card">
            <div class="chat-card-header">
                <div class="header-left">
                    <button class="back-btn" onclick="window.location.href='{{ path('app_candidate_messages') }}'">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                    <div class="chat-avatar">
                        {{ otherUser.firstName|first|upper }}{{ otherUser.lastName|first|upper }}
                    </div>
                    <div>
                        <div class="chat-user-name">{{ otherUser.firstName }} {{ otherUser.lastName }}</div>
                        <div class="chat-user-status">
                            <i class="fas fa-circle me-1" style="font-size: 8px;"></i> En ligne
                        </div>
                    </div>
                </div>
                <button class="archive-btn" id="archiveConversationBtn">
                    <i class="fas fa-archive me-1"></i> Archiver
                </button>
            </div>

            <div class="messages-container" id="chatMessages">
                <div class="text-center text-muted py-5">
                    <i class="fas fa-spinner fa-spin"></i> Chargement...
                </div>
            </div>

            <div class="input-footer">
                <div class="input-group-custom">
                    <textarea class="message-input-custom" id="messageInput" rows="1" placeholder="Écrivez votre message..."></textarea>
                    <button class="btn btn-primary send-custom" id="sendMessageBtn">
                        <i class="fas fa-paper-plane me-1"></i> Envoyer
                    </button>
                </div>
                <div class="info-text">
                    <i class="fas fa-info-circle"></i> Entrée pour envoyer • Shift+Entrée pour nouvelle ligne
                </div>
                <div class="invalid-feedback d-none mt-2" id="messageError"></div>
            </div>
        </div>
    </div>

    <!-- Modal d'édition de message -->
    <div class="modal fade edit-modal" id="editMessageModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-edit me-2"></i>Modifier le message
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <textarea id="editMessageContent" class="form-control" rows="4"></textarea>
                    <small class="text-muted mt-2 d-block">
                        <i class="fas fa-info-circle"></i> Le message doit commencer par une majuscule
                    </small>
                    <div class="invalid-feedback mt-2" id="editMessageError"></div>
                </div>
                <div class="modal-footer border-0 pt-0 pb-4">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Annuler</button>
                    <button type="button" class="btn btn-primary" id="saveEditMessageBtn" style="background: linear-gradient(135deg, #667eea, #764ba2);">
                        <i class="fas fa-save me-2"></i>Enregistrer
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        const conversationId = {{ conversation.id }};
        let refreshInterval = null;
        let currentEditMessageId = null;

        function loadMessages() {
            fetch(`/messagerie/conversation/${conversationId}/messages`)
                .then(response => response.json())
                .then(messages => {
                    const container = document.getElementById('chatMessages');
                    let html = '';

                    if (messages.length === 0) {
                        container.innerHTML = '<div class="text-center text-muted py-5"><i class="fas fa-comment-dots fa-2x mb-2"></i><p>Aucun message</p><p class="small">Envoyez votre premier message !</p></div>';
                        return;
                    }

                    for (const msg of messages) {
                        const msgClass = msg.est_moi ? 'sent' : 'received';
                        const editedBadge = msg.statut === 'edited' ? '<span class="edited-badge">(modifié)</span>' : '';

                        html += `
                        <div class="message ${msgClass}" data-message-id="${msg.id}">
                            <div class="bubble">
                                ${escapeHtml(msg.contenu)}${editedBadge}
                            </div>
                            <div class="message-time">${msg.date_envoi}</div>
                            ${msg.est_moi ? `
                                <div class="message-actions">
                                    <button class="edit-btn" onclick="openEditModal(${msg.id}, '${escapeHtml(msg.contenu).replace(/'/g, "\\'")}')">
                                        <i class="fas fa-pencil-alt"></i>
                                    </button>
                                    <button class="delete-btn" onclick="deleteMessage(${msg.id})">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            ` : ''}
                        </div>
                    `;
                    }

                    container.innerHTML = html;
                    scrollToBottom();
                })
                .catch(error => console.error('Error loading messages:', error));
        }

        function openEditModal(messageId, content) {
            currentEditMessageId = messageId;
            document.getElementById('editMessageContent').value = content;
            document.getElementById('editMessageError').classList.add('d-none');
            new bootstrap.Modal(document.getElementById('editMessageModal')).show();
        }

        function deleteMessage(messageId) {
            if (confirm('Êtes-vous sûr de vouloir supprimer ce message ?')) {
                fetch(`/messagerie/delete-message/${messageId}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            loadMessages();
                        } else {
                            alert(data.error);
                        }
                    })
                    .catch(error => console.error('Error deleting message:', error));
            }
        }

        document.getElementById('saveEditMessageBtn')?.addEventListener('click', function() {
            const newContent = document.getElementById('editMessageContent').value;
            const errorDiv = document.getElementById('editMessageError');

            if (!newContent.trim()) {
                errorDiv.textContent = 'Le message ne peut pas être vide';
                errorDiv.classList.remove('d-none');
                return;
            }

            if (!/^[A-Z]/.test(newContent.trim())) {
                errorDiv.textContent = 'Le message doit commencer par une majuscule';
                errorDiv.classList.remove('d-none');
                return;
            }

            fetch(`/messagerie/edit-message/${currentEditMessageId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `content=${encodeURIComponent(newContent)}`
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        bootstrap.Modal.getInstance(document.getElementById('editMessageModal')).hide();
                        loadMessages();
                    } else {
                        errorDiv.textContent = data.error;
                        errorDiv.classList.remove('d-none');
                    }
                })
                .catch(error => console.error('Error editing message:', error));
        });

        document.getElementById('archiveConversationBtn')?.addEventListener('click', function() {
            if (confirm('Archiver cette conversation ?')) {
                fetch(`/messagerie/conversation/${conversationId}/archive`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    }
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            window.location.href = '{{ path('app_candidate_messages') }}';
                        }
                    })
                    .catch(error => console.error('Error archiving conversation:', error));
            }
        });

        function sendMessage() {
            const messageInput = document.getElementById('messageInput');
            const content = messageInput.value;
            const errorDiv = document.getElementById('messageError');

            if (!content.trim()) {
                errorDiv.textContent = 'Le message ne peut pas être vide';
                errorDiv.classList.remove('d-none');
                return;
            }

            if (!/^[A-Z]/.test(content.trim())) {
                errorDiv.textContent = 'Le message doit commencer par une majuscule';
                errorDiv.classList.remove('d-none');
                return;
            }

            errorDiv.classList.add('d-none');

            fetch('/messagerie/send-message', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `conversation_id=${conversationId}&content=${encodeURIComponent(content)}`
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        messageInput.value = '';
                        loadMessages();
                    } else {
                        errorDiv.textContent = data.error;
                        errorDiv.classList.remove('d-none');
                    }
                })
                .catch(error => console.error('Error sending message:', error));
        }

        function scrollToBottom() {
            const container = document.getElementById('chatMessages');
            if (container) {
                container.scrollTop = container.scrollHeight;
            }
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        // Event listeners
        document.getElementById('sendMessageBtn').addEventListener('click', sendMessage);
        document.getElementById('messageInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        // Chargement initial
        loadMessages();

        // Rafraîchissement périodique toutes les 5 secondes
        refreshInterval = setInterval(() => {
            loadMessages();
        }, 5000);

        // Nettoyage
        window.addEventListener('beforeunload', function() {
            if (refreshInterval) clearInterval(refreshInterval);
        });
    </script>
{% endblock %}