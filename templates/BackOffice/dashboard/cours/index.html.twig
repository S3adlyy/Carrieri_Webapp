{# templates/BackOffice/dashboard/cours/index.html.twig #}
{% extends 'BackOffice/base.html.twig' %}

{% block title %}Gestion des cours{% endblock %}

{% block page_title %}Cours{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item active">Cours</li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Liste des cours</h3>
            <span class="badge badge-info">{{ cours_list|length }} cours</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead>
                    <tr>
                        <th>ID</th>
                        <th>Titre</th>
                        <th>Niveau</th>
                        <th>Durée</th>
                        <th>Prix</th>
                        {% if is_admin_view|default(false) %}
                            <th>Auteur</th>
                        {% endif %}
                    </tr>
                    </thead>
                    <tbody>
                    {% for c in cours_list %}
                        <tr>
                            <td>{{ c.id }}</td>
                            <td>{{ c.titre|default('—') }}</td>
                            <td>{{ c.niveau|default('—') }}</td>
                            <td>{{ c.duree|default('—') }}</td>
                            <td>{% if c.prix is not null %}{{ c.prix }}{% else %}—{% endif %}</td>
                            {% if is_admin_view|default(false) %}
                                <td>
                                    {% set u = c.user %}
                                    {% if u %}{{ (u.firstName ~ ' ' ~ u.lastName)|trim ?: u.email }}{% else %}—{% endif %}
                                </td>
                            {% endif %}
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="{{ is_admin_view|default(false) ? 6 : 5 }}" class="text-center text-muted">Aucun cours.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
