<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Export cours - {{ cours.titre|default('Cours') }}</title>
    <style>
        @page {
            size: A4;
            margin: 18mm 14mm;
        }

        body {
            font-family: DejaVu Sans, Arial, sans-serif;
            font-size: 11px;
            color: #1f2937;
            line-height: 1.5;
        }

        .cover {
            border: 1px solid #dbeafe;
            border-radius: 10px;
            padding: 18px;
            margin-bottom: 14px;
            background: #f8fbff;
        }

        .cover-title {
            font-size: 26px;
            font-weight: 700;
            color: #1e3a8a;
            margin-bottom: 6px;
        }

        .cover-subtitle {
            font-size: 13px;
            color: #475569;
            margin-bottom: 12px;
        }

        .meta-grid {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        .meta-grid td {
            border: 1px solid #dbeafe;
            padding: 8px;
            vertical-align: top;
        }

        .meta-label {
            font-size: 10px;
            color: #64748b;
            text-transform: uppercase;
        }

        .meta-value {
            font-size: 13px;
            color: #0f172a;
            font-weight: 700;
            margin-top: 2px;
        }

        .section {
            margin-top: 14px;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px;
            background: #ffffff;
        }

        .section-title {
            font-size: 15px;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 8px;
            border-bottom: 1px solid #e5e7eb;
            padding-bottom: 6px;
        }

        .module-card {
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            margin-top: 10px;
            padding: 10px;
            background: #fcfdff;
        }

        .module-title {
            font-size: 13px;
            font-weight: 700;
            color: #1e40af;
            margin-bottom: 4px;
        }

        .module-desc {
            font-size: 10.5px;
            color: #475569;
            margin-bottom: 6px;
        }

        .lesson-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 6px;
        }

        .lesson-table th {
            background: #eef2ff;
            color: #3730a3;
            text-align: left;
            font-size: 10px;
            padding: 6px;
            border: 1px solid #dbeafe;
        }

        .lesson-table td {
            border: 1px solid #e5e7eb;
            padding: 6px;
            vertical-align: top;
            font-size: 10px;
        }

        .muted {
            color: #6b7280;
        }

        .footer {
            margin-top: 14px;
            font-size: 9px;
            color: #64748b;
            text-align: right;
        }
    </style>
</head>
<body>
{% set total_lessons = 0 %}
{% for module in modules %}
    {% set total_lessons = total_lessons + (lessons_by_module[module.id]|default([])|length) %}
{% endfor %}

<div class="cover">
    <div class="cover-title">{{ cours.titre|default('Cours') }}</div>
    <div class="cover-subtitle">Document pédagogique complet • Cours, modules et leçons</div>
    <div class="muted">Exporté le {{ generated_at|date('d/m/Y H:i') }}</div>

    <table class="meta-grid">
        <tr>
            <td>
                <div class="meta-label">Niveau</div>
                <div class="meta-value">{{ cours.niveau|default('Non défini') }}</div>
            </td>
            <td>
                <div class="meta-label">Durée</div>
                <div class="meta-value">{{ cours.duree|default('0') }} h</div>
            </td>
            <td>
                <div class="meta-label">Prix</div>
                <div class="meta-value">{{ cours.prix is not null and cours.prix > 0 ? cours.prix ~ ' TND' : 'Gratuit' }}</div>
            </td>
            <td>
                <div class="meta-label">Structure</div>
                <div class="meta-value">{{ modules|length }} modules / {{ total_lessons }} leçons</div>
            </td>
        </tr>
    </table>
</div>

<div class="section">
    <div class="section-title">Description du cours</div>
    <div>{{ cours.description|default('Aucune description') }}</div>
</div>

<div class="section">
    <div class="section-title">Compétences visées</div>
    <div>{{ cours.competencesVisees|default('Aucune compétence indiquée') }}</div>
</div>

<div class="section">
    <div class="section-title">Modules et leçons</div>
    {% if modules is empty %}
        <p class="muted">Aucun module pour ce cours.</p>
    {% else %}
        {% for module in modules %}
            {% set module_lessons = lessons_by_module[module.id]|default([]) %}
            <div class="module-card">
                <div class="module-title">Module {{ module.ordre|default(loop.index) }} • {{ module.titre|default('Sans titre') }}</div>
                <div class="module-desc">{{ module.description|default('Aucune description pour ce module.') }}</div>

                {% if module_lessons is empty %}
                    <div class="muted">Aucune leçon dans ce module.</div>
                {% else %}
                    <table class="lesson-table">
                        <thead>
                            <tr>
                                <th style="width:50px;">Ordre</th>
                                <th style="width:190px;">Leçon</th>
                                <th>Résumé du contenu</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for lesson in module_lessons %}
                                {% set plain_content = lesson.contenu|default('')|striptags|trim %}
                                <tr>
                                    <td>{{ lesson.ordre|default(loop.index) }}</td>
                                    <td><strong>{{ lesson.titre|default('Leçon') }}</strong></td>
                                    <td>{{ plain_content|slice(0, 320) }}{% if plain_content|length > 320 %}...{% endif %}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
        {% endfor %}
    {% endif %}
</div>

<div class="footer">
    Carrieri • Export recruteur / backoffice
</div>
</body>
</html>


