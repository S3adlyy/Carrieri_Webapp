{# templates/BackOffice/dashboard/cours/show.html.twig #}
{% extends 'BackOffice/base.html.twig' %}

{% block title %}Détail — {{ cours.titre }}{% endblock %}
{% block page_title %}Détail du cours{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_cours_index') }}">Cours</a></li>
    <li class="breadcrumb-item active">{{ cours.titre|default('Cours') }}</li>
{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">{{ cours.titre }}</h3>
                    <div class="card-tools">
                        <span class="badge badge-{{ cours.niveau == 'Débutant' ? 'success' : (cours.niveau == 'Intermédiaire' ? 'warning' : 'danger') }}">
                            {{ cours.niveau|default('—') }}
                        </span>
                    </div>
                </div>
                <div class="card-body">
                    {% if cours.imageCouverture %}
                        <img src="data:image/jpeg;base64,{{ cours.imageCouverture|b64encode }}" alt="Couverture" class="img-fluid mb-3 rounded" style="max-height:200px; object-fit:cover;">
                    {% endif %}

                    <h5>Description</h5>
                    <p>{{ cours.description|default('—') }}</p>

                    <h5>Compétences visées</h5>
                    <p>{{ cours.competencesVisees|default('—') }}</p>

                    <hr>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="mb-0">Modules et leçons</h5>
                        <a href="{{ path('app_admin_modules_new', {cours: cours.id}) }}" class="btn btn-sm btn-primary">
                            <i class="fas fa-plus mr-1"></i> Ajouter un module
                        </a>
                    </div>

                    {% if modules is empty %}
                        <p class="text-muted mb-0">Aucun module pour ce cours.</p>
                    {% else %}
                        {% for module in modules %}
                            <div class="border rounded p-3 mb-3 bg-light">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <h6 class="mb-1">Module {{ module.ordre|default(loop.index) }} — {{ module.titre|default('Sans titre') }}</h6>
                                        <p class="mb-0 text-muted">{{ module.description|default('') }}</p>
                                    </div>
                                    <div class="text-right">
                                        <a href="{{ path('app_admin_modules_edit', {id: module.id}) }}" class="btn btn-xs btn-warning mb-1">Modifier module</a>
                                        <a href="{{ path('app_admin_lecons_new', {module: module.id}) }}" class="btn btn-xs btn-success">Ajouter leçon</a>
                                    </div>
                                </div>

                                {% set module_lessons = lessons_by_module[module.id]|default([]) %}
                                {% if module_lessons is empty %}
                                    <small class="text-muted">Aucune leçon dans ce module.</small>
                                {% else %}
                                    <ul class="list-group list-group-flush">
                                        {% for lesson in module_lessons %}
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <span>
                                                <strong>{{ lesson.ordre|default(loop.index) }}.</strong>
                                                {{ lesson.titre|default('Leçon') }}
                                                <span class="badge badge-secondary ml-1">{{ lesson.type|default('texte')|upper }}</span>
                                            </span>
                                                <a href="{{ path('app_admin_lecons_edit', {id: lesson.id}) }}" class="btn btn-xs btn-warning">Modifier</a>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                {% endif %}
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-info">
                <div class="card-header"><h3 class="card-title">Informations</h3></div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tr><th>ID</th><td>{{ cours.id }}</td></tr>
                        <tr><th>Durée</th><td>{{ cours.duree|default('—') }} h</td></tr>
                        <tr><th>Prix</th><td>{{ cours.prix is not null ? cours.prix ~ ' €' : '—' }}</td></tr>
                        <tr><th>Payant</th><td>{{ cours.estPayant ? 'Oui' : 'Non' }}</td></tr>
                        <tr><th>Obligatoire</th><td>{{ cours.estObligatoire ? 'Oui' : 'Non' }}</td></tr>
                    </table>
                </div>
            </div>
            <div class="d-flex flex-column gap-2">
                <a href="{{ path('app_admin_cours_export_pdf', {id: cours.id}) }}" class="btn btn-danger btn-block">
                    <i class="fas fa-file-pdf mr-1"></i> Exporter en PDF
                </a>
                <a href="{{ path('app_admin_modules_index', {cours: cours.id}) }}" class="btn btn-primary btn-block">
                    <i class="fas fa-layer-group mr-1"></i> Accéder aux modules
                </a>
                <a href="{{ path('app_admin_cours_edit', {id: cours.id}) }}" class="btn btn-warning btn-block">
                    <i class="fas fa-edit mr-1"></i> Modifier
                </a>
                <form method="post" action="{{ path('app_admin_cours_delete', {id: cours.id}) }}"
                      onsubmit="return confirm('Supprimer ce cours ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_cours_' ~ cours.id) }}">
                    <button class="btn btn-danger btn-block" type="submit">
                        <i class="fas fa-trash mr-1"></i> Supprimer
                    </button>
                </form>
                <a href="{{ path('app_admin_cours_index') }}" class="btn btn-secondary btn-block">
                    <i class="fas fa-arrow-left mr-1"></i> Retour
                </a>
            </div>
        </div>
    </div>
{% endblock %}