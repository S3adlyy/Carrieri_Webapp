<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Candidatures — {{ offre.titre }}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 13px;
            color: #1f2937;
            margin: 0;
            padding: 20px;
        }

        .header {
            border-bottom: 3px solid #2563eb;
            padding-bottom: 16px;
            margin-bottom: 24px;
        }

        .header h1 {
            font-size: 22px;
            color: #1f3470;
            margin: 0 0 6px 0;
        }

        .header-meta {
            display: flex;
            gap: 30px;
            font-size: 12px;
            color: #6b7280;
            margin-top: 10px;
        }

        .header-meta span strong {
            color: #1f2937;
        }

        .export-date {
            font-size: 11px;
            color: #9ca3af;
            margin-top: 6px;
        }

        .stats-row {
            display: flex;
            gap: 16px;
            margin-bottom: 24px;
        }

        .stat-box {
            flex: 1;
            border-radius: 10px;
            padding: 12px 16px;
            text-align: center;
        }

        .stat-box.total { background: #eff6ff; border: 1px solid #bfdbfe; }
        .stat-box.pending { background: #fffbeb; border: 1px solid #fde68a; }
        .stat-box.accepted { background: #f0fdf4; border: 1px solid #bbf7d0; }
        .stat-box.refused { background: #fef2f2; border: 1px solid #fecaca; }

        .stat-box .stat-number {
            font-size: 24px;
            font-weight: 800;
            display: block;
        }

        .stat-box.total .stat-number { color: #2563eb; }
        .stat-box.pending .stat-number { color: #d97706; }
        .stat-box.accepted .stat-number { color: #059669; }
        .stat-box.refused .stat-number { color: #dc2626; }

        .stat-box .stat-label {
            font-size: 11px;
            color: #6b7280;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        thead tr {
            background: #1f3470;
            color: white;
        }

        thead th {
            padding: 10px 12px;
            text-align: left;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        tbody tr:nth-child(even) {
            background: #f8faff;
        }

        tbody tr:nth-child(odd) {
            background: #ffffff;
        }

        tbody td {
            padding: 10px 12px;
            border-bottom: 1px solid #e5e7eb;
            font-size: 12px;
            vertical-align: top;
        }

        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
        }

        .badge-success { background: #dcfce7; color: #059669; }
        .badge-danger { background: #fee2e2; color: #dc2626; }
        .badge-warning { background: #fef9c3; color: #d97706; }

        .footer {
            margin-top: 30px;
            padding-top: 12px;
            border-top: 1px solid #e5e7eb;
            font-size: 11px;
            color: #9ca3af;
            text-align: center;
        }

        .motivation-text {
            max-width: 200px;
            word-wrap: break-word;
        }
    </style>
</head>
<body>

    <div class="header">
        <h1>Candidatures reçues</h1>
        <div style="font-size:16px; font-weight:700; color:#2563eb; margin-top:4px;">
            {{ offre.titre }}
        </div>
        <div class="header-meta">
            <span><strong>Entreprise:</strong> {{ offre.entreprise|default('—') }}</span>
            <span><strong>Localisation:</strong> {{ offre.localisation|default('—') }}</span>
            <span><strong>Contrat:</strong> {{ offre.typeContrat|default('—') }}</span>
            <span><strong>Salaire:</strong> {{ offre.salaire ? offre.salaire ~ ' DT' : '—' }}</span>
        </div>
        <div class="export-date">Exporté le {{ export_date }}</div>
    </div>

    {% set total = postulations|length %}
    {% set accepted = postulations|filter(p => p.statut == 'Acceptée')|length %}
    {% set refused = postulations|filter(p => p.statut == 'Refusée')|length %}
    {% set pending = postulations|filter(p => p.statut == 'En attente')|length %}

    <div class="stats-row">
        <div class="stat-box total">
            <span class="stat-number">{{ total }}</span>
            <span class="stat-label">Total</span>
        </div>
        <div class="stat-box pending">
            <span class="stat-number">{{ pending }}</span>
            <span class="stat-label">En attente</span>
        </div>
        <div class="stat-box accepted">
            <span class="stat-number">{{ accepted }}</span>
            <span class="stat-label">Acceptées</span>
        </div>
        <div class="stat-box refused">
            <span class="stat-number">{{ refused }}</span>
            <span class="stat-label">Refusées</span>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Candidat</th>
                <th>Email</th>
                <th>Date postulation</th>
                <th>Motivation</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            {% for p in postulations %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td>
                        <strong>
                            {{ p.user ? p.user.firstName|default('') ~ ' ' ~ p.user.lastName|default('') : '—' }}
                        </strong>
                    </td>
                    <td>{{ p.user ? p.user.email|default('—') : '—' }}</td>
                    <td>{{ p.datePostulation ? p.datePostulation|date('d/m/Y H:i') : '—' }}</td>
                    <td class="motivation-text">
                        {% set mot = p.motivationCandidature|default('') %}
                        {{ mot|length > 80 ? mot|slice(0, 80) ~ '...' : (mot ?: '—') }}
                    </td>
                    <td>
                        {% if p.statut == 'Acceptée' %}
                            <span class="badge badge-success">Acceptée</span>
                        {% elseif p.statut == 'Refusée' %}
                            <span class="badge badge-danger">Refusée</span>
                        {% else %}
                            <span class="badge badge-warning">En attente</span>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" style="text-align:center; color:#9ca3af; padding: 20px;">
                        Aucune candidature.
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="footer">
        Carrieri — Document généré automatiquement le {{ export_date }} — {{ total }} candidature(s)
    </div>

</body>
</html>