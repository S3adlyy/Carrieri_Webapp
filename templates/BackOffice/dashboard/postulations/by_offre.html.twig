{% extends 'BackOffice/base.html.twig' %}

{% block title %}Postulations liées à l'offre{% endblock %}
{% block page_title %}Postulations par offre{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item"><a href="{{ path('app_admin_offres_list') }}">Offres d'emploi</a></li>
    <li class="breadcrumb-item active">Postulations liées</li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap">
            <div>
                <h3 class="card-title mb-1">
                    Postulations liées à l'offre :
                    <strong>{{ offre.titre }}</strong>
                </h3>
                <div class="text-muted mt-1">
                    <i class="fas fa-building"></i> {{ offre.entreprise }}
                    &nbsp; | &nbsp;
                    <i class="fas fa-map-marker-alt"></i> {{ offre.localisation }}
                    &nbsp; | &nbsp;
                    <i class="fas fa-file-contract"></i> {{ offre.typeContrat }}
                </div>
            </div>

            <div class="card-tools mt-2 mt-md-0">
                <a href="{{ path('app_admin_offres_list') }}" class="btn btn-secondary btn-sm">
                    <i class="fas fa-arrow-left"></i> Retour aux offres
                </a>
            </div>
        </div>

        <div class="card-body">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type }} alert-dismissible">
                        <button type="button" class="close" data-dismiss="alert">&times;</button>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            <div class="row mb-3">
                <div class="col-md-4">
                    <div class="small-box bg-info">
                        <div class="inner">
                            <h3>{{ postulations|length }}</h3>
                            <p>Total postulations</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-users"></i>
                        </div>
                    </div>
                </div>
            </div>

            {% if postulations is not empty %}
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Candidat</th>
                                <th>Email</th>
                                <th>Téléphone</th>
                                <th>Date postulation</th>
                                <th>Statut</th>
                                <th>CV</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for postulation in postulations %}
                                <tr>
                                    <td>{{ postulation.id }}</td>
                                    <td>
                                        {% if postulation.candidat is defined and postulation.candidat %}
                                            {{ postulation.candidat.nom }} {{ postulation.candidat.prenom }}
                                        {% else %}
                                            —
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if postulation.candidat is defined and postulation.candidat and postulation.candidat.email is defined %}
                                            {{ postulation.candidat.email }}
                                        {% else %}
                                            —
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if postulation.candidat is defined and postulation.candidat and postulation.candidat.telephone is defined %}
                                            {{ postulation.candidat.telephone }}
                                        {% else %}
                                            —
                                        {% endif %}
                                    </td>
                                    <td>
                                        {{ postulation.datePostulation ? postulation.datePostulation|date('d/m/Y H:i') : '—' }}
                                    </td>
                                    <td>
                                        {% if postulation.statut == 'Acceptée' %}
                                            <span class="badge badge-success">Acceptée</span>
                                        {% elseif postulation.statut == 'Refusée' %}
                                            <span class="badge badge-danger">Refusée</span>
                                        {% else %}
                                            <span class="badge badge-warning">En attente</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if postulation.cvPath %}
                                            <a href="{{ asset(postulation.cvPath) }}" target="_blank" class="btn btn-outline-primary btn-sm">
                                                <i class="fas fa-file-pdf"></i> Voir CV
                                            </a>
                                        {% else %}
                                            <span class="text-muted">Aucun CV</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <form method="post" action="{{ path('app_admin_postulations_update_statut', {'id': postulation.id}) }}" style="display:inline-block;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('statut' ~ postulation.id) }}">
                                                <input type="hidden" name="statut" value="Acceptée">
                                                <button type="submit" class="btn btn-success" title="Accepter">
                                                    <i class="fas fa-check"></i>
                                                </button>
                                            </form>

                                            <form method="post" action="{{ path('app_admin_postulations_update_statut', {'id': postulation.id}) }}" style="display:inline-block;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('statut' ~ postulation.id) }}">
                                                <input type="hidden" name="statut" value="Refusée">
                                                <button type="submit" class="btn btn-warning" title="Refuser">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </form>

                                            <button type="button"
                                                    class="btn btn-danger"
                                                    data-toggle="modal"
                                                    data-target="#deleteModal{{ postulation.id }}"
                                                    title="Supprimer">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>

                                        <div class="modal fade" id="deleteModal{{ postulation.id }}" tabindex="-1" role="dialog">
                                            <div class="modal-dialog" role="document">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Confirmer la suppression</h5>
                                                        <button type="button" class="close" data-dismiss="modal">
                                                            <span>&times;</span>
                                                        </button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <p>Êtes-vous sûr de vouloir supprimer cette postulation ?</p>
                                                        <p class="text-muted mb-0">
                                                            ID : <strong>{{ postulation.id }}</strong>
                                                        </p>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                                                        <form method="post" action="{{ path('app_admin_postulations_delete', {'id': postulation.id}) }}">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_postulation_' ~ postulation.id) }}">
                                                            <button type="submit" class="btn btn-danger">Supprimer</button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="alert alert-info mb-0">
                    <i class="fas fa-info-circle"></i>
                    Aucune postulation n'est liée à cette offre pour le moment.
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}