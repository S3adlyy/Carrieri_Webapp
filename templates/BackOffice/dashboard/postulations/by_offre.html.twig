{% extends 'BackOffice/base.html.twig' %}

{% block title %}Candidatures — {{ offre.titre }}{% endblock %}
{% block page_title %}Candidatures reçues{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_postulations_list') }}">Postulations</a></li>
    <li class="breadcrumb-item active">{{ offre.titre }}</li>
{% endblock %}

{% block body %}

    {# Offer summary card #}
    <div class="card card-outline card-primary mb-4">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-briefcase mr-2"></i>{{ offre.titre }}
            </h3>
            <div class="card-tools">
                <a href="{{ path('app_admin_offres_show', {'id': offre.id}) }}" class="btn btn-sm btn-default">
                    <i class="fas fa-eye"></i> Voir l'offre
                </a>
                <a href="{{ path('app_admin_postulations_export_pdf', {'id': offre.id}) }}"
                    class="btn btn-sm btn-danger ml-1" target="_blank">
                        <i class="fas fa-file-pdf"></i> Exporter PDF
                </a>
                <a href="{{ path('app_admin_postulations_list') }}" class="btn btn-sm btn-secondary ml-1">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <small class="text-muted">Entreprise</small>
                    <p class="mb-0"><strong>{{ offre.entreprise|default('—') }}</strong></p>
                </div>
                <div class="col-md-3">
                    <small class="text-muted">Localisation</small>
                    <p class="mb-0">{{ offre.localisation|default('—') }}</p>
                </div>
                <div class="col-md-3">
                    <small class="text-muted">Type de contrat</small>
                    <p class="mb-0">
                        {% if offre.typeContrat == 'CDI' %}
                            <span class="badge badge-success">CDI</span>
                        {% elseif offre.typeContrat == 'CDD' %}
                            <span class="badge badge-warning">CDD</span>
                        {% elseif offre.typeContrat == 'Stage' %}
                            <span class="badge badge-info">Stage</span>
                        {% else %}
                            <span class="badge badge-secondary">{{ offre.typeContrat|default('—') }}</span>
                        {% endif %}
                    </p>
                </div>
                <div class="col-md-3">
                    <small class="text-muted">Candidatures reçues</small>
                    <p class="mb-0"><strong>{{ postulations|length }}</strong></p>
                </div>
            </div>
        </div>
    </div>

    {# Stats row #}
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="info-box">
                <span class="info-box-icon bg-warning"><i class="fas fa-clock"></i></span>
                <div class="info-box-content">
                    <span class="info-box-text">En attente</span>
                    <span class="info-box-number">
                        {{ postulations|filter(p => p.statut == 'En attente')|length }}
                    </span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="info-box">
                <span class="info-box-icon bg-success"><i class="fas fa-check-circle"></i></span>
                <div class="info-box-content">
                    <span class="info-box-text">Acceptées</span>
                    <span class="info-box-number">
                        {{ postulations|filter(p => p.statut == 'Acceptée')|length }}
                    </span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="info-box">
                <span class="info-box-icon bg-danger"><i class="fas fa-times-circle"></i></span>
                <div class="info-box-content">
                    <span class="info-box-text">Refusées</span>
                    <span class="info-box-number">
                        {{ postulations|filter(p => p.statut == 'Refusée')|length }}
                    </span>
                </div>
            </div>
        </div>
    </div>

    {# Flash messages #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type }} alert-dismissible">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# Formulaire de recherche pour cette offre #}
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" action="{{ path('app_admin_postulations_by_offre', {'id': offre.id}) }}" class="row">
                <div class="col-md-4">
                    <input type="text" name="keyword" class="form-control"
                           placeholder="Rechercher candidat..."
                           value="{{ filters.keyword|default('') }}">
                </div>
                <div class="col-md-3">
                    <select name="statut" class="form-control">
                        <option value="">Tous les statuts</option>
                        <option value="En attente" {{ filters.statut == 'En attente' ? 'selected' : '' }}>En attente</option>
                        <option value="Acceptée" {{ filters.statut == 'Acceptée' ? 'selected' : '' }}>Acceptée</option>
                        <option value="Refusée" {{ filters.statut == 'Refusée' ? 'selected' : '' }}>Refusée</option>
                    </select>
                </div>
                
                <div class="col-md-2">
                    <div class="btn-group w-100">
                        <button class="btn btn-primary" type="submit">
                            <i class="fas fa-search"></i>
                        </button>
                        <a href="{{ path('app_admin_postulations_by_offre', {'id': offre.id}) }}" class="btn btn-secondary">
                            <i class="fas fa-times"></i>
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    {# Postulations table #}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Liste des candidats</h3>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead>
                    <tr>
                        <th>Candidat</th>
                        <th>Date postulation</th>
                        <th>Motivation</th>
                        <th>CV</th>
                        <th>Statut actuel</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for p in postulations %}
                        <tr>
                            <td>
                                {% if p.user %}
                                    <strong>{{ p.user.firstName|default('') }} {{ p.user.lastName|default('') }}</strong>
                                    <br><small class="text-muted">{{ p.user.email|default('') }}</small>
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td>{{ p.datePostulation ? p.datePostulation|date('d/m/Y H:i') : '—' }}</td>
                            <td>
                                {% set mot = p.motivationCandidature|default('') %}
                                {% if mot|length > 100 %}
                                    {{ mot|slice(0, 100) }}...
                                    <a href="#" data-toggle="modal" data-target="#motModal{{ p.id }}">
                                        <small>Lire plus</small>
                                    </a>

                                    {# Motivation modal #}
                                    <div class="modal fade" id="motModal{{ p.id }}" tabindex="-1" role="dialog">
                                        <div class="modal-dialog" role="document">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Motivation de {{ p.user ? p.user.firstName : '' }}</h5>
                                                    <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                                                </div>
                                                <div class="modal-body">
                                                    {{ mot|nl2br }}
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Fermer</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                {% else %}
                                    {{ mot ?: '—' }}
                                {% endif %}
                            </td>
                            <td>
                                {% if p.cvPath %}
                                    <a href="/{{ p.cvPath }}" target="_blank" class="btn btn-xs btn-info">
                                        <i class="fas fa-file-pdf"></i> Voir CV
                                    </a>
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if p.statut == 'Acceptée' %}
                                    <span class="badge badge-success">Acceptée</span>
                                {% elseif p.statut == 'Refusée' %}
                                    <span class="badge badge-danger">Refusée</span>
                                {% else %}
                                    <span class="badge badge-warning">En attente</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <form method="post"
                                          action="{{ path('app_admin_postulations_update_statut', {'id': p.id}) }}"
                                          class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('statut' ~ p.id) }}">
                                        <select name="statut" class="form-control form-control-sm"
                                                style="width: 130px; display:inline-block"
                                                onchange="this.form.submit()">
                                            <option value="En attente" {{ p.statut == 'En attente' ? 'selected' : '' }}>
                                                En attente
                                            </option>
                                            <option value="Acceptée" {{ p.statut == 'Acceptée' ? 'selected' : '' }}>
                                                Acceptée
                                            </option>
                                            <option value="Refusée" {{ p.statut == 'Refusée' ? 'selected' : '' }}>
                                                Refusée
                                            </option>
                                        </select>
                                    </form>
                                    <button type="button" class="btn btn-danger btn-sm ml-1"
                                            data-toggle="modal"
                                            data-target="#deletePostulationModal{{ p.id }}"
                                            title="Supprimer">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>

                                {# Modal de confirmation suppression #}
                                <div class="modal fade" id="deletePostulationModal{{ p.id }}" tabindex="-1" role="dialog">
                                    <div class="modal-dialog" role="document">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Confirmer la suppression</h5>
                                                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                                            </div>
                                            <div class="modal-body">
                                                <p>Êtes-vous sûr de vouloir supprimer cette candidature ?</p>
                                                <p class="text-muted">
                                                    <strong>Candidat :</strong> {{ p.user ? p.user.firstName ~ ' ' ~ p.user.lastName : '—' }}<br>
                                                    <strong>Offre :</strong> {{ offre.titre }}<br>
                                                    <strong>Motivation :</strong> {{ p.motivationCandidature|slice(0, 50) ~ '...' }}
                                                </p>
                                                <p class="text-danger small">Cette action est irréversible et supprimera également le CV associé.</p>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                                                <form method="post" action="{{ path('app_admin_postulations_delete', {'id': p.id}) }}">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_postulation_' ~ p.id) }}">
                                                    <button type="submit" class="btn btn-danger">Supprimer</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="fas fa-users fa-2x mb-2"></i>
                                <p>Aucune candidature reçue pour cette offre.</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}