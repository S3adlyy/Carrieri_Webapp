{% extends 'BackOffice/base.html.twig' %}

{% block title %}Insights offre{% endblock %}
{% block page_title %}Analyse d'offre{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_offres_list') }}">Offres d'emploi</a></li>
    <li class="breadcrumb-item active">Insights</li>
{% endblock %}

{% block body %}
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 insight-hero-card">
                <div class="card-body d-flex flex-wrap justify-content-between align-items-start gap-3">
                    <div>
                        <div class="text-muted small mb-2">Analyse intelligente de l'offre</div>
                        <h2 class="mb-2 insight-title">{{ offre.titre }}</h2>
                        <div class="insight-meta">
                            <span><i class="fas fa-building"></i> {{ offre.entreprise }}</span>
                            <span><i class="fas fa-map-marker-alt"></i> {{ offre.localisation }}</span>
                            <span><i class="fas fa-file-contract"></i> {{ offre.typeContrat }}</span>
                            <span><i class="fas fa-briefcase"></i> {{ offre.secteurActivite }}</span>
                        </div>
                    </div>

                    <div class="text-right">
                        <div class="score-ring score-{{ insights.level_color }}">
                            <span>{{ insights.scores.global }}/100</span>
                        </div>
                        <div class="mt-2">
                            <span class="badge badge-{{ insights.level_color }} p-2">{{ insights.level }}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="small-box bg-info">
                <div class="inner">
                    <h3>{{ insights.stats.total_postulations }}</h3>
                    <p>Total postulations</p>
                </div>
                <div class="icon"><i class="fas fa-users"></i></div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="small-box bg-success">
                <div class="inner">
                    <h3>{{ acceptedCount }}</h3>
                    <p>Acceptées</p>
                </div>
                <div class="icon"><i class="fas fa-check-circle"></i></div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="small-box bg-warning">
                <div class="inner">
                    <h3>{{ pendingCount }}</h3>
                    <p>En attente</p>
                </div>
                <div class="icon"><i class="fas fa-hourglass-half"></i></div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="small-box bg-danger">
                <div class="inner">
                    <h3>{{ refusedCount }}</h3>
                    <p>Refusées</p>
                </div>
                <div class="icon"><i class="fas fa-times-circle"></i></div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white">
                    <h3 class="card-title mb-0">Répartition des candidatures</h3>
                </div>
                <div class="card-body">
                    <canvas id="statusChart" height="240"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white">
                    <h3 class="card-title mb-0">Tendance des candidatures (6 dernières semaines)</h3>
                </div>
                <div class="card-body">
                    <canvas id="weeklyChart" height="240"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white">
                    <h3 class="card-title mb-0">Radar qualité de l’offre</h3>
                </div>
                <div class="card-body">
                    <canvas id="qualityChart" height="260"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100 prediction-card">
                <div class="card-header bg-white score-read-header">                    <h3 class="card-title mb-0">Prédiction & remarques</h3>
                    <span class="badge badge-dark">IA heuristique</span>
                </div>
                <div class="card-body">
                    <div class="prediction-text">
                        {{ insights.prediction }}
                    </div>

                    <hr>

                    <h5 class="prediction-subtitle text-success">
                        <i class="fas fa-thumbs-up"></i> Points forts
                    </h5>
                    <ul class="prediction-list">
                        {% for item in insights.strengths %}
                            <li>{{ item }}</li>
                        {% else %}
                            <li>Base correcte, mais l’offre peut encore être davantage différenciée.</li>
                        {% endfor %}
                    </ul>

                    <h5 class="prediction-subtitle text-danger mt-4">
                        <i class="fas fa-exclamation-triangle"></i> Axes d’amélioration
                    </h5>
                    <ul class="prediction-list">
                        {% for item in insights.remarks %}
                            <li>{{ item }}</li>
                        {% else %}
                            <li>L’offre est déjà bien structurée.</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0">Lecture rapide du score</h3>
            <a href="{{ path('app_admin_offres_list') }}" class="btn btn-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> Retour aux offres
            </a>
        </div>
        <div class="card-body">
            <div class="row text-center">
                <div class="col-md-2 col-6 mb-3">
                    <div class="score-mini-card">
                        <div class="score-mini-value">{{ insights.scores.clarity }}</div>
                        <div class="score-mini-label">Clarté</div>
                    </div>
                </div>
                <div class="col-md-2 col-6 mb-3">
                    <div class="score-mini-card">
                        <div class="score-mini-value">{{ insights.scores.attractiveness }}</div>
                        <div class="score-mini-label">Attractivité</div>
                    </div>
                </div>
                <div class="col-md-2 col-6 mb-3">
                    <div class="score-mini-card">
                        <div class="score-mini-value">{{ insights.scores.transparency }}</div>
                        <div class="score-mini-label">Transparence</div>
                    </div>
                </div>
                <div class="col-md-2 col-6 mb-3">
                    <div class="score-mini-card">
                        <div class="score-mini-value">{{ insights.scores.competitiveness }}</div>
                        <div class="score-mini-label">Compétitivité</div>
                    </div>
                </div>
                <div class="col-md-2 col-6 mb-3">
                    <div class="score-mini-card">
                        <div class="score-mini-value">{{ insights.scores.credibility }}</div>
                        <div class="score-mini-label">Crédibilité</div>
                    </div>
                </div>
                <div class="col-md-2 col-6 mb-3">
                    <div class="score-mini-card score-mini-global">
                        <div class="score-mini-value">{{ insights.scores.global }}</div>
                        <div class="score-mini-label">Global</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
    .insight-hero-card {
        border-radius: 18px;
        background: linear-gradient(135deg, #f8fbff 0%, #eef4ff 100%);
    }

    .insight-title {
        font-weight: 800;
        color: #1f2937;
    }

    .insight-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 12px 18px;
        color: #6b7280;
        font-size: 14px;
    }

    .insight-meta span {
        display: inline-flex;
        align-items: center;
        gap: 7px;
    }

    .score-ring {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 22px;
        color: #111827;
        border: 8px solid #dbeafe;
        background: #fff;
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
    }

    .score-success { border-color: #28a74555; }
    .score-info { border-color: #17a2b855; }
    .score-warning { border-color: #ffc10766; }
    .score-danger { border-color: #dc354566; }

    .prediction-card {
        border-radius: 18px;
    }

    .prediction-card .card-header,
    .score-read-header {
        display: flex !important;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: nowrap;
    }

    .prediction-card .card-header .badge,
    .score-read-header .btn {
        margin-left: auto;
        flex-shrink: 0;
    }

    .prediction-text {
        font-size: 15px;
        line-height: 1.8;
        color: #374151;
        font-weight: 500;
    }

    .prediction-subtitle {
        font-size: 16px;
        font-weight: 700;
    }

    .prediction-list {
        margin: 0;
        padding-left: 18px;
    }

    .prediction-list li {
        margin-bottom: 10px;
        line-height: 1.6;
        color: #4b5563;
    }

    .score-mini-card {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 18px 10px;
        height: 100%;
    }

    .score-mini-global {
        background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
        border-color: #bfdbfe;
    }

    .score-mini-value {
        font-size: 28px;
        font-weight: 800;
        color: #111827;
    }

    .score-mini-label {
        margin-top: 6px;
        font-size: 13px;
        font-weight: 600;
        color: #6b7280;
    }

    @media (max-width: 767px) {
        .prediction-card .card-header,
        .score-read-header {
            flex-wrap: wrap;
        }

        .prediction-card .card-header .badge,
        .score-read-header .btn {
            margin-left: 0;
        }
    }
</style>

    <style>
        .insight-hero-card {
            border-radius: 18px;
            background: linear-gradient(135deg, #f8fbff 0%, #eef4ff 100%);
        }

        .insight-title {
            font-weight: 800;
            color: #1f2937;
        }

        .insight-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px 18px;
            color: #6b7280;
            font-size: 14px;
        }

        .insight-meta span {
            display: inline-flex;
            align-items: center;
            gap: 7px;
        }

        .score-ring {
            width: 110px;
            height: 110px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 22px;
            color: #111827;
            border: 8px solid #dbeafe;
            background: #fff;
            box-shadow: 0 10px 30px rgba(0,0,0,0.06);
        }

        .score-success { border-color: #28a74555; }
        .score-info { border-color: #17a2b855; }
        .score-warning { border-color: #ffc10766; }
        .score-danger { border-color: #dc354566; }

        .prediction-card {
            border-radius: 18px;
        }

        .prediction-text {
            font-size: 15px;
            line-height: 1.8;
            color: #374151;
            font-weight: 500;
        }

        .prediction-subtitle {
            font-size: 16px;
            font-weight: 700;
        }

        .prediction-list {
            margin: 0;
            padding-left: 18px;
        }

        .prediction-list li {
            margin-bottom: 10px;
            line-height: 1.6;
            color: #4b5563;
        }

        .score-mini-card {
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 18px 10px;
            height: 100%;
        }

        .score-mini-global {
            background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
            border-color: #bfdbfe;
        }

        .score-mini-value {
            font-size: 28px;
            font-weight: 800;
            color: #111827;
        }

        .score-mini-label {
            margin-top: 6px;
            font-size: 13px;
            font-weight: 600;
            color: #6b7280;
        }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const statusCtx = document.getElementById('statusChart');
        const weeklyCtx = document.getElementById('weeklyChart');
        const qualityCtx = document.getElementById('qualityChart');

        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: ['Acceptées', 'En attente', 'Refusées'],
                datasets: [{
                    data: [{{ acceptedCount }}, {{ pendingCount }}, {{ refusedCount }}],
                    backgroundColor: ['#28a745', '#ffc107', '#dc3545'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

        new Chart(weeklyCtx, {
            type: 'line',
            data: {
                labels: {{ weeklyLabels|json_encode|raw }},
                datasets: [{
                    label: 'Candidatures',
                    data: {{ weeklyCounts|json_encode|raw }},
                    borderColor: '#3b82f6',
                    backgroundColor: 'rgba(59,130,246,0.12)',
                    fill: true,
                    tension: 0.35,
                    pointBackgroundColor: '#2563eb',
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            precision: 0
                        }
                    }
                }
            }
        });

        new Chart(qualityCtx, {
            type: 'radar',
            data: {
                labels: ['Clarté', 'Attractivité', 'Transparence', 'Compétitivité', 'Crédibilité'],
                datasets: [{
                    label: 'Score',
                    data: [
                        {{ insights.scores.clarity }},
                        {{ insights.scores.attractiveness }},
                        {{ insights.scores.transparency }},
                        {{ insights.scores.competitiveness }},
                        {{ insights.scores.credibility }}
                    ],
                    borderColor: '#111827',
                    backgroundColor: 'rgba(17,24,39,0.12)',
                    pointBackgroundColor: '#111827',
                    pointRadius: 3
                }]
            },
            options: {
                responsive: true,
                scales: {
                    r: {
                        beginAtZero: true,
                        min: 0,
                        max: 100,
                        ticks: {
                            stepSize: 20
                        }
                    }
                },
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });
    </script>
{% endblock %}