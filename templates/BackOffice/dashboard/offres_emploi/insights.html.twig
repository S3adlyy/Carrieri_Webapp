{% extends 'BackOffice/base.html.twig' %}

{% block title %}Insights offre{% endblock %}
{% block page_title %}Analyse d'offre{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_offres_list') }}">Offres d'emploi</a></li>
    <li class="breadcrumb-item active">Insights</li>
{% endblock %}

{% block body %}
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 insight-hero-card">
                <div class="card-body hero-body">
                    <div class="hero-left">
                        <div class="text-muted small mb-2">Analyse intelligente de l'offre</div>

                        <div class="hero-title-row">
                            <h2 class="mb-0 insight-title">{{ offre.titre }}</h2>

                            <div class="score-inline score-{{ insights.level_color }}">
                                <div class="premium-score-ring">
                                    <svg class="score-svg" viewBox="0 0 120 120">
                                        <defs>
                                            <linearGradient id="scoreGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#60a5fa"/>
                                                <stop offset="50%" stop-color="#8b5cf6"/>
                                                <stop offset="100%" stop-color="#22c55e"/>
                                            </linearGradient>
                                        </defs>

                                        <circle class="score-track" cx="60" cy="60" r="48"></circle>
                                        <circle
                                            class="score-progress"
                                            cx="60"
                                            cy="60"
                                            r="48"
                                            style="stroke-dasharray: 301.59; stroke-dashoffset: calc(301.59 - (301.59 * {{ insights.scores.global }}) / 100);"
                                        ></circle>
                                    </svg>

                                    <div class="score-center">
                                        <span class="score-value">{{ insights.scores.global }}</span>
                                        <span class="score-total">/100</span>
                                    </div>
                                </div>

                                <div class="score-side">
                                    <div class="score-side-label">Score global</div>
                                    <div class="score-level-badge score-level-{{ insights.level_color }}">
                                        {{ insights.level }}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="insight-meta mt-3">
                            <span><i class="fas fa-building"></i> {{ offre.entreprise }}</span>
                            <span><i class="fas fa-map-marker-alt"></i> {{ offre.localisation }}</span>
                            <span><i class="fas fa-file-contract"></i> {{ offre.typeContrat }}</span>
                            <span><i class="fas fa-briefcase"></i> {{ offre.secteurActivite }}</span>
                        </div>
                    </div>

                    <div class="hero-right">
                        <div class="insight-top-actions">
                            <a href="{{ path('app_admin_offres_insights_export_pdf', {'id': offre.id}) }}" class="btn btn-outline-danger btn-sm export-top-btn">
                                <i class="fas fa-file-pdf"></i>
                                <span>Export PDF</span>
                            </a>

                            <a href="{{ path('app_admin_offres_insights_export_excel', {'id': offre.id}) }}" class="btn btn-outline-success btn-sm export-top-btn">
                                <i class="fas fa-file-excel"></i>
                                <span>Export Excel</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="small-box bg-info">
                <div class="inner">
                    <h3>{{ insights.stats.total_postulations }}</h3>
                    <p>Total postulations</p>
                </div>
                <div class="icon"><i class="fas fa-users"></i></div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="small-box bg-success">
                <div class="inner">
                    <h3>{{ acceptedCount }}</h3>
                    <p>Acceptées</p>
                </div>
                <div class="icon"><i class="fas fa-check-circle"></i></div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="small-box bg-warning">
                <div class="inner">
                    <h3>{{ pendingCount }}</h3>
                    <p>En attente</p>
                </div>
                <div class="icon"><i class="fas fa-hourglass-half"></i></div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="small-box bg-danger">
                <div class="inner">
                    <h3>{{ refusedCount }}</h3>
                    <p>Refusées</p>
                </div>
                <div class="icon"><i class="fas fa-times-circle"></i></div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white">
                    <h3 class="card-title mb-0">Répartition des candidatures</h3>
                </div>
                <div class="card-body">
                    <canvas id="statusChart" height="240"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white">
                    <h3 class="card-title mb-0">Tendance des candidatures (6 dernières semaines)</h3>
                </div>
                <div class="card-body">
                    <canvas id="weeklyChart" height="240"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white">
                    <h3 class="card-title mb-0">Radar qualité de l’offre</h3>
                </div>
                <div class="card-body">
                    <canvas id="qualityChart" height="260"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100 prediction-card">
                <div class="card-header bg-white prediction-header">
                    <h3 class="card-title mb-0">Prédiction & remarques</h3>
                    <span class="badge ai-badge">IA heuristique</span>
                </div>
                <div class="card-body">
                    <div class="prediction-text">
                        {{ insights.prediction }}
                    </div>

                    <hr>

                    <h5 class="prediction-subtitle text-success">
                        <i class="fas fa-thumbs-up"></i> Points forts
                    </h5>
                    <ul class="prediction-list">
                        {% for item in insights.strengths %}
                            <li>{{ item }}</li>
                        {% else %}
                            <li>Base correcte, mais l’offre peut encore être davantage différenciée.</li>
                        {% endfor %}
                    </ul>

                    <h5 class="prediction-subtitle text-danger mt-4">
                        <i class="fas fa-exclamation-triangle"></i> Axes d’amélioration
                    </h5>
                    <ul class="prediction-list">
                        {% for item in insights.remarks %}
                            <li>{{ item }}</li>
                        {% else %}
                            <li>L’offre est déjà bien structurée.</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white score-read-header">
            <h3 class="card-title mb-0">Lecture rapide du score</h3>

            <div class="score-read-actions">
                <a href="{{ path('app_admin_offres_list') }}" class="btn btn-outline-primary btn-sm retour-offres-btn">
                    <i class="fas fa-arrow-left"></i>
                    <span>Retour aux offres</span>
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="row text-center">
                <div class="col-md-2 col-6 mb-3">
                    <div class="score-mini-card">
                        <div class="score-mini-value">{{ insights.scores.clarity }}</div>
                        <div class="score-mini-label">Clarté</div>
                    </div>
                </div>
                <div class="col-md-2 col-6 mb-3">
                    <div class="score-mini-card">
                        <div class="score-mini-value">{{ insights.scores.attractiveness }}</div>
                        <div class="score-mini-label">Attractivité</div>
                    </div>
                </div>
                <div class="col-md-2 col-6 mb-3">
                    <div class="score-mini-card">
                        <div class="score-mini-value">{{ insights.scores.transparency }}</div>
                        <div class="score-mini-label">Transparence</div>
                    </div>
                </div>
                <div class="col-md-2 col-6 mb-3">
                    <div class="score-mini-card">
                        <div class="score-mini-value">{{ insights.scores.competitiveness }}</div>
                        <div class="score-mini-label">Compétitivité</div>
                    </div>
                </div>
                <div class="col-md-2 col-6 mb-3">
                    <div class="score-mini-card">
                        <div class="score-mini-value">{{ insights.scores.credibility }}</div>
                        <div class="score-mini-label">Crédibilité</div>
                    </div>
                </div>
                <div class="col-md-2 col-6 mb-3">
                    <div class="score-mini-card score-mini-global">
                        <div class="score-mini-value">{{ insights.scores.global }}</div>
                        <div class="score-mini-label">Global</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .insight-hero-card {
            border-radius: 22px;
            background: linear-gradient(135deg, #f8fbff 0%, #eef4ff 55%, #f8fbff 100%);
            overflow: hidden;
        }

        .hero-body {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 28px;
            flex-wrap: nowrap;
        }

        .hero-left {
            flex: 1;
            min-width: 0;
        }

        .hero-right {
            margin-left: auto;
            display: flex;
            align-items: flex-start;
            justify-content: flex-end;
            flex-shrink: 0;
        }

        .hero-title-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
            flex-wrap: wrap;
        }

        .insight-title {
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.02em;
            margin: 0;
        }

        .insight-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px 18px;
            color: #6b7280;
            font-size: 14px;
        }

        .insight-meta span {
            display: inline-flex;
            align-items: center;
            gap: 7px;
        }

        .score-inline {
            display: inline-flex;
            align-items: center;
            gap: 16px;
            padding: 10px 16px 10px 10px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
            backdrop-filter: blur(10px);
            box-shadow: 0 10px 35px rgba(59, 130, 246, 0.10);
            border: 1px solid rgba(148, 163, 184, 0.18);
            position: relative;
            overflow: hidden;
        }

        .score-inline::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, rgba(96,165,250,0.06), rgba(139,92,246,0.06), rgba(34,197,94,0.06));
            pointer-events: none;
        }

        .premium-score-ring {
            position: relative;
            width: 92px;
            height: 92px;
            flex-shrink: 0;
            filter: drop-shadow(0 0 14px rgba(96, 165, 250, 0.18));
        }

        .score-svg {
            width: 92px;
            height: 92px;
            transform: rotate(-90deg);
        }

        .score-track {
            fill: none;
            stroke: #e5eefc;
            stroke-width: 9;
        }

        .score-progress {
            fill: none;
            stroke: url(#scoreGradient);
            stroke-width: 9;
            stroke-linecap: round;
            transition: stroke-dashoffset 1.2s ease;
            animation: scorePulse 2.8s ease-in-out infinite alternate;
        }

        .score-center {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0f172a;
            font-weight: 800;
            z-index: 2;
        }

        .score-value {
            font-size: 24px;
            line-height: 1;
        }

        .score-total {
            font-size: 18px;
            line-height: 1;
            margin-left: 1px;
        }

        .score-side {
            display: flex;
            flex-direction: column;
            gap: 7px;
            position: relative;
            z-index: 2;
        }

        .score-side-label {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #64748b;
        }

        .score-level-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: fit-content;
            padding: 8px 14px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 800;
            white-space: nowrap;
            box-shadow: 0 6px 16px rgba(15, 23, 42, 0.08);
        }

        .score-level-success {
            background: #dcfce7;
            color: #166534;
        }

        .score-level-info {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .score-level-warning {
            background: #fef3c7;
            color: #b45309;
        }

        .score-level-danger {
            background: #fee2e2;
            color: #b91c1c;
        }

        .insight-top-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 10px;
            flex-wrap: wrap;
        }

        .export-top-btn {
            min-width: 145px;
            height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border-radius: 12px;
            font-weight: 700;
            background: #fff !important;
            box-shadow: none !important;
        }

        .export-top-btn.btn-outline-danger:hover {
            background: #fff5f5 !important;
        }

        .export-top-btn.btn-outline-success:hover {
            background: #f0fdf4 !important;
        }

        .prediction-card {
            border-radius: 18px;
        }

        .prediction-header,
        .score-read-header {
            display: flex !important;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            width: 100%;
            flex-wrap: nowrap;
            background: #ffffff !important;
            border-bottom: 1px solid #eef2f7;
        }

        .prediction-header .card-title,
        .score-read-header .card-title {
            margin: 0;
            color: #1f2937;
            font-weight: 700;
        }

        .ai-badge {
            margin-left: auto;
            flex-shrink: 0;
            background: #111827 !important;
            color: #ffffff !important;
            border-radius: 999px;
            padding: 8px 12px;
            font-size: 12px;
            font-weight: 700;
        }

        .prediction-text {
            font-size: 15px;
            line-height: 1.8;
            color: #374151;
            font-weight: 500;
        }

        .prediction-subtitle {
            font-size: 16px;
            font-weight: 700;
        }

        .prediction-list {
            margin: 0;
            padding-left: 18px;
        }

        .prediction-list li {
            margin-bottom: 10px;
            line-height: 1.6;
            color: #4b5563;
        }

        .score-read-actions {
            margin-left: auto;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            flex-shrink: 0;
        }

        .retour-offres-btn {
            margin-left: auto;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-width: 170px;
            height: 38px;
            border-radius: 10px;
            font-weight: 600;
            background: transparent !important;
            color: #2563eb !important;
            border: 1px solid #bfdbfe !important;
            box-shadow: none !important;
        }

        .retour-offres-btn:hover {
            background: #eff6ff !important;
            color: #1d4ed8 !important;
            border-color: #93c5fd !important;
        }

        .score-mini-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 18px 10px;
            height: 100%;
            box-shadow: none;
        }

        .score-mini-global {
            background: #f8fbff;
            border-color: #bfdbfe;
        }

        .score-mini-value {
            font-size: 28px;
            font-weight: 800;
            color: #111827;
        }

        .score-mini-label {
            margin-top: 6px;
            font-size: 13px;
            font-weight: 600;
            color: #6b7280;
        }

        @keyframes scorePulse {
            0% {
                filter: drop-shadow(0 0 0 rgba(96, 165, 250, 0.10));
            }
            100% {
                filter: drop-shadow(0 0 12px rgba(139, 92, 246, 0.22));
            }
        }

        @media (max-width: 991px) {
            .hero-body {
                flex-wrap: wrap;
            }

            .hero-right {
                width: 100%;
                justify-content: flex-start;
                margin-left: 0;
            }

            .hero-title-row {
                align-items: flex-start;
            }
        }

        @media (max-width: 767px) {
            .hero-title-row {
                flex-direction: column;
                align-items: flex-start;
            }

         .score-inline-old {
        display: inline-flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .score-ring-old {
        width: 92px;
        height: 92px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 20px;
        color: #111827;
        background: #fff;
        border: 8px solid #f5d97a;
        box-shadow: 0 8px 18px rgba(245, 217, 122, 0.18);
    }

    .score-level-badge-old {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        padding: 11px 18px;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 800;
        white-space: nowrap;
    }

    .score-level-success {
        background: #dcfce7;
        color: #166534;
    }

    .score-level-info {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .score-level-warning {
        background: #facc15;
        color: #1f2937;
    }

    .score-level-danger {
        background: #fee2e2;
        color: #b91c1c;
    }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const statusCtx = document.getElementById('statusChart');
        const weeklyCtx = document.getElementById('weeklyChart');
        const qualityCtx = document.getElementById('qualityChart');

        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: ['Acceptées', 'En attente', 'Refusées'],
                datasets: [{
                    data: [{{ acceptedCount }}, {{ pendingCount }}, {{ refusedCount }}],
                    backgroundColor: ['#28a745', '#ffc107', '#dc3545'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

        new Chart(weeklyCtx, {
            type: 'line',
            data: {
                labels: {{ weeklyLabels|json_encode|raw }},
                datasets: [{
                    label: 'Candidatures',
                    data: {{ weeklyCounts|json_encode|raw }},
                    borderColor: '#3b82f6',
                    backgroundColor: 'rgba(59,130,246,0.12)',
                    fill: true,
                    tension: 0.35,
                    pointBackgroundColor: '#2563eb',
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            precision: 0
                        }
                    }
                }
            }
        });

        new Chart(qualityCtx, {
            type: 'radar',
            data: {
                labels: ['Clarté', 'Attractivité', 'Transparence', 'Compétitivité', 'Crédibilité'],
                datasets: [{
                    label: 'Score',
                    data: [
                        {{ insights.scores.clarity }},
                        {{ insights.scores.attractiveness }},
                        {{ insights.scores.transparency }},
                        {{ insights.scores.competitiveness }},
                        {{ insights.scores.credibility }}
                    ],
                    borderColor: '#111827',
                    backgroundColor: 'rgba(17,24,39,0.12)',
                    pointBackgroundColor: '#111827',
                    pointRadius: 3
                }]
            },
            options: {
                responsive: true,
                scales: {
                    r: {
                        beginAtZero: true,
                        min: 0,
                        max: 100,
                        ticks: {
                            stepSize: 20
                        }
                    }
                },
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });
    </script>
{% endblock %}