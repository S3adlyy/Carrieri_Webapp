{% extends 'BackOffice/base.html.twig' %}

{% block title %}Créer une offre d'emploi{% endblock %}
{% block page_title %}Créer une offre{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_offres_list') }}">Offres d'emploi</a></li>
    <li class="breadcrumb-item active">Créer</li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Nouvelle offre d'emploi</h3>
        </div>
        <div class="card-body">

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert">&times;</button>
                    {{ message }}
                </div>
            {% endfor %}

            {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'offre-form', 'id': 'offreForm'}}) }}

            <div class="row">

                <div class="col-md-8">
                    <div class="form-group">
                        <div class="field-label-row">
                            {{ form_label(form.titre, null, {'label_attr': {'class': 'form-label fw-bold mb-0'}}) }}
                            <button type="button" id="generate-ai-title-btn" class="btn btn-success btn-sm ai-inline-btn">
                                🤖 Améliorer le titre
                            </button>
                        </div>
                        {{ form_widget(form.titre, {'attr': {
                            'class': 'form-control',
                            'data-required': 'true',
                            'data-minlength': '5',
                            'data-maxlength': '100',
                            'data-pattern': '^[a-zA-Z]',
                            'data-unique': 'true',
                            'data-field-name': 'Titre'
                        }}) }}
                        <small class="text-muted">Min 5 caractères, max 100. Ne peut pas commencer par un chiffre.</small>
                        <div class="invalid-feedback" style="display: none;"></div>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <div class="field-label-row">
                    {{ form_label(form.description, null, {'label_attr': {'class': 'form-label fw-bold mb-0'}}) }}
                    <button type="button" id="generate-ai-description-btn" class="btn btn-success btn-sm ai-inline-btn">
                        🤖 Générer la description
                    </button>
                </div>
                {{ form_widget(form.description, {'attr': {
                    'class': 'form-control',
                    'rows': 5,
                    'data-required': 'true',
                    'data-minlength': '10',
                    'data-pattern': '^[a-zA-Z]',
                    'data-field-name': 'Description'
                }}) }}
                <small class="text-muted">Min 10 caractères. Ne peut pas commencer par un chiffre.</small>
                <div class="invalid-feedback" style="display: none;"></div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.entreprise, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.entreprise, {'attr': {
                            'class': 'form-control',
                            'data-required': 'true',
                            'data-field-name': 'Entreprise'
                        }}) }}
                        <div class="invalid-feedback" style="display: none;"></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.localisation, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.localisation, {'attr': {
                            'class': 'form-control',
                            'data-required': 'true',
                            'data-field-name': 'Localisation'
                        }}) }}
                        <div class="invalid-feedback" style="display: none;"></div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group">
                        {{ form_label(form.typeContrat, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.typeContrat, {'attr': {
                            'class': 'form-control',
                            'data-required': 'true',
                            'data-field-name': 'Type contrat'
                        }}) }}
                        <div class="invalid-feedback" style="display: none;"></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        {{ form_label(form.salaire, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.salaire, {'attr': {
                            'class': 'form-control',
                            'data-required': 'true',
                            'data-type': 'number',
                            'data-min': '0',
                            'data-field-name': 'Salaire'
                        }}) }}
                        <div class="invalid-feedback" style="display: none;"></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        {{ form_label(form.niveauQualification, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.niveauQualification, {'attr': {
                            'class': 'form-control',
                            'data-required': 'true',
                            'data-field-name': 'Niveau qualification'
                        }}) }}
                        <div class="invalid-feedback" style="display: none;"></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        {{ form_label(form.experienceRequise, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.experienceRequise, {'attr': {
                            'class': 'form-control',
                            'data-required': 'true',
                            'data-field-name': 'Expérience requise'
                        }}) }}
                        <div class="invalid-feedback" style="display: none;"></div>
                    </div>
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.competencesRequises, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.competencesRequises, {'attr': {
                    'class': 'form-control',
                    'rows': 3,
                    'data-required': 'true',
                    'data-minlength': '10',
                    'data-field-name': 'Compétences requises'
                }}) }}
                <small class="text-muted">Min 10 caractères.</small>
                <div class="invalid-feedback" style="display: none;"></div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.secteurActivite, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.secteurActivite, {'attr': {
                            'class': 'form-control',
                            'data-required': 'true',
                            'data-field-name': 'Secteur activité'
                        }}) }}
                        <div class="invalid-feedback" style="display: none;"></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.contactRecruteur, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.contactRecruteur, {'attr': {
                            'class': 'form-control',
                            'data-required': 'true',
                            'data-type': 'email',
                            'data-field-name': 'Contact recruteur'
                        }}) }}
                        <div class="invalid-feedback" style="display: none;"></div>
                    </div>
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.dateExpiration, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.dateExpiration, {'attr': {
                    'class': 'form-control',
                    'data-required': 'true',
                    'data-future': 'true',
                    'data-field-name': 'Date expiration'
                }}) }}
                <small class="text-muted"><i class="fas fa-info-circle"></i> La date doit être dans le futur</small>
                <div class="invalid-feedback" style="display: none;"></div>
            </div>

            <div class="form-actions mt-4 pt-3" style="border-top: 1px solid #e2e8f0;">
                <button type="submit" class="btn btn-primary" id="submitBtn">
                    <i class="fas fa-save"></i> Créer l'offre
                </button>
                <a href="{{ path('app_admin_offres_list') }}" class="btn btn-secondary ml-2">
                    <i class="fas fa-times"></i> Annuler
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>

    <div id="aiTitleModal" class="ai-modal-overlay" hidden>
        <div class="ai-modal-card" role="dialog" aria-modal="true" aria-labelledby="aiTitleModalLabel">
            <div class="ai-modal-badge">🤖 Suggestion IA</div>
            <h4 id="aiTitleModalLabel" class="ai-modal-title">Conserver ce titre proposé ?</h4>
            <p class="ai-modal-text">L'IA a préparé une amélioration du titre actuel. Vous pouvez l'accepter ou garder votre version.</p>
            <div class="ai-modal-suggestion" id="aiTitleSuggestion"></div>
            <div class="ai-modal-actions">
                <button type="button" class="btn btn-light ai-modal-cancel" id="aiTitleCancelBtn">Garder mon titre</button>
                <button type="button" class="btn btn-success ai-modal-confirm" id="aiTitleConfirmBtn">Utiliser ce titre</button>
            </div>
        </div>
    </div>

    <div id="appMessageModal" class="ai-modal-overlay" hidden>
        <div class="ai-modal-card ai-message-card" role="alertdialog" aria-modal="true" aria-labelledby="appMessageTitle">
            <div id="appMessageBadge" class="ai-modal-badge ai-message-badge">Information</div>
            <h4 id="appMessageTitle" class="ai-modal-title">Message</h4>
            <p id="appMessageText" class="ai-modal-text mb-0"></p>
            <div class="ai-modal-actions">
                <button type="button" class="btn btn-success ai-modal-confirm" id="appMessageOkBtn">OK</button>
            </div>
        </div>
    </div>

    <style>
        .form-control.is-invalid {
            border-color: #dc2626 !important;
            background-color: #fef2f2 !important;
        }
        .invalid-feedback {
            display: block;
            color: #dc2626;
            font-size: 12px;
            margin-top: 5px;
            padding: 6px 12px;
            background-color: #fef2f2;
            border-radius: 6px;
            border-left: 3px solid #dc2626;
        }
        .form-group {
            margin-bottom: 1rem;
        }
        .form-label {
            margin-bottom: 0.5rem;
        }
        .field-label-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            margin-bottom: 0.5rem;
        }
        .ai-inline-btn {
            white-space: nowrap;
            border-radius: 999px;
            padding: 0.45rem 0.95rem;
            font-weight: 600;
            box-shadow: 0 8px 20px rgba(40, 167, 69, 0.16);
        }
        .ai-modal-overlay {
            position: fixed;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            background: rgba(15, 23, 42, 0.52);
            backdrop-filter: blur(4px);
            z-index: 1050;
        }
        .ai-modal-card {
            width: min(100%, 520px);
            padding: 1.5rem;
            border-radius: 18px;
            background: #ffffff;
            box-shadow: 0 30px 80px rgba(15, 23, 42, 0.22);
        }
        .ai-modal-badge {
            display: inline-flex;
            align-items: center;
            padding: 0.35rem 0.7rem;
            margin-bottom: 0.9rem;
            border-radius: 999px;
            background: #e8f7ec;
            color: #1f7a35;
            font-size: 0.82rem;
            font-weight: 700;
        }
        .ai-modal-title {
            margin-bottom: 0.5rem;
            font-size: 1.35rem;
            font-weight: 700;
            color: #102a43;
        }
        .ai-modal-text {
            margin-bottom: 1rem;
            color: #52606d;
            line-height: 1.6;
        }
        .ai-modal-suggestion {
            padding: 1rem 1.1rem;
            margin-bottom: 1.15rem;
            border: 1px solid #cfe8d6;
            border-radius: 14px;
            background: linear-gradient(135deg, #f8fff9 0%, #eefaf1 100%);
            color: #163a24;
            font-size: 1.02rem;
            font-weight: 600;
            line-height: 1.5;
        }
        .ai-modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 0.75rem;
        }
        .ai-modal-cancel,
        .ai-modal-confirm {
            min-width: 150px;
            border-radius: 999px;
            font-weight: 600;
        }
        .ai-message-card {
            width: min(100%, 460px);
        }
        .ai-message-badge.is-warning {
            background: #fff4db;
            color: #9a6700;
        }
        .ai-message-badge.is-error {
            background: #fde8e8;
            color: #b42318;
        }
        .ai-generator-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1rem 1.25rem;
            border: 1px solid #dbe7f3;
            border-radius: 12px;
            background: linear-gradient(135deg, #f8fbff 0%, #f3f9f4 100%);
        }
        .ai-generator-copy {
            flex: 0 0 260px;
        }
        .ai-generator-title {
            margin-bottom: 0.25rem;
            font-size: 1rem;
            font-weight: 700;
            color: #1f2937;
        }
        .ai-generator-controls {
            display: flex;
            align-items: center;
            justify-content: flex-end;
        }
        .ai-generate-btn {
            white-space: nowrap;
            border-radius: 10px;
            padding: 0.75rem 1.1rem;
            font-weight: 600;
            box-shadow: 0 8px 20px rgba(40, 167, 69, 0.18);
        }
        @media (max-width: 767.98px) {
            .field-label-row {
                flex-direction: column;
                align-items: flex-start;
            }
            .ai-modal-actions {
                flex-direction: column-reverse;
            }
            .ai-modal-cancel,
            .ai-modal-confirm {
                width: 100%;
            }
            .ai-generator-card,
            .ai-generator-controls {
                flex-direction: column;
                align-items: flex-start;
            }
            .ai-generator-copy,
            .ai-generate-btn {
                width: 100%;
            }
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('offreForm');
            const fields = document.querySelectorAll('[data-required], [data-minlength], [data-maxlength], [data-pattern], [data-type], [data-unique], [data-future]');
            
            let hasBeenSubmitted = false;
            
            // Vérifier l'unicité du titre (AJAX)
            async function checkUniqueTitre(titre, currentId = null) {
                try {
                    const response = await fetch('{{ path('app_admin_offres_check_unique_titre') }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({
                            titre: titre,
                            id: currentId
                        })
                    });
                    const data = await response.json();
                    return data.valid;
                } catch (error) {
                    console.error('Erreur lors de la vérification du titre:', error);
                    return true;
                }
            }
            
            // Validation d'un champ (retourne les erreurs)
            async function getFieldErrors(field) {
                const value = field.value.trim();
                const fieldName = field.dataset.fieldName || field.name;
                let errors = [];
                
                // Requis
                if (field.dataset.required === 'true' && !value) {
                    errors.push(`Le champ "${fieldName}" est obligatoire.`);
                }
                
                if (value) {
                    // Longueur minimale
                    if (field.dataset.minlength && value.length < parseInt(field.dataset.minlength)) {
                        errors.push(`Le champ "${fieldName}" doit contenir au moins ${field.dataset.minlength} caractères.`);
                    }
                    
                    // Longueur maximale
                    if (field.dataset.maxlength && value.length > parseInt(field.dataset.maxlength)) {
                        errors.push(`Le champ "${fieldName}" ne doit pas dépasser ${field.dataset.maxlength} caractères.`);
                    }
                    
                    // Pattern (ne pas commencer par un chiffre)
                    if (field.dataset.pattern && !new RegExp(field.dataset.pattern).test(value)) {
                        errors.push(`Le champ "${fieldName}" ne peut pas commencer par un chiffre.`);
                    }
                    
                    // Type number
                    if (field.dataset.type === 'number' && (isNaN(parseFloat(value)) || !isFinite(value))) {
                        errors.push(`Le champ "${fieldName}" doit être un nombre valide.`);
                    }
                    
                    // Min value
                    if (field.dataset.min !== undefined && parseFloat(value) < parseFloat(field.dataset.min)) {
                        errors.push(`Le champ "${fieldName}" doit être supérieur ou égal à ${field.dataset.min}.`);
                    }
                    
                    // Email
                    if (field.dataset.type === 'email' && !/^[^\s@]+@([^\s@.,]+\.)+[^\s@.,]{2,}$/.test(value)) {
                        errors.push(`Le champ "${fieldName}" doit être une adresse email valide.`);
                    }
                    
                    // Unicité du titre
                    if (field.dataset.unique === 'true' && value) {
                        const isUnique = await checkUniqueTitre(value, null);
                        if (!isUnique) {
                            errors.push('Ce titre d\'offre existe déjà. Veuillez choisir un titre unique.');
                        }
                    }
                    
                    // Date dans le futur
                    if (field.dataset.future === 'true' && value) {
                        const selectedDate = new Date(value);
                        const now = new Date();
                        if (selectedDate <= now) {
                            errors.push(`La ${fieldName} doit être dans le futur.`);
                        }
                    }
                }
                
                return errors;
            }
            
            // Mettre à jour l'affichage d'un champ
            async function updateFieldDisplay(field) {
                const errors = await getFieldErrors(field);
                const feedbackDiv = field.closest('.form-group').querySelector('.invalid-feedback');
                
                if (errors.length > 0) {
                    field.classList.add('is-invalid');
                    if (feedbackDiv) {
                        feedbackDiv.textContent = errors[0];
                        feedbackDiv.style.display = 'block';
                    }
                    return false;
                } else {
                    field.classList.remove('is-invalid');
                    if (feedbackDiv) {
                        feedbackDiv.style.display = 'none';
                        feedbackDiv.textContent = '';
                    }
                    return true;
                }
            }
            
            // Valider tous les champs et mettre à jour l'affichage
            async function validateAndUpdateAll() {
                let isValid = true;
                for (const field of fields) {
                    const isFieldValid = await updateFieldDisplay(field);
                    if (!isFieldValid) isValid = false;
                }
                return isValid;
            }
            
            // Écouter les événements input - réévalue et met à jour l'affichage SEULEMENT si déjà soumis
            fields.forEach(field => {
                field.addEventListener('input', async function() {
                    if (hasBeenSubmitted) {
                        await updateFieldDisplay(this);
                    }
                });
                field.addEventListener('change', async function() {
                    if (hasBeenSubmitted) {
                        await updateFieldDisplay(this);
                    }
                });
            });
            
            // Validation UNIQUEMENT à la soumission
            form.addEventListener('submit', async function(e) {
                e.preventDefault(); // Temporairement empêcher la soumission pour validation
                
                hasBeenSubmitted = true;
                const isValid = await validateAndUpdateAll();
                
                if (!isValid) {
                    const firstInvalid = document.querySelector('.is-invalid');
                    if (firstInvalid) {
                        firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        firstInvalid.focus();
                    }
                    
                    if (typeof window.showAppMessage === 'function') {
                        window.showAppMessage(
                            'Erreurs de validation',
                            'Veuillez corriger les erreurs avant de soumettre le formulaire.',
                            'error'
                        );
                    }
                } else {
                    // Si tout est valide, soumettre le formulaire
                    form.submit();
                }
            });
        });
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const titleInput = document.querySelector('[name="offre_emploi[titre]"]');
            const titleButton = document.getElementById('generate-ai-title-btn');
            const descriptionButton = document.getElementById('generate-ai-description-btn');
            const modal = document.getElementById('aiTitleModal');
            const suggestionBox = document.getElementById('aiTitleSuggestion');
            const confirmBtn = document.getElementById('aiTitleConfirmBtn');
            const cancelBtn = document.getElementById('aiTitleCancelBtn');
            const messageModal = document.getElementById('appMessageModal');
            const messageBadge = document.getElementById('appMessageBadge');
            const messageTitle = document.getElementById('appMessageTitle');
            const messageText = document.getElementById('appMessageText');
            const messageOkBtn = document.getElementById('appMessageOkBtn');

            let pendingSuggestedTitle = '';

            function openTitleModal(suggestedTitle) {
                pendingSuggestedTitle = suggestedTitle;
                suggestionBox.textContent = suggestedTitle;
                modal.hidden = false;
                document.body.style.overflow = 'hidden';
            }

            function closeTitleModal() {
                modal.hidden = true;
                document.body.style.overflow = '';
                pendingSuggestedTitle = '';
            }

            function openMessageModal(title, text, tone = 'warning') {
                messageTitle.textContent = title;
                messageText.textContent = text;
                messageBadge.textContent = tone === 'error' ? 'Erreur' : 'Attention';
                messageBadge.classList.remove('is-warning', 'is-error');
                messageBadge.classList.add(tone === 'error' ? 'is-error' : 'is-warning');
                messageModal.hidden = false;
                document.body.style.overflow = 'hidden';
            }

            function closeMessageModal() {
                messageModal.hidden = true;
                document.body.style.overflow = '';
            }

            window.showAppMessage = openMessageModal;

            function collectTitlePayload() {
                return {
                    titre: titleInput?.value.trim() || '',
                    typeContrat: document.querySelector('[name="offre_emploi[typeContrat]"]')?.value || '',
                    entreprise: document.querySelector('[name="offre_emploi[entreprise]"]')?.value.trim() || '',
                    localisation: document.querySelector('[name="offre_emploi[localisation]"]')?.value.trim() || '',
                    experienceRequise: document.querySelector('[name="offre_emploi[experienceRequise]"]')?.value.trim() || '',
                    niveauQualification: document.querySelector('[name="offre_emploi[niveauQualification]"]')?.value.trim() || '',
                };
            }

            async function fetchAiTitleSuggestion() {
                const response = await fetch('{{ path('app_admin_offres_generate_ai') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        mode: 'title',
                        payload: collectTitlePayload()
                    })
                });

                const data = await response.json();

                if (!response.ok || data.error) {
                    throw new Error(data.error || 'La génération du titre a échoué.');
                }

                return data;
            }

            titleButton?.addEventListener('click', async function() {
                const originalLabel = this.innerHTML;
                this.disabled = true;
                this.innerHTML = '🤖 Analyse du titre...';

                try {
                    const data = await fetchAiTitleSuggestion();

                    if (!data.titre) {
                        throw new Error('Aucune suggestion de titre n’a été retournée.');
                    }

                    openTitleModal(data.titre);
                } catch (error) {
                    openMessageModal(
                        'Génération impossible',
                        error.message || 'La génération du titre a échoué.',
                        'error'
                    );
                } finally {
                    this.disabled = false;
                    this.innerHTML = originalLabel;
                }
            });

            confirmBtn?.addEventListener('click', function() {
                if (titleInput && pendingSuggestedTitle) {
                    titleInput.value = pendingSuggestedTitle;
                    titleInput.dispatchEvent(new Event('input', { bubbles: true }));
                }
                closeTitleModal();
            });

            cancelBtn?.addEventListener('click', closeTitleModal);
            messageOkBtn?.addEventListener('click', closeMessageModal);

            modal?.addEventListener('click', function(event) {
                if (event.target === modal) {
                    closeTitleModal();
                }
            });
            messageModal?.addEventListener('click', function(event) {
                if (event.target === messageModal) {
                    closeMessageModal();
                }
            });

            document.addEventListener('keydown', function(event) {
                if (event.key === 'Escape' && modal && !modal.hidden) {
                    closeTitleModal();
                }
                if (event.key === 'Escape' && messageModal && !messageModal.hidden) {
                    closeMessageModal();
                }
            });

            descriptionButton?.addEventListener('click', function() {
                openMessageModal(
                    'Fonction en préparation',
                    "Le popup du titre est prêt. L'étape suivante sera de brancher la génération IA de la description.",
                    'warning'
                );
            });
        });
    </script>


{% endblock %}
