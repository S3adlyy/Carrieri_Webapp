{# templates/BackOffice/dashboard/offres_emploi/index.html.twig #}
{% extends 'BackOffice/base.html.twig' %}

{% block title %}Gestion des offres d'emploi{% endblock %}

{% block page_title %}Offres d'emploi{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item active">Offres d'emploi</li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Liste des offres d'emploi</h3>
            <div class="card-tools">
                <button type="button" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus"></i> Ajouter une offre
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> Page en construction...
            </div>
            <p>La liste des offres d'emploi sera affichée ici prochainement.</p>
        </div>
    </div>
{% endblock %}