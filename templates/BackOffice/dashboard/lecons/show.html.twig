{# templates/BackOffice/dashboard/lecons/show.html.twig #}
{% extends 'BackOffice/base.html.twig' %}

{% block title %}Détail — {{ lecon.titre }}{% endblock %}
{% block page_title %}Détail de la leçon{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_lecons_index') }}">Leçons</a></li>
    <li class="breadcrumb-item active">{{ lecon.titre|default('Leçon') }}</li>
{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">{{ lecon.titre }}</h3>
                    <div class="card-tools">
                        {% set type_badges = {video: 'danger', texte: 'primary', quiz: 'success', pdf: 'warning'} %}
                        <span class="badge badge-{{ type_badges[lecon.type]|default('secondary') }}">
                            {{ lecon.type|default('—') }}
                        </span>
                    </div>
                </div>
                <div class="card-body">
                    <h5>Contenu</h5>
                    <div class="p-3 bg-light rounded mb-3">{{ lecon.contenu|default('—') }}</div>

                    {% if lecon.video %}
                        <h5>Vidéo</h5>
                        <p><a href="{{ lecon.video }}" target="_blank" class="btn btn-sm btn-danger">
                            <i class="fab fa-youtube mr-1"></i> Voir la vidéo
                        </a></p>
                    {% endif %}

                    {% if lecon.module %}
                        <h5>Module</h5>
                        <p>
                            <a href="{{ path('app_admin_modules_show', {id: lecon.module.id}) }}" class="btn btn-info btn-sm">
                                <i class="fas fa-layer-group mr-1"></i>{{ lecon.module.titre }}
                            </a>
                            {% if lecon.module.cours %}
                                &rarr;
                                <a href="{{ path('app_admin_cours_show', {id: lecon.module.cours.id}) }}" class="btn btn-secondary btn-sm">
                                    <i class="fas fa-book mr-1"></i>{{ lecon.module.cours.titre }}
                                </a>
                            {% endif %}
                        </p>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-info">
                <div class="card-header"><h3 class="card-title">Informations</h3></div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tr><th>ID</th><td>{{ lecon.id }}</td></tr>
                        <tr><th>Ordre</th><td>{{ lecon.ordre|default('—') }}</td></tr>
                        <tr><th>Type</th><td>{{ lecon.type|default('—') }}</td></tr>
                        <tr><th>Module ID</th><td>{{ lecon.moduleId|default('—') }}</td></tr>
                    </table>
                </div>
            </div>
            <a href="{{ path('app_admin_lecons_edit', {id: lecon.id}) }}" class="btn btn-warning btn-block">
                <i class="fas fa-edit mr-1"></i> Modifier
            </a>
            <form method="post" action="{{ path('app_admin_lecons_delete', {id: lecon.id}) }}"
                  onsubmit="return confirm('Supprimer cette leçon ?')" class="mt-2">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_lecon_' ~ lecon.id) }}">
                <button class="btn btn-danger btn-block" type="submit">
                    <i class="fas fa-trash mr-1"></i> Supprimer
                </button>
            </form>
            <a href="{{ path('app_admin_lecons_index') }}" class="btn btn-secondary btn-block mt-2">
                <i class="fas fa-arrow-left mr-1"></i> Retour
            </a>
        </div>
    </div>
{% endblock %}
