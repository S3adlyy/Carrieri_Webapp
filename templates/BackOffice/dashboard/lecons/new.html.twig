{# templates/BackOffice/dashboard/lecons/new.html.twig #}
{% extends 'BackOffice/base.html.twig' %}

{% block title %}Nouvelle leçon{% endblock %}
{% block page_title %}Nouvelle leçon{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_lecons_index') }}">Leçons</a></li>
    <li class="breadcrumb-item active">Nouvelle</li>
{% endblock %}

{% block body %}
    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Créer une nouvelle leçon</h3>
        </div>
        {{ form_start(form) }}
        <div class="card-body">
            {% if not is_admin_view|default(false) and selected_module is defined and selected_module %}
                <div class="alert alert-info">
                    Vous ajoutez une leçon au module: <strong>{{ selected_module.titre }}</strong>
                </div>
            {% endif %}
            <div class="form-group">
                {{ form_label(form.titre) }}
                {{ form_widget(form.titre) }}
                {{ form_errors(form.titre) }}
            </div>
            <div class="form-group">
                {{ form_label(form.contenu) }}
                {{ form_widget(form.contenu) }}
                {{ form_errors(form.contenu) }}
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.type) }}
                        {{ form_widget(form.type) }}
                        {{ form_errors(form.type) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.module) }}
                        {{ form_widget(form.module) }}
                        {{ form_errors(form.module) }}
                    </div>
                </div>
            </div>
            <div class="form-group">
                {{ form_label(form.video) }}
                {{ form_widget(form.video) }}
                {{ form_errors(form.video) }}
                <small class="form-text text-muted">Laisser vide si pas de vidéo.</small>
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save mr-1"></i> Enregistrer
            </button>
            <a href="{{ path('app_admin_lecons_index') }}" class="btn btn-secondary ml-2">
                <i class="fas fa-times mr-1"></i> Annuler
            </a>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
