{# templates/BackOffice/dashboard/entretiens/export_candidats_excel.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <title>Candidats acceptés</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
        }
        h1 {
            color: #333;
            border-bottom: 2px solid #007bff;
            padding-bottom: 10px;
        }
        .header-info {
            margin-bottom: 20px;
            color: #666;
            font-size: 12px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        th {
            background-color: #007bff;
            color: white;
            padding: 10px;
            text-align: left;
            font-size: 12px;
            border: 1px solid #ddd;
        }
        td {
            border: 1px solid #ddd;
            padding: 8px;
            font-size: 11px;
        }
        tr:nth-child(even) {
            background-color: #f9f9f9;
        }
        .footer {
            margin-top: 30px;
            text-align: center;
            font-size: 10px;
            color: #666;
            border-top: 1px solid #ddd;
            padding-top: 10px;
        }
    </style>
</head>
<body>
<h1>Liste des candidats acceptés</h1>
<div class="header-info">
    <p>Date d'export : {{ export_date }}</p>
    <p>Nombre total de candidats : <strong>{{ candidats|length }}</strong></p>
</div>

<table>
    <thead>
    <tr>
        <th>Candidat</th>
        <th>Email</th>
        <th>Mission</th>
        <th>Score</th>
        <th>Date de soumission</th>
        <th>Statut entretien</th>
    </tr>
    </thead>
    <tbody>
    {% for rendu in candidats %}
        <tr>
            <td>{{ rendu.user ? (rendu.user.firstName ~ ' ' ~ rendu.user.lastName)|trim : 'Candidat #' ~ rendu.candidatId }}</td>
            <td>{{ rendu.user ? rendu.user.email : '—' }}</td>
            <td>{{ rendu.mission.type }}</td>
            <td>{{ rendu.score|round }}%</td>
            <td>{{ rendu.dateRendu|date('d/m/Y H:i') }}</td>
            <td>
                {% set entretien = rendu.entretiens|first %}
                {% if entretien %}
                    {% if entretien.status == 'planifie' %}
                        Planifié
                    {% elseif entretien.status == 'effectue' %}
                        Effectué
                    {% elseif entretien.status == 'annule' %}
                        Annulé
                    {% endif %}
                {% else %}
                    Non planifié
                {% endif %}
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="6" style="text-align: center;">Aucun candidat trouvé</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

<div class="footer">
    <p>Généré par Carrieri Admin - {{ export_date }}</p>
</div>
</body>
</html>