{# templates/BackOffice/dashboard/missions/create.html.twig #}
{% extends 'BackOffice/base.html.twig' %}

{% block title %}Créer une nouvelle mission{% endblock %}

{% block page_title %}Créer une mission{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_missions_list') }}">Missions</a></li>
    <li class="breadcrumb-item active">Créer</li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Nouvelle mission</h3>
        </div>
        <div class="card-body">
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert">&times;</button>
                    {{ message }}
                </div>
            {% endfor %}

            {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'mission-form'}}) }}

            <div class="form-group">
                {{ form_label(form.description, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.description, {'attr': {
                    'class': 'form-control' ~ (form.description.vars.errors|length ? ' is-invalid' : ''),
                    'rows': 6,
                    'placeholder': 'Décrivez la mission en détail...'
                }}) }}
                <div class="form-hint">
                    <small class="text-muted">
                        <i class="fas fa-info-circle"></i>
                        Décrivez la mission en détail (minimum 10 caractères, maximum 2000 caractères)
                    </small>
                </div>
                <div class="character-counter" data-target="description">
                    <span id="desc-length">0</span> / 2000 caractères
                </div>
                {{ form_errors(form.description) }}
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.type, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.type, {'attr': {
                            'class': 'form-control' ~ (form.type.vars.errors|length ? ' is-invalid' : ''),
                            'placeholder': 'Ex: Développement, Design, Marketing...'
                        }}) }}
                        <div class="form-hint">
                            <small class="text-muted">
                                <i class="fas fa-tag"></i>
                                Type de mission (minimum 3 caractères)
                            </small>
                        </div>
                        {{ form_errors(form.type) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.scoreMin, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.scoreMin, {'attr': {
                            'class': 'form-control' ~ (form.scoreMin.vars.errors|length ? ' is-invalid' : ''),
                            'placeholder': 'Ex: 75',
                            'min': 0,
                            'max': 100
                        }}) }}
                        <div class="form-hint">
                            <small class="text-muted">
                                <i class="fas fa-chart-line"></i>
                                Score minimum requis (0-100)
                            </small>
                        </div>
                        <div class="score-preview">
                            <div class="score-bar">
                                <div class="score-fill" id="scoreFill" style="width: 0%"></div>
                            </div>
                            <span id="scoreValue" class="score-value-text">0</span>
                        </div>
                        {{ form_errors(form.scoreMin) }}
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Créer la mission
                </button>
                <a href="{{ path('app_admin_missions_list') }}" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Annuler
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>

    <style>
        /* Styles pour le formulaire */
        .mission-form .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            font-size: 14px;
            margin-bottom: 8px;
            color: #2c3e50;
            display: block;
        }

        .form-control {
            border-radius: 8px;
            border: 1px solid #d1d5db;
            padding: 10px 12px;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
            outline: none;
        }

        .form-control.is-invalid {
            border-color: #dc2626;
            background-color: #fef2f2;
        }

        .form-control.is-invalid:focus {
            border-color: #dc2626;
            box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
        }

        .form-hint {
            margin-top: 5px;
        }

        .invalid-feedback {
            display: block;
            color: #dc2626;
            font-size: 12px;
            margin-top: 5px;
            padding: 6px 12px;
            background-color: #fef2f2;
            border-radius: 6px;
            border-left: 3px solid #dc2626;
        }

        .character-counter {
            font-size: 11px;
            color: #6c757d;
            margin-top: 5px;
            text-align: right;
        }

        .character-counter.warning {
            color: #f59e0b;
        }

        .character-counter.danger {
            color: #dc2626;
        }

        /* Score preview */
        .score-preview {
            margin-top: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .score-bar {
            flex: 1;
            height: 8px;
            background-color: #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
        }

        .score-fill {
            height: 100%;
            background: linear-gradient(90deg, #667eea, #764ba2);
            border-radius: 10px;
            transition: width 0.3s ease;
        }

        .score-value-text {
            font-size: 12px;
            font-weight: 600;
            color: #667eea;
            min-width: 35px;
        }

        /* Actions */
        .form-actions {
            display: flex;
            gap: 10px;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
        }

        .btn {
            padding: 10px 24px;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.3s;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }

        .btn-secondary {
            background-color: #f1f5f9;
            border: 1px solid #e2e8f0;
            color: #475569;
        }

        .btn-secondary:hover {
            background-color: #e2e8f0;
        }

        /* Animation */
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }

        .is-invalid {
            animation: shake 0.3s ease;
        }
    </style>

    <script>
        // Compteur de caractères pour la description
        const descriptionField = document.getElementById('mission_description');
        const descLengthSpan = document.getElementById('desc-length');
        const charCounter = document.querySelector('.character-counter');

        function updateCharCount() {
            if (descriptionField) {
                const length = descriptionField.value.length;
                descLengthSpan.textContent = length;

                if (length < 10) {
                    charCounter.classList.add('warning');
                    charCounter.classList.remove('danger');
                } else if (length > 1900) {
                    charCounter.classList.add('danger');
                    charCounter.classList.remove('warning');
                } else {
                    charCounter.classList.remove('warning', 'danger');
                }
            }
        }

        if (descriptionField) {
            descriptionField.addEventListener('input', updateCharCount);
            updateCharCount();
        }

        // Aperçu du score
        const scoreField = document.getElementById('mission_scoreMin');
        const scoreFill = document.getElementById('scoreFill');
        const scoreValue = document.getElementById('scoreValue');

        function updateScorePreview() {
            if (scoreField) {
                const value = parseInt(scoreField.value) || 0;
                const percentage = Math.min(Math.max(value, 0), 100);
                scoreFill.style.width = percentage + '%';
                scoreValue.textContent = percentage;

                // Couleur selon le score
                if (percentage >= 70) {
                    scoreFill.style.background = 'linear-gradient(90deg, #10b981, #059669)';
                } else if (percentage >= 40) {
                    scoreFill.style.background = 'linear-gradient(90deg, #f59e0b, #d97706)';
                } else {
                    scoreFill.style.background = 'linear-gradient(90deg, #ef4444, #dc2626)';
                }
            }
        }

        if (scoreField) {
            scoreField.addEventListener('input', updateScorePreview);
            updateScorePreview();
        }
    </script>
{% endblock %}