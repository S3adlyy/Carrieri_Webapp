{# templates/BackOffice/dashboard/missions/submissions.html.twig #}
{% extends 'BackOffice/base.html.twig' %}

{% block title %}Soumissions - {{ mission.type }}{% endblock %}

{% block page_title %}Soumissions pour la mission : {{ mission.type }}{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_missions_list') }}">Missions</a></li>
    <li class="breadcrumb-item"><a href="{{ path('app_admin_missions_show', {'id': mission.id}) }}">Mission #{{ mission.id }}</a></li>
    <li class="breadcrumb-item active">Soumissions</li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Liste des candidatures</h3>
            <div class="card-tools">
                <span class="badge badge-info">{{ rendus|length }} soumission(s)</span>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead>
                    <tr>
                        <th>Candidat</th>
                        <th>Email</th>
                        <th>Date de soumission</th>
                        <th>Score</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for rendu in rendus %}
                        <tr>
                            <td>
                                {% set candidat = rendu.user %}
                                {% if candidat %}
                                    {{ (candidat.firstName ~ ' ' ~ candidat.lastName)|trim ?: candidat.email }}
                                {% else %}
                                    Candidat #{{ rendu.candidatId }}
                                {% endif %}
                            </td>
                            <td>{{ candidat ? candidat.email : '—' }}</td>
                            <td>{{ rendu.dateRendu|date('d/m/Y H:i') }}</td>
                            <td>
                                <span class="badge {% if rendu.score >= 70 %}badge-success{% elseif rendu.score >= 40 %}badge-warning{% else %}badge-danger{% endif %}">
                                    {{ rendu.score|default(0)|round }}%
                                </span>
                            </td>
                            <td>
                                {% if rendu.statut == 'accepte' %}
                                    <span class="badge badge-success">✓ Acceptée</span>
                                {% elseif rendu.statut == 'refuse' %}
                                    <span class="badge badge-danger">✗ Refusée</span>
                                {% else %}
                                    <span class="badge badge-warning">⏳ En attente</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="{{ path('app_admin_submission_view', {'id': rendu.id}) }}"
                                       class="btn btn-info" title="Voir le détail">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    {% if rendu.statut == 'en_attente' %}
                                        <button type="button"
                                                class="btn btn-success"
                                                data-toggle="modal"
                                                data-target="#acceptModal{{ rendu.id }}"
                                                title="Accepter">
                                            <i class="fas fa-check"></i>
                                        </button>
                                        <button type="button"
                                                class="btn btn-danger"
                                                data-toggle="modal"
                                                data-target="#rejectModal{{ rendu.id }}"
                                                title="Refuser">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    {% endif %}
                                </div>

                                <!-- Modal Accepter -->
                                <div class="modal fade" id="acceptModal{{ rendu.id }}" tabindex="-1" role="dialog">
                                    <div class="modal-dialog" role="document">
                                        <div class="modal-content">
                                            <form method="post" action="{{ path('app_admin_submission_review', {'id': rendu.id}) }}">
                                                <div class="modal-header bg-success text-white">
                                                    <h5 class="modal-title">Accepter la soumission</h5>
                                                    <button type="button" class="close text-white" data-dismiss="modal">
                                                        <span>&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body">
                                                    <p>Êtes-vous sûr de vouloir accepter cette soumission ?</p>
                                                    <div class="form-group">
                                                        <label for="feedback{{ rendu.id }}">Feedback (optionnel) :</label>
                                                        <textarea name="feedback" id="feedback{{ rendu.id }}" class="form-control" rows="3" placeholder="Félicitations ! Votre solution a été acceptée..."></textarea>
                                                    </div>
                                                    <input type="hidden" name="action" value="accept">
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                                                    <button type="submit" class="btn btn-success">Accepter</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <!-- Modal Refuser -->
                                <div class="modal fade" id="rejectModal{{ rendu.id }}" tabindex="-1" role="dialog">
                                    <div class="modal-dialog" role="document">
                                        <div class="modal-content">
                                            <form method="post" action="{{ path('app_admin_submission_review', {'id': rendu.id}) }}">
                                                <div class="modal-header bg-danger text-white">
                                                    <h5 class="modal-title">Refuser la soumission</h5>
                                                    <button type="button" class="close text-white" data-dismiss="modal">
                                                        <span>&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body">
                                                    <p>Êtes-vous sûr de vouloir refuser cette soumission ?</p>
                                                    <div class="form-group">
                                                        <label for="feedback{{ rendu.id }}">Feedback (optionnel) :</label>
                                                        <textarea name="feedback" id="feedback{{ rendu.id }}" class="form-control" rows="3" placeholder="Désolé, votre solution n'a pas été retenue..."></textarea>
                                                    </div>
                                                    <input type="hidden" name="action" value="reject">
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                                                    <button type="submit" class="btn btn-danger">Refuser</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                <div class="py-4">
                                    <i class="fas fa-inbox fa-2x mb-2"></i>
                                    <p>Aucune soumission pour cette mission.</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer">
            <a href="{{ path('app_admin_missions_list') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Retour aux missions
            </a>
        </div>
    </div>
{% endblock %}