{# templates/BackOffice/dashboard/missions/edit.html.twig #}
{% extends 'BackOffice/base.html.twig' %}

{% block title %}Modifier la mission #{{ mission.id }}{% endblock %}

{% block page_title %}Modifier la mission{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_missions_list') }}">Missions</a></li>
    <li class="breadcrumb-item"><a href="{{ path('app_admin_missions_show', {'id': mission.id}) }}">Mission #{{ mission.id }}</a></li>
    <li class="breadcrumb-item active">Modifier</li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header">
            <div class="card-tools">
                <span class="badge badge-info">Créée le {{ mission.createdAt|date('d/m/Y') }}</span>
            </div>
        </div>
        <div class="card-body">
            {# Affichage des erreurs globales du formulaire #}
            {% if form.vars.errors|length > 0 %}
                <div class="alert alert-danger">
                    <button type="button" class="close" data-dismiss="alert">&times;</button>
                    <h5><i class="icon fas fa-ban"></i> Erreur de validation</h5>
                    <ul class="mb-0">
                        {% for error in form.vars.errors %}
                            <li>{{ error.message }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {
                    'attr': {
                        'class': 'form-control' ~ (form.description.vars.errors|length ? ' is-invalid' : ''),
                        'rows': 5,
                        'placeholder': 'Décrivez la mission en détail...'
                    }
                }) }}

                {# Affichage des erreurs pour le champ description #}
                {% if form.description.vars.errors|length > 0 %}
                    <div class="invalid-feedback d-block">
                        {% for error in form.description.vars.errors %}
                            <strong>{{ error.message }}</strong><br>
                        {% endfor %}
                    </div>
                {% endif %}

                <small class="form-text text-muted">
                    <i class="fas fa-info-circle"></i>
                    Minimum 10 caractères (actuel: {{ mission.description|length }} caractères) - Maximum 2000 caractères
                </small>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.type) }}
                        {{ form_widget(form.type, {
                            'attr': {
                                'class': 'form-control' ~ (form.type.vars.errors|length ? ' is-invalid' : ''),
                                'placeholder': 'Ex: Développement, Design, Marketing...'
                            }
                        }) }}

                        {% if form.type.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.type.vars.errors %}
                                    <strong>{{ error.message }}</strong><br>
                                {% endfor %}
                            </div>
                        {% endif %}

                        <small class="form-text text-muted">
                            <i class="fas fa-tag"></i>
                            Type actuel: <strong>{{ mission.type }}</strong> - Minimum 3 caractères
                        </small>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.scoreMin) }}
                        {{ form_widget(form.scoreMin, {
                            'attr': {
                                'class': 'form-control' ~ (form.scoreMin.vars.errors|length ? ' is-invalid' : ''),
                                'placeholder': 'Ex: 75',
                                'min': 0,
                                'max': 100
                            }
                        }) }}

                        {% if form.scoreMin.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.scoreMin.vars.errors %}
                                    <strong>{{ error.message }}</strong><br>
                                {% endfor %}
                            </div>
                        {% endif %}

                        <small class="form-text text-muted">
                            <i class="fas fa-chart-line"></i>
                            Score actuel: <strong>{{ mission.scoreMin }}</strong> - Doit être entre 0 et 100
                        </small>
                    </div>
                </div>
            </div>

            <div class="form-group mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Enregistrer les modifications
                </button>
                <a href="{{ path('app_admin_missions_show', {'id': mission.id}) }}" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Annuler
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>

    {# Affichage des informations supplémentaires #}
    <div class="card mt-3">
        <div class="card-header bg-light">
            <h3 class="card-title">
                <i class="fas fa-history"></i> Informations sur la mission
            </h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <small class="text-muted">Date de création</small>
                    <p><strong>{{ mission.createdAt ? mission.createdAt|date('d/m/Y à H:i:s') : '—' }}</strong></p>
                </div>
                <div class="col-md-4">
                    <small class="text-muted">Créée par</small>
                    <p>
                        <strong>
                            {% set u = mission.user %}
                            {% if u %}
                                {{ (u.firstName ~ ' ' ~ u.lastName)|trim ?: u.email }}
                            {% else %}
                                —
                            {% endif %}
                        </strong>
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}