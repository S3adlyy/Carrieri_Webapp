{# templates/BackOffice/dashboard/missions/show.html.twig #}
{% extends 'BackOffice/base.html.twig' %}

{% block title %}Mission #{{ mission.id }}{% endblock %}

{% block page_title %}Détails de la mission{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_missions_list') }}">Missions</a></li>
    <li class="breadcrumb-item active">Mission #{{ mission.id }}</li>
{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Informations de la mission</h3>
                    <div class="card-tools">
                        <a href="{{ path('app_admin_missions_edit', {'id': mission.id}) }}" class="btn btn-warning btn-sm">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                    </div>
                </div>
                <div class="card-body">

                    <div class="form-group">
                        <label><strong>Description</strong></label>
                        <div class="p-3 bg-light rounded">
                            {{ mission.description|nl2br }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label><strong>Type de mission</strong></label>
                                <p><span class="badge badge-info">{{ mission.type }}</span></p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label><strong>Score minimum requis</strong></label>
                                <p><span class="badge badge-warning">{{ mission.scoreMin }} points</span></p>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label><strong>Date de création</strong></label>
                                <p>{{ mission.createdAt ? mission.createdAt|date('d/m/Y à H:i:s') : '—' }}</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label><strong>Créée par</strong></label>
                                <p>
                                    {% set u = mission.user %}
                                    {% if u %}
                                        {{ (u.firstName ~ ' ' ~ u.lastName)|trim ?: u.email }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <a href="{{ path('app_admin_missions_list') }}" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Retour à la liste
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h3 class="card-title">Zone de danger</h3>
                </div>
                <div class="card-body">
                    <p>La suppression d'une mission est irréversible.</p>
                    <button type="button" class="btn btn-danger btn-block" data-toggle="modal" data-target="#deleteModal">
                        <i class="fas fa-trash"></i> Supprimer cette mission
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal de confirmation de suppression -->
    <div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmer la suppression</h5>
                    <button type="button" class="close" data-dismiss="modal">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <p>Êtes-vous sûr de vouloir supprimer cette mission ? Cette action est irréversible.</p>
                    <p class="text-muted"><strong>ID:</strong> #{{ mission.id }}</p>
                    <p class="text-muted"><strong>Description:</strong> {{ mission.description|slice(0, 100) }}...</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                    <form method="post" action="{{ path('app_admin_missions_delete', {'id': mission.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ mission.id) }}">
                        <button type="submit" class="btn btn-danger">Supprimer définitivement</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}