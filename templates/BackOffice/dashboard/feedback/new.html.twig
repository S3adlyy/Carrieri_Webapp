{% extends 'BackOffice/base.html.twig' %}

{% block title %}Nouveau feedback{% endblock %}

{% block page_title %}Donner un feedback{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_dashboard_feedback_rendus') }}">Rendus</a></li>
    <li class="breadcrumb-item active">Nouveau feedback</li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h3 class="card-title">Informations du rendu</h3>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <tr>
                    <th style="width: 150px;">Mission</th>
                    <td>Mission #{{ rendu.mission ? rendu.mission.id : '—' }}</td>
                </tr>
                <tr>
                    <th>Candidat</th>
                    <td>{{ rendu.user ? rendu.user.firstName ~ ' ' ~ rendu.user.lastName : '—' }}</td>  {# ← candidat → user #}
                </tr>
                <tr>
                    <th>Date de rendu</th>
                    <td>{{ rendu.dateRendu ? rendu.dateRendu|date('d/m/Y H:i') : '—' }}</td>
                </tr>
                {% if rendu.fichier %}
                <tr>
                    <th>Fichier</th>
                    <td>
                        <a href="{{ asset('uploads/rendus/' ~ rendu.fichier) }}" target="_blank" class="btn btn-sm btn-secondary">
                            <i class="fas fa-download"></i> Télécharger
                        </a>
                    </td>
                </tr>
                {% endif %}
            </table>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-success text-white">
            <h3 class="card-title">Formulaire de feedback</h3>
        </div>
        <div class="card-body">
            {{ form_start(form) }}
                <div class="row">
                    <div class="col-12">
                        {{ form_label(form.commentaire) }}
                        {{ form_widget(form.commentaire) }}
                        {{ form_errors(form.commentaire) }}
                        <small class="text-muted">Minimum 10 caractères</small>
                    </div>
                    <div class="col-12 mt-3">
                        {{ form_label(form.note) }}
                        {{ form_widget(form.note) }}
                        {{ form_errors(form.note) }}
                        <small class="text-muted">Note de 1 à 5</small>
                    </div>
                </div>
                <div class="alert alert-info mt-3">
                    <i class="fas fa-info-circle"></i> 
                    Votre feedback aide le candidat à s'améliorer. Soyez constructif !
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-paper-plane"></i> Envoyer le feedback
                    </button>
                    <a href="{{ path('app_dashboard_feedback_rendus') }}" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Annuler
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}