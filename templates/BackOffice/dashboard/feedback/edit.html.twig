{% extends 'BackOffice/base.html.twig' %}

{% block title %}Modifier feedback #{{ feedback.id }}{% endblock %}

{% block page_title %}Modifier mon feedback{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_dashboard_feedback_rendus') }}">Rendus</a></li>
    <li class="breadcrumb-item"><a href="{{ path('app_dashboard_feedback_index') }}">Mes feedbacks</a></li>
    <li class="breadcrumb-item active">Modifier #{{ feedback.id }}</li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header bg-warning text-white">
            <h3 class="card-title">Modifier le feedback #{{ feedback.id }}</h3>
        </div>
        <div class="card-body">
            {{ form_start(form) }}
            <div class="row">
                <div class="col-12">
                    {{ form_row(form.commentaire) }}
                </div>
                <div class="col-12">
                    {{ form_row(form.note) }}
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-warning">
                    <i class="fas fa-save"></i> Mettre à jour
                </button>
                <a href="{{ path('app_dashboard_feedback_index') }}" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Annuler
                </a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}