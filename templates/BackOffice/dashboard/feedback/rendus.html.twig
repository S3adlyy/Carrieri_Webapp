{% extends 'BackOffice/base.html.twig' %}

{% block title %}Rendus de mission{% endblock %}

{% block page_title %}Rendus de mission à évaluer{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item active">Rendus</li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Liste des rendus de mission</h3>
            <div class="card-tools">
                <a href="{{ path('app_dashboard_feedback_index') }}" class="btn btn-info btn-sm">
                    <i class="fas fa-star"></i> Mes feedbacks
                </a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Mission</th>
                            <th>Candidat</th>
                            <th>Date de rendu</th>
                            <th>Langue</th>
                            <th>Score</th>
                            <th>Statut</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for rendu in rendus %}
                            {% set feedbackExiste = rendu.feedbacks is defined and rendu.feedbacks|length > 0 %}
                            <tr>
                                <td>{{ rendu.id }}</td>
                                <td>Mission #{{ rendu.mission ? rendu.mission.id : '—' }}</td>
                                <td>{{ rendu.user ? rendu.user.firstName ~ ' ' ~ rendu.user.lastName : '—' }}</td>
                                <td>{{ rendu.dateRendu ? rendu.dateRendu|date('d/m/Y H:i') : '—' }}</td>
                                <td>{{ rendu.langue|default('—') }}</td>
                                <td>{{ rendu.score|default('—') }}</td>
                                <td>
                                    {% if feedbackExiste %}
                                        <span class="badge badge-success">Évalué</span>
                                    {% else %}
                                        <span class="badge badge-warning">À évaluer</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if not feedbackExiste %}
                                        <a href="{{ path('app_dashboard_feedback_new', {'renduId': rendu.id}) }}" class="btn btn-sm btn-primary">
                                            <i class="fas fa-star"></i> Donner un feedback
                                        </a>
                                    {% else %}
                                        <a href="{{ path('app_dashboard_feedback_show', {'id': rendu.feedbacks|first.id}) }}" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i> Voir feedback
                                        </a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="8" class="text-center text-muted">Aucun rendu de mission disponible.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}