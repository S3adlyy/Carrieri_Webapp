{# templates/BackOffice/dashboard/modules/edit.html.twig #}
{% extends 'BackOffice/base.html.twig' %}

{% block title %}Modifier le module{% endblock %}
{% block page_title %}Modifier le module{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_modules_index') }}">Modules</a></li>
    <li class="breadcrumb-item"><a href="{{ path('app_admin_modules_show', {id: module.id}) }}">{{ module.titre|default('Module') }}</a></li>
    <li class="breadcrumb-item active">Modifier</li>
{% endblock %}

{% block body %}
    <div class="card card-warning">
        <div class="card-header">
            <h3 class="card-title">Modifier : <em>{{ module.titre }}</em></h3>
        </div>
        {{ form_start(form) }}
        <div class="card-body">
            <div class="form-group">
                {{ form_label(form.titre) }}
                {{ form_widget(form.titre) }}
                {{ form_errors(form.titre) }}
            </div>
            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description) }}
                {{ form_errors(form.description) }}
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group">
                        {{ form_label(form.cours) }}
                        {{ form_widget(form.cours) }}
                        {{ form_errors(form.cours) }}
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-warning">
                <i class="fas fa-save mr-1"></i> Mettre à jour
            </button>
            <a href="{{ path('app_admin_modules_index') }}" class="btn btn-secondary ml-2">
                <i class="fas fa-times mr-1"></i> Annuler
            </a>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
