{# templates/BackOffice/dashboard/lecons/edit.html.twig #}
{% extends 'BackOffice/base.html.twig' %}

{% block title %}Modifier la leçon{% endblock %}
{% block page_title %}Modifier la leçon{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_lecons_index') }}">Leçons</a></li>
    <li class="breadcrumb-item"><a href="{{ path('app_admin_lecons_show', {id: lecon.id}) }}">{{ lecon.titre|default('Leçon') }}</a></li>
    <li class="breadcrumb-item active">Modifier</li>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .lesson-form .form-group { margin-bottom: 1.5rem; position: relative; }
        .form-label { font-size: 14px; margin-bottom: 8px; color: #2c3e50; display: block; font-weight: 600; }
        .form-control { border-radius: 8px; border: 2px solid #e2e8f0; padding: 10px 40px 10px 12px; transition: all 0.3s ease; width: 100%; }
        .form-control:focus { outline: none; border-color: #667eea; }
        .form-group.valid .form-control { border-color: #10b981; background-color: #f0fdf4; }
        .form-group.invalid .form-control { border-color: #dc2626; background-color: #fef2f2; }
        .validation-icon { position: absolute; right: 12px; top: 42px; font-size: 16px; display: none; }
        .validation-icon i { display: none; }
        .form-group.valid .validation-icon,
        .form-group.invalid .validation-icon { display: block; }
        .form-group.valid .validation-icon .fa-check-circle { display: inline-block; color: #10b981; }
        .form-group.invalid .validation-icon .fa-times-circle { display: inline-block; color: #dc2626; }
        .error-message { font-size: 12px; margin-top: 5px; padding: 6px 12px; border-radius: 6px; display: none; }
        .form-group.invalid .error-message { display: block; background-color: #fef2f2; color: #dc2626; border-left: 3px solid #dc2626; }
        .form-status { margin: 20px 0; padding: 12px 16px; border-radius: 8px; background-color: #f8fafc; border: 1px solid #e2e8f0; }
        .status-indicator { display: flex; align-items: center; gap: 10px; font-size: 14px; font-weight: 500; }
        .status-indicator.valid { color: #10b981; }
        .status-indicator.invalid { color: #dc2626; }
        .form-actions { display: flex; gap: 10px; margin-top: 30px; padding-top: 20px; border-top: 1px solid #e2e8f0; }
        .btn { padding: 10px 24px; border-radius: 8px; font-weight: 500; transition: all 0.3s; }
        .btn-primary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; color: white; }
        .btn-secondary { background-color: #f1f5f9; border: 1px solid #e2e8f0; color: #475569; }
    </style>
{% endblock %}

{% block body %}
    <div class="card card-warning">
        <div class="card-header">
            <h3 class="card-title">Modifier : <em>{{ lecon.titre }}</em></h3>
        </div>
        {{ form_start(form, {'attr': {'class': 'lesson-form', 'enctype': 'multipart/form-data', 'novalidate': 'novalidate', 'data-live-validation': '1'}}) }}
        {% if form.vars.submitted and not form.vars.valid %}
            <div class="alert alert-danger m-3 mb-0">
                <strong>Veuillez corriger les erreurs suivantes :</strong>
                {{ form_errors(form) }}
            </div>
        {% endif %}
        <div class="card-body">
            <div class="form-group">
                {{ form_label(form.titre) }}
                {{ form_widget(form.titre, {'attr': {'class': 'form-control' ~ (form.titre.vars.errors|length ? ' is-invalid' : '')}}) }}
                <div class="validation-icon"><i class="fas fa-check-circle"></i><i class="fas fa-times-circle"></i></div>
                {{ form_errors(form.titre) }}
                <div class="error-message"></div>
            </div>
            <div class="form-group">
                {{ form_label(form.contenu) }}
                {{ form_widget(form.contenu, {'attr': {'class': 'form-control' ~ (form.contenu.vars.errors|length ? ' is-invalid' : '')}}) }}
                <div class="validation-icon"><i class="fas fa-check-circle"></i><i class="fas fa-times-circle"></i></div>
                {{ form_errors(form.contenu) }}
                <div class="error-message"></div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group">
                        {{ form_label(form.module) }}
                        {{ form_widget(form.module, {'attr': {'class': 'form-control' ~ (form.module.vars.errors|length ? ' is-invalid' : '')}}) }}
                        <div class="validation-icon"><i class="fas fa-check-circle"></i><i class="fas fa-times-circle"></i></div>
                        {{ form_errors(form.module) }}
                        <div class="error-message"></div>
                    </div>
                </div>
            </div>
            <div class="form-group">
                {{ form_label(form.video) }}
                {{ form_widget(form.video, {'attr': {'class': 'form-control' ~ (form.video.vars.errors|length ? ' is-invalid' : '')}}) }}
                <div class="validation-icon"><i class="fas fa-check-circle"></i><i class="fas fa-times-circle"></i></div>
                {{ form_errors(form.video) }}
                <div class="error-message"></div>
            </div>
            <div class="form-status">
                <div class="status-indicator invalid"><i class="fas fa-times-circle"></i> Formulaire incomplet</div>
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-warning">
                <i class="fas fa-save mr-1"></i> Mettre à jour
            </button>
            <a href="{{ path('app_admin_lecons_index') }}" class="btn btn-secondary ml-2">
                <i class="fas fa-times mr-1"></i> Annuler
            </a>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function () {
            function getMessage(field) {
                var value = (field.value || '').trim();
                var tag = (field.tagName || '').toLowerCase();
                var type = (field.getAttribute('type') || '').toLowerCase();
                if (type === 'file') return '';
                if (field.required && value.length === 0) return 'Ce champ est obligatoire.';
                if (value.length === 0) return '';
                var minLengthAttr = field.getAttribute('minlength');
                if (minLengthAttr) { var minLength = parseInt(minLengthAttr, 10); if (!isNaN(minLength) && value.length < minLength) return 'Minimum ' + minLength + ' caracteres.'; }
                var maxLengthAttr = field.getAttribute('maxlength');
                if (maxLengthAttr) { var maxLength = parseInt(maxLengthAttr, 10); if (!isNaN(maxLength) && value.length > maxLength) return 'Maximum ' + maxLength + ' caracteres.'; }
                if (type === 'number') { var numberValue = parseFloat(field.value); if (isNaN(numberValue)) return 'Veuillez saisir un nombre valide.'; var minAttr = field.getAttribute('min'); if (minAttr !== null && numberValue < parseFloat(minAttr)) return 'La valeur minimale est ' + minAttr + '.'; var maxAttr = field.getAttribute('max'); if (maxAttr !== null && numberValue > parseFloat(maxAttr)) return 'La valeur maximale est ' + maxAttr + '.'; }
                if (tag === 'select' && field.required && !field.value) return 'Veuillez selectionner une valeur.';
                return '';
            }
            function validateField(field, showError) {
                if (!field || field.disabled || field.type === 'hidden') return true;
                var group = field.closest('.form-group');
                if (!group) return true;
                var errorBox = group.querySelector('.error-message');
                var serverInvalid = field.classList.contains('is-invalid') && field.dataset.touched !== '1';
                var message = getMessage(field);
                var invalid = message !== '';
                group.classList.remove('valid', 'invalid');
                if (serverInvalid || (showError && invalid)) { group.classList.add('invalid'); if (errorBox && invalid) errorBox.textContent = message; return false; }
                if (!invalid && field.value && field.value.trim && field.value.trim().length > 0) group.classList.add('valid');
                if (errorBox) errorBox.textContent = showError ? message : '';
                return !invalid;
            }
            function attach(form) {
                var fields = form.querySelectorAll('input, textarea, select');
                var submitBtn = form.querySelector('button[type="submit"]');
                var status = form.querySelector('.status-indicator');
                var submitted = false;
                function refresh() { var allValid = true; for (var i = 0; i < fields.length; i += 1) { var field = fields[i]; var showError = submitted || field.dataset.touched === '1'; if (!validateField(field, showError)) allValid = false; } if (submitBtn) submitBtn.disabled = !allValid; if (status) { if (allValid) { status.className = 'status-indicator valid'; status.innerHTML = '<i class="fas fa-check-circle"></i> Formulaire complet et valide'; } else { status.className = 'status-indicator invalid'; status.innerHTML = '<i class="fas fa-times-circle"></i> Verifiez les champs obligatoires'; } } }
                for (var i = 0; i < fields.length; i += 1) { fields[i].addEventListener('input', function (event) { event.target.dataset.touched = '1'; event.target.classList.remove('is-invalid'); refresh(); }); fields[i].addEventListener('change', function (event) { event.target.dataset.touched = '1'; event.target.classList.remove('is-invalid'); refresh(); }); fields[i].addEventListener('blur', function (event) { event.target.dataset.touched = '1'; event.target.classList.remove('is-invalid'); refresh(); }); }
                form.addEventListener('submit', function (event) { submitted = true; refresh(); if (submitBtn && submitBtn.disabled) { event.preventDefault(); } });
                refresh();
            }
            document.addEventListener('DOMContentLoaded', function () { var forms = document.querySelectorAll('form[data-live-validation="1"]'); for (var i = 0; i < forms.length; i += 1) attach(forms[i]); });
        })();
    </script>
{% endblock %}