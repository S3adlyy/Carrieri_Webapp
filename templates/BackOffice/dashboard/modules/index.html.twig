{# templates/BackOffice/dashboard/modules/index.html.twig #}
{% extends 'BackOffice/base.html.twig' %}

{% block title %}Gestion des modules{% endblock %}
{% block page_title %}Modules{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item active">Modules</li>
{% endblock %}

{% block body %}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show">
                {{ message }}
                <button type="button" class="close" data-dismiss="alert">×</button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0">Liste des modules</h3>
            {% if is_admin_view|default(false) %}
                <a href="{{ path('app_admin_modules_new') }}" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus mr-1"></i> Nouveau module
                </a>
            {% else %}
                <div>
                    {% if selected_cours is defined and selected_cours %}
                        <a href="{{ path('app_admin_modules_new', {cours: selected_cours.id}) }}" class="btn btn-primary btn-sm">
                            <i class="fas fa-plus mr-1"></i> Nouveau module
                        </a>
                    {% endif %}
                </div>
            {% endif %}
        </div>
        {% if not is_admin_view|default(false) and selected_cours is defined and selected_cours %}
            <div class="card-body border-bottom py-2">
                <span class="badge badge-info">Cours sélectionné</span>
                <strong class="ml-1">{{ selected_cours.titre }}</strong>
            </div>
        {% endif %}
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="thead-dark">
                    <tr>
                        <th>#</th>
                        <th>Titre</th>
                        <th>Description</th>
                        <th>Ordre</th>
                        <th>Cours associé</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for m in modules %}
                        <tr>
                            <td>{{ m.id }}</td>
                            <td>
                                <a href="{{ path('app_admin_lecons_index', {module: m.id}) }}" title="Ouvrir les leçons de ce module">
                                    <strong>{{ m.titre|default('—') }}</strong>
                                </a>
                            </td>
                            <td>{{ m.description|default('—')|slice(0,60) }}{% if m.description|length > 60 %}…{% endif %}</td>
                            <td><span class="badge badge-secondary">{{ m.ordre|default('—') }}</span></td>
                            <td>
                                {% if m.cours %}
                                    <a href="{{ path('app_admin_cours_show', {id: m.cours.id}) }}">{{ m.cours.titre }}</a>
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('app_admin_modules_edit', {id: m.id}) }}" class="btn btn-xs btn-warning" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" action="{{ path('app_admin_modules_delete', {id: m.id}) }}" style="display:inline"
                                      onsubmit="return confirm('Supprimer ce module ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_module_' ~ m.id) }}">
                                    <button class="btn btn-xs btn-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-3">Aucun module trouvé.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer text-muted">Total : <strong>{{ modules|length }}</strong> modules</div>
    </div>
{% endblock %}
