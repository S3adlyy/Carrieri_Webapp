{% extends 'BackOffice/base.html.twig' %}

{% block title %}Modifier l'utilisateur{% endblock %}
{% block page_title %}Modifier l'utilisateur{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_utilisateurs') }}">Utilisateurs</a></li>
    <li class="breadcrumb-item active">Modifier</li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                Modifier: {{ user.firstName }} {{ user.lastName }}
            </h3>
            <div class="card-tools">
                <a href="{{ path('app_admin_utilisateurs') }}" class="btn btn-secondary btn-sm">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
        </div>

        <div class="card-body">
            {{ form_start(form, {'attr': {'class': 'form-horizontal'}}) }}

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.firstName, 'Prénom', {'label_attr': {'class': 'control-label'}}) }}
                        {{ form_widget(form.firstName) }}
                        {{ form_errors(form.firstName) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.lastName, 'Nom', {'label_attr': {'class': 'control-label'}}) }}
                        {{ form_widget(form.lastName) }}
                        {{ form_errors(form.lastName) }}
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.email, 'Email', {'label_attr': {'class': 'control-label'}}) }}
                        {{ form_widget(form.email) }}
                        {{ form_errors(form.email) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.phone, 'Téléphone', {'label_attr': {'class': 'control-label'}}) }}
                        {{ form_widget(form.phone) }}
                        {{ form_errors(form.phone) }}
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.type, 'Type d\'utilisateur', {'label_attr': {'class': 'control-label'}}) }}
                        {{ form_widget(form.type) }}
                        {{ form_errors(form.type) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.location, 'Localisation', {'label_attr': {'class': 'control-label'}}) }}
                        {{ form_widget(form.location) }}
                        {{ form_errors(form.location) }}
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.isActive, 'Statut', {'label_attr': {'class': 'control-label'}}) }}
                        {{ form_widget(form.isActive) }}
                        {{ form_errors(form.isActive) }}
                    </div>
                </div>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Enregistrer les modifications
                </button>
                <a href="{{ path('app_admin_utilisateurs') }}" class="btn btn-secondary">
                    Annuler
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>

    <style>
        .form-group {
            margin-bottom: 1.5rem;
        }
        .form-control {
            border-radius: 4px;
        }
        .control-label {
            font-weight: 600;
            margin-bottom: 0.5rem;
            display: block;
        }
    </style>
{% endblock %}