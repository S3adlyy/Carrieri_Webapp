{# templates/BackOffice/partials/_navbar.html.twig #}
{% set logged_user = app.user %}
{% set display_name = logged_user ? ((logged_user.firstName|default('') ~ ' ' ~ logged_user.lastName|default(''))|trim) : '' %}
{% if display_name is empty and logged_user %}
    {% set display_name = logged_user.email|default('Utilisateur') %}
{% endif %}

<nav class="main-header navbar navbar-expand navbar-white navbar-light">
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#" role="button">
                <i class="fas fa-bars"></i>
            </a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="{{ path('app_admin_dashboard') }}" class="nav-link">Accueil</a>
        </li>
    </ul>

    <ul class="navbar-nav ml-auto">
        <li class="nav-item dropdown">
            <a class="nav-link" data-toggle="dropdown" href="#">
                <i class="fas fa-user-circle"></i>
                <span class="ml-1">{{ display_name }}</span>
            </a>
            <div class="dropdown-menu dropdown-menu-right">
                <span class="dropdown-item-text text-muted small">{{ logged_user.email|default('') }}</span>
                <div class="dropdown-divider"></div>
                <a href="{{ path('app_home') }}" class="dropdown-item">
                    <i class="fas fa-globe mr-2"></i> Site public
                </a>
                <div class="dropdown-divider"></div>
                <a href="{{ path('app_logout') }}" class="dropdown-item">
                    <i class="fas fa-sign-out-alt mr-2"></i> Déconnexion
                </a>
            </div>
        </li>
    </ul>
</nav>
